---
interface Props {
  num: string
  date: string
  title: string
  description: string
  speakerRole: string
  speakerBio: string
  speakerNote?: string
}

const { num, date, title, description, speakerRole, speakerBio, speakerNote = 'Session, samedi après-midi' } = Astro.props
---

<div class="bg-white border border-black/5 rounded-sm p-8 md:p-10">
  <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-10">
    <!-- Left: number + date -->
    <div class="flex-shrink-0 md:w-32">
      <span class="text-2xl font-light tracking-[0.1em] text-[#C4A855]">{num}</span>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mt-2">{date}</p>
    </div>

    <!-- Right: content -->
    <div class="flex-1">
      <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-4 tracking-tight">{title}</h3>
      <p class="text-base font-light text-[#2C2824]/70 leading-relaxed mb-8">
        {description}
      </p>

      <!-- Speaker -->
      <div class="flex items-start gap-5 pt-6 border-t border-black/5">
        <!-- Avatar slot - allows static HTML that Image Manager can modify -->
        <slot name="avatar">
          <!-- Default placeholder if no avatar provided -->
          <div class="w-20 h-20 rounded-full bg-[#E8E3D8] flex items-center justify-center flex-shrink-0">
            <svg class="w-8 h-8 text-[#2C2824]/25" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"></path>
            </svg>
          </div>
        </slot>
        
        <div>
          <p class="text-sm font-medium text-[#2C2824] mb-1">{speakerRole}</p>
          <p class="text-sm font-light text-[#2C2824]/60 leading-relaxed mb-2">{speakerBio}</p>
          <p class="text-xs font-light text-[#C4A855]">{speakerNote}</p>
        </div>
      </div>
    </div>
  </div>
</div>
