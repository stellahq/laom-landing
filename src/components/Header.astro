---
import { getTranslations, getLocalizedPath, getAlternateLocale } from '~/i18n/utils'

const lang = Astro.currentLocale || 'fr'
const t = getTranslations(lang as 'fr' | 'en')
const altLang = getAlternateLocale(lang as 'fr' | 'en')
const currentPath = Astro.url.pathname
const altPath = getLocalizedPath(currentPath, altLang)
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#F3EEDC]/95 backdrop-blur-md transition-all duration-200">
  <nav class="max-w-7xl mx-auto px-10 sm:px-16 lg:px-24 pt-5 pb-0">
    <div class="flex items-center justify-between border-b border-black/10 pb-5">
      <!-- Logo -->
      <a href={getLocalizedPath('/', lang as 'fr' | 'en')} class="font-playfair text-2xl font-medium tracking-[0.05em] text-black hover:opacity-70 transition-opacity z-50 relative">
        LAOM
      </a>

      <div class="flex items-center gap-10">
        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-10">
          <a href={getLocalizedPath('/', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.home}</a>
          <a href={getLocalizedPath('/project', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.project}</a>
          <!-- Accompagnements dropdown -->
          <div class="relative" id="accomp-dropdown">
            <button id="accomp-btn" class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors flex items-center gap-1" type="button">
              {t.nav.accompagnements}
              <svg class="w-3 h-3 text-black/40 transition-transform duration-200" id="accomp-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="accomp-panel" class="absolute top-full left-0 pt-2 opacity-0 pointer-events-none transition-all duration-200">
              <div class="bg-white border border-black/10 rounded-sm shadow-lg py-2 min-w-[200px]">
                <a href={getLocalizedPath('/mentorat', lang as 'fr' | 'en')} class="block px-5 py-2.5 text-sm font-light text-black/70 hover:text-black hover:bg-[#F3EEDC]/50 transition-colors">
                  {lang === 'fr' ? 'Mentorat' : 'Mentoring'}
                </a>
                <a href={getLocalizedPath('/school/online', lang as 'fr' | 'en')} class="block px-5 py-2.5 text-sm font-light text-black/70 hover:text-black hover:bg-[#F3EEDC]/50 transition-colors">
                  LAOMSCHOOL
                </a>
                <a href={getLocalizedPath('/capital', lang as 'fr' | 'en')} class="block px-5 py-2.5 text-sm font-light text-black/70 hover:text-black hover:bg-[#F3EEDC]/50 transition-colors">
                  LAOM Capital
                </a>
              </div>
            </div>
          </div>
          <a href={getLocalizedPath('/events', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.events}</a>
          <a href={getLocalizedPath('/blog', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.blog}</a>
          <a href={getLocalizedPath('/resources', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.resources}</a>
          <a href={getLocalizedPath('/contact', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.contact}</a>
        </nav>

        <!-- Language Switcher & Mobile Toggle -->
        <div class="flex items-center gap-6 pl-6 border-l border-black/10">
          <a 
            href={altPath} 
            class="text-sm font-normal tracking-wide text-black/60 hover:text-black transition-colors"
            hreflang={altLang}
          >
            {altLang}
          </a>
          
          <!-- Mobile Menu Button -->
          <button 
            id="mobile-menu-button"
            class="md:hidden text-black focus:outline-none p-2 -mr-2"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="hidden md:hidden mt-6 pb-4 border-t border-black/10">
      <div class="flex flex-col space-y-4 pt-4">
        <a href={getLocalizedPath('/', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.home}</a>
        <a href={getLocalizedPath('/project', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.project}</a>
        <div class="pl-4 space-y-3 border-l border-[#C4A855]/30">
          <p class="text-xs font-light tracking-[0.15em] uppercase text-black/40">{t.nav.accompagnements}</p>
          <a href={getLocalizedPath('/mentorat', lang as 'fr' | 'en')} class="block text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{lang === 'fr' ? 'Mentorat' : 'Mentoring'}</a>
          <a href={getLocalizedPath('/school/online', lang as 'fr' | 'en')} class="block text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">LAOMSCHOOL</a>
          <a href={getLocalizedPath('/capital', lang as 'fr' | 'en')} class="block text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">LAOM Capital</a>
        </div>
        <a href={getLocalizedPath('/events', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.events}</a>
        <a href={getLocalizedPath('/blog', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.blog}</a>
        <a href={getLocalizedPath('/resources', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.resources}</a>
        <a href={getLocalizedPath('/contact', lang as 'fr' | 'en')} class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors">{t.nav.contact}</a>
        <a 
          href={altPath} 
          class="text-sm font-normal tracking-wide text-black/70 hover:text-black transition-colors pt-2 border-t border-black/10"
          hreflang={altLang}
        >
          {altLang}
        </a>
      </div>
    </nav>
  </nav>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button')
  const mobileMenu = document.getElementById('mobile-menu')
  
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden')
    })
  }

  const mobileLinks = mobileMenu?.querySelectorAll('a')
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden')
    })
  })

  // Accompagnements dropdown,  click toggle
  const accompBtn = document.getElementById('accomp-btn')
  const accompPanel = document.getElementById('accomp-panel')
  const accompChevron = document.getElementById('accomp-chevron')
  let accompOpen = false

  function toggleAccomp(open: boolean) {
    accompOpen = open
    if (accompPanel) {
      accompPanel.style.opacity = open ? '1' : '0'
      accompPanel.style.pointerEvents = open ? 'auto' : 'none'
    }
    if (accompChevron) {
      accompChevron.style.transform = open ? 'rotate(180deg)' : ''
    }
  }

  accompBtn?.addEventListener('click', (e) => {
    e.stopPropagation()
    toggleAccomp(!accompOpen)
  })

  document.addEventListener('click', (e) => {
    const dropdown = document.getElementById('accomp-dropdown')
    if (accompOpen && dropdown && !dropdown.contains(e.target as Node)) {
      toggleAccomp(false)
    }
  })
</script>
