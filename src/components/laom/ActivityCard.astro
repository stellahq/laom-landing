---
// ActivityCard — carte photo, dégradé bas, flèche en haut à droite, label centré bas.
interface Props { img: string; title: string; href?: string; class?: string }
const { img, title, href = '#', class: cls = '' } = Astro.props
---
<a href={href} class:list={['imgzoom lift group relative rounded-3xl block aspect-[4/5]', cls]}>
  <img src={img} alt={title} class="w-full h-full object-cover" loading="lazy" />
  <div class="absolute inset-0 bg-gradient-to-t from-[#1D1B18]/70 via-transparent to-transparent"></div>
  <span class="circle-btn absolute top-4 right-4 w-11 h-11">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H8M17 7v9"/></svg>
  </span>
  <div class="absolute inset-x-4 bottom-4 glass-dark rounded-2xl py-3 text-center">
    <h3 class="text-base font-bold text-[#F2EBDB]">{title}</h3>
  </div>
</a>
