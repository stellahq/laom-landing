---
// Testimonial — avis client : citation + avatar + nom.
interface Props { quote: string; name: string; avatar?: string; role?: string; class?: string }
const { quote, name, avatar, role, class: cls = '' } = Astro.props
---
<figure class:list={['bg-[#FBF6EA] rounded-3xl p-7 shadow-sm', cls]}>
  <blockquote class="text-[#1D1B18]/80 leading-relaxed italic">“{quote}”</blockquote>
  <figcaption class="flex items-center gap-3 mt-5">
    {avatar && <img src={avatar} alt={name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />}
    <div>
      <p class="text-sm font-bold text-[#412F1F]">{name}</p>
      {role && <p class="text-xs text-[#73673E]">{role}</p>}
    </div>
  </figcaption>
</figure>
