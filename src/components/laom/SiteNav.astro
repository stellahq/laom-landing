---
// SiteNav — barre de navigation FIXE (sticky). transparent=true : superposée au
// hero/photo, puis devient solide (fond crème + flou + ombre) au scroll.
// Survol desktop : soulignement qui balaie + passage à la couleur d'accent.
import Logo from './Logo.astro'
interface NavLink { label: string; href: string }
interface Props { links?: NavLink[]; ctaText?: string; ctaHref?: string; transparent?: boolean; logoHref?: string }
const {
  logoHref = '/',
  links = [
    { label: 'Accueil', href: '/' },
    { label: 'Le lieu', href: '#lieu' },
    { label: 'Habitats', href: '#habitats' },
    { label: 'Activités', href: '#activites' },
    { label: 'Blog', href: '#blog' },
    { label: 'Contact', href: '#contact' },
  ],
  ctaText = 'Réserver', ctaHref = '#contact', transparent = true,
} = Astro.props
const path = Astro.url.pathname
const isActive = (href: string) => href === path || href + '/' === path || href === path + '/'
---
<header class:list={['site-nav', transparent ? 'site-nav--over' : 'site-nav--solid']}>
  <nav class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14 pt-6">
    <div class="snav-row flex items-center justify-between gap-4 lg:grid lg:grid-cols-[1fr_auto_1fr] pb-5">
      <a href={logoHref} class="snav-logo justify-self-start" aria-label="LAOM — accueil"><Logo height="1.6rem" /></a>
      <ul class="hidden lg:flex items-center gap-9 justify-self-center">
        {links.map((n) => (
          <li><a href={n.href} class="snav-link" aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a></li>
        ))}
      </ul>
      <div class="flex items-center gap-3 justify-self-end">
        <a href={ctaHref} class="snav-cta hidden lg:inline-block">{ctaText}</a>
        <button type="button" class="snav-burger lg:hidden" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="snav-mobile" data-burger>
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <!-- Menu mobile (sous lg) -->
    <div id="snav-mobile" class="snav-mobile lg:hidden" data-mobile-panel hidden>
      <ul class="snav-mobile-list">
        {links.map((n) => (
          <li><a href={n.href} class="snav-mobile-link" aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a></li>
        ))}
      </ul>
      <a href={ctaHref} class="snav-mobile-cta">{ctaText}</a>
    </div>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    transition: background-color .45s ease, box-shadow .45s ease, backdrop-filter .45s ease;
  }
  /* État au sommet, par-dessus la photo */
  .site-nav--over {
    background: transparent;
    --snav-ink: #F2EBDB;
    --snav-accent: #CB7A5C;
    --snav-border: rgba(242, 235, 219, .22);
  }
  /* État solide (scrollé, ou variante non-transparente) */
  .site-nav--over.is-scrolled,
  .site-nav--solid {
    background: rgba(251, 246, 234, .92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 30px -14px rgba(65, 47, 31, .28);
    --snav-ink: #412F1F;
    --snav-accent: #9A3922;
    --snav-border: rgba(65, 47, 31, .08);
  }

  .snav-row { border-bottom: 1px solid var(--snav-border); transition: border-color .45s ease; }
  .site-nav--over.is-scrolled .snav-row,
  .site-nav--solid .snav-row { border-bottom-color: transparent; }

  .snav-logo { color: var(--snav-ink); transition: color .45s ease; }

  /* Liens + survol stylé : soulignement directionnel + couleur d'accent */
  .snav-link {
    position: relative;
    color: var(--snav-ink);
    opacity: .78;
    font-size: .875rem;
    letter-spacing: .02em;
    padding-bottom: 2px;
    transition: color .3s ease, opacity .3s ease;
  }
  .snav-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -6px;
    height: 2px;
    background: var(--snav-accent);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform .45s cubic-bezier(.16, 1, .3, 1);
  }
  .snav-link:hover { opacity: 1; color: var(--snav-accent); }
  .snav-link:hover::after { transform: scaleX(1); transform-origin: left center; }
  .snav-link[aria-current="page"] { opacity: 1; }
  .snav-link[aria-current="page"]::after { transform: scaleX(1); transform-origin: left center; }

  /* CTA */
  .snav-cta {
    white-space: nowrap;
    border-radius: 9999px;
    padding: .7rem 1.6rem;
    font-size: .875rem;
    font-weight: 600;
    line-height: 1;
    transition: background-color .45s ease, color .45s ease, transform .25s ease, box-shadow .25s ease;
  }
  .site-nav--over .snav-cta { background: #F2EBDB; color: #412F1F; }
  .site-nav--over.is-scrolled .snav-cta,
  .site-nav--solid .snav-cta { background: #9A3922; color: #F2EBDB; }
  .snav-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -10px rgba(65, 47, 31, .42); }
  .snav-cta:active { transform: translateY(0); }

  /* Burger (mobile, sous lg) */
  .snav-burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.75rem; height: 2.75rem;
    margin-right: -0.5rem;
    border-radius: 9999px;
    color: var(--snav-ink);
    transition: color .45s ease;
  }
  .snav-burger span {
    display: block;
    width: 22px; height: 2px;
    margin-inline: auto;
    background: currentColor;
    border-radius: 2px;
    transition: transform .3s cubic-bezier(.16, 1, .3, 1), opacity .2s ease;
  }
  .site-nav.is-open .snav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .site-nav.is-open .snav-burger span:nth-child(2) { opacity: 0; }
  .site-nav.is-open .snav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Menu ouvert : la barre passe en solide pour la lisibilité du panneau */
  .site-nav.is-open {
    background: rgba(251, 246, 234, .98);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 30px -14px rgba(65, 47, 31, .28);
  }
  .site-nav.is-open.site-nav--over { --snav-ink: #412F1F; --snav-accent: #9A3922; }

  /* Panneau mobile (sous la barre) */
  .snav-mobile { overflow: hidden; }
  .snav-mobile[hidden] { display: none; }
  .snav-mobile-list { display: flex; flex-direction: column; padding: .25rem 0 .5rem; }
  .snav-mobile-link {
    display: block;
    padding: .9rem .25rem;
    font-size: 1.125rem;
    color: #412F1F;
    border-bottom: 1px solid rgba(65, 47, 31, .08);
    transition: color .2s ease;
  }
  .snav-mobile-link:hover,
  .snav-mobile-link[aria-current="page"] { color: #9A3922; }
  .snav-mobile-cta {
    display: block;
    text-align: center;
    margin: 1rem 0 1.5rem;
    border-radius: 9999px;
    padding: .95rem 1.6rem;
    font-weight: 600;
    background: #9A3922;
    color: #F2EBDB;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .snav-mobile-cta:active { transform: translateY(1px); }

  @media (prefers-reduced-motion: reduce) {
    .site-nav, .snav-row, .snav-logo, .snav-link, .snav-link::after, .snav-cta, .snav-burger span { transition: none; }
  }
</style>

<script>
  for (const nav of document.querySelectorAll('.site-nav--over')) {
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 60)
    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })
  }

  // Menu mobile (burger)
  for (const nav of document.querySelectorAll('.site-nav')) {
    const burger = nav.querySelector('[data-burger]')
    const panel = nav.querySelector('[data-mobile-panel]')
    if (!burger || !panel) continue
    const setOpen = (open: boolean) => {
      nav.classList.toggle('is-open', open)
      burger.setAttribute('aria-expanded', String(open))
      burger.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu')
      if (open) panel.removeAttribute('hidden')
      else panel.setAttribute('hidden', '')
    }
    burger.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')))
    panel.addEventListener('click', (e) => {
      if (e.target instanceof Element && e.target.closest('a')) setOpen(false)
    })
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false) })
    window.addEventListener('resize', () => { if (window.innerWidth >= 1024) setOpen(false) })
  }
</script>
