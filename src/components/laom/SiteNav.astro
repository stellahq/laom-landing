---
// SiteNav — barre de navigation. transparent=true pour superposition sur hero photo.
import Logo from './Logo.astro'
interface NavLink { label: string; href: string }
interface Props { links?: NavLink[]; ctaText?: string; ctaHref?: string; transparent?: boolean }
const {
  links = [
    { label: 'Accueil', href: '/' },
    { label: 'Le lieu', href: '#lieu' },
    { label: 'Habitats', href: '#habitats' },
    { label: 'Activités', href: '#activites' },
    { label: 'Blog', href: '#blog' },
    { label: 'Contact', href: '#contact' },
  ],
  ctaText = 'Réserver', ctaHref = '#contact', transparent = true,
} = Astro.props
const ink = transparent ? '#F2EBDB' : '#412F1F'
const wrap = transparent ? 'absolute top-0 left-0 right-0 z-40' : 'sticky top-0 z-40 bg-[#F2EBDB]/95 backdrop-blur-md'
---
<header class={wrap}>
  <nav class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14 pt-6">
    <div class="grid grid-cols-[1fr_auto_1fr] items-center pb-5" style={`border-bottom:1px solid ${transparent ? 'rgba(242,235,219,0.2)' : 'rgba(65,47,31,0.12)'}`}>
      <a href="/" class:list={['justify-self-start', transparent ? 'text-[#F2EBDB]' : 'text-[#9A3922]']}><Logo height="1.6rem" /></a>
      <ul class="hidden lg:flex items-center gap-10 justify-self-center">
        {links.map((n, i) => (
          <li><a href={n.href} class="text-sm tracking-wide transition-opacity hover:opacity-70" style={`color:${ink};opacity:${i === 0 ? 1 : 0.75}`}>{n.label}</a></li>
        ))}
      </ul>
      <a href={ctaHref} class:list={['justify-self-end', transparent ? 'pill pill-light' : 'pill pill-primary']} style="padding:.7rem 1.6rem">{ctaText}</a>
    </div>
  </nav>
</header>
