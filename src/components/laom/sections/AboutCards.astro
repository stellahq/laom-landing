---
// AboutCards — section "À propos" : head (titre + accent + intro) puis rangée 4 colonnes
// alternant photo / carte texte colorée (marron, vert). L'assemblage de 14.07.58.
import SectionHead from './SectionHead.astro'
interface TextCard { kind: 'text'; title: string; text: string; color?: 'marron' | 'vert' }
interface PhotoCard { kind: 'photo'; img: string; alt?: string }
type Item = TextCard | PhotoCard
interface Props { eyebrow?: string; title: string; accent?: string; intro?: string; items: Item[]; bg?: string }
const { eyebrow = 'À propos', title, accent, intro, items, bg = 'bg-[#F2EBDB]' } = Astro.props
const colorClass = { marron: 'bg-[#412F1F] text-[#F2EBDB]/70', vert: 'bg-[#73673E] text-[#F2EBDB]/80' }
---
<section id="lieu" class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class="grid lg:grid-cols-[180px_1fr] gap-8 lg:gap-16 mb-16">
      <p class="eyebrow pt-3">{eyebrow}</p>
      <SectionHead title={title} accent={accent} intro={intro} />
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {items.map((it) => it.kind === 'photo' ? (
        <div class="imgzoom rounded-3xl overflow-hidden aspect-[3/4]">
          <img src={it.img} alt={it.alt ?? ''} class="w-full h-full object-cover" loading="lazy" />
        </div>
      ) : (
        <div class:list={['rounded-3xl p-8 flex flex-col justify-center', colorClass[it.color ?? 'marron']]}>
          <h3 class="text-2xl font-extrabold text-[#F2EBDB] leading-tight mb-4">{it.title}</h3>
          <p class="leading-relaxed">{it.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
