---
// FoundersQuotes — deux cartes « personne » premium : grand portrait + guillemet
// + citation à la première personne + prénom souligné d'un filet terre.
import SectionHead from './SectionHead.astro'
interface Person { img: string; name: string; quote: string }
interface Props { eyebrow?: string; title: string; accent?: string; people: Person[]; bg?: string }
const { eyebrow, title, accent, people, bg = 'bg-[#F2EBDB]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class="mb-14 md:mb-16 text-center"><SectionHead align="center" eyebrow={eyebrow} title={title} accent={accent} /></div>
    <div class="grid md:grid-cols-2 gap-6 md:gap-8">
      {people.map((p) => (
        <figure class="group grid grid-cols-1 sm:grid-cols-[44%_1fr] rounded-3xl overflow-hidden bg-[#FBF6EA] border border-[#412F1F]/10 shadow-[0_10px_40px_-12px_rgba(65,47,31,0.18)] lift">
          <div class="imgzoom overflow-hidden">
            <div class="h-64 sm:h-full sm:min-h-[24rem]">
              <img src={p.img} alt={p.name} loading="lazy" class="w-full h-full object-cover" />
            </div>
          </div>
          <figcaption class="p-8 md:p-10 flex flex-col justify-center">
            <svg class="w-10 h-10 text-[#9A3922]/20 mb-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <blockquote class="text-lg md:text-xl text-[#412F1F]/85 leading-relaxed">{p.quote}</blockquote>
            <div class="mt-7 flex items-center gap-3">
              <span class="h-px w-8 bg-[#9A3922]"></span>
              <span class="font-extrabold text-sm uppercase tracking-[0.12em] text-[#9A3922]">{p.name}</span>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
