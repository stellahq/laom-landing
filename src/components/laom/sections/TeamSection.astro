---
// TeamSection — "Meet your storytellers" : head + grille de TeamCard (hover + zoom).
import SectionHead from './SectionHead.astro'
import TeamCard from '../TeamCard.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; intro?: string;
  members: { img: string; name: string; role: string }[]; bg?: string;
}
const { eyebrow = 'L’équipe', title, accent, intro, members, bg = 'bg-[#FBF6EA]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <SectionHead eyebrow={eyebrow} title={title} accent={accent} intro={intro} align="center" class="mb-14" />
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
      {members.map((m) => <TeamCard img={m.img} name={m.name} role={m.role} />)}
    </div>
  </div>
</section>
