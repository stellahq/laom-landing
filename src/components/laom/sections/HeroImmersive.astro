---
// HeroImmersive — ouverture plein écran, centrée, LOGO mis en avant.
// Vidéo (ou photo) plein cadre + overlay fort pour une lisibilité parfaite.
import Logo from '../Logo.astro'
import Pill from '../Pill.astro'
interface Props {
  img: string; video?: string; alt?: string
  navLinks?: { label: string; href: string }[]
  navCta?: string; navCtaHref?: string
  eyebrow?: string; title: string; accent?: string; subtitle?: string
  ctaText?: string; ctaHref?: string
}
const {
  img, video, alt = '', navLinks = [], navCta = 'Candidater', navCtaHref = '/candidater/',
  eyebrow, title, accent, subtitle, ctaText = 'Candidater', ctaHref = '/candidater/',
} = Astro.props
const videoType = video?.endsWith('.mp4') ? 'video/mp4' : 'video/webm'
---
<section class="relative min-h-screen w-full overflow-hidden flex flex-col">
  {video
    ? <video autoplay muted loop playsinline poster={img} class="absolute inset-0 w-full h-full object-cover"><source src={video} type={videoType} /></video>
    : <img src={img} alt={alt} class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />}
  <div class="absolute inset-0 bg-[#1D1B18]/55"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-[#1D1B18]/55 via-[#1D1B18]/25 to-[#1D1B18]/85"></div>

  <nav class="relative z-20 max-w-7xl w-full mx-auto px-6 md:px-10 lg:px-14 pt-7 flex items-center justify-between gap-6">
    <ul class="hidden md:flex items-center gap-9">
      {navLinks.map((n) => <li><a href={n.href} class="text-sm tracking-wide text-[#F2EBDB]/85 hover:text-white transition-colors">{n.label}</a></li>)}
    </ul>
    <a href={navCtaHref} class="pill pill-light shrink-0" style="padding:.7rem 1.6rem">{navCta}</a>
  </nav>

  <div class="relative z-10 flex-1 flex flex-col items-center justify-center text-center px-6 pb-20">
    <Logo class="text-[#F2EBDB] drop-shadow-[0_2px_20px_rgba(0,0,0,0.4)]" height="clamp(3rem,7vw,5.5rem)" />
    {eyebrow && <p class="mt-9 mb-6 text-xs md:text-sm font-medium tracking-[0.28em] uppercase text-[#F2EBDB]/80">{eyebrow}</p>}
    <h1 class="font-extrabold text-[#F2EBDB] text-[clamp(2.3rem,5.5vw,4.8rem)] leading-[1.04] tracking-[-0.03em] max-w-4xl text-balance">
      {title}{accent && <> <span class="acc-light">{accent}</span></>}
    </h1>
    {subtitle && <p class="mt-7 text-lg md:text-xl text-[#F2EBDB]/85 max-w-xl leading-relaxed">{subtitle}</p>}
    <Pill href={ctaHref} variant="primary" arrow={true} class="mt-10">{ctaText}</Pill>
  </div>

  <div class="relative z-10 pb-8 flex justify-center">
    <span aria-hidden="true" class="block w-px h-12 bg-gradient-to-b from-transparent to-[#F2EBDB]/60"></span>
  </div>
</section>
