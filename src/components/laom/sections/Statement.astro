---
// Statement — déclaration centrée et aérée (manifeste, vision, CTA fort).
// Beaucoup d'air, très lisible. CTA + texture topo optionnels. light = fond sombre.
import SectionHead from './SectionHead.astro'
import Pill from '../Pill.astro'
import TopoBg from '../graphics/TopoBg.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; intro?: string
  ctaText?: string; ctaHref?: string
  bg?: string; texture?: boolean; light?: boolean
}
const {
  eyebrow, title, accent, intro, ctaText, ctaHref = '#',
  bg = 'bg-[#FBF6EA]', texture = false, light = false,
} = Astro.props
---
<section class:list={[bg, 'relative overflow-hidden py-28 md:py-40']}>
  {texture && <TopoBg kind="topo" variant="light" class="opacity-50" />}
  <div class="relative max-w-3xl mx-auto px-6 md:px-10 text-center">
    <SectionHead align="center" light={light} eyebrow={eyebrow} title={title} accent={accent} intro={intro} size="text-4xl md:text-5xl xl:text-6xl" />
    {ctaText && <div class="mt-10"><Pill href={ctaHref} variant="primary">{ctaText}</Pill></div>}
  </div>
</section>
