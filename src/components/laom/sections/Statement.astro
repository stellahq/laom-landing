---
// Statement — déclaration centrée, spacieuse (manifeste, vision…). Texte large,
// très lisible, beaucoup d'air. Texture topo optionnelle pour habiller.
import SectionHead from './SectionHead.astro'
import TopoBg from '../graphics/TopoBg.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; intro?: string
  bg?: string; texture?: boolean
}
const { eyebrow, title, accent, intro, bg = 'bg-[#FBF6EA]', texture = false } = Astro.props
---
<section class:list={[bg, 'relative overflow-hidden py-28 md:py-40']}>
  {texture && <TopoBg kind="topo" variant="light" class="opacity-50" />}
  <div class="relative max-w-3xl mx-auto px-6 md:px-10">
    <SectionHead
      align="center"
      eyebrow={eyebrow}
      title={title}
      accent={accent}
      intro={intro}
      size="text-4xl md:text-5xl xl:text-6xl" />
  </div>
</section>
