---
// MediaText — photo nette d'un côté, texte (eyebrow + titre + intro) + CTA de l'autre.
// La photo est MONTRÉE (pas en fond sombre). reverse pour inverser le sens.
import Pill from '../Pill.astro'
import SectionHead from './SectionHead.astro'
interface Props {
  img: string; alt?: string
  eyebrow?: string; title: string; accent?: string; text?: string
  ctaText?: string; ctaHref?: string
  reverse?: boolean; bg?: string; ratio?: string
}
const {
  img, alt = '', eyebrow, title, accent, text,
  ctaText, ctaHref = '#', reverse = false, bg = 'bg-[#F2EBDB]', ratio = 'aspect-[4/3]',
} = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14 grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
    <div class:list={['imgzoom rounded-3xl overflow-hidden', ratio, reverse && 'lg:order-2']}>
      <img src={img} alt={alt} class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div class={reverse ? 'lg:order-1' : ''}>
      <SectionHead eyebrow={eyebrow} title={title} accent={accent} intro={text} />
      {ctaText && <Pill href={ctaHref} variant="primary" class="mt-8">{ctaText}</Pill>}
    </div>
  </div>
</section>
