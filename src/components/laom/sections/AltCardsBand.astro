---
// AltCardsBand — bande alternée : pour chaque item, une photo + une carte colorée.
// 2 items = photo / carte / photo / carte. (Compo template.) Tons alternés.
interface Item { img: string; alt?: string; title: string; text: string }
interface Props { items: Item[]; bg?: string }
const { items, bg = 'bg-[#F2EBDB]' } = Astro.props
const tones = ['bg-[#412F1F]', 'bg-[#73673E]'] // marron, vert olive
---
<section class:list={[bg, 'py-12 md:py-16']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {items.map((it, i) => (
        <>
          <div class="rounded-2xl overflow-hidden aspect-[4/5] imgzoom">
            <img src={it.img} alt={it.alt ?? ''} loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class:list={[tones[i % 2], 'rounded-2xl p-7 md:p-8 flex flex-col justify-center']}>
            <h3 class="text-2xl font-extrabold text-[#F2EBDB] leading-tight">{it.title}</h3>
            <p class="text-[#F2EBDB]/75 mt-4 leading-relaxed">{it.text}</p>
          </div>
        </>
      ))}
    </div>
  </div>
</section>
