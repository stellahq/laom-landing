---
// MissionSection — carte sombre CONTENUE (arrondie, marge) sur photo + veinage :
// head clair + 4 cartes numérotées en verre. Numéros = vraie séquence.
import SectionHead from './SectionHead.astro'
import NumberedCard from '../NumberedCard.astro'
import TopoBg from '../graphics/TopoBg.astro'
import Parallax from '../graphics/Parallax.astro'
interface Props {
  img?: string; eyebrow?: string; title: string; accent?: string; intro?: string;
  items: { num: string; title: string; text: string }[]; bg?: string;
}
const { img, eyebrow, title, accent, intro, items, bg = 'bg-[#F2EBDB]' } = Astro.props
---
<section class:list={[bg, 'py-16 md:py-24']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class="relative overflow-hidden rounded-[2rem] bg-[#412F1F] px-6 md:px-12 py-16 md:py-20">
      {img && <Parallax src={img} class="opacity-25" speed={0.16} />}
      <TopoBg variant="light" />
      <div class="relative">
        <SectionHead eyebrow={eyebrow} title={title} accent={accent} intro={intro} align="center" light={true} class="mb-14" />
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {items.map((it) => <NumberedCard num={it.num} title={it.title} text={it.text} glass={true} />)}
        </div>
      </div>
    </div>
  </div>
</section>
