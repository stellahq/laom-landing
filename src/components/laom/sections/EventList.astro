---
// EventList — agenda : head + liste de lignes (date · titre · desc · flèche).
import SectionHead from './SectionHead.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string;
  events: { date: string; sub?: string; title: string; desc?: string; href?: string }[]; bg?: string;
}
const { eyebrow = 'Agenda', title, accent, events, bg = 'bg-[#F2EBDB]' } = Astro.props
---
<section id="events" class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-4xl mx-auto px-6 md:px-10 lg:px-14">
    <SectionHead eyebrow={eyebrow} title={title} accent={accent} class="mb-12" />
    <div class="divide-y divide-[#412F1F]/12">
      {events.map((e) => (
        <a href={e.href ?? '#'} class="group flex items-start gap-6 py-6 first:pt-0">
          <div class="w-28 flex-shrink-0">
            <p class="text-sm font-medium tracking-wide uppercase text-[#9A3922]">{e.date}</p>
            {e.sub && <p class="text-xs text-[#1D1B18]/40 mt-0.5">{e.sub}</p>}
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-bold text-[#412F1F] group-hover:text-[#9A3922] transition-colors leading-snug">{e.title}</h3>
            {e.desc && <p class="text-sm text-[#1D1B18]/55 mt-1 line-clamp-1">{e.desc}</p>}
          </div>
          <span class="circle-btn w-10 h-10 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H8M17 7v9"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
