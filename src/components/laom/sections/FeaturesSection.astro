---
// FeaturesSection — "Comfortable living systems" : head + grille de bénéfices (FeatureItem).
import SectionHead from './SectionHead.astro'
import FeatureItem from '../FeatureItem.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; intro?: string;
  items: { title: string; text: string }[]; bg?: string;
}
const { eyebrow, title, accent, intro, items, bg = 'bg-[#FBF6EA]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-6xl mx-auto px-6 md:px-10 lg:px-14">
    <SectionHead eyebrow={eyebrow} title={title} accent={accent} intro={intro} align="center" class="mb-14" />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-8">
      {items.map((f) => <FeatureItem title={f.title}>{f.text}</FeatureItem>)}
    </div>
  </div>
</section>
