---
// PhotoStrip — bande de 2 à 4 photos alignées (rounded + zoom au survol), légendes
// optionnelles. Pour enrichir une section récit de plusieurs visuels.
interface Item { img: string; alt?: string; caption?: string }
interface Props { items: Item[]; bg?: string }
const { items, bg = 'bg-[#F2EBDB]' } = Astro.props
const cols = items.length === 2 ? 'sm:grid-cols-2' : items.length >= 4 ? 'sm:grid-cols-2 lg:grid-cols-4' : 'sm:grid-cols-3'
---
<section class:list={[bg, 'py-12 md:py-16']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class:list={['grid grid-cols-1 gap-4 md:gap-5', cols]}>
      {items.map((it) => (
        <figure class="lift">
          <div class="rounded-2xl overflow-hidden imgzoom aspect-[4/3]">
            <img src={it.img} alt={it.alt ?? ''} loading="lazy" class="w-full h-full object-cover" />
          </div>
          {it.caption && <figcaption class="text-sm text-[#1D1B18]/60 mt-3 px-1">{it.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</section>
