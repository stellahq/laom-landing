---
// HabitatsSection — eyebrow + titre + intro à droite + grille de MediaCard.
import SectionHead from './SectionHead.astro'
import MediaCard from '../MediaCard.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; intro?: string;
  items: { img: string; alt?: string; title: string; desc?: string; href?: string }[];
  bg?: string;
}
const { eyebrow = 'Nos habitats', title, accent, intro, items, bg = 'bg-[#FBF6EA]' } = Astro.props
---
<section id="habitats" class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class="grid lg:grid-cols-2 gap-8 items-end mb-14">
      <SectionHead eyebrow={eyebrow} title={title} accent={accent} />
      {intro && <p class="text-lg text-[#1D1B18]/70 leading-relaxed lg:pb-2 lg:max-w-md lg:justify-self-end">{intro}</p>}
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((h) => <MediaCard img={h.img} alt={h.alt ?? h.title} title={h.title} desc={h.desc} href={h.href} />)}
    </div>
  </div>
</section>
