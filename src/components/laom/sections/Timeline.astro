---
// Timeline — frise horaire verticale (une journée type). Heure + moment, points
// reliés par un filet. Sobre, lisible.
import SectionHead from './SectionHead.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; intro?: string
  items: { time: string; label: string }[]; note?: string; bg?: string
}
const { eyebrow, title, accent, intro, items, note, bg = 'bg-[#FBF6EA]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-3xl mx-auto px-6 md:px-10">
    <div class="mb-14 text-center">
      <SectionHead align="center" eyebrow={eyebrow} title={title} accent={accent} intro={intro} />
    </div>
    <ol class="relative ml-2 border-l border-[#412F1F]/15 space-y-8">
      {items.map((it) => (
        <li class="relative pl-8">
          <span class="absolute -left-[7px] top-1.5 w-3.5 h-3.5 rounded-full bg-[#9A3922] ring-4 ring-[var(--tw-ring,transparent)]" style={`box-shadow:0 0 0 4px ${bg.includes('FBF6EA') ? '#FBF6EA' : '#F2EBDB'}`}></span>
          <p class="text-sm font-extrabold tracking-wide text-[#9A3922]">{it.time}</p>
          <p class="text-lg text-[#1D1B18]/85 leading-snug">{it.label}</p>
        </li>
      ))}
    </ol>
    {note && <p class="text-center italic text-[#1D1B18]/60 mt-12 max-w-md mx-auto">{note}</p>}
  </div>
</section>
