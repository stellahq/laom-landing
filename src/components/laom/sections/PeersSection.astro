---
// PeersSection — « Qui vient » : bloc narratif éditorial. Eyebrow + titre asymétrique
// (même grille que SplitHeading), deux paragraphes, une grande photo « entre pairs »,
// puis une ligne de clôture détachée et centrée. Compo template, langage visuel DS1.
interface Props {
  eyebrow: string; title: string; accent?: string
  paragraphs: string[]
  img: string; alt?: string
  closing: string; closingAccent?: string
  bg?: string
}
const { eyebrow, title, accent, paragraphs, img, alt = '', closing, closingAccent, bg = 'bg-[#FBF6EA]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
    <div class="grid lg:grid-cols-[0.7fr_2fr] gap-6 lg:gap-16 items-start">
      <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] lg:pt-3">{eyebrow}</p>
      <div>
        <h2 class="text-4xl md:text-5xl xl:text-6xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.08] text-balance">
          {title}{accent && <> <span class="acc">{accent}</span></>}
        </h2>
        <div class="mt-7 space-y-5 max-w-2xl">
          {paragraphs.map((p) => <p class="text-lg text-[#1D1B18]/70 leading-relaxed">{p}</p>)}
        </div>
      </div>
    </div>

    <div class="imgzoom rounded-3xl overflow-hidden aspect-[16/9] md:aspect-[21/9] mt-14 md:mt-20">
      <img src={img} alt={alt} class="w-full h-full object-cover" loading="lazy" />
    </div>

    <p class="text-2xl md:text-3xl font-extrabold text-[#412F1F] tracking-[-0.01em] leading-[1.15] text-balance text-center max-w-3xl mx-auto mt-14 md:mt-20">
      {closing}{closingAccent && <> <span class="acc">{closingAccent}</span></>}
    </p>
  </div>
</section>
