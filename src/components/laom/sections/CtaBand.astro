---
// CtaBand — bande d'appel à l'action PROPRE : aplat terre, texte centré, CTA.
// Pas de photo en fond, pas de calque. Sobre et lisible.
import Pill from '../Pill.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string; subtitle?: string
  primaryText: string; primaryHref: string
  secondaryText?: string; secondaryHref?: string
}
const { eyebrow, title, accent, subtitle, primaryText, primaryHref, secondaryText, secondaryHref } = Astro.props
---
<section class="bg-[#9A3922] py-24 md:py-32">
  <div class="max-w-3xl mx-auto px-6 text-center">
    {eyebrow && <p class="text-xs uppercase tracking-[0.18em] text-[#F2EBDB]/65 font-semibold mb-4">{eyebrow}</p>}
    <h2 class="text-4xl md:text-5xl font-extrabold text-[#F2EBDB] tracking-[-0.02em] leading-[1.08] text-balance">{title}{accent && <> <span class="italic font-medium text-[#F2EBDB]/85">{accent}</span></>}</h2>
    {subtitle && <p class="text-lg text-[#F2EBDB]/80 mt-5 max-w-xl mx-auto leading-relaxed">{subtitle}</p>}
    <div class="flex flex-wrap gap-4 justify-center items-center mt-10">
      <Pill href={primaryHref} variant="light" arrow={true}>{primaryText}</Pill>
      {secondaryText && <a href={secondaryHref} class="text-[#F2EBDB]/85 underline underline-offset-4 hover:text-[#F2EBDB] transition-colors text-sm">{secondaryText}</a>}
    </div>
  </div>
</section>
