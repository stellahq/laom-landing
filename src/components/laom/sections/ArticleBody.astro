---
// ArticleBody — corps d'article long-forme : titre de section + prose + paire d'images.
// Le contenu riche passe en slot (markdown rendu / HTML).
import SectionHeading from '../SectionHeading.astro'
interface Props { heading?: string; accent?: string; images?: { src: string; alt?: string }[]; bg?: string }
const { heading, accent, images = [], bg = 'bg-[#F2EBDB]' } = Astro.props
---
<section class:list={[bg, 'py-16 md:py-24']}>
  <div class="max-w-3xl mx-auto px-6 md:px-10">
    {heading && <SectionHeading text={heading} accent={accent} as="h2" size="text-3xl md:text-4xl" class="mb-8" />}
    <div class="prose-laom text-lg text-[#1D1B18]/80 leading-relaxed [&>p]:mb-5 [&>h3]:text-2xl [&>h3]:font-extrabold [&>h3]:text-[#412F1F] [&>h3]:mt-10 [&>h3]:mb-4">
      <slot />
    </div>
    {images.length > 0 && (
      <div class="grid sm:grid-cols-2 gap-5 mt-10">
        {images.map((im) => <div class="rounded-2xl overflow-hidden aspect-[4/3]"><img src={im.src} alt={im.alt ?? ''} class="w-full h-full object-cover" loading="lazy" /></div>)}
      </div>
    )}
  </div>
</section>
