---
// TestimonialsSection — head + grille de Testimonial.
import SectionHead from './SectionHead.astro'
import Testimonial from '../Testimonial.astro'
interface Props {
  eyebrow?: string; title: string; accent?: string;
  items: { quote: string; name: string; avatar?: string; role?: string }[]; bg?: string;
}
const { eyebrow = 'Témoignages', title, accent, items, bg = 'bg-[#F2EBDB]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-6xl mx-auto px-6 md:px-10 lg:px-14">
    <SectionHead eyebrow={eyebrow} title={title} accent={accent} align="center" class="mb-14" />
    <div class="grid md:grid-cols-3 gap-6">
      {items.map((t) => <Testimonial quote={t.quote} name={t.name} avatar={t.avatar} role={t.role} />)}
    </div>
  </div>
</section>
