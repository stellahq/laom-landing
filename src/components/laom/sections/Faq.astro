---
// Faq — questions/réponses en accordéon natif (<details>), accessible, sans JS.
// Lève les objections qui bloquent le passage à l'action. Compo template DS1.
interface Item { q: string; a: string }
interface Props { eyebrow?: string; title: string; accent?: string; items: Item[]; bg?: string }
const { eyebrow = 'Questions fréquentes', title, accent, items, bg = 'bg-[#F2EBDB]' } = Astro.props
---
<section class:list={[bg, 'py-24 md:py-32']}>
  <div class="max-w-3xl mx-auto px-6 md:px-10">
    <div class="mb-12">
      <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-5">{eyebrow}</p>
      <h2 class="text-4xl md:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.08] text-balance">{title}{accent && <> <span class="acc">{accent}</span></>}</h2>
    </div>
    <div class="divide-y divide-[#412F1F]/12 border-y border-[#412F1F]/12">
      {items.map((it) => (
        <details class="faq group py-5">
          <summary class="flex items-center justify-between gap-6 cursor-pointer list-none text-lg md:text-xl font-semibold text-[#412F1F]">
            <span>{it.q}</span>
            <span class="shrink-0 w-7 h-7 grid place-items-center rounded-full bg-[#9A3922]/10 text-[#9A3922] transition-transform duration-300 group-open:rotate-45">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
            </span>
          </summary>
          <p class="text-[#1D1B18]/70 leading-relaxed mt-4 pr-10">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
<style>
  .faq summary::-webkit-details-marker { display: none; }
</style>
