---
// Jeu d'icônes maison LAOM — tracé original, à la charte (stroke = currentColor,
// donc la couleur se pilote via la classe Tailwind du parent).
interface Props {
  name: string
  class?: string
}
const { name, class: className = '' } = Astro.props

const icons: Record<string, string> = {
  tipi: '<path d="M3 20 12 4 21 20Z"/><path d="M9.5 6.5 13 3M14.5 6.5 11 3"/><path d="M12 20v-5"/>',
  coworking: '<rect x="5" y="6" width="14" height="9" rx="1"/><path d="M3 18h18l1.4 2.4H1.6Z"/>',
  cuisine: '<path d="M5 11h14v3a5 5 0 0 1-5 5h-4a5 5 0 0 1-5-5z"/><path d="M3 11h18"/><path d="M9 7c0-1 6-1 6 0"/>',
  potager: '<path d="M12 3c6 4 5 14 0 18C7 17 6 7 12 3Z"/><path d="M12 7v12"/>',
  guinguette: '<path d="M3 6q9 4 18 0"/><path d="M6 6.6 8 11 10 6.1M13 6.1 15 11 17 5.6"/>',
  exterieurs: '<circle cx="12" cy="9" r="5"/><path d="M12 14v6"/><path d="M8 20h8"/>',
  repas: '<path d="M4 12h16a8 8 0 0 1-16 0Z"/><path d="M3 12h18"/><path d="M9 7q1-2 0-4M13 7q1-2 0-4"/>',
  yoga: '<circle cx="12" cy="6" r="2"/><path d="M12 9c-2 2-3 5-3 7M12 9c2 2 3 5 3 7"/><path d="M6 18q6-3 12 0"/>',
  communaute: '<circle cx="9" cy="9" r="2.5"/><circle cx="16" cy="10" r="2"/><path d="M4 19c0-3 2.2-5 5-5s5 2 5 5"/><path d="M14.4 19c0-2 .7-3.4 2-4.1"/>',
  boussole: '<circle cx="12" cy="12" r="9"/><path d="M15 9 13 13 9 15 11 11Z"/>',
  feu: '<path d="M12 4c4 5 2 9 0 12C10 13 8 9 12 4Z"/><path d="M5 20 19 16M5 16 19 20"/>',
  causses: '<path d="M3 19 9 9 13 14 17 7 21 19Z"/>',
  etoiles: '<path d="M12 4 13 10 19 11 13 12 12 18 11 12 5 11 11 10Z"/>',
}
const markup = icons[name] ?? ''
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={markup}
></svg>
