    taches: [
      'الشرفات المشتركة (مع شارلي + دافيد كوست)',
      'الصرف الصحي إذا وافق SPANC',
    ]
  },
  {
    periode: 'أغسطس - سبتمبر',
    taches: [
      'تنسيق الحدائق (مع دافيد كوست)',
      'تسوية الأرض + الصرف',
      'الممرات + الزراعة',
    ]
  },
]

const cuisineFr = {
  titre: 'Cuisine (ete)',
  sousTitre: 'Soutien equipe Lorenzo',
  taches: [
    'Preparation mezzes syriens',
    'Baklava maison (pistaches, miel, fleur d\'oranger)',
    'Soutien general en cuisine',
    'Aide service si besoin',
  ]
}

const cuisineAr = {
  titre: 'المطبخ (صيف)',
  sousTitre: 'دعم فريق لورينزو',
  taches: [
    'تحضير المقبلات السورية',
    'بقلاوة منزلية (فستق، عسل، ماء زهر)',
    'دعم عام في المطبخ',
    'مساعدة في الخدمة عند الحاجة',
  ]
}

const quotidienFr = {
  titre: 'Au quotidien',
  items: [
    { label: 'Point matin avec Charly', desc: 'Chaque jour, planning de la journee' },
    { label: 'Autonomie sur les taches', desc: 'Tu sais ce qu\'il faut faire' },
    { label: 'Renfort la ou c\'est necessaire', desc: 'Flexibilite selon les priorites' },
  ]
}

const quotidienAr = {
  titre: 'اليوم العادي',
  items: [
    { label: 'اجتماع صباحي مع شارلي', desc: 'كل يوم، تخطيط اليوم' },
    { label: 'استقلالية في المهام', desc: 'أنت تعرف ما يجب القيام به' },
    { label: 'دعم حيث يلزم', desc: 'مرونة حسب الأولويات' },
  ]
}

const labelsFr = {
  pageTitle: 'Planning 2026',
  travaux: 'Travaux',
  cuisine: 'Cuisine',
  quotidien: 'Au quotidien',
  contact: 'Contact',
  questionContact: 'Questions ? Contacte Charly',
  roles: 'Roles',
  contrat: 'Contrat',
  salaire: 'Salaire',
  switchLang: 'عربي',
}

const labelsAr = {
  pageTitle: 'خطة 2026',
  travaux: 'الأعمال',
  cuisine: 'المطبخ',
  quotidien: 'اليوم العادي',
  contact: 'اتصال',
  questionContact: 'أسئلة؟ اتصل بشارلي',
  roles: 'الأدوار',
  contrat: 'العقد',
  salaire: 'الراتب',
  switchLang: 'FR',
