  nom: 'خلدون',
  roles: ['عامل متعدد المهام', 'دعم المطبخ'],
  contrat: '12 شهر',
  salaire: '2,000 يورو / شهر',
  contact: '06.73.68.35.73 (شارلي)',
}

const travauxFr = [
  {
    periode: 'FEVRIER - MARS',
    taches: [
      'Electricite Grand Shambala (avec Charly)',
      'Corten + etancheite facades (15 jours)',
      'Cloisons etage',
    ]
  },
  {
    periode: 'AVRIL - MAI',
    taches: [
      'Studio Charly (avec Charly)',
      'Preparation paysagement',
    ]
  },
  {
    periode: 'JUIN',
    taches: [
      'Installation guinguette (avec Charly)',
      'Monter tente 300m²',
      'Equipements cuisine',
    ]
  },
  {
    periode: 'JUILLET',
    taches: [
      'Terrasses communes (avec Charly + David Coste)',
      'Assainissement si SPANC OK',
    ]
  },
  {
    periode: 'AOUT - SEPTEMBRE',
    taches: [
      'Paysagement (avec David Coste)',
      'Terrassement + drainage',
      'Chemins + plantations',
    ]
  },
]

