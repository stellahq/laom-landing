---
// Page 2 — COLIVING (présentation), composition reprise du template "À propos"
// (header photo + breadcrumb, titre 2 colonnes, bande alternée photo/cartes,
// mission + cartes numérotées qui chevauchent + 3 cartes services), habillée en
// charte Lucas avec le texte du brief et les vraies photos LAOM.
// Route isolée /coliving-labo (noindex, hors menu).
import Layout from '~/layouts/Layout.astro'
import PageHeader from '~/components/laom/PageHeader.astro'
import SplitHeading from '~/components/laom/sections/SplitHeading.astro'
import AltCardsBand from '~/components/laom/sections/AltCardsBand.astro'
import MissionShowcase from '~/components/laom/sections/MissionShowcase.astro'
import OfferFeature from '~/components/laom/sections/OfferFeature.astro'
import CtaBand from '~/components/laom/sections/CtaBand.astro'
import StickyCta from '~/components/laom/StickyCta.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const F = (n: string) => `/images/festival/${n}.webp`
const L = (n: string) => `/images/laom/${n}.webp`

const navLinks = [
  { label: 'Accueil', href: '/accueil-labo/' },
  { label: 'Coliving', href: '/coliving-labo/' },
  { label: 'Le lieu', href: '/le-lieu/' },
  { label: 'Notre histoire', href: '/notre-histoire/' },
  { label: 'Contact', href: '/contact/' },
]
---

<Layout title="LAOM — Coliving entrepreneurs, présentation" hideChrome={true} seo={{ noIndex: true }}>

  <!-- HEADER (photo arrondie + breadcrumb) -->
  <PageHeader
    img={F('hero')}
    navLinks={navLinks} navCta="Candidater" navCtaHref="/candidater/"
    crumbs={[{ label: 'Accueil', href: '/accueil-labo/' }, { label: 'Coliving' }]}
    title="Vivre et travailler autrement"
    subtitle="Une semaine en pleine nature, entre douze entrepreneurs. On s’occupe de tout — tu gardes ton énergie pour ce que tu es venu·e créer." />

  <!-- INTRO — titre 2 colonnes -->
  <div animate-fade-in-up class="opacity-0">
    <SplitHeading bg="bg-[#FBF6EA]"
      eyebrow="Le coliving"
      title="Une semaine pour poser ton ordi dans un cadre que tu n’as jamais eu," accent="et rien d’autre à gérer."
      text="Tu es entrepreneur depuis quelques années. Tu as construit quelque chose qui marche, mais ton quotidien ressemble de moins en moins à ce que tu voulais créer au départ. LAOM, c’est une semaine pour travailler dans le calme, manger ce qui pousse ici, et rencontrer des pairs qui vivent la même chose. Ce n’est pas une retraite, ce n’est pas un séminaire. C’est un mode de vie, le temps d’une semaine." />
  </div>

  <!-- BANDE ALTERNÉE — photo / carte / photo / carte -->
  <div animate-fade-in-up class="opacity-0">
    <AltCardsBand bg="bg-[#F2EBDB]"
      items={[
        { img: F('act-chillworking'), alt: 'Coworking en pleine nature à LAOM', title: 'Coworking en pleine nature', text: 'Wifi haut débit, calme absolu, face à la vallée. Tu bosses le matin, tu décroches l’après-midi.' },
        { img: L('diner-golden-hour-laom'), alt: 'Dîner fait maison à LAOM', title: 'Repas faits maison', text: 'Produits du potager et producteurs locaux, trois fois par jour. Tu ne penses plus à rien.' },
      ]} />
  </div>

  <!-- MISSION — cartes numérotées qui chevauchent + 3 cartes services -->
  <div animate-fade-in-up class="opacity-0">
    <MissionShowcase bg="bg-[#FBF6EA]"
      topImg={F('about-2')}
      topEyebrow="Tout est inclus"
      topTitle="Tu ne gères rien," topAccent="tu profites de tout."
      steps={[
        { num: '01', title: 'Hébergement en tipi', text: 'Au cœur du domaine, six nuits.' },
        { num: '02', title: 'Trois repas par jour', text: 'Faits maison, produits d’ici.' },
        { num: '03', title: 'Espace coworking', text: 'Équipé, wifi haut débit, au calme.' },
        { num: '04', title: 'Activités chaque jour', text: 'Yoga, rando, ateliers, soirées.' },
      ]}
      bottomImg={F('about-1')}
      bottomEyebrow="Aller plus loin"
      bottomTitle="Découvre le reste de" bottomAccent="LAOM."
      bottomText="Le lieu, l’histoire, et comment réserver ta semaine."
      features={[
        { title: 'Le lieu', text: '21 hectares, les tipis, le potager, la rivière.', href: '/le-lieu/' },
        { title: 'Notre histoire', text: 'Charly, Amandine et la naissance de LAOM.', href: '/notre-histoire/' },
        { title: 'Candidater', text: 'Deux minutes pour réserver ta semaine.', href: '/candidater/' },
      ]} />
  </div>

  <!-- L'OFFRE — bloc centré (encarts + prix) -->
  <div animate-fade-in-up class="opacity-0">
    <OfferFeature bg="bg-[#F2EBDB]"
      eyebrow="L’offre"
      title="Une semaine. Douze entrepreneurs." accent="Tout est inclus."
      callouts={[
        { value: '12', label: 'places / semaine' },
        { value: '6', label: 'nuits en tipi' },
        { value: '18', label: 'repas faits maison' },
        { value: '1h30', label: 'de Montpellier' },
      ]}
      priceLabel="Prix de lancement, août 2026"
      price="1 500 € HT" priceSuffix="/ semaine, tout compris"
      ctaText="Candidater" ctaHref="/candidater/" />
  </div>

  <!-- CTA FINAL -->
  <div animate-fade-in-up class="opacity-0">
    <CtaBand
      eyebrow="À toi de jouer"
      title="Prêt·e à vivre la semaine ?" accent="On t’attend."
      subtitle="Un échange de 15 minutes, sans pression. 12 places par semaine, on prend le temps de se connaître."
      primaryText="Candidater" primaryHref="/candidater/"
      secondaryText="ou fais le quiz" secondaryHref="/candidater/" />
  </div>

  <SiteFooter />

  <StickyCta text="Candidater" href="/candidater/" />
</Layout>
