---
// Page 2 — COLIVING (présentation). Le DESIGN sert le TEXTE : copie storytellée
// validée (registre présentation, pas page de vente), chaque section habillée du
// bon composant de la grammaire template, rien n'est coupé.
// Route isolée /coliving-labo (noindex, hors menu).
import Layout from '~/layouts/Layout.astro'
import { laboNav as navLinks } from '~/data/laboNav'
import PageHeader from '~/components/laom/PageHeader.astro'
import SplitHeading from '~/components/laom/sections/SplitHeading.astro'
import AltCardsBand from '~/components/laom/sections/AltCardsBand.astro'
import MosaicGallery from '~/components/laom/sections/MosaicGallery.astro'
import IncludedGrid from '~/components/laom/sections/IncludedGrid.astro'
import Timeline from '~/components/laom/sections/Timeline.astro'
import FitCheck from '~/components/laom/sections/FitCheck.astro'
import PeersSection from '~/components/laom/sections/PeersSection.astro'
import MediaText from '~/components/laom/sections/MediaText.astro'
import Statement from '~/components/laom/sections/Statement.astro'
import OfferFeature from '~/components/laom/sections/OfferFeature.astro'
import CtaImage from '~/components/laom/sections/CtaImage.astro'
import StickyCta from '~/components/laom/StickyCta.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const F = (n: string) => `/images/festival/${n}.webp`
const L = (n: string) => `/images/laom/${n}.webp`
---

<Layout title="LAOM — Coliving entrepreneurs, présentation" hideChrome={true} seo={{ noIndex: true }}>

  <!-- ① HEADER -->
  <PageHeader
    img={L('coworking-duo-table')}
    navLinks={navLinks} navCta="Candidater" navCtaHref="/candidater-labo/" logoHref="/accueil-labo/"
    crumbs={[{ label: 'Accueil', href: '/accueil-labo/' }, { label: 'Coliving' }]}
    title="Vivre et travailler autrement, le temps d’une semaine."
    subtitle="Douze entrepreneurs, vingt-et-un hectares de nature dans le sud de l’Aveyron, et une semaine où tu n’as rien à gérer. Juste à vivre, créer, respirer." />

  <!-- ② LE PROJET -->
  <div animate-fade-in-up class="opacity-0">
    <SplitHeading bg="bg-[#FBF6EA]"
      eyebrow="Le projet"
      title="Pas un lieu de plus." accent="Un lieu de vie."
      text="LAOM, c’est un coliving installé dans un domaine de vingt-et-un hectares, en pleine nature, à 1h30 de Montpellier. On l’a pensé pour les entrepreneurs déjà installés, celles et ceux qui ont bâti quelque chose, et qui savent qu’on crée mieux quand on peut, de temps en temps, ralentir et se reconnecter : à soi, aux autres, au vivant. Ni un hôtel, ni un coworking de plus. Un endroit où l’on vient vivre, une semaine, ce qu’on a envie de vivre depuis longtemps." />
  </div>

  <!-- ③ TA SEMAINE — narration + deux moments (bloc unique, aéré comme les autres) -->
  <div animate-fade-in-up class="opacity-0 bg-[#F2EBDB] pt-24 md:pt-32 pb-24 md:pb-32">
    <SplitHeading bg="bg-transparent" pad={false}
      eyebrow="Ta semaine"
      title="Le premier matin, tu ouvres ton ordi" accent="face à la vallée."
      text="Le wifi est là, le calme aussi, celui que tu n’avais plus. Tu travailles le matin, quand ta tête est la plus claire. À midi, tu poses tout : on mange ce qui a poussé ici, à la même table que onze autres qui, deux jours plus tôt, ne se connaissaient pas. L’après-midi, tu choisis : avancer encore, ou descendre jusqu’à la rivière. Le soir, c’est le feu, les conversations qui partent loin, et la voie lactée au-dessus de toi, sans une lumière pour la troubler." />
    <div class="mt-12 md:mt-16">
      <AltCardsBand bg="bg-transparent" pad={false}
        items={[
          { img: L('coworking-coussins'), alt: 'Entrepreneurs en coworking dans le shala de LAOM', title: 'Le matin, tu crées.', text: 'Coworking face à la vallée, wifi fibre, le silence que tu cherchais. Tu avances sur ce qui compte vraiment.' },
          { img: L('diner-golden-hour-laom'), alt: 'Soirée au feu à LAOM', title: 'Le soir, on se retrouve.', text: 'Repas faits maison, le feu, des gens qui parlent vrai. C’est souvent ça qui compte le plus.' },
        ]} />
    </div>
  </div>

  <!-- ④ LE LIEU -->
  <div animate-fade-in-up class="opacity-0">
    <MosaicGallery bg="bg-[#FBF6EA]"
      eyebrow="Le lieu"
      title="Vingt-et-un hectares," accent="et plus rien autour."
      intro="Un ancien domaine agricole dans le sud de l’Aveyron, posé loin du bruit. Des tipis dans l’herbe, un potager qui nourrit la table, une rivière, des chemins en forêt. Et la nuit, le ciel entier."
      images={[
        { src: '/images/vue-aeriene-laom2-hero.webp', alt: 'Vue aérienne du domaine LAOM' },
        { src: L('tipis'), alt: 'Les tipis de LAOM' },
        { src: L('laom-potager'), alt: 'Le potager de LAOM' },
        { src: L('riviere-laom'), alt: 'La rivière du domaine' },
        { src: L('diner-golden-hour-laom'), alt: 'Dîner en communauté à LAOM' },
      ]}
      ctaText="Découvrir le lieu en détail" ctaHref="/le-lieu-labo/" />
  </div>

  <!-- ⑤ TOUT EST INCLUS -->
  <div animate-fade-in-up class="opacity-0">
    <IncludedGrid bg="bg-[#F2EBDB]"
      eyebrow="Tout est inclus"
      title="Tu poses tes affaires." accent="On s’occupe du reste."
      intro="On a pensé la semaine pour que tu n’aies aucune intendance en tête. Pas de courses, pas de cuisine, pas d’organisation. Tu arrives, et tout est déjà là."
      items={[
        { title: 'Hébergement en tipi', desc: 'Six nuits au cœur du domaine.' },
        { title: 'Trois repas par jour', desc: 'Faits maison, du potager et des producteurs d’à côté.' },
        { title: 'Espace coworking', desc: 'Équipé, wifi fibre, au calme.' },
        { title: 'Pratiques du matin', desc: 'Yoga, mouvement, marche.' },
        { title: 'Ateliers & soirées', desc: 'Au fil de la semaine.' },
        { title: 'Accès libre au domaine', desc: 'Forêt, rivière, potager, feu.' },
      ]} />
  </div>

  <!-- ⑥ UNE JOURNÉE -->
  <div animate-fade-in-up class="opacity-0">
    <Timeline bg="bg-[#FBF6EA]"
      eyebrow="Une journée type"
      title="Le rythme d’une" accent="journée ici."
      items={[
        { time: '7h30', label: 'Réveil en pleine nature' },
        { time: '8h00', label: 'Petit-déjeuner, produits du domaine' },
        { time: '9h00 – 12h30', label: 'Coworking : le calme, la concentration' },
        { time: '12h30', label: 'Déjeuner à la grande table' },
        { time: '14h00 – 17h00', label: 'Travail ou activité, au choix' },
        { time: '17h00', label: 'Pratique collective : yoga, marche, atelier' },
        { time: '19h30', label: 'Dîner fait maison' },
        { time: '21h00', label: 'Veillée au feu, sous les étoiles' },
      ]}
      note="Rien n’est obligatoire. Tout est proposé. Tu choisis ce qui te fait du bien." />
  </div>

  <!-- ⑦ POUR QUI -->
  <div animate-fade-in-up class="opacity-0">
    <FitCheck bg="bg-[#F2EBDB]"
      eyebrow="Pour qui"
      title="Cette semaine n’est pas pour tout le monde." accent="Et c’est tant mieux."
      forItems={[
        'Tu es entrepreneur ou indépendant, installé depuis quelques années',
        'Tu cherches un cadre pour créer autrement, pas des vacances',
        'Tu as envie de rencontrer des pairs qui vivent la même chose',
        'La vie en collectif, même une semaine, ne te fait pas peur',
      ]}
      notItems={[
        'Tu cherches des vacances all inclusive au soleil',
        'Tu veux une formation business ou un programme rythmé',
        'Tu préfères rester seul et à distance des autres',
        'Tu cherches du luxe hôtelier',
      ]} />
  </div>

  <!-- ⑦bis QUI VIENT — les pairs dans la pièce -->
  <div animate-fade-in-up class="opacity-0">
    <PeersSection bg="bg-[#FBF6EA]"
      eyebrow="Qui vient"
      title="Ici, tu n’auras" accent="rien à expliquer."
      paragraphs={[
        'Tu connais ce moment où tu racontes ce que tu fais, et où, en face, ça ne prend pas vraiment. Ici, ça n’arrive pas. Les gens qui viennent à LAOM ont déjà bâti quelque chose. Ils savent ce que c’est d’y croire seul certains matins, de trancher sans filet, de tenir le cap quand personne ne regarde. Tu n’as pas besoin de te présenter longtemps : en deux phrases, on te comprend.',
        'Ils ne viennent pas chercher une méthode. Ils viennent prendre de la hauteur, se frotter à d’autres regards, et se rappeler qu’on crée mieux à plusieurs. C’est souvent au bord de la rivière ou autour du feu, sans le vouloir, que les vraies choses se disent. Et qu’une décision qui traînait depuis des mois finit par se débloquer.',
      ]}
      img={L('peers-groupe')} alt="Des entrepreneurs en échange à LAOM"
      closing="Tu arrives parmi des inconnus." closingAccent="Tu repars avec des gens qui comptent." />
  </div>

  <!-- ⑧ LES GENS -->
  <div animate-fade-in-up class="opacity-0">
    <MediaText bg="bg-[#F2EBDB]" reverse={true} img={L('charly-amandine-rire')} alt="Charly et Amandine, fondateurs de LAOM"
      eyebrow="Charly & Amandine"
      title="Ils ont construit le lieu" accent="qu’ils auraient voulu trouver."
      text="Charly et Amandine ont quitté la ville, acheté vingt-et-un hectares dans le sud de l’Aveyron, et passé des années à en faire un endroit où la nature, le travail et la vie en commun tiennent ensemble. LAOM, c’est leur projet de vie. Le coliving, c’est leur manière de t’inviter à le vivre, pas en visiteur, mais comme si, une semaine durant, c’était un peu le tien."
      ctaText="Lire notre histoire" ctaHref="/notre-histoire-labo/" />
  </div>

  <!-- ⑨ CE QUE TU EN REPARS -->
  <div animate-fade-in-up class="opacity-0">
    <Statement bg="bg-[#FBF6EA]"
      eyebrow="Au fond"
      title="On ne te promet pas de te changer." accent="On te propose un cadre."
      intro="On ne sait pas ce que cette semaine fera naître chez toi : une idée, une décision, du repos, ou simplement le plaisir d’avoir été là. Et c’est très bien ainsi. Ce que tu en retireras, c’est toi qui le décideras. Nous, on s’occupe de réunir les meilleures conditions pour que quelque chose ait la place d’arriver." />
  </div>

  <!-- ⑩ LE PRIX -->
  <div animate-fade-in-up class="opacity-0">
    <OfferFeature bg="bg-[#F2EBDB]"
      eyebrow="L’offre"
      title="Une semaine. Douze entrepreneurs." accent="Tout compris."
      callouts={[
        { value: '12', label: 'places / semaine' },
        { value: '6', label: 'nuits en tipi' },
        { value: '18', label: 'repas faits maison' },
        { value: '1h30', label: 'de Montpellier' },
      ]}
      priceLabel="Prix de lancement · août 2026 · pas de frais cachés"
      price="1 500 € HT" priceSuffix="/ semaine, tout compris"
      ctaText="Candidater" ctaHref="/candidater-labo/" />
  </div>

  <!-- ⑪ L'INVITATION -->
  <div animate-fade-in-up class="opacity-0">
    <CtaImage bg="bg-[#FBF6EA]" img={L('festival-laom-ambiance-nature-aveyron')}
      eyebrow="Nous rejoindre"
      title="Si l’idée te parle," accent="viens passer une semaine."
      subtitle="On accueille douze personnes à la fois, pour que chacun ait vraiment sa place. Si ça résonne, écris-nous : on prendra le temps d’un échange, sans engagement."
      primaryText="Candidater" primaryHref="/candidater-labo/"
      secondaryText="ou découvrir le lieu" secondaryHref="/le-lieu-labo/" />
  </div>

  <SiteFooter />

  <StickyCta text="Candidater" href="/candidater-labo/" />
</Layout>
