---
import Layout from '~/layouts/Layout.astro'
import MobileNav from '~/components/MobileNav.astro'

export const prerender = true

// ==========================================
// ESPACE MAGALI ROUBY
// Presentation personnalisee — Fevrier 2026
// ==========================================

// Couleur d'accent : Mauve doux (#7B6B8A)
const ACCENT = '#7B6B8A'

// Budget global
const budgetTotal = 535000

// Lot SCIA
const lotSCIA = { nom: 'Le Ruisseau', surface: '—', quotepart: 174281, scia: 'SCIA LAOM Est' }

// Travaux
const travaux = [
  { poste: 'SAS d\'entree / Veranda', surface: '15 m2', estimBasse: 12000, estimHaute: 20000, detail: 'Creation d\'un sas d\'entree de 15 m2, type veranda. Variabilite selon materiaux, vitrage et complexite d\'integration.' },
  { poste: 'Poele Tully Kiwi + pose', surface: '—', estimBasse: 8000, estimHaute: 17000, detail: 'Fourniture et installation complete (conduit, habillage, mise en service). Fourchette haute : conduit complexe et finition premium.' },
  { poste: 'Cuisine', surface: '—', estimBasse: 10000, estimHaute: 10000, detail: 'Pose d\'une cuisine equipee complete. Poste stable.' },
  { poste: 'Frais annexes (SDB, placards)', surface: '—', estimBasse: 10000, estimHaute: 10000, detail: 'Petits travaux salle de bain et placards sur mesure installes. Poste stable.' },
]
const totalTravauxBas = travaux.reduce((s, t) => s + t.estimBasse, 0)
const totalTravauxHaut = travaux.reduce((s, t) => s + t.estimHaute, 0)

// Pergola
const pergola = {
  achat: 8979,
  construction: 50000,
  surface: 25,
  prixM2: 2000,
  revenuAnnuelMin: 2000,
  revenuAnnuelMax: 3000,
  demarrage: 'Saison 2027',
}
const totalPergola = pergola.achat + pergola.construction

// Frais d'installation
const frais = [
  { poste: 'Main a main (petit materiel domaine)', montant: 4500, detail: 'Contribution a l\'achat du petit materiel d\'entretien collectif du domaine. Reglement en cash a l\'arrivee.' },
  { poste: 'Provision frais de notaire', montant: 4000, detail: 'Provision conservatoire. En principe non due, reservee par prudence.' },
  { poste: 'Quote-part foyer commun', montant: 7000, detail: 'Contribution a l\'acquisition de la quote-part du foyer commun du domaine.' },
  { poste: 'Entree au capital SAS (1 action)', montant: 50, detail: 'Part symbolique — donne la qualite d\'associee pour ouvrir un Compte Courant.' },
]
const totalFrais = frais.reduce((s, f) => s + f.montant, 0)

// CCA
const ccaMontant = 200000

// Totaux
const totalDepensesBas = lotSCIA.quotepart + totalTravauxBas + totalPergola + totalFrais
const totalDepensesHaut = lotSCIA.quotepart + totalTravauxHaut + totalPergola + totalFrais
const epargneBas = budgetTotal - totalDepensesHaut - ccaMontant
const epargneHaut = budgetTotal - totalDepensesBas - ccaMontant

// Scenarios CCA
const scenarioA = {
  nom: 'Scenario A',
  duree: 15,
  taux: 2.5,
  tauxLabel: 'Inflation (~2,5%)',
  tauxType: 'Variable (indexe inflation)',
  mensualite: 1333,
  totalRecu: 239940,
  totalInterets: 39940,
  ageFin: 76,
  tableau: [
    { annee: 1, age: 61, interets: 4830, capital: 11166, restant: 188834 },
    { annee: 2, age: 62, interets: 4545, capital: 11451, restant: 177383 },
    { annee: 3, age: 63, interets: 4250, capital: 11746, restant: 165637 },
    { annee: 4, age: 64, interets: 3945, capital: 12051, restant: 153586 },
    { annee: 5, age: 65, interets: 3630, capital: 12366, restant: 141220 },
    { annee: 6, age: 66, interets: 3305, capital: 12691, restant: 128529 },
    { annee: 7, age: 67, interets: 2970, capital: 13026, restant: 115503 },
    { annee: 8, age: 68, interets: 2625, capital: 13371, restant: 102132 },
    { annee: 9, age: 69, interets: 2270, capital: 13726, restant: 88406 },
    { annee: 10, age: 70, interets: 1905, capital: 14091, restant: 74315 },
    { annee: 11, age: 71, interets: 1530, capital: 14466, restant: 59849 },
    { annee: 12, age: 72, interets: 1140, capital: 14856, restant: 44993 },
    { annee: 13, age: 73, interets: 740, capital: 15256, restant: 29737 },
    { annee: 14, age: 74, interets: 330, capital: 15666, restant: 14071 },
    { annee: 15, age: 75, interets: 0, capital: 14071, restant: 0 },
  ]
}

const scenarioB = {
  nom: 'Scenario B',
  duree: 25,
  taux: 4.5,
  tauxLabel: '4,5% fixe',
  tauxType: 'Fixe',
  mensualite: 1111,
  totalRecu: 333300,
  totalInterets: 133300,
  ageFin: 86,
  tableau: [
    { annee: 1, age: 61, interets: 8860, capital: 4472, restant: 195528 },
    { annee: 2, age: 62, interets: 8655, capital: 4677, restant: 190851 },
    { annee: 3, age: 63, interets: 8440, capital: 4892, restant: 185959 },
    { annee: 4, age: 64, interets: 8215, capital: 5117, restant: 180842 },
    { annee: 5, age: 65, interets: 7978, capital: 5354, restant: 175488 },
    { annee: 6, age: 66, interets: 7730, capital: 5602, restant: 169886 },
    { annee: 7, age: 67, interets: 7470, capital: 5862, restant: 164024 },
    { annee: 8, age: 68, interets: 7197, capital: 6135, restant: 157889 },
    { annee: 9, age: 69, interets: 6910, capital: 6422, restant: 151467 },
    { annee: 10, age: 70, interets: 6608, capital: 6724, restant: 144743 },
    { annee: 11, age: 71, interets: 6290, capital: 7042, restant: 137701 },
    { annee: 12, age: 72, interets: 5955, capital: 7377, restant: 130324 },
    { annee: 13, age: 73, interets: 5600, capital: 7732, restant: 122592 },
    { annee: 14, age: 74, interets: 5226, capital: 8106, restant: 114486 },
    { annee: 15, age: 75, interets: 4830, capital: 8502, restant: 105984 },
    { annee: 16, age: 76, interets: 4410, capital: 8922, restant: 97062 },
    { annee: 17, age: 77, interets: 3965, capital: 9367, restant: 87695 },
    { annee: 18, age: 78, interets: 3494, capital: 9838, restant: 77857 },
    { annee: 19, age: 79, interets: 2994, capital: 10338, restant: 67519 },
    { annee: 20, age: 80, interets: 2464, capital: 10868, restant: 56651 },
    { annee: 21, age: 81, interets: 1902, capital: 11430, restant: 45221 },
    { annee: 22, age: 82, interets: 1305, capital: 12027, restant: 33194 },
    { annee: 23, age: 83, interets: 670, capital: 12662, restant: 20532 },
    { annee: 24, age: 84, interets: 340, capital: 12992, restant: 7540 },
    { annee: 25, age: 85, interets: 0, capital: 7540, restant: 0 },
  ]
}

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}

function formatK(n: number): string {
  return (n / 1000).toFixed(0) + 'k'
}
---

<Layout
  title="Magali Rouby — Espace Personnel | LAOM"
  description="Espace personnel de Magali Rouby — Projet d'installation et montage financier"
  seo={{ noindex: true, nofollow: true }}
>
  <style is:global>
    .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 2px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; }
    .table-container { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .table-container table { min-width: 100%; }
    @media (max-width: 640px) {
      .table-container table { font-size: 0.8rem; }
      .table-container th, .table-container td { padding: 0.5rem 0.375rem; }
    }
  </style>

  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#7B6B8A]/10 border border-[#7B6B8A]/20 mb-6">
          <svg class="w-8 h-8 text-[#7B6B8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Espace Magali</h2>
        <p class="text-white/50 text-sm">Document personnel et confidentiel</p>
      </div>

      <form id="password-form" class="space-y-4">
        <input
          type="password"
          id="password-input"
          placeholder="Mot de passe"
          class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#7B6B8A]/50 focus:ring-1 focus:ring-[#7B6B8A]/30 transition-all"
          autocomplete="off"
        />
        <button
          type="submit"
          class="w-full px-6 py-4 rounded-sm bg-[#7B6B8A] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#6A5C78] transition-colors"
        >
          Acceder
        </button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <!-- Navbar -->
  <MobileNav currentPage="/magali/" />

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-20 sm:pt-24 pb-8 sm:pb-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 sm:mb-6">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#7B6B8A] mb-2">Espace personnel</p>
          <h1 class="font-playfair text-2xl sm:text-3xl md:text-4xl font-medium text-white tracking-tight">
            Votre projet a LAOM
          </h1>
        </div>
        <div class="text-left sm:text-right">
          <p class="text-xs text-white/40">Fevrier 2026</p>
          <p class="text-sm text-white/70">Magali Rouby</p>
        </div>
      </div>
      <p class="text-sm text-white/50 max-w-2xl">
        Document personnalise — Budget, travaux, montage financier et simulation de revenu.
      </p>

      <!-- Quick stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 pt-6 border-t border-white/10">
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-[#7B6B8A]">{formatK(budgetTotal)}</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Budget total</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-white">{formatK(lotSCIA.quotepart)}</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Lot Le Ruisseau</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-white">{formatK(ccaMontant)}</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Investissement CCA</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-[#4A7C59]">2 scenarios</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">A votre choix</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <nav class="sticky top-14 z-40 bg-white/95 backdrop-blur-sm border-b border-black/5 py-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="flex gap-3 sm:gap-4 overflow-x-auto text-xs sm:text-sm pb-1">
        <a href="#lot" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap font-medium">Votre lot</a>
        <a href="#travaux" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Travaux</a>
        <a href="#pergola" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Pergola</a>
        <a href="#budget" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Budget</a>
        <a href="#epargne" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Epargne</a>
        <a href="#scenarios" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Scenarios</a>
        <a href="#comparatif" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Comparatif</a>
        <a href="#garanties" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Garanties</a>
        <a href="#etapes" class="text-[#2C2824]/60 hover:text-[#7B6B8A] transition-colors whitespace-nowrap">Etapes</a>
      </div>
    </div>
  </nav>

  <!-- VOTRE LOT -->
  <section id="lot" class="py-8 sm:py-10 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Votre lot : Le Ruisseau</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">SCIA LAOM Est — Quote-part : {formatNumber(lotSCIA.quotepart)} EUR</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6">
          <h3 class="text-sm font-medium text-[#2C2824] mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#7B6B8A]"></span>
            Ce que vous achetez
          </h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">Parts dans la SCIA LAOM Est</p>
                <p class="text-xs text-[#2C2824]/50">Proportionnelles a votre lot — jouissance exclusive du Ruisseau</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">Usage des parties communes</p>
                <p class="text-xs text-[#2C2824]/50">Acces aux espaces partages du domaine</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">Patrimoine revalorisable</p>
                <p class="text-xs text-[#2C2824]/50">La valeur augmente avec les ameliorations du domaine</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">Parts cessibles</p>
                <p class="text-xs text-[#2C2824]/50">Revendables si vous quittez le collectif (sous agrement)</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-[#7B6B8A]/5 rounded-sm border border-[#7B6B8A]/20 p-4 sm:p-6">
          <h3 class="text-sm font-medium text-[#7B6B8A] mb-4">Qu'est-ce qu'une SCIA ?</h3>
          <p class="text-sm text-[#2C2824]/70 leading-relaxed mb-3">
            La <strong>Societe Civile Immobiliere d'Attribution</strong> est la structure juridique qui porte les batiments du domaine. Chaque habitant detient des parts proportionnelles a son lot.
          </p>
          <p class="text-sm text-[#2C2824]/70 leading-relaxed">
            Vos parts vous donnent la <strong>jouissance exclusive</strong> de votre logement (Le Ruisseau) et un <strong>droit d'usage</strong> des parties communes. C'est un patrimoine immobilier reel, valorise a {formatNumber(lotSCIA.quotepart)} EUR.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRAVAUX -->
  <section id="travaux" class="py-8 sm:py-10 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Travaux d'amenagement</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">Amenagement interieur de votre lot — Estimation basse et haute</p>
      </div>

      <div class="space-y-4 mb-6">
        {travaux.map((t) => (
          <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4 sm:p-5">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="font-medium text-[#2C2824]">{t.poste}</h3>
                  {t.surface !== '—' && <span class="badge bg-[#7B6B8A]/10 text-[#7B6B8A]">{t.surface}</span>}
                </div>
                <p class="text-sm text-[#2C2824]/60">{t.detail}</p>
              </div>
              <div class="grid grid-cols-2 gap-3 min-w-[200px]">
                <div class="bg-white rounded-sm p-3 text-center">
                  <p class="text-xs text-[#2C2824]/40 uppercase tracking-wider mb-1">Estim. basse</p>
                  <p class="font-playfair text-lg font-medium text-[#2C2824]">{formatK(t.estimBasse)}</p>
                </div>
                <div class="bg-white rounded-sm p-3 text-center">
                  <p class="text-xs text-[#2C2824]/40 uppercase tracking-wider mb-1">Estim. haute</p>
                  <p class="font-playfair text-lg font-medium text-[#7B6B8A]">{formatK(t.estimHaute)}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Total travaux -->
      <div class="bg-[#1a1a1a] rounded-sm p-4 sm:p-6">
        <div class="flex items-center justify-between">
          <span class="text-white/50 text-sm">Total travaux</span>
          <div class="flex items-center gap-4">
            <div class="text-right">
              <p class="text-xs text-white/40">Basse</p>
              <p class="text-xl font-medium text-white">{formatK(totalTravauxBas)}</p>
            </div>
            <span class="text-white/30">—</span>
            <div class="text-right">
              <p class="text-xs text-[#7B6B8A]/70">Haute</p>
              <p class="text-xl font-medium text-[#7B6B8A]">{formatK(totalTravauxHaut)}</p>
            </div>
          </div>
        </div>
        <p class="text-xs text-white/40 mt-4">
          La variabilite ({formatNumber(totalTravauxHaut - totalTravauxBas)} EUR d'ecart) se concentre sur le SAS/veranda et le poele Tully Kiwi. La cuisine et les frais annexes sont stables.
        </p>
      </div>
    </div>
  </section>

  <!-- PERGOLA -->
  <section id="pergola" class="py-8 sm:py-10 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Pergola</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">{pergola.surface} m2 — Hebergement independant exploite en direct</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Couts -->
        <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6">
          <h3 class="text-sm font-medium text-[#2C2824] mb-4">Investissement</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between py-2 px-3 rounded-sm bg-[#FAF8F5]">
              <div>
                <span class="text-sm text-[#2C2824]">Quote-part achat pergola</span>
                <span class="block text-xs text-[#2C2824]/40">Part proportionnelle de la structure existante</span>
              </div>
              <span class="text-sm font-medium text-[#2C2824]">{formatNumber(pergola.achat)} EUR</span>
            </div>
            <div class="flex items-center justify-between py-2 px-3 rounded-sm bg-[#FAF8F5]">
              <div>
                <span class="text-sm text-[#2C2824]">Construction / amenagement</span>
                <span class="block text-xs text-[#2C2824]/40">{pergola.surface} m2 x {formatNumber(pergola.prixM2)} EUR/m2 — ossature existante, reprise etancheite</span>
              </div>
              <span class="text-sm font-medium text-[#2C2824]">{formatNumber(pergola.construction)} EUR</span>
            </div>
          </div>
