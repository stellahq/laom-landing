---
import Layout from '~/layouts/Layout.astro'
import NewsletterBanner from '~/components/NewsletterBanner.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Ressources — LAOM',
  url: Astro.url.toString(),
  description: 'Livres, guides et contenus pour comprendre et construire un ecolieu regeneratif.',
})
---

<Layout
  title="Ressources — LAOM"
  description="Livres, guides et contenus pour comprendre et construire un ecolieu regeneratif."
  seo={{
    ldJSON: pageSchema,
  }}
>
  <!-- Hero -->
  <section class="py-32 lg:py-40 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Ressources</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-[#2C2824] mb-6 tracking-tight">
        Ce qu'on partage
      </h1>
      <p class="text-xl md:text-2xl font-light text-[#2C2824]/60 max-w-3xl mx-auto leading-relaxed">
        Livres, guides et contenus pour comprendre et construire un ecolieu regeneratif. Tout ce qu'on aurait aime trouver avant de commencer.
      </p>
    </div>
  </section>

  <!-- Livre Grand Shambala -->
  <section class="py-16 md:py-20 bg-[#2C2824]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-14 opacity-0" animate-fade-in-up>
        <div class="shrink-0 w-48 md:w-56">
          <div class="aspect-[3/4] bg-[#3D3832] border border-white/10 rounded-sm flex items-center justify-center shadow-2xl" role="img" aria-label="Jaquette du livre Grand Shambala — a venir">
            <div class="text-center px-6">
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mb-4"></div>
              <p class="font-playfair text-base text-white/80 leading-snug mb-2">Grand Shambala</p>
              <p class="text-[10px] font-light text-white/40 uppercase tracking-[0.2em]">Le livre</p>
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mt-4"></div>
            </div>
          </div>
        </div>
        <div class="text-center md:text-left">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Sortie mars 2026</p>
          <p class="font-playfair text-2xl md:text-3xl font-medium text-white mb-4 tracking-tight leading-snug">
            Comment on a construit le plus grand batiment en paille porteuse au monde.
          </p>
          <p class="text-base font-light text-white/60 leading-relaxed mb-8 max-w-md">
            Construction, materiaux, couts reels, erreurs, lecons. 850 m2 sur deux niveaux, en auto-construction. Tout ce qu'on aurait aime lire avant de commencer. Les inscrits le recoivent gratuitement en avant-premiere.
          </p>
          <a href="/newsletter/" class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-8 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors">
            Recevoir le livre gratuitement
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Livre LAOM -->
  <section class="py-16 md:py-20 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-14 opacity-0" animate-fade-in-up>
        <div class="shrink-0 w-48 md:w-56">
          <div class="aspect-[3/4] bg-[#E8E3D8] border border-black/5 rounded-sm flex items-center justify-center shadow-lg" role="img" aria-label="Jaquette du livre LAOM — a venir">
            <div class="text-center px-6">
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mb-4"></div>
              <p class="font-playfair text-base text-[#2C2824]/80 leading-snug mb-2">LAOM</p>
              <p class="text-[10px] font-light text-[#2C2824]/40 uppercase tracking-[0.2em]">Le livre</p>
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mt-4"></div>
            </div>
          </div>
        </div>
        <div class="text-center md:text-left">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Sortie avril 2026</p>
          <p class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] mb-4 tracking-tight leading-snug">
            L'histoire complete d'un ecolieu, de l'idee au modele.
          </p>
          <p class="text-base font-light text-[#2C2824]/60 leading-relaxed mb-8 max-w-md">
            Comment on a forme le groupe, achete le lieu, traverse les conflits, construit la gouvernance, monte la SCIA, obtenu le STECAL, et cree un modele replicable. Les inscrits le recoivent gratuitement en avant-premiere.
          </p>
          <a href="/newsletter/" class="inline-flex items-center justify-center rounded-sm bg-[#2C2824] text-white px-8 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors">
            Recevoir le livre gratuitement
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Suivre l'aventure — YouTube -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">YouTube</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6 title-underline mx-auto">
        Suivre l'aventure
      </h2>
      <p class="text-lg font-light text-[#2C2824]/60 leading-relaxed mb-10 max-w-2xl mx-auto">
        Charly documente la construction de LAOM en video. Chantier, decisions, erreurs, apprentissages — tout est la, sans filtre.
      </p>
      <a
        href="https://www.youtube.com/@charlyaubert"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-sm bg-[#2C2824] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        S'abonner a la chaine
      </a>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterBanner />
</Layout>
