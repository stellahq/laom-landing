---
import Layout from '~/layouts/Layout.astro'
import { createWebSiteSchema } from '~/utils/schema'
import { getTranslations as getI18nTranslations, getLocalizedPath } from '~/i18n/utils'
import { getCollection } from 'astro:content'

const allPosts = (await getCollection('blog'))
  .filter(post => post.data.locale === 'fr' && !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const lang = 'fr'
const t = getI18nTranslations(lang as 'fr' | 'en')
const siteSchema = createWebSiteSchema({
  url: Astro.site?.toString() || 'https://laom.com',
  description: t.site.description,
})

// Kit form options
const formKitOptions = {
  settings: {
    after_subscribe: {
      action: 'message',
      success_message: 'Bienvenue ! Consultez votre boîte mail pour confirmer.',
      redirect_url: '',
    },
    powered_by: { show: false },
    recaptcha: { enabled: false },
  },
  version: '5',
}

const eventImages = [
  '/images/claire-danse-libre-retraite-2048x1368.webp',
  '/images/event-rencontre-perspective.webp',
  '/images/colette.webp',
  '/images/david-lin-fyneo.webp',
]
const events = t.events.items.map((item, index) => ({
  ...item,
  image: eventImages[index] || '/images/david-lin-fyneo.webp',
}))

const spaceImages = [
  'https://images.unsplash.com/photo-1512621776951-a57141f2eefd?w=420&h=560&fit=crop&q=85',
  'https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=420&h=560&fit=crop&q=85',
  '/images/laom/tipis.webp',
  '/images/laom/salle-de-pratique.webp',
  '/images/laom/planification/agri-1-0246e509.webp',
  'https://images.unsplash.com/photo-1521017432531-fbd92d768814?w=420&h=560&fit=crop&q=85',
  'https://images.unsplash.com/photo-1497366811353-6870744d04b2?w=420&h=560&fit=crop&q=85',
]
const spaces = t.home.ourSpaces.items.map((item, i) => ({ ...item, image: spaceImages[i] || spaceImages[0] }))

---

<Layout 
  title={`${t.site.name} – ${t.site.tagline}`}
  description={t.site.description}
  seo={{
    ldJSON: siteSchema,
  }}
>
  <style is:global>
    .formkit-alert:empty { display: none; }
    .formkit-alert-error {
      background: rgba(254, 226, 226, 0.9);
      border: 1px solid #fecaca;
      color: #b91c1c;
      border-radius: 0.25rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      margin: 0 0 0.75rem 0;
    }
    .formkit-alert-success {
      background: rgba(187, 247, 208, 0.9);
      border: 1px solid #bbf7d0;
      color: #166534;
      border-radius: 0.25rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      margin: 0 0 0.75rem 0;
    }
  </style>

  <!-- 1. Hero Split -->
  <section class="min-h-screen -mt-24 md:-mt-28 pt-24 md:pt-28">
    <div class="grid lg:grid-cols-2 min-h-[calc(100vh-6rem)]">
      
      <!-- Colonne gauche : Contenu + Form -->
      <div class="flex flex-col justify-center px-8 md:px-12 lg:px-16 xl:px-24 py-16 lg:py-20 bg-[#FAF8F5] order-2 lg:order-1">
        <div class="max-w-lg">
          <p class="text-[11px] font-light tracking-[0.3em] uppercase text-[#2C2824]/40 mb-8">
            Habitat · Coliving · Événements · Création
          </p>
          
          <h1 class="font-playfair text-4xl md:text-5xl xl:text-6xl font-medium text-[#2C2824] mb-6 tracking-tight leading-[1.1]">
            Vivre et créer,<br/>
            <span class="text-[#C4A855]">ensemble</span>
          </h1>
          
          <p class="text-lg md:text-xl font-light text-[#2C2824]/70 mb-10 leading-relaxed">
            Un écolieu dans le sud de l'Aveyron. À la fois habitat, espace d'accueil et terrain d'expérimentation, on y vient ralentir, se relier, créer et s'inspirer.
          </p>
          
          <!-- Newsletter Form -->
          <div class="mb-8">
            <p class="text-sm font-medium text-[#2C2824]/80 mb-4">
              Recevez les coulisses chaque dimanche
            </p>
            <form
              action="https://app.kit.com/forms/8987350/subscriptions"
              class="seva-form formkit-form"
              method="post"
              data-sv-form="8987350"
              data-uid="af2e0fc1e5"
              data-format="inline"
              data-version="5"
              data-options={JSON.stringify(formKitOptions).replace(/"/g, '&quot;').replace(/&/g, '&amp;')}
            >
              <div data-style="clean">
                <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert" aria-live="polite"></ul>
                <div data-element="fields" data-stacked="false" class="flex flex-col sm:flex-row gap-3">
                  <input
                    class="flex-1 px-5 py-4 rounded-sm bg-white border border-[#2C2824]/10 text-[#2C2824] placeholder-[#2C2824]/40 text-base focus:outline-none focus:border-[#C4A855] focus:ring-1 focus:ring-[#C4A855]/30 transition-all"
                    name="email_address"
                    type="email"
                    required
                    aria-label="Votre adresse e-mail"
                    placeholder="votre@email.com"
                    autocomplete="email"
                  />
                  <button
                    type="submit"
                    data-element="submit"
                    class="px-8 py-4 rounded-sm bg-[#2C2824] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#3D3830] transition-colors whitespace-nowrap"
                  >
                    S'inscrire
                  </button>
                </div>
              </div>
            </form>
            <p class="text-xs text-[#2C2824]/40 mt-3">Pas de spam. Désinscription en un clic.</p>
          </div>
          
          <!-- Quick links -->
          <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
            <a href="/project/" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors underline underline-offset-4">Découvrir le projet</a>
            <a href="/stage-danse/" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors underline underline-offset-4">Prochaine retraite</a>
          </div>
        </div>
      </div>
      
      <!-- Colonne droite : Image -->
      <div class="relative h-[50vh] lg:h-auto order-1 lg:order-2 overflow-hidden">
        <img 
          src="/images/laom/vanlifest-img1373.webp" 
          alt="Communauté LAOM lors d'une retraite"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent lg:hidden"></div>
      </div>
    </div>
  </section>

  <!-- 2. Chiffres clés -->
  <section class="py-16 md:py-20 bg-[#FAF8F5] border-t border-[#2C2824]/5">
    <div class="max-w-5xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-6">
        <div class="text-center">
          <p class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-2">21</p>
          <p class="text-xs font-light tracking-[0.15em] uppercase text-[#2C2824]/40">hectares</p>
        </div>
        <div class="text-center">
          <p class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-2">15</p>
          <p class="text-xs font-light tracking-[0.15em] uppercase text-[#2C2824]/40">familles</p>
        </div>
        <div class="text-center">
          <p class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-2">850</p>
          <p class="text-xs font-light tracking-[0.15em] uppercase text-[#2C2824]/40">m² paille porteuse</p>
        </div>
        <div class="text-center">
          <p class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-2">2021</p>
          <p class="text-xs font-light tracking-[0.15em] uppercase text-[#2C2824]/40">depuis</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Image aérienne plein width -->
  <section class="relative">
    <div class="aspect-[21/9] md:aspect-[3/1] overflow-hidden">
      <img 
        src="/images/laom/newsletter/vue%20aeriene%20laom2.webp" 
        alt="Vue aérienne du domaine LAOM, 21 hectares, prairies, forêt, bâtiments, rivière"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </section>

  <!-- 4. Immersions signature -->
  <section id="immersions" class="py-24 md:py-32 bg-[#FAF8F5] overflow-hidden">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-4">Immersions signature</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">
          Nos programmes d'immersion
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- En Mouvement -->
        <a href="/stage-danse/" class="group block opacity-0" animate-fade-in-up>
          <div class="aspect-[4/5] bg-neutral-100 overflow-hidden rounded-sm mb-6">
            <img
              src="/images/laom/samuel-planas.webp"
              alt="Samuel Planas, En Mouvement, immersion par le corps à LAOM"
              class="w-full h-full object-cover object-top rounded-sm group-hover:scale-[1.02] transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-3">Corps & mouvement</p>
          <h3 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] mb-3 group-hover:text-[#C4A855] transition-colors">
            En Mouvement
          </h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed mb-4">
            5 jours d'immersion par la danse et le mouvement. Guidé par Samuel Planas et Charly Aubert. Ouvert à tous.
          </p>
          <p class="text-sm font-light text-[#2C2824]/50">
            Août 2026 · 3 sessions
          </p>
        </a>

        <!-- Clarté -->
        <a href="/clarte/" class="group block opacity-0" animate-fade-in-up style="animation-delay: 100ms">
          <div class="aspect-[4/5] bg-[#1a1a1a] overflow-hidden rounded-sm mb-6 flex items-center justify-center relative">
            <!-- Gradient abstrait pour Clarté -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#2C2824] via-[#1a1a1a] to-[#0a0a0a]"></div>
            <div class="absolute inset-0 opacity-40" style="background-image: radial-gradient(circle at 30% 40%, rgba(196,168,85,0.2) 0%, transparent 50%), radial-gradient(circle at 70% 60%, rgba(196,168,85,0.15) 0%, transparent 40%);"></div>
            <div class="relative z-10 text-center px-8">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#C4A855]/10 border border-[#C4A855]/20 mb-4">
                <svg class="w-8 h-8 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <p class="font-playfair text-3xl font-medium text-white tracking-tight">Clarté</p>
            </div>
          </div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-3">Vision & système</p>
          <h3 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] mb-3 group-hover:text-[#C4A855] transition-colors">
            Clarté
          </h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed mb-4">
            Un week-end pour créer ton système de vie : vision, PARA, et Claude Code comme agent IA personnel.
          </p>
          <p class="text-sm font-light text-[#2C2824]/50">
            25-27 avril 2026 · 12 places
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. Journal de bord -->
  <section class="py-16 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-normal text-black tracking-tight mb-14 opacity-0 title-underline" animate-fade-in-up>
        Journal de bord
      </h2>

      <div class="opacity-0" animate-fade-in-up>
        <!-- Featured: Grand Shambala -->
        <a href="/grand-shambala-v2/" class="group block mb-10">
          <article class="flex flex-col md:flex-row gap-8 items-start">
            <div class="w-full md:w-2/3 aspect-[16/9] overflow-hidden rounded-sm">
              <img
                src="/images/laom/grand-shambala/p1.webp"
                alt="Grand Shambala,  850 m2 de paille porteuse"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="flex-1 py-2">
              <p class="text-xs font-light tracking-[0.2em] uppercase text-black/40 mb-3">
                À la une
              </p>
              <h3 class="font-playfair text-2xl md:text-3xl font-normal text-black mb-3 tracking-tight leading-snug">
                Grand Shambala
              </h3>
              <p class="text-base font-light text-black/60 leading-relaxed line-clamp-3">
                Le plus grand bâtiment en paille porteuse au monde. 850 m2 sur deux niveaux, construit en 3 mois. De l'intention au chantier,  tout est là.
              </p>
              <span class="inline-block mt-4 text-sm text-black/50 group-hover:text-black transition-colors underline underline-offset-4">
                Lire l'article
              </span>
            </div>
          </article>
        </a>

        <!-- Other articles from blog -->
        {allPosts.length > 0 && (
          <div class="grid md:grid-cols-2 gap-8">
            {allPosts.slice(0, 2).map((post) => (
              <a href={getLocalizedPath(`/blog/${post.slug}/`, 'fr')} class="group block">
                <article class="flex flex-col">
                  {post.data.heroImage && (
                    <div class="aspect-[16/10] overflow-hidden rounded-sm mb-5">
                      <img
                        src={post.data.heroImage}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <p class="text-xs font-light tracking-[0.2em] uppercase text-black/40 mb-2">
                    {new Date(post.data.pubDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                  </p>
                  <h3 class="font-playfair text-xl font-normal text-black mb-2 tracking-tight leading-snug">
                    {post.data.title}
                  </h3>
                  <p class="text-sm font-light text-black/60 leading-relaxed line-clamp-2">
                    {post.data.description}
                  </p>
                </article>
              </a>
            ))}
          </div>
        )}
      </div>

      <div class="text-center mt-12">
        <a
          href={getLocalizedPath('/blog/', 'fr')}
          class="text-base text-black/60 hover:text-black transition-colors font-normal underline underline-offset-4"
        >
          Tous les articles
        </a>
      </div>
    </div>
  </section>

  <!-- 6. Nos Espaces -->
  <section id="spaces" class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-normal text-black tracking-tight text-center mb-16 opacity-0 title-underline mx-auto" animate-fade-in-up>
        {t.home.ourSpaces.sectionTitle}
      </h2>
    </div>
    <div class="relative">
      <button
        type="button"
        id="spaces-prev"
        class="spaces-arrow absolute left-2 md:left-4 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full border border-black/20 bg-[#FAF8F5]/90 flex items-center justify-center text-black/60 hover:bg-[#FAF8F5] hover:border-black/40 hover:text-black transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-black/30"
        aria-label="Espace précédent"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button
        type="button"
        id="spaces-next"
        class="spaces-arrow absolute right-2 md:right-4 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full border border-black/20 bg-[#FAF8F5]/90 flex items-center justify-center text-black/60 hover:bg-[#FAF8F5] hover:border-black/40 hover:text-black transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-black/30"
        aria-label="Espace suivant"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
      <div id="spaces-scroll" class="spaces-scroll overflow-x-auto overflow-y-hidden scroll-smooth snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch;">
        <div class="flex gap-6 pl-10 sm:pl-16 lg:pl-24 pr-14 sm:pr-24 lg:pr-36 py-2 min-w-max">
          {spaces.map((space, i) => (
            <article class="spaces-card flex-shrink-0 w-[260px] sm:w-[280px] snap-start opacity-0" animate-fade-in-up style={`animation-delay: ${i * 80}ms`}>
              <div class="aspect-[3/4] bg-neutral-100 overflow-hidden rounded-sm">
                <img
                  src={space.image}
                  alt={(space as { imageAlt?: string }).imageAlt ?? space.title}
                  class={`w-full h-full object-cover rounded-sm ${i === 2 ? 'object-left' : i === 3 ? 'object-right' : ''}`}
                  loading="lazy"
                  width="420"
                  height="560"
                  decoding="async"
                />
              </div>
              <div class="mt-5 px-2 sm:px-3">
                <h3 class="text-base font-normal tracking-wide text-black mb-3 uppercase">
                  {space.title}
                </h3>
                <p class="text-sm font-normal text-black/70 leading-relaxed">
                  {space.description}
                  {(space as { note?: string }).note && (
                    <>
                      <br />
                      {(space as { note?: string }).note}
                    </>
                  )}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const container = document.getElementById('spaces-scroll')
      const prevBtn = document.getElementById('spaces-prev')
      const nextBtn = document.getElementById('spaces-next')
      if (!container || !prevBtn || !nextBtn) return
      const card = container.querySelector('.spaces-card')
      const gap = 24
      const scrollAmount = (card ? card.offsetWidth + gap : 304)

      prevBtn.addEventListener('click', () => {
        container.scrollBy({ left: -scrollAmount, behavior: 'smooth' })
      })
      nextBtn.addEventListener('click', () => {
        container.scrollBy({ left: scrollAmount, behavior: 'smooth' })
      })
    })()
  </script>

  <!-- 7. Events partenaires -->
  <section id="events" class="py-24 md:py-32 px-10 sm:px-16 lg:px-24 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-20 opacity-0" animate-fade-in-up>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-normal text-black tracking-tight mb-4 title-underline">
          {t.events.allTitle}
        </h2>
        <a
          href={getLocalizedPath('/events/', lang as 'fr' | 'en')}
          class="block mt-4 text-sm text-black/60 hover:text-black transition-colors font-normal underline underline-offset-4"
        >
          {t.events.viewAllLink}
        </a>
      </div>

      <div class="space-y-16 opacity-0" animate-fade-in-up>
        {events.map((event) => {
          const eventHref = 'href' in event ? (event as { href?: string }).href : undefined
          const inner = (
            <>
              <div class="w-full md:w-80 flex-shrink-0">
                <div class="aspect-[4/3] bg-neutral-100 overflow-hidden rounded-sm">
                <img
                  src={event.image}
                  alt={event.title}
                  class="w-full h-full object-cover rounded-sm"
                  loading="lazy"
                  width="400"
                  height="300"
                  decoding="async"
                  />
                </div>
              </div>
              <div class="flex-1">
                <p class="text-sm font-normal text-black/50 mb-2">
                  {event.date}
                </p>
                <h3 class="text-2xl md:text-3xl font-normal text-black mb-4 tracking-tight">
                  {event.title}
                </h3>
                <p class="text-base font-normal text-black/70 leading-relaxed">
                  {event.description}
                </p>
              </div>
            </>
          )
          return (
            <article class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
              {eventHref ? (
                <a
                  href={eventHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex flex-col md:flex-row gap-8 md:gap-12 items-start w-full group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/20 focus-visible:ring-offset-2"
                  aria-label={`${event.title} (ouvre dans un nouvel onglet)`}
                >
                  {inner}
                </a>
              ) : (
                <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start w-full">
                  {inner}
                </div>
              )}
            </article>
          )
        })}
      </div>
    </div>
  </section>

  <!-- LaomFest – Citadel Garden style -->
  <section id="laomfest" class="py-24 md:py-32 px-10 sm:px-16 lg:px-24 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-normal text-black tracking-tight mb-6">
          {t.home.laomfest.title}
        </h2>
        <p class="text-xl md:text-2xl font-normal text-black/70 mb-2 max-w-3xl mx-auto leading-relaxed">
          {t.home.laomfest.description}
        </p>
        <p class="text-sm font-normal text-black/60 italic">{t.home.laomfest.dateNote}</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4" aria-label="Photos d’illustration LAOMFEST">
