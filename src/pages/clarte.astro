---
import Layout from '~/layouts/Layout.astro'
import NewsletterForm from '~/components/NewsletterForm.astro'
import { createWebPageSchema } from '~/utils/schema'

export const prerender = true

const pageSchema = createWebPageSchema({
  name: 'Expérience Clarté — Vision, PARA & Agent IA Personnel | LAOM',
  url: Astro.url.toString(),
  description: 'Un week-end pour intégrer un système qui te libère du temps perso et optimise ton business. Vision, méthode PARA et agent IA personnel. LAOM, Aveyron.',
})

const transformation = [
  { before: 'Trop d\'idées, pas assez d\'actions', after: 'Un système qui capte tout et te dit quoi faire' },
  { before: 'Tu jongles entre perso et pro sans filet', after: 'Tes projets sont organisés, visibles, pilotables' },
  { before: 'Tu délègues au hasard à l\'IA', after: 'Un agent IA configuré pour TOI qui te connaît vraiment' },
  { before: 'Tu te disperses sur 10 fronts', after: 'Tes priorités sont claires, tes actions cohérentes' },
  { before: 'Tu dors en pensant à ce que tu as oublié', after: 'Tu dors serein — tout est capturé' },
  { before: 'Tu subis ton organisation', after: 'Tu pilotes ta vie' },
]

const pillars = [
  {
    num: '01',
    title: 'Vision',
    subtitle: 'Clarifier ce que tu veux vivre',
    description: 'Avant de construire un système, il faut savoir vers quoi il te mène. On va poser les fondations : tes valeurs, tes intentions, ce qui compte vraiment. Pas une vision corporate. Ta vision. Celle qui te fait te lever le matin.',
  },
  {
    num: '02',
    title: 'PARA',
    subtitle: 'Ton système d\'organisation',
    description: 'PARA (Projets, Aires, Ressources, Archives) est le système d\'organisation le plus simple et le plus robuste qui existe. On va le construire ensemble, adapté à ta vie, pas à une théorie. Un système dans lequel tu peux avoir confiance.',
  },
  {
    num: '03',
    title: 'Ton Agent IA Personnel',
    subtitle: 'Un assistant qui te connaît — vraiment',
    description: 'Pas un chatbot. Un agent IA à ton service, configuré avec ta vision, ton organisation PARA, tes préférences et tes patterns. Il garde la mémoire. Il lit tes fichiers. Il exécute. Il te challenge quand tu te disperses. Il devient ton copilote permanent — disponible à tout moment, aligné sur qui tu es.',
  },
]
---

<Layout
  title="Expérience Clarté — Vision, PARA & Agent IA Personnel | LAOM"
  description="Un week-end pour intégrer un système qui te libère du temps perso et optimise ton business. Vision, méthode PARA et agent IA personnel. LAOM, Aveyron."
  ogImage="/images/clarte-jaquette-claude-code.webp"
  seo={{ ldJSON: pageSchema }}
>

  <!-- Hero -->
  <section class="py-20 lg:py-32 -mt-24 md:-mt-28 pt-36 md:pt-44 bg-[#1a1a1a]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">

      <span class="inline-block px-4 py-1.5 text-xs font-mono tracking-[0.15em] uppercase text-[#C4A855] bg-[#C4A855]/5 border border-[#C4A855]/15 rounded-sm mb-8">Cohorte Avril 2026 · Places limitées</span>

      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-4 tracking-tight leading-[1.1]">
        Expérience Clarté
      </h1>
      <p class="text-lg md:text-xl font-light text-white/50 max-w-2xl mx-auto leading-relaxed mb-12">
        Un week-end pour intégrer un système qui te libère du temps perso et optimise ton business.
      </p>

      <div class="flex flex-wrap justify-center gap-8 md:gap-12 mb-12">
        <div class="text-center">
          <p class="text-2xl font-medium text-white">3 jours</p>
          <p class="text-xs font-light text-white/40 mt-1">d'immersion</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-medium text-white">12 places</p>
          <p class="text-xs font-light text-white/40 mt-1">maximum</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-medium text-white">1 000 €</p>
          <p class="text-xs font-light text-white/40 mt-1">tout compris</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/clarte/reservation/" class="px-8 py-3 text-sm font-medium bg-[#C4A855] text-[#1a1a1a] rounded-sm hover:opacity-90 transition-opacity">Réserver ma place</a>
        <a href="#programme" class="px-8 py-3 text-sm font-medium text-white/70 border border-white/15 rounded-sm hover:border-white/30 transition-colors">Découvrir le programme</a>
      </div>

    </div>
  </section>

  <!-- Le problème -->
  <section id="probleme" class="py-24 md:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-8">Le constat</p>
      <div class="space-y-6 text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        <p>
          Tu réfléchis beaucoup. Peut-être trop.
        </p>
        <p>
          Le soir, tu rumines. Les idées tournent. Tu te demandes si tu fais les bons choix, si tu avances vraiment, si tu n'oublies pas quelque chose d'important.
        </p>
        <p>
          Ta to-do list déborde. Tu as des notes partout — Notion, Apple Notes, des bouts de papier. Tu sais que tu devrais "mieux t'organiser" mais tu n'as jamais trouvé le système qui te convient.
        </p>
        <p>
          Tu aimerais avoir plus de clarté. Savoir où tu vas. Te sentir aligné entre ce que tu fais et ce que tu veux vraiment.
        </p>
        <p class="text-[#2C2824] font-medium">
          Et si tu pouvais déléguer tout ça à un système intelligent — un système qui te connaît, qui garde la mémoire, et qui t'aide à rester cohérent ?
        </p>
      </div>
    </div>
  </section>

  <!-- La transformation -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">La transformation</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Ce qui change après le week-end</h2>

      <div class="space-y-6">
        {transformation.map((t) => (
          <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8 py-5 border-b border-black/5">
            <div class="flex-1">
              <p class="text-base font-light text-[#2C2824]/50 line-through decoration-[#2C2824]/20">{t.before}</p>
            </div>
            <div class="hidden md:block text-[#C4A855]">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-base font-medium text-[#2C2824]">{t.after}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Livrables -->
  <section class="py-28 md:py-36 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Ce avec quoi tu repars</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4">Du concret. Installé. Utilisable dès lundi.</h2>
      <p class="text-base font-light text-[#2C2824]/60 mb-16 max-w-2xl">Pas des slides. Pas des bonnes intentions. Du concret, installé sur ton ordinateur, utilisable dès le lundi matin.</p>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <span class="text-3xl font-light text-[#C4A855]/40">01</span>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mt-4 mb-3">Une organisation structurée sur ton ordinateur</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">Tes fichiers, tes projets, tes ressources classés selon la méthode PARA. Plus rien ne se perd. Tout est au bon endroit, accessible en quelques secondes.</p>
        </div>
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <span class="text-3xl font-light text-[#C4A855]/40">02</span>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mt-4 mb-3">Un agent IA intégré à ton organisation personnelle</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">Configuré avec ta vision, ton système, tes préférences. Il te connaît. Il t'assiste. Il exécute ce que tu n'as pas le temps de faire.</p>
        </div>
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <span class="text-3xl font-light text-[#C4A855]/40">03</span>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mt-4 mb-3">Un système qui optimise ton temps pro ET perso</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">Tu sais ce qui est prioritaire, quand le faire, et comment déléguer le reste à ton agent. Moins de bruit. Plus d'impact — dans tous les domaines de ta vie.</p>
        </div>
        <div class="bg-[#FAF8F5] p-8 rounded-sm border-l-4 border-[#C4A855]">
          <span class="text-3xl font-light text-[#C4A855]/40">04</span>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mt-4 mb-3">De la délivrabilité — dès la première semaine</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">Tu ne repars pas avec une méthode à appliquer "quand tu auras le temps". Tu repars avec quelque chose qui livre des résultats concrets dès le retour.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Ce qu'ils en disent</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-12">Retours des participants</h2>
      
      <div class="space-y-8">
        <div class="bg-[#FAF8F5] p-8 rounded-sm border-l-4 border-[#C4A855]">
          <blockquote class="text-base font-light text-[#2C2824]/80 leading-relaxed italic mb-4">
            "Mes 5 prises de conscience les plus précieuses : organiser l'ensemble de mes fichiers en seulement 4 grandes catégories — simplicité = clarté. Garder mes idées de projets "en couveuse" dans un espace facile d'accès. M'accorder des temps de respiration en pleine semaine, sans forcément les planifier. Et surtout, adapter mon organisation quotidienne à l'énergie et à l'état émotionnel du moment, plutôt que d'imposer des cadences figées."
          </blockquote>
          <p class="text-base font-light text-[#2C2824]/80 leading-relaxed italic mb-6">
            "Merci à Charly pour son accompagnement tout en finesse, qui a rendu ces prises de conscience possibles, concrètes, et durables."
          </p>
          <div class="flex items-center gap-4">
            <img src="/images/marie-pierre-sampson.jpeg" alt="Marie-Pierre Sampson" class="w-12 h-12 rounded-full object-cover" loading="lazy" />
            <div>
              <a href="https://www.linkedin.com/in/marie-pierre-sampson-oculus-patrimoine-4526231ba/" target="_blank" rel="noopener noreferrer" class="font-medium text-[#2C2824] hover:text-[#8B7A3A] transition-colors">Marie-Pierre Sampson</a>
              <p class="text-sm text-[#2C2824]/50">Fondatrice d'Oculus Patrimoine — Valorisation du patrimoine bâti et des territoires</p>
            </div>
          </div>
        </div>

        <div class="bg-[#FAF8F5] p-8 rounded-sm border-l-4 border-[#C4A855]">
          <blockquote class="text-base font-light text-[#2C2824]/80 leading-relaxed italic mb-6">
            "L'accompagnement de Charly m'a vraiment fait passer à un autre niveau. Avant, j'avais des idées partout, des projets dans tous les sens, et l'impression de ne jamais avancer sur l'essentiel. Aujourd'hui, j'ai un système clair, une vision qui tient la route, et un agent IA qui me connaît et me recentre quand je dérive. C'est un game changer."
          </blockquote>
          <div class="flex items-center gap-4">
            <img src="/images/mathieu-barre.jpeg" alt="Mathieu Barre" class="w-12 h-12 rounded-full object-cover" loading="lazy" />
            <div>
              <a href="https://www.linkedin.com/in/mathieu-barre/" target="_blank" rel="noopener noreferrer" class="font-medium text-[#2C2824] hover:text-[#8B7A3A] transition-colors">Mathieu Barre</a>
              <p class="text-sm text-[#2C2824]/50">Entrepreneur à impact & Architecte d'événements engagés</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Les 3 piliers -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Le système</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Ce que tu vas construire</h2>

      <div class="space-y-16">
        {pillars.map((p) => (
          <div class="flex gap-8">
            <div class="flex-shrink-0">
              <span class="text-3xl font-light text-[#C4A855]/40">{p.num}</span>
            </div>
            <div>
              <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">{p.title}</h3>
              <p class="text-sm font-light text-[#C4A855] mb-4 uppercase tracking-wider">{p.subtitle}</p>
              <p class="text-lg font-light text-[#2C2824]/75 leading-relaxed">{p.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Le week-end, étape par étape -->
  <section id="programme" class="py-24 md:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Le programme</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Le week-end, étape par étape</h2>

      <div class="border-l-2 border-[#C4A855] pl-8 space-y-14">
        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Vendredi soir</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Arrivée & Intention</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Tu arrives à LAOM. On se retrouve autour d'un repas. Cercle d'ouverture : chacun pose son intention pour le week-end. Tu rencontres le groupe — des gens qui, comme toi, veulent créer plus de clarté dans leur vie.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Samedi matin</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Vision + PARA</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            On commence par le fondement : qu'est-ce que tu veux vraiment vivre ? Pas tes objectifs. Pas ta to-do. Ta vision. Ce qui te fait vibrer. Puis on construit ton système d'organisation — PARA : Projets, Aires, Ressources, Archives. Simple, robuste, adapté à ta vie. Tu repars avec une structure claire dans laquelle tu peux avoir confiance.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Samedi après-midi</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Agent IA Personnel</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            On installe et configure ton agent IA. Il apprend qui tu es, ta vision, ton système PARA, tes préférences. Premières interactions guidées. Tu découvres ce qu'un agent IA peut vraiment faire quand il te connaît.
          </p>
        </div>

        <div class="py-5 px-6 bg-[#FAF8F5] rounded-sm border-l-4 border-[#C4A855]">
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Samedi soir</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Soirée musicale + Networking</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Après une journée intense, on lâche prise. Musique, feu de camp, échanges libres entre entrepreneurs. Un moment humain et convivial — le genre de soirée dont on parle encore longtemps après.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Dimanche matin</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Agent IA Personnel — approfondissement</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            On pousse plus loin. Cas d'usage avancés, automatisations, personnalisation poussée. L'agent devient ton copilote permanent — capable de te challenger, d'exécuter, et de garder la mémoire de tes projets.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Dimanche après-midi</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Intégration</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            On teste le système ensemble. Questions, ajustements, cas pratiques. Tu repars avec un setup fonctionnel, une documentation personnalisée, et la confiance de pouvoir l'utiliser dès lundi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi ça marche -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-10">Pourquoi ça marche</h2>
      <div class="space-y-6 text-lg font-light text-[#2C2824]/80 leading-relaxed">
        <p>
          Un système externe libère le cerveau. Quand tu sais que tout est capturé, organisé, accessible — tu arrêtes de ruminer. La charge mentale disparaît.
        </p>
        <p>
          L'IA amplifie ta capacité. Ton agent IA n'est pas là pour te remplacer. Il est là pour exécuter ce que tu n'as pas le temps de faire, te rappeler ce que tu oublies, et te challenger quand tu te disperses.
        </p>
        <p>
          Le groupe crée l'engagement. Seul chez toi, tu procrastines. En immersion avec d'autres, tu avances. Le week-end crée le momentum pour installer des habitudes qui durent.
        </p>
        <p>
          Tu repars avec du concret. Pas des slides. Pas des idées. Un système installé, configuré, fonctionnel. Quelque chose que tu utilises dès le lundi.
        </p>
      </div>
    </div>
  </section>

  <!-- Ton formateur -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="bg-[#FAF8F5] border border-[#2C2824]/10 rounded-sm overflow-hidden">
        <div class="grid md:grid-cols-2">

          <!-- Photo -->
          <div class="relative h-72 md:h-auto">
            <img
              src="/images/en-mouvement/charly-aubert.webp"
              alt="Charly Aubert, fondateur de LAOM"
              class="absolute inset-0 w-full h-full object-cover"
              style="object-position: center 20%"
              loading="lazy"
              width="800"
              height="1000"
            />
          </div>

          <!-- Texte -->
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <span class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4 block">Ton formateur</span>
            <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">Charly Aubert</h3>
            <p class="text-sm font-light text-[#2C2824]/50 mb-6">Fondateur de LAOM · Ancien d'Epitech · IA depuis 2012</p>
            <div class="space-y-4 text-base font-light text-[#2C2824]/75 leading-relaxed">
              <p>
                Ancien d'Epitech, je travaille dans l'intelligence artificielle depuis 2012. Aujourd'hui, j'utilise ce système au quotidien. Vision documentée, PARA dans Obsidian, un agent IA comme copilote. C'est ce qui me permet de piloter un écolieu de 21 hectares, accompagner des clients, et élever mon fils — sans perdre la tête.
              </p>
              <p>
                J'ai développé mon propre agent IA personnel, avec une mémoire de plusieurs années. Il connaît mes projets, mes valeurs, mes patterns. Il me challenge quand je me disperse. Il m'aide à rester cohérent.
              </p>
              <p class="text-[#2C2824] font-medium">
                Ce week-end, je te transmets exactement ce que j'ai mis des années à construire — en un format condensé, pratique, applicable immédiatement.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Le lieu -->
  <section class="py-28 md:py-36 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">

      <div class="text-center mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Le lieu</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">Un écrin pour la clarté</h2>
      </div>

      <!-- Photo panoramique pleine largeur -->
      <div class="aspect-[21/9] overflow-hidden rounded-sm mb-16">
        <img
          src="/images/en-mouvement/le-shala.webp"
          alt="Vue aérienne de LAOM : le Shala, salle de pratique de 121 m², entouré de tipis dans une vallée verdoyante de l'Aveyron"
          title="Le Shala et les tipis à LAOM, Aveyron"
          class="w-full h-full object-cover"
          loading="lazy"
          width="1400"
          height="600"
        />
      </div>

      <!-- Texte + grille photos -->
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 mb-16">

        <!-- Colonne texte -->
        <div>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-6">Le Shala, 121 m²</h3>
          <div class="space-y-4 text-base font-light text-[#2C2824]/75 leading-relaxed">
            <p>
