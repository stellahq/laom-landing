---
import Layout from '~/layouts/Layout.astro'

export const prerender = true

// ==========================================
// ÉVÉNEMENTS LAOM
// ==========================================
const PRIX_REPAS_LAOM = 20
const COUT_MATIERE_REPAS = 0.35 // 35%
const FORFAIT_MENAGE_LAOM = 150

const evenementsLAOM = [
  { date: '25-27 avril', nom: 'Clarté', desc: 'Vision + PARA + Claude Code', animateur: 'Charly', prix: 1000, places: 12, taux: 100, nbRepas: 5, chargesSamuel: 0 },
  { date: '8-10 mai', nom: 'LAOM School #1', desc: 'Projet, financement, business model, gouvernance, culture', animateur: 'Charly', prix: 1000, places: 15, taux: 80, nbRepas: 5, chargesSamuel: 0 },
  { date: '27-28 juin', nom: 'Weekend Famille', desc: 'Format accessible, familial', animateur: 'Amandine & Charly', prix: 450, places: 20, taux: 80, nbRepas: 3, chargesSamuel: 0 },
  { date: '5-9 août', nom: 'En Mouvement #1', desc: 'Immersion danse avec Samuel Planas', animateur: 'Samuel & Charly', prix: 1100, places: 15, taux: 100, nbRepas: 9, chargesSamuel: 1500 },
  { date: '11-15 août', nom: 'En Mouvement #2', desc: 'Immersion danse avec Samuel Planas', animateur: 'Samuel & Charly', prix: 1100, places: 15, taux: 100, nbRepas: 9, chargesSamuel: 1500 },
  { date: '16-20 août', nom: 'En Mouvement #3', desc: 'Immersion danse avec Samuel Planas', animateur: 'Samuel & Charly', prix: 1100, places: 15, taux: 100, nbRepas: 9, chargesSamuel: 1500 },
  { date: '16-18 octobre', nom: 'LAOM School #2', desc: 'Projet, financement, business model, gouvernance, culture', animateur: 'Charly', prix: 1000, places: 15, taux: 80, nbRepas: 5, chargesSamuel: 0 },
]

// ==========================================
// ÉVÉNEMENTS PARTENAIRES - TARIF STANDARD
// 180€/j salle + 360€ tipis + repas + 150€ ménage
// ==========================================
const partenairesStandard = [
  { date: '5-8 mars', nom: 'Rencontre Perspective #4', orga: 'Eliott/JC', jours: 4, pers: 35, nbRepas: 7, prixRepas: 15 },
  { date: '30 avr - 3 mai', nom: 'Désir d\'Aventure #1', orga: 'Colette', jours: 4, pers: 21, nbRepas: 7, prixRepas: 18 },
  { date: '13-17 mai', nom: 'Au cœur de tes désirs', orga: 'Colette', jours: 5, pers: 21, nbRepas: 9, prixRepas: 18 },
  { date: '28-31 mai', nom: 'Désir d\'Aventure #2', orga: 'Colette', jours: 4, pers: 21, nbRepas: 7, prixRepas: 18 },
  { date: '11-13 juin', nom: 'Rencontre Fyneo #1', orga: 'David Lin', jours: 3, pers: 50, nbRepas: 5, prixRepas: 18, salleMulti: 3 }, // salle ×3
]
const FORFAIT_MENAGE = 150

// ==========================================
// ÉVÉNEMENTS PARTENAIRES - TARIF -20%
// 144€/j salle + 288€ tipis + repas + 150€ ménage
// ==========================================
const partenairesReduits = [
  { date: '25-28 fév', nom: 'Danse & Silence #3', orga: 'Amawé (Claire)', jours: 4, pers: 16, nbRepas: 7, prixRepas: 18 },
  { date: '11-15 mars', nom: 'Énergie Illimitée #1', orga: 'Amawé', jours: 5, pers: 16, nbRepas: 9, prixRepas: 18 },
  { date: '21-24 mai', nom: 'Frère d\'Âme', orga: 'Grégoire Renevier', jours: 4, pers: 16, nbRepas: 7, prixRepas: 18 },
  { date: '11-14 juillet', nom: 'Summer Camp', orga: 'Amawé', jours: 4, pers: 16, nbRepas: 7, prixRepas: 18 },
  { date: '17-20 juillet', nom: 'Énergie Illimitée #2', orga: 'Amawé', jours: 4, pers: 16, nbRepas: 7, prixRepas: 18 },
  { date: '23-26 juillet', nom: 'Aime-Être', orga: 'Grégoire Renevier', jours: 4, pers: 16, nbRepas: 7, prixRepas: 18 },
]

// ==========================================
// ÉVÉNEMENTS PARTENAIRES - FORFAITS SPÉCIAUX
// ==========================================
const partenairesSpeciaux = [
  { 
    date: '5-8 juin', 
    nom: 'Festival Perspective', 
    orga: 'Eliott/JC', 
    location: 1200, 
    pers: 200, 
    nbRepas: 7, 
    prixRepas: 18,
    menage: 150,
    chargeMenage: 448, // 7h × 16€ × 4j
  },
  { 
    date: '22-28 août', 
    nom: 'Guérison des Blessures', 
    orga: 'Patricia Salgon', 
    location: 400, 
    pers: 18, 
    nbRepas: 13, // 7 jours = 13 repas (arrivée soir, départ matin)
    prixRepas: 18,
    menage: 150,
    chargeMenage: 0,
  },
]

// ==========================================
// CALCULS ÉVÉNEMENTS LAOM (billetterie pure, hors repas)
// ==========================================
const calcLAOM = evenementsLAOM.map(e => {
  const persEstimees = Math.round(e.places * (e.taux / 100))
  const caBilletterie = e.prix * persEstimees
  const chargesMenage = FORFAIT_MENAGE_LAOM
  const chargesTotal = e.chargesSamuel + chargesMenage
  const marge = caBilletterie - chargesTotal
  // Repas pour la guinguette prestations
  const nbRepasTotal = persEstimees * e.nbRepas
  const caRepas = nbRepasTotal * PRIX_REPAS_LAOM
  return { ...e, persEstimees, caBilletterie, chargesMenage, chargesTotal, marge, nbRepasTotal, caRepas }
})
const totalCALAOM = calcLAOM.reduce((acc, e) => acc + e.caBilletterie, 0)
const totalChargesLAOM = calcLAOM.reduce((acc, e) => acc + e.chargesTotal, 0)
const totalMargeLAOM = calcLAOM.reduce((acc, e) => acc + e.marge, 0)
const totalRepasLAOM = calcLAOM.reduce((acc, e) => acc + e.nbRepasTotal, 0)
const totalCARepasLAOM = calcLAOM.reduce((acc, e) => acc + e.caRepas, 0)

// ==========================================
// CALCULS PARTENAIRES STANDARD (location pure, hors repas)
// ==========================================
const calcStandard = partenairesStandard.map(e => {
  const salleBase = e.jours * 180
  const salle = e.salleMulti ? salleBase * e.salleMulti : salleBase
  const tipis = 360
  const menage = FORFAIT_MENAGE
  const totalLocation = salle + tipis + menage // HORS repas
  // Repas pour la guinguette prestations
  const nbRepasTotal = e.pers * e.nbRepas
  const caRepas = nbRepasTotal * e.prixRepas
  return { ...e, salle, tipis, menage, totalLocation, nbRepasTotal, caRepas }
})
const totalLocationStandard = calcStandard.reduce((acc, e) => acc + e.totalLocation, 0)
const totalRepasStandard = calcStandard.reduce((acc, e) => acc + e.nbRepasTotal, 0)
const totalCARepasStandard = calcStandard.reduce((acc, e) => acc + e.caRepas, 0)

// ==========================================
// CALCULS PARTENAIRES -20% (location pure, hors repas)
// ==========================================
const calcReduits = partenairesReduits.map(e => {
  const salle = e.jours * 144 // -20%
  const tipis = 288 // -20%
  const menage = FORFAIT_MENAGE // Pas de -20% sur ménage
  const totalLocation = salle + tipis + menage // HORS repas
  // Repas pour la guinguette prestations
  const nbRepasTotal = e.pers * e.nbRepas
  const caRepas = nbRepasTotal * e.prixRepas
  return { ...e, salle, tipis, menage, totalLocation, nbRepasTotal, caRepas }
})
const totalLocationReduits = calcReduits.reduce((acc, e) => acc + e.totalLocation, 0)
const totalRepasReduits = calcReduits.reduce((acc, e) => acc + e.nbRepasTotal, 0)
const totalCARepasReduits = calcReduits.reduce((acc, e) => acc + e.caRepas, 0)

// ==========================================
// CALCULS PARTENAIRES SPÉCIAUX (location pure, hors repas)
// ==========================================
const calcSpeciaux = partenairesSpeciaux.map(e => {
  const totalLocation = e.location + e.menage // HORS repas
  // Repas pour la guinguette prestations
  const nbRepasTotal = e.pers * e.nbRepas
  const caRepas = nbRepasTotal * e.prixRepas
  return { ...e, totalLocation, nbRepasTotal, caRepas, chargeMenageTotal: e.chargeMenage }
})
const totalLocationSpeciaux = calcSpeciaux.reduce((acc, e) => acc + e.totalLocation, 0)
const totalChargesSpeciaux = calcSpeciaux.reduce((acc, e) => acc + e.chargeMenageTotal, 0)
const totalRepasSpeciaux = calcSpeciaux.reduce((acc, e) => acc + e.nbRepasTotal, 0)
const totalCARepasSpeciaux = calcSpeciaux.reduce((acc, e) => acc + e.caRepas, 0)

// TOTAUX PARTENAIRES (location uniquement)
const totalLocationPartenaires = totalLocationStandard + totalLocationReduits + totalLocationSpeciaux
const totalChargesPartenaires = totalChargesSpeciaux // Seuls les spéciaux ont des charges (ménage Festival)

// ==========================================
// GUINGUETTE PUBLIC - Mi-juin à mi-septembre (3 mois)
// ==========================================
const guinguetteJours = 90 // ~3 mois
const guinguetteCouverts = 25
const guinguettePanier = 27
const guinguetteCAPublic = guinguetteJours * guinguetteCouverts * guinguettePanier
const guinguetteChargesPersonnel = 2 * 1800 * 3 // Lorenzo + Lily, 3 mois
const guinguetteChargesMatierePublic = Math.round(guinguetteCAPublic * COUT_MATIERE_REPAS)
const guinguetteChargesPublic = guinguetteChargesPersonnel + guinguetteChargesMatierePublic
const guinguetteMargePublic = guinguetteCAPublic - guinguetteChargesPublic

// ==========================================
// GUINGUETTE PRESTATIONS - Tous les repas événements
// ==========================================
const totalRepasPartenaires = totalRepasStandard + totalRepasReduits + totalRepasSpeciaux
const totalCARepasPartenaires = totalCARepasStandard + totalCARepasReduits + totalCARepasSpeciaux

const guinguetteCAPrestations = totalCARepasLAOM + totalCARepasPartenaires
const guinguetteNbRepasPrestations = totalRepasLAOM + totalRepasPartenaires
const guinguetteChargesMatierePrestations = Math.round(guinguetteCAPrestations * COUT_MATIERE_REPAS)
// + charge ménage Festival (externalisée car volume)
const guinguetteChargesPrestations = guinguetteChargesMatierePrestations + totalChargesSpeciaux
const guinguetteMargePrestations = guinguetteCAPrestations - guinguetteChargesPrestations

// ==========================================
// TOTAUX GLOBAUX
// ==========================================
// CA brut par flux
const totalCABrut = totalCALAOM + totalLocationPartenaires + guinguetteCAPublic + guinguetteCAPrestations
// Charges par flux
const totalCharges = totalChargesLAOM + totalChargesPartenaires + guinguetteChargesPublic + guinguetteChargesPrestations
// Marge par flux
const totalMarge = totalMargeLAOM + (totalLocationPartenaires - totalChargesPartenaires) + guinguetteMargePublic + guinguetteMargePrestations

// ==========================================
// ESTIMATION TVA
// ==========================================
// TVA 5.5% sur restauration (guinguette public + prestations)
const baseRestauTTC = guinguetteCAPublic + guinguetteCAPrestations
const baseRestauHT = Math.round(baseRestauTTC / 1.055)
const tvaRestau = baseRestauTTC - baseRestauHT

// TVA 20% sur services (événements LAOM + location partenaires)
const baseServicesTTC = totalCALAOM + totalLocationPartenaires
const baseServicesHT = Math.round(baseServicesTTC / 1.20)
const tvaServices = baseServicesTTC - baseServicesHT

const tvaTotale = tvaRestau + tvaServices

// ==========================================
// TIMELINE
// ==========================================
const timeline = [
  { mois: 'Février', events: [{ nom: 'Danse & Silence #3', date: '25-28', type: 'partenaire', orga: 'Amawé' }] },
  { mois: 'Mars', events: [
    { nom: 'Rencontre Perspective #4', date: '5-8', type: 'partenaire', orga: 'Eliott/JC' },
    { nom: 'Énergie Illimitée #1', date: '11-15', type: 'partenaire', orga: 'Amawé' },
  ]},
  { mois: 'Avril', events: [{ nom: 'Clarté', date: '25-27', type: 'laom', orga: 'Charly' }] },
  { mois: 'Mai', events: [
    { nom: 'Désir d\'Aventure #1', date: '30 avr - 3', type: 'partenaire', orga: 'Colette' },
    { nom: 'LAOM School #1', date: '8-10', type: 'laom', orga: 'Charly' },
    { nom: 'Au cœur de tes désirs', date: '13-17', type: 'partenaire', orga: 'Colette' },
    { nom: 'Frère d\'Âme', date: '21-24', type: 'partenaire', orga: 'Grégoire R.' },
    { nom: 'Désir d\'Aventure #2', date: '28-31', type: 'partenaire', orga: 'Colette' },
  ]},
  { mois: 'Juin', events: [
    { nom: 'Festival Perspective', date: '5-8', type: 'partenaire', orga: 'Eliott/JC' },
    { nom: 'Rencontre Fyneo #1', date: '11-13', type: 'partenaire', orga: 'David Lin' },
    { nom: 'Guinguette ouvre', date: 'Mi-juin', type: 'guinguette', orga: 'Lorenzo + Lily' },
    { nom: 'Weekend Famille', date: '27-28', type: 'laom', orga: 'Amandine + Charly' },
  ]},
  { mois: 'Juillet', events: [
    { nom: 'Summer Camp', date: '11-14', type: 'partenaire', orga: 'Amawé' },
    { nom: 'Énergie Illimitée #2', date: '17-20', type: 'partenaire', orga: 'Amawé' },
    { nom: 'Aime-Être', date: '23-26', type: 'partenaire', orga: 'Grégoire R.' },
  ]},
  { mois: 'Août', events: [
    { nom: 'En Mouvement #1', date: '5-9', type: 'laom', orga: 'Samuel + Charly' },
    { nom: 'En Mouvement #2', date: '11-15', type: 'laom', orga: 'Samuel + Charly' },
    { nom: 'En Mouvement #3', date: '16-20', type: 'laom', orga: 'Samuel + Charly' },
    { nom: 'Guérison des Blessures', date: '22-28', type: 'partenaire', orga: 'Patricia Salgon' },
  ]},
  { mois: 'Septembre', events: [
    { nom: 'Guinguette ferme', date: 'Mi-sept.', type: 'guinguette', orga: 'Lorenzo + Lily' },
  ]},
  { mois: 'Octobre', events: [
    { nom: 'LAOM School #2', date: '16-18', type: 'laom', orga: 'Charly' },
  ]},
]

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}
---

<Layout
  title="Brainstorming 2026 — Programmation & Prévisionnel | LAOM"
  description="Document de travail interne — Programmation et prévisionnel financier 2026"
  seo={{ noindex: true, nofollow: true }}
>
  <style is:global>
    .type-laom { background: linear-gradient(135deg, #C4A855 0%, #B09A4A 100%); color: white; }
    .type-partenaire { background: #2C2824; color: white; }
    .type-guinguette { background: linear-gradient(135deg, #4A7C59 0%, #3D6B4A 100%); color: white; }
    .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 2px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; }
  </style>

  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#C4A855]/10 border border-[#C4A855]/20 mb-6">
          <svg class="w-8 h-8 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Accès associés</h2>
        <p class="text-white/50 text-sm">Document de travail réservé aux associés LAOM</p>
      </div>
      
      <form id="password-form" class="space-y-4">
        <input 
          type="password" 
          id="password-input"
          placeholder="Mot de passe"
          class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#C4A855]/50 focus:ring-1 focus:ring-[#C4A855]/30 transition-all"
          autocomplete="off"
        />
        <button 
          type="submit"
          class="w-full px-6 py-4 rounded-sm bg-[#C4A855] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#B09A4A] transition-colors"
        >
          Accéder
        </button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <!-- Header -->
  <section class="bg-[#1a1a1a] -mt-24 md:-mt-28 pt-32 pb-16">
    <div class="max-w-6xl mx-auto px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-light tracking-[0.2em] uppercase text-white/40">Document de travail</span>
        <span class="text-white/20">·</span>
        <span class="text-xs font-light text-white/40">Non référencé</span>
      </div>
      <h1 class="font-playfair text-4xl md:text-5xl font-medium text-white mb-4 tracking-tight">
        Brainstorming 2026
      </h1>
      <p class="text-lg font-light text-white/60 max-w-2xl">
        Programmation des événements et prévisionnel financier — Session Charly & Amandine
      </p>
      
      <!-- Quick stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-8 border-t border-white/10">
        <div>
          <p class="font-playfair text-3xl font-medium text-[#C4A855]">{formatNumber(totalCABrut)}€</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">CA brut total</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-white">{formatNumber(totalMarge)}€</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Marge estimée</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-white">{evenementsLAOM.length + partenairesStandard.length + partenairesReduits.length + partenairesSpeciaux.length}</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Événements</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-white">{guinguetteJours}</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Jours guinguette</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation rapide -->
  <nav class="sticky top-20 z-40 bg-white/95 backdrop-blur-sm border-b border-black/5 py-4">
    <div class="max-w-6xl mx-auto px-8 md:px-12 lg:px-16">
      <div class="flex gap-6 overflow-x-auto text-sm">
        <a href="#timeline" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors whitespace-nowrap">Timeline</a>
        <a href="#laom" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors whitespace-nowrap">Événements LAOM</a>
        <a href="#partenaires" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors whitespace-nowrap">Partenaires</a>
        <a href="#guinguette" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors whitespace-nowrap">Guinguette</a>
        <a href="#recap" class="text-[#2C2824]/60 hover:text-[#C4A855] transition-colors whitespace-nowrap">Récap financier</a>
      </div>
    </div>
  </nav>

  <!-- Timeline visuelle -->
  <section id="timeline" class="py-16 md:py-20 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-8 md:px-12 lg:px-16">
      <div class="flex items-center justify-between mb-10">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-2">Vue d'ensemble</p>
          <h2 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight">Timeline 2026</h2>
        </div>
        <div class="flex gap-4 text-xs">
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm bg-[#C4A855]"></span> LAOM</span>
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm bg-[#2C2824]"></span> Partenaires</span>
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm bg-[#4A7C59]"></span> Guinguette</span>
        </div>
      </div>

      <div class="space-y-8">
        {timeline.map((mois) => (
          <div class="flex gap-6">
            <div class="w-24 flex-shrink-0 pt-1">
              <p class="font-playfair text-lg font-medium text-[#2C2824]">{mois.mois}</p>
            </div>
            <div class="flex-1 flex flex-wrap gap-3">
              {mois.events.map((e) => (
                <div class={`badge type-${e.type}`}>
                  <span class="opacity-70">{e.date}</span> · {e.nom}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Événements LAOM -->
  <section id="laom" class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-8 md:px-12 lg:px-16">
      <div class="flex items-center justify-between mb-10">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">Billetterie (hors repas)</p>
          <h2 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight">Événements LAOM</h2>
        </div>
        <div class="text-right">
          <p class="font-playfair text-2xl font-medium text-[#C4A855]">{formatNumber(totalMargeLAOM)}€</p>
          <p class="text-xs text-[#2C2824]/40">Marge brute TTC</p>
        </div>
      </div>

      <div class="mb-4 p-3 bg-[#FAF8F5] rounded-sm text-xs text-[#2C2824]/60">
        <strong>Note :</strong> Les repas sont facturés séparément via la guinguette (20€/repas). Voir section "Guinguette Prestations".
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-black/10 bg-[#FAF8F5]">
              <th class="text-left py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Date</th>
              <th class="text-left py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Événement</th>
              <th class="text-left py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Animé par</th>
              <th class="text-right py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Prix</th>
              <th class="text-right py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Pers.</th>
              <th class="text-right py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">CA brut</th>
              <th class="text-right py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Charges</th>
              <th class="text-right py-3 px-2 font-light text-[#2C2824]/50 uppercase tracking-wider text-xs">Marge</th>
            </tr>
