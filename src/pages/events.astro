---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations as getI18nTranslations } from '~/i18n/utils'

import PageHeader from '~/components/laom/PageHeader.astro'
import EventList from '~/components/laom/sections/EventList.astro'
import CtaSection from '~/components/laom/sections/CtaSection.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const lang = 'fr'
const t = getI18nTranslations(lang as 'fr' | 'en')
const pageSchema = createWebPageSchema({
  name: t.pages.eventsPage.heroTitle,
  url: Astro.url.toString(),
  description: t.pages.eventsPage.heroSubtitle,
})

const F = (n: string) => `/images/festival/${n}.webp`

// Agenda réel — on retire En Mouvement + Forum Éco-construction (retirés du live)
const removed = ['En Mouvement', 'Rencontre Forum Éco-construction']
const agenda = t.events.items
  .filter((e) => !removed.includes(e.title))
  .map((e) => ({ date: e.date, title: e.title, desc: e.description, href: e.href }))
---

<Layout
  title={`${t.pages.eventsPage.heroTitle} – LAOM`}
  description={t.pages.eventsPage.heroSubtitle}
  hideChrome={true}
  seo={{ ldJSON: pageSchema }}
>
  <PageHeader img={F('act-danse')} title={t.pages.eventsPage.heroTitle} subtitle={t.pages.eventsPage.heroSubtitle} />

  <EventList eyebrow={t.pages.eventsPage.agendaLabel} title="Tous les événements qui ont lieu" accent="à LAOM"
    bg="bg-[#F2EBDB]" events={agenda} />

  <CtaSection img={F('cta')} bg="bg-[#FBF6EA]" eyebrow="Accueillir"
    title={t.pages.eventsPage.ctaTitle} accent=""
    primaryText={t.pages.eventsPage.ctaButton} primaryHref="/contact/"
    secondaryText={t.pages.eventsPage.ctaRatesButton} secondaryHref="/location/"
    items={[
      {title:'21 hectares',desc:'Forêt, rivière et prairies'},
      {title:'Hébergement & cuisine',desc:'Tipis, salle, guinguette'},
      {title:'Logistique sur place',desc:'On t\'accompagne de A à Z'},
    ]} />

  <SiteFooter />
</Layout>
