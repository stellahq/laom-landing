---
import Layout from '~/layouts/Layout.astro'
import NewsletterForm from '~/components/NewsletterForm.astro'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations as getI18nTranslations } from '~/i18n/utils'

const lang = Astro.currentLocale || 'fr'
const t = getI18nTranslations(lang as 'fr' | 'en')
const pageSchema = createWebPageSchema({
  name: t.pages.eventsPage.heroTitle,
  url: Astro.url.toString(),
  description: t.pages.eventsPage.heroSubtitle,
})

// Images pour les événements partenaires (Photos partenaires - LAOM)
const eventImages = [
  '/images/laom/laomfest/vanlifest-IMG_1373.webp',                            // 0  Clarté
  '/images/colette.webp',                                                      // 1  Désir d'Aventure #1
  '/images/laom/preparation-terre-laom.webp',                                  // 2  LAOM School
  '/images/laom/partenaires/freres-d-ame-retraite-partenaire-LAOM.webp',      // 3  Frères d'Âme
  '/images/colette.webp',                                                      // 4  Désir d'Aventure #2
  '/images/event-rencontre-perspective.webp',                                  // 5  Festival Perspective
  '/images/laom/partenaires/fyneo-logo-F-vert-texte-vert-copie.webp',         // 6  Rencontre Fyneo #1
  '/images/laom/tipis.webp',                                                   // 7  LAOM Coliving E&C 1
  '/images/laom/petit-shambala-exterieur.webp',                                // 8  Rencontre Forum Éco-construction
  '/images/laom/les-enfants-sauvages-15.webp',                                   // 9  Family Camp 1
  '/images/laom/partenaires/summer-camp-amawe-partenaire-LAOM.webp',          // 10 Summer Camp Amawé
  '/images/laom/partenaires/Aime-Etre-retraite-partenaire-LAOM.webp',        // 11 Aime-Être
  '/images/laom/samuel-planas.webp',                                           // 12 En Mouvement
  '/images/laom/tipis.webp',                                                   // 13 LAOM Coliving E&C 2
  '/images/laom/les-enfants-sauvages-15.webp',                                   // 14 Family Camp 2
  '/images/laom/partenaires/Stage-guerison-blessures-partenaire-LAOM.webp',   // 15 Guérison des Blessures
]
const events = t.events.items.map((item, index) => ({
  ...item,
  image: eventImages[index] || '/images/david-lin-fyneo.webp',
}))

// Sessions En Mouvement
const emSessions = t.pages.eventsPage.enMouvementBlock.sessions

// Immersions LAOM
//
// ARCHIVÉ — Week-end Clarté
// À réactiver quand une nouvelle session est programmée : décommente le bloc
// ci-dessous et mets à jour la date.
// {
//   title: 'Clarté',
//   date: 'JJ-JJ MOIS 2026',
//   description: 'Un week-end pour créer le système qui libère ta tête. Vision, PARA, Claude Code.',
//   price: '1 000 €',
//   animateur: 'Charly Aubert',
//   href: '/clarte',
//   image: '/images/laom/laomfest/vanlifest-IMG_1373.webp',
// },
const weekendsLaom = [
  {
    title: 'LAOMSCHOOL',
    date: 'Accompagnement · 12 lives sur 6 mois',
    description: 'La feuille de route pour créer ton lieu : 12 lives collectifs sur 6 mois pour t\'accompagner pas à pas, animés par Charly.',
    price: '497 €',
    animateur: 'Charly Aubert',
    href: '/school/online',
    image: '/images/laom/preparation-terre-laom.webp',
  },
  {
    title: 'Séjour Chillworking',
    date: 'En juin ou en août 2026',
    description: 'Format vacances-travail pour entrepreneurs, dirigeants, freelances, créatifs et salariés en remote. Séances de mouvement le matin, sessions de travail dans la journée à ton rythme, ressourcement et soirées de partage. Durée flexible (5 jours min.).',
    price: '180 € / jour tout compris · 2 000 € pour 14 jours',
    animateur: 'Équipe LAOM',
    href: '/chillworking',
    image: '/images/laom/tipis.webp',
  },
  {
    title: 'Rencontre Forum Éco-construction',
    date: '3-5 juillet 2026',
    description: 'Un week-end pour échanger avec des professionnels de l\'éco-construction : auto-constructeurs, projets de lieux d\'accueil innovants, habitats collectifs.',
    price: '150 €',
    animateur: 'Charly Aubert',
    href: '/forum-eco-construction',
    image: '/images/laom/laom-batiment-paille-hero.jpeg',
  },
  {
    title: 'En Mouvement',
    date: '5-9 août 2026',
    description: '5 jours d\'immersion par la danse et le mouvement. Guidé par Samuel Planas (CNSMDP) et Charly Aubert. Ouvert à tous, aucune expérience requise.',
    price: '1 100 €',
    animateur: 'Samuel Planas & Charly Aubert',
    href: '/stage-danse',
    image: '/images/laom/samuel-planas.webp',
  },
]

// Images LAOM Fest
const laomfestImages = [
  'vanlifest-IMG_1021',
  'vanlifest-IMG_1373',
  'vanlifest-IMG_1399',
  'vanlifest-IMG_2563',
  'vanlifest-IMG_2846',
  'vanlifest-IMG_9979',
]
---

<Layout
  title={`${t.pages.eventsPage.heroTitle} – LAOM`}
  description={t.pages.eventsPage.heroSubtitle}
  seo={{ ldJSON: pageSchema }}
>
  <!-- Hero -->
  <section class="relative py-32 lg:py-40 flex items-center justify-center overflow-hidden -mt-24 md:-mt-28">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/events-hero.webp"
        alt="Rassemblement en plein air à LAOM, bâtiment LAOM, prairie, événement et communauté"
        title="Événement en plein air à LAOM, sud Aveyron"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.25em] uppercase text-white/70 mb-6">{t.pages.eventsPage.agendaLabel}</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-6 tracking-tight drop-shadow-lg">
        {t.pages.eventsPage.heroTitle}
      </h1>
      <p class="text-lg md:text-xl font-light text-white/85 max-w-2xl mx-auto leading-relaxed">
        {t.pages.eventsPage.heroSubtitle}
      </p>
    </div>
  </section>

  <!-- Immersions LAOM -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Immersions LAOM</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4">
          Nos événements 2026
        </h2>
        <p class="text-lg font-light text-[#2C2824]/70 max-w-2xl">
          Weekends thématiques animés par l'équipe LAOM. Formations, immersions, retraites.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {weekendsLaom.map((w) => (
          <a href={w.href} class="group block">
            <article class="bg-white rounded-sm overflow-hidden hover:shadow-lg transition-all">
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={w.image}
                  alt={w.title}
                  title={w.title}
                  class={`w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500 ${w.title.startsWith('Clarté') ? 'scale-105 object-center' : w.title === 'En Mouvement' ? 'object-[center_20%]' : 'object-center'}`}
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="mb-3">
                  <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855]">{w.date}</p>
                </div>
                <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2 group-hover:text-[#C4A855] transition-colors">
                  {w.title}
                </h3>
                <p class="text-base font-light text-[#2C2824]/60 leading-relaxed mb-4">
                  {w.description}
                </p>
                <p class="text-xs font-light text-[#2C2824]/40">
                  Animé par {w.animateur}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Événements partenaires -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">{t.pages.eventsPage.partnersLabel}</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">
        {t.pages.eventsPage.partnersSectionTitle}
      </h2>

      <div class="space-y-12">
        {events.map((event) => {
          const isFyneo = event.title.includes('Fyneo')
          return (
          <article class="flex flex-col md:flex-row gap-8 md:gap-12 items-start group">
            <div class="w-full md:w-72 flex-shrink-0">
              <div class={`aspect-[4/3] overflow-hidden rounded-sm ${isFyneo ? 'bg-white flex items-center justify-center p-4 border border-[#2C2824]/15' : 'bg-neutral-100'}`}>
                <img
                  src={event.image}
                  alt={event.title}
                  title={event.title}
                  class={`w-full h-full rounded-sm transition-transform duration-500 ${isFyneo ? 'object-contain group-hover:scale-[1.02]' : 'object-cover group-hover:scale-[1.02]'}`}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="flex-1">
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-2">
                {event.date}
              </p>
              <h3 class="font-playfair text-2xl md:text-3xl font-normal text-[#2C2824] mb-3 tracking-tight">
                {event.title}
              </h3>
              <p class="text-base font-light text-[#2C2824]/60 leading-relaxed">
                {event.description}
              </p>
            </div>
          </article>
          )
        })}
      </div>
    </div>
  </section>

  <!-- LAOM Fest (à venir) -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="mb-12">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">{t.pages.eventsPage.laomfest.label}</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4">{t.pages.eventsPage.laomfest.title}</h2>
        <p class="text-lg font-light text-[#2C2824]/70 leading-relaxed mb-2 max-w-2xl">
          {t.pages.eventsPage.laomfest.description}
        </p>
        <p class="text-sm font-light text-[#2C2824]/50 italic">{t.pages.eventsPage.laomfest.dateNote}</p>
      </div>
      
      <!-- Gallery -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
        {laomfestImages.map((name) => (
          <div class="aspect-[4/3] rounded-sm overflow-hidden bg-neutral-100">
            <img
              src={`/images/laom/laomfest/${name}.webp`}
              alt=""
              class="w-full h-full object-cover rounded-sm"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </div>
        ))}
      </div>

      <!-- Newsletter -->
      <div class="mt-16 pt-12 border-t border-[#2C2824]/10">
        <p class="text-base font-light text-[#2C2824]/80 leading-relaxed mb-6 max-w-2xl">
          {t.pages.eventsPage.laomfest.newsletterCtaBefore}<strong class="font-semibold underline decoration-[#8B7A3A] underline-offset-2">{t.pages.eventsPage.laomfest.newsletterCtaHighlight}</strong>{t.pages.eventsPage.laomfest.newsletterCtaMiddle}<strong class="font-semibold underline decoration-[#8B7A3A] underline-offset-2">{t.pages.eventsPage.laomfest.newsletterCtaHighlight2}</strong>
        </p>
        <div class="max-w-md">
          <NewsletterForm variant="light" />
        </div>
      </div>
    </div>
  </section>

  <!-- Organiser un événement -->
  <section class="py-24 md:py-32 bg-[#2C2824] text-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">{t.pages.eventsPage.ctaLabel}</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-normal mb-4 tracking-tight">{t.pages.eventsPage.ctaTitle}</h2>
      <p class="text-base font-light text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">{t.pages.eventsPage.ctaDescription}</p>
      <a
        href="/location/"
        class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors"
      >
        {t.pages.eventsPage.ctaRatesButton}
      </a>
    </div>
  </section>
</Layout>
