---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations as getI18nTranslations } from '~/i18n/utils'

const lang = 'en' as const
const t = getI18nTranslations(lang)
const pageSchema = createWebPageSchema({
  name: t.pages.eventsPage.heroTitle,
  url: Astro.url.toString(),
  description: t.pages.eventsPage.heroSubtitle,
})

const eventImages = [
  '/images/claire-danse-libre-retraite-2048x1368.webp',
  '/images/event-rencontre-perspective.jpg',
  '/images/colette.webp',
  '/images/david-lin-fyneo.jpg',
]
const events = t.events.items.map((item, index) => ({
  ...item,
  image: eventImages[index] || '/images/david-lin-fyneo.jpg',
}))
---

<Layout
  title={`${t.pages.eventsPage.heroTitle} – LAOM`}
  description={t.pages.eventsPage.heroSubtitle}
  seo={{
    ldJSON: pageSchema,
  }}
>
  <!-- Hero with event photo background -->
  <section class="relative py-32 lg:py-40 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/laomfest/vanlifest-IMG_2846.jpg"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        aria-hidden="true"
        width="1920"
        height="1280"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <span class="block text-xs font-light tracking-[0.2em] uppercase text-white/80 mb-6">
        Agenda
      </span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-light text-white mb-6 tracking-tight">
        {t.pages.eventsPage.heroTitle}
      </h1>
      <p class="text-xl md:text-2xl font-light text-white/90 max-w-3xl mx-auto leading-relaxed">
        {t.pages.eventsPage.heroSubtitle}
      </p>
    </div>
  </section>

  <!-- Signature Events & Immersions -->
  <section class="py-24 bg-[#faf9f6]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-light text-black mb-12">
        {t.pages.eventsPage.signatureSectionTitle}
      </h2>

      <!-- « En Mouvement » Workshops -->
      <div class="mb-16">
        <h3 class="text-2xl font-light text-black mb-8">{t.pages.eventsPage.enMouvement.sectionTitle}</h3>
        <div class="grid gap-6">
          {t.pages.eventsPage.enMouvement.sessions.map((session) => (
            <div class="group border border-black/10 bg-white overflow-hidden flex flex-col md:flex-row">
              <div class="md:w-64 lg:w-72 bg-neutral-100 rounded-sm overflow-hidden">
                <img src="/images/laom/immersion-mouvement-card.webp" alt={session.title} class="w-full h-48 md:h-full object-cover rounded-sm" loading="lazy" width="800" height="1067" />
              </div>
              <div class="flex-1 p-6 md:p-8 flex flex-col justify-between">
                <div>
                  <p class="text-xs font-light tracking-widest uppercase text-black/50 mb-3">{session.date}</p>
                  <h4 class="text-2xl font-light mb-3 group-hover:translate-x-1 transition-transform duration-300">
                    {session.title}
                  </h4>
                  <p class="text-sm font-light text-black/60">{session.description}</p>
                </div>
                <div class="mt-6 text-xs tracking-widest uppercase text-black/40 group-hover:text-black transition-colors">
                  {t.events.cta}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- LAOMFEST -->
      <div>
        <h3 class="text-2xl font-light text-black mb-4">{t.pages.eventsPage.laomfest.title}</h3>
        <p class="text-black/70 font-light leading-relaxed mb-2 max-w-2xl">
          {t.pages.eventsPage.laomfest.description}
        </p>
        <p class="text-sm font-light text-black/60 italic mb-8">{t.pages.eventsPage.laomfest.dateNote}</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4" aria-label="LAOMFEST illustration photos">
          {['vanlifest-IMG_1021', 'vanlifest-IMG_1373', 'vanlifest-IMG_1399', 'vanlifest-IMG_2563', 'vanlifest-IMG_2846', 'vanlifest-IMG_9979'].map((name) => (
            <div class="aspect-[4/3] rounded-sm overflow-hidden bg-neutral-100">
              <img
                src={`/images/laom/laomfest/${name}.jpg`}
                alt=""
                class="w-full h-full object-cover rounded-sm"
                loading="lazy"
                width="400"
                height="300"
                aria-hidden="true"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- All partner events -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-light text-black mb-12">
        {t.pages.eventsPage.partnersSectionTitle}
      </h2>
      <div class="grid gap-6">
        {events.map((event) => {
          const eventHref = 'href' in event ? (event as { href?: string }).href : undefined
          const isFyneo = event.title.includes('Fyneo')
          const inner = (
            <>
              <div class="md:w-64 lg:w-72 flex-shrink-0 aspect-[4/3] bg-neutral-100 rounded-sm overflow-hidden">
                <img
                  src={event.image}
                  alt={event.title}
                  class={`w-full h-full object-cover rounded-sm ${isFyneo ? 'object-[50%_25%]' : ''}`}
                  loading="lazy"
                />
              </div>
              <div class="flex-1 p-6 md:p-8 flex flex-col justify-between">
                <div>
                  <p class="text-xs font-light tracking-widest uppercase text-black/50 mb-3">{event.date}</p>
                  <h3 class="text-2xl font-light mb-3 group-hover:translate-x-1 transition-transform duration-300">
                    {event.title}
                  </h3>
                  <p class="text-sm font-light text-black/60">{event.description}</p>
                </div>
                <div class="mt-6 text-xs tracking-widest uppercase text-black/40 group-hover:text-black transition-colors">
                  {t.events.cta}
                </div>
              </div>
            </>
          )
          return (
            <div class="group border border-black/10 bg-white overflow-hidden flex flex-col md:flex-row">
              {eventHref ? (
                <a
                  href={eventHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex flex-col md:flex-row w-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/20 focus-visible:ring-offset-2"
                  aria-label={`${event.title} (opens in new tab)`}
                >
                  {inner}
                </a>
              ) : (
                <div class="flex flex-col md:flex-row w-full">
                  {inner}
                </div>
              )}
            </div>
          )
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#2d5016] text-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <h2 class="text-3xl md:text-4xl font-light mb-4">{t.pages.eventsPage.ctaTitle}</h2>
      <p class="text-lg font-light text-white/80 mb-8">{t.pages.eventsPage.ctaDescription}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="mailto:contact@laom.fr"
          class="inline-flex items-center justify-center rounded-sm bg-white text-black px-8 py-3 text-xs tracking-[0.25em] uppercase hover:bg-white/90 transition-colors"
        >
          {t.pages.eventsPage.ctaButton}
        </a>
        <a
          href="https://drive.google.com/file/d/1qfl7IQG1LKvjJLyDkv2KXct5iayeV80Q/view?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${t.pages.eventsPage.ctaRatesButton} (opens in new tab)`}
          class="inline-flex items-center justify-center rounded-sm border border-white text-white px-8 py-3 text-xs tracking-[0.25em] uppercase hover:bg-white hover:text-black transition-colors"
        >
          {t.pages.eventsPage.ctaRatesButton}
        </a>
      </div>
    </div>
  </section>
</Layout>
