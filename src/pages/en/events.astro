---
import Layout from '~/layouts/Layout.astro'
import NewsletterForm from '~/components/NewsletterForm.astro'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations as getI18nTranslations } from '~/i18n/utils'

const lang = 'en' as const
const t = getI18nTranslations(lang)
const pageSchema = createWebPageSchema({
  name: t.pages.eventsPage.heroTitle,
  url: Astro.url.toString(),
  description: t.pages.eventsPage.heroSubtitle,
})

// Partner event images (same order as FR — Photos partenaires - LAOM)
const eventImages = [
  '/images/laom/partenaires/retraite-silence-amawe-partenaire-LAOM.webp',     // Dance & Silence #3
  '/images/event-rencontre-perspective.webp',                                 // Perspective Meeting #4
  '/images/laom/partenaires/Energie-illimitee-amawe-stage-partenaire-LAOM.webp', // Unlimited Energy #1
  '/images/colette.webp',                                                      // Adventure Desires #1
  '/images/laom/partenaires/au-coeur-de-tes-desirs-colette-partenaire-laom.webp', // At the Heart of Your Desires
  '/images/laom/partenaires/freres-d-ame-retraite-partenaire-LAOM.webp',      // Soul Brothers
  '/images/colette.webp',                                                      // Adventure Desires #2
  '/images/event-rencontre-perspective.webp',                                  // Perspective Festival
  '/images/laom/partenaires/fyneo-logo-F-vert-texte-vert-copie.webp',          // Fyneo Gathering #1
  '/images/laom/partenaires/summer-camp-amawe-partenaire-LAOM.webp',           // Summer Camp Amawé
  '/images/laom/partenaires/Energie-illimitee-amawe-stage-partenaire-LAOM.webp', // Unlimited Energy #2
  '/images/laom/partenaires/Aime-Etre-retraite-partenaire-LAOM.webp',         // Love-Being
  '/images/laom/partenaires/Stage-guerison-blessures-partenaire-LAOM.webp',    // Healing Wounds
]
const events = t.events.items.map((item, index) => ({
  ...item,
  image: eventImages[index] || '/images/david-lin-fyneo.webp',
}))

const emSessions = t.pages.eventsPage.enMouvementBlock.sessions
const laomfestImages = [
  'vanlifest-IMG_1021',
  'vanlifest-IMG_1373',
  'vanlifest-IMG_1399',
  'vanlifest-IMG_2563',
  'vanlifest-IMG_2846',
  'vanlifest-IMG_9979',
]
---

<Layout
  title={`${t.pages.eventsPage.heroTitle} – LAOM`}
  description={t.pages.eventsPage.heroSubtitle}
  seo={{ ldJSON: pageSchema }}
>
  <!-- Hero -->
  <section class="relative py-32 lg:py-40 flex items-center justify-center overflow-hidden -mt-24 md:-mt-28">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/events-hero.webp"
        alt="Outdoor gathering at LAOM, LAOM building, meadow, event and community"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1280"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.25em] uppercase text-white/70 mb-6">{t.pages.eventsPage.agendaLabel}</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-6 tracking-tight drop-shadow-lg">
        {t.pages.eventsPage.heroTitle}
      </h1>
      <p class="text-lg md:text-xl font-light text-white/85 max-w-2xl mx-auto leading-relaxed">
        {t.pages.eventsPage.heroSubtitle}
      </p>
    </div>
  </section>

  <!-- En Mouvement, signature immersion -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

        <!-- Image Samuel -->
        <div class="w-full lg:w-[400px] flex-shrink-0">
          <a href="/en/stage-danse/" class="block group">
            <div class="aspect-[3/4] overflow-hidden rounded-sm">
              <img
                src="/images/laom/samuel-planas.webp"
                alt="Samuel Planas, En Mouvement"
                class="w-full h-full object-cover object-top rounded-sm group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
              />
            </div>
          </a>
        </div>

        <!-- Content -->
        <div class="flex-1">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">{t.pages.eventsPage.enMouvementBlock.label}</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4">{t.pages.eventsPage.enMouvementBlock.title}</h2>
          <p class="text-lg font-light text-[#2C2824]/70 leading-relaxed mb-8">
            {t.pages.eventsPage.enMouvementBlock.description}
          </p>

          <!-- Sessions -->
          <div class="space-y-3 mb-10">
            {emSessions.map((s) => (
              <div class="flex justify-between items-center py-3 border-b border-black/5">
                <span class="text-sm font-light text-[#2C2824]/50">{s.label}</span>
                <span class="font-playfair text-base text-[#2C2824]">{s.date} 2026</span>
              </div>
            ))}
          </div>

          <a
            href="/en/stage-danse/"
            class="inline-flex items-center justify-center rounded-sm bg-[#2C2824] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors"
          >
            {t.pages.eventsPage.enMouvementBlock.cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- LAOMFEST -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="mb-12">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">{t.pages.eventsPage.laomfest.label}</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4">{t.pages.eventsPage.laomfest.title}</h2>
        <p class="text-lg font-light text-[#2C2824]/70 leading-relaxed mb-2 max-w-2xl">
          {t.pages.eventsPage.laomfest.description}
        </p>
        <p class="text-sm font-light text-[#2C2824]/50 italic">{t.pages.eventsPage.laomfest.dateNote}</p>
      </div>

      <!-- LAOMFEST Gallery -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
        {laomfestImages.map((name) => (
          <div class="aspect-[4/3] rounded-sm overflow-hidden bg-neutral-100">
            <img
              src={`/images/laom/laomfest/${name}.webp`}
              alt=""
              class="w-full h-full object-cover rounded-sm"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </div>
        ))}
      </div>

      <!-- Newsletter CTA LAOMFEST -->
      <div class="mt-16 pt-12 border-t border-[#2C2824]/10">
        <p class="text-base font-light text-[#2C2824]/80 leading-relaxed mb-6 max-w-2xl">
          {t.pages.eventsPage.laomfest.newsletterCtaBefore}<strong class="font-semibold underline decoration-[#8B7A3A] underline-offset-2">{t.pages.eventsPage.laomfest.newsletterCtaHighlight}</strong>{t.pages.eventsPage.laomfest.newsletterCtaMiddle}<strong class="font-semibold underline decoration-[#8B7A3A] underline-offset-2">{t.pages.eventsPage.laomfest.newsletterCtaHighlight2}</strong>
        </p>
        <div class="max-w-md">
          <NewsletterForm variant="light" />
        </div>
      </div>
    </div>
  </section>

  <!-- LAOM School, 4 weekends -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
        <!-- Placeholder image -->
        <div class="w-full lg:w-[400px] flex-shrink-0">
          <div class="aspect-[3/4] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm" role="img" aria-label={t.pages.eventsPage.school.placeholderAlt}>
            <div class="text-center px-8">
              <p class="text-xs font-medium text-black/40 uppercase tracking-[0.2em] mb-2">Placeholder</p>
              <p class="text-sm font-light text-black/50 max-w-[250px]">{t.pages.eventsPage.school.placeholderDesc}</p>
            </div>
          </div>
        </div>
        <div class="flex-1">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">{t.pages.eventsPage.school.label}</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4">{t.pages.eventsPage.school.title}</h2>
          <div class="space-y-4 mb-8">
            {t.pages.eventsPage.school.paragraphs.map((p) => (
              <p class="text-lg font-light text-[#2C2824]/70 leading-relaxed">
                {p}
              </p>
            ))}
          </div>

          <!-- Sessions -->
          <div class="space-y-3 mb-10">
            {t.pages.eventsPage.school.weekends.map((w) => (
              <div class="flex justify-between items-center py-3 border-b border-black/5">
                <span class="text-sm font-light text-[#2C2824]/50">{w.label}</span>
                <span class="font-playfair text-base text-[#2C2824]">{w.date}</span>
              </div>
            ))}
          </div>

          <a
            href="/en/school/"
            class="inline-flex items-center justify-center rounded-sm bg-[#2C2824] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors"
          >
            {t.pages.eventsPage.school.cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- All partner events -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">{t.pages.eventsPage.partnersLabel}</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">
        {t.pages.eventsPage.partnersSectionTitle}
      </h2>

      <div class="space-y-12">
        {events.map((event) => {
          const isFyneo = event.title.includes('Fyneo')
          return (
            <article class="flex flex-col md:flex-row gap-8 md:gap-12 items-start group">
              <div class="w-full md:w-72 flex-shrink-0">
                <div class={`aspect-[4/3] overflow-hidden rounded-sm ${isFyneo ? 'bg-white flex items-center justify-center p-4 border border-[#2C2824]/15' : 'bg-neutral-100'}`}>
                  <img
                    src={event.image}
                    alt={event.title}
                    class={`w-full h-full rounded-sm transition-transform duration-500 ${isFyneo ? 'object-contain group-hover:scale-[1.02]' : 'object-cover group-hover:scale-[1.02]'}`}
                    loading="lazy"
                  />
                </div>
              </div>
              <div class="flex-1">
                <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-2">
                  {event.date}
                </p>
                <h3 class="font-playfair text-2xl md:text-3xl font-normal text-[#2C2824] mb-3 tracking-tight">
                  {event.title}
                </h3>
                <p class="text-base font-light text-[#2C2824]/60 leading-relaxed">
                  {event.description}
                </p>
              </div>
            </article>
          )
        })}
      </div>
    </div>
  </section>

  <!-- Host an event CTA -->
  <section class="py-24 md:py-32 bg-[#2C2824] text-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">{t.pages.eventsPage.ctaLabel}</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-normal mb-4 tracking-tight">{t.pages.eventsPage.ctaTitle}</h2>
      <p class="text-base font-light text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">{t.pages.eventsPage.ctaDescription}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="mailto:hello@laom.fr"
          class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors"
        >
          {t.pages.eventsPage.ctaButton}
        </a>
        <a
          href="https://drive.google.com/file/d/1qfl7IQG1LKvjJLyDkv2KXct5iayeV80Q/view?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-sm border border-white/30 text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-white hover:text-[#2C2824] transition-colors"
          aria-label={`${t.pages.eventsPage.ctaRatesButton} (opens in new tab)`}
        >
          {t.pages.eventsPage.ctaRatesButton}
        </a>
      </div>
    </div>
  </section>
</Layout>
