---
import Layout from '~/layouts/Layout.astro'
import NewsletterBanner from '~/components/NewsletterBanner.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Resources – LAOM',
  url: Astro.url.toString(),
  description: 'Books, guides and content to understand and build a regenerative eco-place.',
})
---

<Layout
  title="Resources – LAOM"
  description="Books, guides and content to understand and build a regenerative eco-place."
  seo={{
    ldJSON: pageSchema,
  }}
>
  <!-- Hero -->
  <section class="py-32 lg:py-40 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Resources</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-[#2C2824] mb-6 tracking-tight">
        What we share
      </h1>
      <p class="text-xl md:text-2xl font-light text-[#2C2824]/60 max-w-3xl mx-auto leading-relaxed">
        Books, guides and content to understand and build a regenerative eco-place. Everything we wish we'd had before we started.
      </p>
    </div>
  </section>

  <!-- Grand Shambala book -->
  <section class="py-16 md:py-20 bg-[#2C2824]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-14 opacity-0" animate-fade-in-up>
        <div class="shrink-0 w-48 md:w-56">
          <div class="aspect-[3/4] bg-[#3D3832] border border-white/10 rounded-sm flex items-center justify-center shadow-2xl" role="img" aria-label="Grand Shambala book cover, coming soon">
            <div class="text-center px-6">
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mb-4"></div>
              <p class="font-playfair text-base text-white/80 leading-snug mb-2">Grand Shambala</p>
              <p class="text-[10px] font-light text-white/40 uppercase tracking-[0.2em]">The book</p>
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mt-4"></div>
            </div>
          </div>
        </div>
        <div class="text-center md:text-left">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Release March 2026</p>
          <p class="font-playfair text-2xl md:text-3xl font-medium text-white mb-4 tracking-tight leading-snug">
            How we built the world's largest load-bearing straw building.
          </p>
          <p class="text-base font-light text-white/60 leading-relaxed mb-8 max-w-md">
            Construction, materials, real costs, mistakes, lessons. 850 m² on two levels, self-built. Everything we wish we'd read before we started. Subscribers get it free as an early preview.
          </p>
          <a href="/en/newsletter/" class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-8 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors">
            Get the book for free
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- LAOM book -->
  <section class="py-16 md:py-20 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-14 opacity-0" animate-fade-in-up>
        <div class="shrink-0 w-48 md:w-56">
          <div class="aspect-[3/4] bg-[#E8E3D8] border border-black/5 rounded-sm flex items-center justify-center shadow-lg" role="img" aria-label="LAOM book cover, coming soon">
            <div class="text-center px-6">
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mb-4"></div>
              <p class="font-playfair text-base text-[#2C2824]/80 leading-snug mb-2">LAOM</p>
              <p class="text-[10px] font-light text-[#2C2824]/40 uppercase tracking-[0.2em]">The book</p>
              <div class="w-10 h-[2px] bg-[#C4A855] mx-auto mt-4"></div>
            </div>
          </div>
        </div>
        <div class="text-center md:text-left">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Release April 2026</p>
          <p class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] mb-4 tracking-tight leading-snug">
            The full story of an eco-place, from idea to model.
          </p>
          <p class="text-base font-light text-[#2C2824]/60 leading-relaxed mb-8 max-w-md">
            How we formed the group, bought the place, went through conflicts, built governance, set up the SCIA, obtained STECAL, and created a replicable model. Subscribers get it free as an early preview.
          </p>
          <a href="/en/newsletter/" class="inline-flex items-center justify-center rounded-sm bg-[#2C2824] text-white px-8 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors">
            Get the book for free
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Follow the adventure, YouTube -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">YouTube</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6 title-underline mx-auto">
        Follow the adventure
      </h2>
      <p class="text-lg font-light text-[#2C2824]/60 leading-relaxed mb-10 max-w-2xl mx-auto">
        Charly documents the construction of LAOM on video. Build, decisions, mistakes, learnings — it's all there, unfiltered.
      </p>
      <a
        href="https://www.youtube.com/@charlyaubert"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-sm bg-[#2C2824] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        Subscribe to the channel
      </a>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterBanner />
</Layout>
