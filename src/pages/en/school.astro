---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'LAOM School – Ecosystem for eco-place project holders',
  url: Astro.url.toString(),
  description: 'The ecosystem for eco-place project holders. 4 immersive weekends at LAOM, monthly check-ins, a community of builders.',
})

const weekends = [
  {
    num: '01',
    date: 'June 2026',
    title: 'Project & Funding',
    description: 'Clarify your vision. Structure your plan. Identify funding strategies that fit your project: grants, SCIA, fundraising, self-financing. Leave with a funded action plan.',
    speaker: {
      role: 'Impact funding expert',
      bio: 'Specialist in funding social and environmental impact projects. Public grants, impact investment funds, innovative legal structures.',
    },
  },
  {
    num: '02',
    date: 'July 2026',
    title: 'Business model',
    description: 'Build a viable economic model without betraying the vision. Positioning, pricing, revenue diversification: coliving, workshops, agriculture, training, events. What works. What doesn\'t.',
    speaker: {
      role: 'Coliving / third-place founder',
      bio: 'Entrepreneur who has created and stabilised an economic model for a living place. Concrete feedback on the first years, pivots, and financial balance.',
    },
  },
  {
    num: '03',
    date: 'October 2026',
    title: 'Regenerative culture',
    description: 'Eco-construction, regenerative agriculture, energy autonomy, site design, landscape integration. How to design a place that regenerates more than it consumes. Technical choices, mistakes to avoid, real costs.',
    speaker: {
      role: 'Architect / regenerative designer',
      bio: 'Recognised practitioner in eco-construction or regenerative design. Load-bearing straw, raw earth, bioclimatic, permaculture applied to the scale of a living place.',
    },
  },
  {
    num: '04',
    date: 'May 2027',
    title: 'Community culture',
    description: 'Governance, collective intelligence, conflict management, community facilitation, legal framework for the collective. How to create a group that lasts. Departures, arrivals, crises, and how to move through them.',
    speaker: {
      role: 'Facilitator / shared governance expert',
      bio: 'Specialist in collective governance. Sociocracy, holacracy, NVC, decision-making processes. Works with collectives, cooperatives and eco-places for over 10 years.',
    },
  },
]

const formules = [
  {
    name: 'Online',
    price: '2,000',
    featured: false,
    items: [
      'Monthly check-ins (group calls or video)',
      'Session recordings',
      'LAOM community',
      'Access to resources and tools',
    ],
  },
  {
    name: 'The 4 weekends',
    price: '4,000',
    featured: true,
    items: [
      '4 immersive weekends at LAOM',
      'Sessions with guest facilitators',
      'Monthly check-ins',
      'Session recordings',
      'LAOM community',
      'Accommodation and meals included',
    ],
  },
  {
    name: 'Full support',
    price: '9,000',
    featured: false,
    items: [
      'Everything in "The 4 weekends"',
      'Personalised funding support',
      'Personalised legal support',
      'Access to LAOM Capital (seed fund)',
      'Individual follow-up between weekends',
    ],
  },
]
---

<Layout
  title="LAOM School – Ecosystem for eco-place project holders | LAOM"
  description="The ecosystem for eco-place project holders. 4 immersive weekends at LAOM, monthly check-ins, a community of builders."
  seo={{
    ldJSON: pageSchema,
  }}
>
  <!-- Hero -->
  <section class="py-32 lg:py-40 bg-[#F3EEDC]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Cohort 1, June 2026 / May 2027</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-[#2C2824] mb-8 tracking-tight">
        LAOM School
      </h1>
      <p class="text-xl md:text-2xl font-light text-[#2C2824]/60 max-w-3xl mx-auto leading-relaxed">
        The ecosystem for eco-place project holders. 4 immersive weekends at LAOM. Monthly check-ins. A community of builders.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 opacity-0" animate-fade-in-up>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed mb-6">
        You're not here to take a course. You're here to work on your project, surrounded by people doing the same, in a place that's already done it.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed mb-6">
        LAOM is 5 years in the field. Within Oasis La Margue, a 21-hectare estate we acquired collectively. 15 households. The world's largest load-bearing straw building. Everything we've learned – the wins, the mistakes, the shortcuts, the dead ends – we're making it available.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        Each weekend, you come with your project. You work on it. You test your ideas with other project holders and with experts who've already walked the path. You leave with decisions made, not slide decks.
      </p>
    </div>
  </section>

  <!-- The 4 weekends -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Programme</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight title-underline mx-auto">
          4 weekends, 4 themes
        </h2>
      </div>

      <div class="space-y-8 opacity-0" animate-fade-in-up>
        {weekends.map((w) => (
          <div class="bg-white border border-black/5 rounded-sm p-8 md:p-10">
            <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-10">
              <!-- Left: number + date -->
              <div class="flex-shrink-0 md:w-32">
                <span class="text-2xl font-light tracking-[0.1em] text-[#C4A855]">{w.num}</span>
                <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mt-2">{w.date}</p>
              </div>

              <!-- Right: content -->
              <div class="flex-1">
                <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-4 tracking-tight">{w.title}</h3>
                <p class="text-base font-light text-[#2C2824]/70 leading-relaxed mb-8">
                  {w.description}
                </p>

                <!-- Speaker -->
                <div class="flex items-start gap-4 pt-6 border-t border-black/5">
                  <div class="w-12 h-12 rounded-full bg-[#E8E3D8] flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[#2C2824]/25" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-[#2C2824] mb-1">{w.speaker.role}</p>
                    <p class="text-sm font-light text-[#2C2824]/60 leading-relaxed mb-2">{w.speaker.bio}</p>
                    <p class="text-xs font-light text-[#C4A855]">Session, Saturday afternoon &middot; <em class="text-[#2C2824]/40">To be confirmed</em></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Placeholder image -->
      <div class="mt-12 aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm opacity-0" animate-fade-in-up>
        <p class="text-sm font-light text-[#2C2824]/40 px-8 text-center">Photo to take: group of project holders in a circle at Grand Shambala, LAOM School weekend</p>
      </div>
    </div>
  </section>

  <!-- Office hours -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Between weekends</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">
        Check-ins
      </h2>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed mb-6">
        1 group call (or video) per month. You move forward on your project, ask your questions, benefit from the perspective of other project holders and the LAOM team.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        Around 10 sessions over the programme, from June 2026 to May 2027. Included in all formulas.
      </p>
    </div>
  </section>

  <!-- The ecosystem -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Ecosystem</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight title-underline mx-auto">
          What you're joining
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 opacity-0" animate-fade-in-up>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Training</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-4">LAOM School</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            4 immersive weekends at LAOM. Sessions with experts. Monthly check-ins. Recordings of all sessions.
          </p>
        </div>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Community</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-4">LAOM community</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            The builders' network. A space for mutual support, resource sharing and experience feedback among those creating living places. Peer support, co-development, cross visits.
          </p>
        </div>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Funding</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-4">LAOM Capital</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            The impact fund to support seed stages. Financial and strategic support for eco-place projects emerging from LAOM School.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Pricing</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight title-underline mx-auto">
          3 formulas
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 opacity-0" animate-fade-in-up>
        {formules.map((f) => (
          <div class={`rounded-sm p-8 md:p-10 flex flex-col ${f.featured ? 'border-2 border-[#C4A855] bg-[#FAF8F5] relative' : 'border border-black/5 bg-[#FAF8F5]'}`}>
            {f.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#C4A855] text-white text-[10px] tracking-[0.2em] uppercase px-4 py-1 rounded-sm">Recommended</span>
            )}
            <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-2">{f.name}</h3>
            <div class="mb-6">
              <span class="text-3xl font-light text-[#2C2824] tracking-tight">{f.price}</span>
              <span class="text-base font-light text-[#2C2824]/40 ml-1">€</span>
            </div>
            <ul class="space-y-3 mb-8 flex-1">
              {f.items.map((item) => (
                <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
                  <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="https://cal.atomik.world/charly/30min"
              target="_blank"
              rel="noopener noreferrer"
              class={`inline-flex items-center justify-center rounded-sm px-8 py-3.5 text-xs tracking-[0.2em] uppercase transition-colors text-center ${f.featured ? 'bg-[#C4A855] text-white hover:bg-[#B09A4A]' : 'bg-[#2C2824] text-white hover:bg-[#3D3832]'}`}
              aria-label="Book a call (opens in new tab)"
            >
              Book a call
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-24 bg-[#2C2824]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">First exchange</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white tracking-tight mb-6">
        Let's talk?
      </h2>
      <p class="text-base font-light text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">
        30 minutes to discuss your project and see if LAOM School is the right fit for you. By video, no commitment.
      </p>
      <a
        href="https://cal.atomik.world/charly/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-10 py-4 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors"
        aria-label="Book a call (opens in new tab)"
      >
        Book a call
      </a>
    </div>
  </section>
</Layout>
