---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

export const prerender = true

const pageSchema = createWebPageSchema({
  name: 'Book LAOM School — Weekend training',
  url: Astro.url.toString(),
  description: 'Book your spot for LAOM School. 3 days to structure your ecovillage project. 1000€ all-inclusive.',
})

const sessions = [
  { 
    id: 'may-2026',
    num: '01', 
    date: 'May 8-10, 2026', 
    status: 'Next session',
    spotsLeft: 12,
    stripeLink: '#STRIPE_LINK_SESSION_1'
  },
]

const inclus = [
  { icon: 'bed', text: 'On-site accommodation (tipi or room)' },
  { icon: 'food', text: 'All meals (homemade, local products)' },
  { icon: 'book', text: 'Work materials and resources' },
  { icon: 'users', text: 'Access to LAOM community after training' },
]

const reassurance = [
  { icon: 'users', title: '15 spots max', desc: 'Quality guidance' },
  { icon: 'shield', title: '5 years of fieldwork', desc: 'No theory, real experience' },
  { icon: 'lock', title: 'Simple booking', desc: 'By email' },
  { icon: 'calendar', title: 'Cancel -14 days', desc: 'Full refund' },
]
---

<Layout
  title="Book LAOM School — Weekend training | LAOM"
  description="Book your spot for LAOM School. 3 days to structure your ecovillage project. 1000€ all-inclusive."
  seo={{ ldJSON: pageSchema, noindex: true }}
>
  <!-- Hero minimaliste -->
  <section class="bg-[#FAF8F5] -mt-24 md:-mt-28 pt-32 pb-16">
    <div class="max-w-3xl mx-auto px-8 md:px-12 lg:px-16 text-center">
      <a href="/en/school" class="inline-flex items-center gap-2 text-sm font-light text-[#2C2824]/50 hover:text-[#C4A855] transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        Back to LAOM School
      </a>
      <p class="text-xs font-light tracking-[0.25em] uppercase text-[#C4A855] mb-4">Booking</p>
      <h1 class="font-playfair text-4xl md:text-5xl font-medium text-[#2C2824] mb-4 tracking-tight">
        LAOM School
      </h1>
      <p class="text-lg font-light text-[#2C2824]/70 max-w-xl mx-auto">
        3 days to structure your ecovillage project and leave with an action plan
      </p>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-8 md:px-12 lg:px-16">
      
      <!-- Session -->
      <div class="mb-12">
        <div class="p-6 rounded-sm border-2 border-[#C4A855] bg-[#C4A855]/5">
          <div class="flex items-start justify-between mb-4">
            <div>
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855]">Session 01</p>
              <p class="font-playfair text-xl font-medium text-[#2C2824] mt-1">May 8-10, 2026</p>
            </div>
          </div>
          <p class="text-sm font-light text-[#2C2824]/50">Next session</p>
          <p class="text-xs font-light text-[#4A7C59] mt-2">12 spots available</p>
        </div>
      </div>

      <!-- What's included -->
      <div class="mb-12 p-8 bg-[#FAF8F5] rounded-sm">
        <h3 class="text-sm font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">What's included</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          {inclus.map((item) => (
            <div class="flex items-start gap-3">
              <span class="text-[#C4A855] mt-0.5">&#10003;</span>
              <span class="text-base font-light text-[#2C2824]/80">{item.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Price and payment -->
      <div class="mb-12 p-8 border-2 border-[#C4A855] rounded-sm bg-white">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-8">
          <div>
            <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">All-inclusive price</p>
            <div class="flex items-baseline gap-2">
              <span class="font-playfair text-5xl font-medium text-[#2C2824]">1,000</span>
              <span class="text-xl font-light text-[#2C2824]/50">€</span>
            </div>
            <p class="text-sm font-light text-[#2C2824]/50 mt-2">One-time payment, no subscription</p>
          </div>
          <div class="flex-shrink-0">
            <a 
              href="mailto:hello@laom.fr?subject=Booking%20LAOM%20School"
              class="inline-flex items-center justify-center gap-3 rounded-sm bg-[#C4A855] text-white px-10 py-4 text-sm tracking-[0.1em] uppercase hover:bg-[#B09A4A] transition-colors w-full md:w-auto"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Book by email
            </a>
          </div>
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-4 pt-6 border-t border-black/5 text-xs font-light text-[#2C2824]/50">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Write to us at hello@laom.fr
          </span>
          <span>|</span>
          <span>We reply within 24h</span>
          <span>|</span>
          <span>Invoice sent by email</span>
        </div>
      </div>

      <!-- Reassurance -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        {reassurance.map((r) => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-[#FAF8F5] flex items-center justify-center">
              {r.icon === 'users' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              )}
              {r.icon === 'shield' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {r.icon === 'lock' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              )}
              {r.icon === 'calendar' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              )}
            </div>
            <p class="text-sm font-medium text-[#2C2824]">{r.title}</p>
            <p class="text-xs font-light text-[#2C2824]/50 mt-1">{r.desc}</p>
          </div>
        ))}
      </div>

      <!-- Quote -->
      <div class="mb-12 p-8 bg-[#2C2824] rounded-sm text-center">
        <blockquote class="font-playfair text-xl md:text-2xl font-normal text-white/90 italic leading-relaxed">
          "You don't come to take a course. You come to work on YOUR project, surrounded by people doing the same thing."
        </blockquote>
        <p class="text-sm font-light text-white/50 mt-4">— Charly Aubert, LAOM founder</p>
      </div>

      <!-- Contact -->
      <div class="text-center p-8 bg-[#FAF8F5] rounded-sm">
        <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Have a question before booking?</h3>
        <p class="text-base font-light text-[#2C2824]/60 mb-6">
          Talk directly with Charly to see if LAOM School is right for you.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://cal.atomik.world/charly/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-sm border border-[#2C2824]/20 text-[#2C2824] px-6 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#2C2824] hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Schedule a call
          </a>
          <a
            href="mailto:hello@laom.fr"
            class="inline-flex items-center justify-center gap-2 rounded-sm border border-[#2C2824]/20 text-[#2C2824] px-6 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#2C2824] hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            hello@laom.fr
          </a>
        </div>
      </div>
    </div>
  </section>




</Layout>
