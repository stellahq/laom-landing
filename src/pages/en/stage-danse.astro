---
import Layout from '~/layouts/Layout.astro'
import NewsletterForm from '~/components/NewsletterForm.astro'
import { createWebPageSchema } from '~/utils/schema'

export const prerender = true

const pageSchema = createWebPageSchema({
  name: 'En Mouvement – Body immersion | LAOM',
  url: Astro.url.toString(),
  description: '5 days to let emerge what wants to be expressed, through intensive dance and movement practice. LAOM, Aveyron.',
})

const sessions = [
  { date: '5–9 August 2026', label: 'Session 1' },
  { date: '11–15 August 2026', label: 'Session 2' },
  { date: '16–20 August 2026', label: 'Session 3' },
]
---

<Layout
  title="En Mouvement – Body immersion | LAOM"
  description="5 days to let emerge what wants to be expressed, through intensive dance and movement practice. LAOM, Aveyron."
  seo={{ ldJSON: pageSchema }}
>

  <!-- Hero -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden -mt-24 md:-mt-28">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/samuel-planas.webp"
        alt="Samuel Planas, dancer and choreographer, guide of En Mouvement immersions"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center pt-32 pb-16">
      <p class="text-xs font-light tracking-[0.25em] uppercase text-white/70 mb-6">LAOM presents</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-6 tracking-tight leading-tight drop-shadow-lg">
        En Mouvement
      </h1>
      <p class="text-lg md:text-xl font-light text-white/85 max-w-2xl mx-auto leading-relaxed">
        5 days to let emerge what wants to be expressed, through intensive dance and movement practice.
      </p>
    </div>

    <!-- Scroll arrow -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
      <a href="#invitation" class="block text-white/50 hover:text-white transition-colors" aria-label="Scroll down">
        <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- The invitation -->
  <section id="invitation" class="py-24 md:py-32 bg-white">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-8">The invitation</p>
      <div class="space-y-6 text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        <p>
          You sense that something in you wants to be expressed.
        </p>
        <p>
          An energy. An impulse. A part of you that hasn't yet found its space.
        </p>
        <p>
          For 5 days, in a place outside of time, you'll explore what emerges when you move with a group that holds you.
        </p>
        <p>
          No need to know how to dance. Just the desire to move, to let yourself be surprised, to discover what happens when you allow yourself to be fully there.
        </p>
      </div>
    </div>
  </section>

  <!-- What you'll experience – timeline -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">The progression</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">The 5 days, step by step</h2>

      <div class="border-l-2 border-[#C4A855] pl-8 space-y-14">
        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Day 0 – Arrival</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Landing</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            You discover the place, the other participants, the facilitators. First free dance to break the ice. Shared meal. We create a safe, supportive frame.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Day 1</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Daring</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Guided embodiment in continuous flow. Playful, slightly absurd workshops. You explore movement without taking yourself seriously. Trust builds.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Day 2</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Diving in</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Deeper, more introspective practices. Controlled chaos. The mind dissolves.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Sensations become finer. What was held can start to move again.
          </p>
        </div>

        <!-- Placeholder image -->
        <div class="!ml-[-2.5rem] my-8">
          <div class="aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm" role="img" aria-label="Photo coming soon">
            <div class="text-center px-8">
              <p class="text-xs font-medium text-black/40 uppercase tracking-[0.2em] mb-2">Placeholder</p>
              <p class="text-sm font-light text-black/50 max-w-lg">Dancers in movement in the Shala, natural light, soft silhouettes, total immersion atmosphere. Photo from a workshop.</p>
            </div>
          </div>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Day 3</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Creating together</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Collaborative workshops. Relational and somatic work.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Contact dance, body listening, quality of presence in relationship. We observe how the body responds to the other, to the collective.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            If a collective energy has emerged, we work on a shared project.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Day 4</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Sharing</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Integration and expression. What the body has been through finds a form.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Improvisations, small groups, individual expression. Closing circle.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            You leave with an experience integrated, inscribed in the body.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What makes this experience unique -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">The approach</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">What makes this experience unique</h2>

      <div class="grid md:grid-cols-2 gap-x-16 gap-y-12">
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">A somatic approach</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            The starting point isn't the head, but the body. We work from sensations, impulses, micro-movements. Movement becomes a tool for regulation, expression and integration.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Continuous flow</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            The music doesn't stop. No moment where you drop back into your head to analyse. You stay in the movement, in the body, in the experience.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">The group that holds you</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Shared meals, gentle progression, moments of sharing. When you move with others, when your rhythms sync, your nervous system regulates naturally.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Guidance in movement</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            The facilitators guide continuously, through movement itself. If something emerges, we go through it together, through the body, not through analysis.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Accessible to all</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            You don't need technique. Just the desire to move and let yourself be surprised. Samuel is used to facilitating groups of 200 amateurs of all levels.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why it works -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-10">Why movement transforms</h2>
      <div class="space-y-6 text-lg font-light text-[#2C2824]/80 leading-relaxed">
        <p>
          Neuroscience research shows that some transformations cannot happen through reflection alone.
        </p>
        <p>
          The body holds the trace of what hasn't been digested: stress, emotions, past experiences are inscribed in the nervous system and tissues. Dance and movement more broadly allow this information to move again.
        </p>
        <p>
          When we move together, when our rhythms synchronise, our nervous system regulates naturally. That's why the group experience is so powerful.
        </p>
        <p>
          All of this rests on an essential base: safety. A safe container allows the body to relax, explore, integrate, and let new responses emerge.
        </p>
      </div>
      <div class="mt-10 pt-8 border-t border-black/10">
        <p class="text-sm font-light text-[#2C2824]/40">
          This approach is inspired by the work of Bessel van der Kolk, Peter Levine and Stephen Porges, and by direct experience of body-based work in groups.
        </p>
      </div>
    </div>
  </section>

  <!-- The facilitators -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">The guides</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Who will guide you</h2>

      <div class="grid md:grid-cols-2 gap-16">
        <!-- Charly -->
        <div>
          <div class="aspect-[3/4] bg-[#E8E3D8] overflow-hidden rounded-sm mb-6 flex items-center justify-center border border-black/5" role="img" aria-label="Charly photo coming soon">
            <div class="text-center px-8">
              <p class="text-xs font-medium text-black/40 uppercase tracking-[0.2em] mb-2">Placeholder</p>
              <p class="text-sm font-light text-black/50">Portrait of Charly, outdoors at LAOM, natural light, direct gaze, simple clothes. No pose, just presence.</p>
            </div>
          </div>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">Charly Aubert</h3>
          <p class="text-sm font-light text-[#2C2824]/50 mb-4">LAOM co-founder</p>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Builder, coach, polymath. Charly brings the coaching approach, structures the experience and supports the process as a whole. He works from what shows up in the body (tension, impulse, emotion) and supports the process so that each person can move through what emerges, in movement.
          </p>
        </div>

        <!-- Samuel -->
        <div>
          <div class="aspect-[3/4] overflow-hidden rounded-sm mb-6">
            <img
              src="/images/laom/samuel-planas.webp"
              alt="Samuel Planas, dancer and choreographer"
              class="w-full h-full object-cover object-top rounded-sm"
              loading="lazy"
            />
          </div>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">Samuel Planas</h3>
          <p class="text-sm font-light text-[#2C2824]/50 mb-4">Professional dancer and choreographer</p>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            At 23, Samuel moves between the biggest contemporary dance stages and facilitating amateur groups. Trained at the Paris Conservatoire, performer for Boris Charmatz, Noé Soulier and Wim Vandekeybus. He has led 200 amateurs at the Grand Palais in the CERCLES project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The venue -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
        <div class="w-full lg:w-96 flex-shrink-0">
          <div class="aspect-[3/4] overflow-hidden rounded-sm">
            <img
              src="/images/laom/salle-de-pratique.webp"
              alt="The Shala, LAOM practice room, 120 m², professional Harlequin dance floor, natural materials, natural light"
              class="w-full h-full object-cover rounded-sm"
              loading="lazy"
            />
          </div>
        </div>
        <div class="flex-1">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">The venue</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8">The Shala (practice room), 120 m²</h2>
          <div class="space-y-4 text-lg font-light text-[#2C2824]/80 leading-relaxed">
            <p>
              LAOM is an eco-place in the south of Aveyron, at the heart of the Grands Causses Natural Park.
            </p>
            <p>
              The workshop takes place in the Shala, our practice room: professional dance floor (Harlequin), room built with natural materials, large openings onto the hills, clean air, natural light. A space designed for movement.
            </p>
            <p>
              On-site accommodation: rooms, tipis, dormitory. Meals prepared with vegetables from the garden.
            </p>
          </div>

          <!-- Placeholder gallery -->
          <div class="mt-8 grid grid-cols-2 gap-3">
            <div class="aspect-square bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm" role="img">
              <p class="text-xs font-light text-black/40 text-center px-4">View of the estate at sunrise, meadows, forest, light mist</p>
            </div>
            <div class="aspect-square bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm" role="img">
              <p class="text-xs font-light text-black/40 text-center px-4">Tipi or room, unusual accommodation, linen sheets, soft light</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practical info -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Practical</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-12">Practical info</h2>

      <!-- Sessions -->
      <div class="mb-12">
        <p class="text-sm font-light text-[#2C2824]/50 mb-4 uppercase tracking-widest">3 sessions this summer</p>
        <div class="space-y-3">
          {sessions.map((s) => (
            <div class="flex justify-between items-center py-3 border-b border-black/5">
              <span class="text-sm font-light text-[#2C2824]/50">{s.label}</span>
              <span class="font-playfair text-lg text-[#2C2824]">{s.date}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="space-y-4">
        <div class="flex justify-between items-start py-3 border-b border-black/5">
          <span class="text-base font-light text-[#2C2824]/50">Duration</span>
          <span class="text-base font-light text-[#2C2824] text-right">5 days / 4 nights</span>
        </div>
        <div class="flex justify-between items-start py-3 border-b border-black/5">
          <span class="text-base font-light text-[#2C2824]/50">Venue</span>
          <span class="text-base font-light text-[#2C2824] text-right">LAOM, Aveyron</span>
        </div>
        <div class="flex justify-between items-start py-3 border-b border-black/5">
          <span class="text-base font-light text-[#2C2824]/50">Places</span>
          <span class="text-base font-light text-[#2C2824] text-right">12–15 people</span>
        </div>
        <div class="flex justify-between items-start py-3 border-b border-black/5">
          <span class="text-base font-light text-[#2C2824]/50">Price</span>
          <span class="text-base font-light text-[#2C2824] text-right">To be announced</span>
        </div>
        <div class="flex justify-between items-start py-3 border-b border-black/5">
          <span class="text-base font-light text-[#2C2824]/50">Accommodation</span>
          <span class="text-base font-light text-[#2C2824] text-right">Rooms, tipis, dormitory</span>
        </div>
        <div class="flex justify-between items-start py-3 border-b border-black/5">
          <span class="text-base font-light text-[#2C2824]/50">Level required</span>
          <span class="text-base font-light text-[#2C2824] text-right">None, open to all</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 bg-[#2C2824] text-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">Summer 2026</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-normal mb-4 tracking-tight">Interested?</h2>
      <p class="text-base font-light text-white/60 mb-10 max-w-xl mx-auto leading-relaxed">
        Dates are set. Price and details will be announced first by email. Sign up to be notified.
      </p>
      <div class="max-w-md mx-auto">
        <NewsletterForm variant="light" textOnDarkBackground />
      </div>
    </div>
  </section>

</Layout>
