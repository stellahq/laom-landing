---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Coliving',
  url: Astro.url.toString(),
  description:
    'Opening late 2026: 7 rooms, shared living/kitchen, summer kitchen, multipurpose hall, coworking, river and meadows.',
})

const galleryImages = [
  '/images/laom/coliving/coliving-laom-rendu-3d-vue-generale.webp',
  '/images/laom/coliving/coliving-laom-plan-etage.webp',
  '/images/laom/coliving/coliving-laom-rendu-chambre.webp',
  '/images/laom/coliving/coliving-laom-rendu-facade.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-01.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-02.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-03.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-04.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-05.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-06.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-07.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-08.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-09.webp',
  '/images/laom/coliving/coliving-laom-vue-interieure-10.webp',
  '/images/laom/coliving/coliving-laom-maquette-interieure.webp',
  '/images/laom/coliving/hameau-5-8b46de75.webp',
  '/images/laom/coliving/coliving-laom-vue-domaine.webp',
]
---

<Layout
  title="Coliving – LAOM"
  description="Opening late 2026: 7 rooms, shared living/kitchen, summer kitchen, multipurpose hall, coworking, river and meadows."
  seo={{ ldJSON: pageSchema }}
>
  <section class="py-32 lg:py-40 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <span class="block text-xs font-light tracking-[0.2em] uppercase text-black/40 mb-6">Opening late 2026</span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-light text-black mb-6 tracking-tight">Coliving</h1>
      <p class="text-xl md:text-2xl font-light text-black/60 leading-relaxed">
        7 rooms · 1 shared living room / kitchen · 1 summer kitchen · 1 multipurpose hall · 21 hectares · a river
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid gap-6 md:grid-cols-3">
        <img
          src="/images/laom/coliving/coliving-laom-vue-domaine.webp"
          alt="Coliving house"
          title="View of the LAOM coliving estate"
          class="h-64 w-full rounded-sm object-cover border border-black/10"
          loading="lazy"
        />
        <img
          src="/images/laom/coliving/coliving-laom-maquette-interieure.webp"
          alt="Coliving interior spaces"
          title="Interior model of the LAOM coliving"
          class="h-64 w-full rounded-sm object-cover border border-black/10"
          loading="lazy"
        />
        <img
          src="/images/laom/coliving/hameau-5-8b46de75.webp"
          alt="View of the hamlet and valley"
          title="The hamlet of La Margue and the valley"
          class="h-64 w-full rounded-sm object-cover border border-black/10"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="py-24 bg-[#faf9f6]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          'Bedrooms',
          'Bathrooms',
          'Shared lounge and kitchen',
          'The hall',
          'Coworking space',
        ].map((title) => (
          <article class="border border-black/10 bg-white p-6 lg:p-8 shadow-sm">
            <h2 class="text-xl font-light text-black mb-4">{title}</h2>
            <p class="text-sm font-light text-black/60 leading-relaxed">
              Because we offer far more than a simple room, discover all the services and amenities of our coliving
              spaces.
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-light text-black mb-8">The Margue estate</h2>
      <p class="text-lg font-light text-black/70 leading-relaxed mb-10">
        A coliving stay in the heart of nature, on a living estate where work, rest, and encounters flow together.
      </p>
      <div class="grid gap-4 md:grid-cols-2 text-lg font-light text-black/70">
        <div class="border border-black/10 p-5">In nature</div>
        <div class="border border-black/10 p-5">The river</div>
        <div class="border border-black/10 p-5">The meadows</div>
        <div class="border border-black/10 p-5">The valley</div>
        <div class="border border-black/10 p-5">Shows and shared moments</div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-[#faf9f6]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-light text-black mb-10">Gallery</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {galleryImages.map((src, index) => (
          <img
            src={src}
            alt={`Coliving Gallery ${index + 1}`}
            title={`LAOM Coliving - photo ${index + 1}`}
            class="h-56 w-full rounded-sm object-cover border border-black/10 bg-white"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>
</Layout>
