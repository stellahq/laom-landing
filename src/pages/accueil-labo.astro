---
// Page 1 — ACCUEIL, au format exact du brief (6 sections), assemblée en DS1.
// Route isolée /accueil-labo (noindex, hors menu) — ne touche aucune page du site.
import Layout from '~/layouts/Layout.astro'
import HeroLeader from '~/components/laom/sections/HeroLeader.astro'
import AboutCards from '~/components/laom/sections/AboutCards.astro'
import CtaSection from '~/components/laom/sections/CtaSection.astro'
import HabitatsSection from '~/components/laom/sections/HabitatsSection.astro'
import StickyCta from '~/components/laom/StickyCta.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const F = (n: string) => `/images/festival/${n}.webp`
const L = (n: string) => `/images/laom/${n}.webp`

const navLinks = [
  { label: 'Accueil', href: '/' },
  { label: 'Coliving', href: '/coliving/' },
  { label: 'Le lieu', href: '/le-lieu/' },
  { label: 'Notre histoire', href: '/notre-histoire/' },
]
---

<Layout title="LAOM — Coliving entrepreneurs (accueil)" hideChrome={true} seo={{ noIndex: true }}>

  <!-- 1. HERO -->
  <HeroLeader
    video="/videos/aveyron_hero.webm" img={F('hero')} alt="Le domaine LAOM en sud Aveyron"
    navLinks={navLinks} navCta="Candidater" navCtaHref="/candidater/"
    eyebrow="Coliving pour entrepreneurs · Sud Aveyron"
    title="Vis et travaille autrement, en pleine nature," accent="entre pairs"
    ctaText="Candidater" ctaHref="/candidater/" />

  <!-- 2. MANIFESTE -->
  <AboutCards
    eyebrow="Le manifeste"
    title="On y a construit un" accent="lieu de vie."
    intro="LAOM, c’est un ancien domaine agricole de 21 hectares, entre causses et vallées, dans le sud de l’Aveyron."
    items={[
      {kind:'photo',img:F('about-1')},
      {kind:'text',color:'marron',title:'Pas un hôtel, pas un centre de formation',text:'Un endroit où l’on mange ce qui pousse ici, où l’on travaille dans le calme, et où l’on partage le quotidien avec des gens qui nous ressemblent.'},
      {kind:'photo',img:F('about-2')},
      {kind:'text',color:'vert',title:'Pour qui ?',text:'On accueille des entrepreneurs qui ont construit quelque chose et qui cherchent un cadre pour continuer, autrement.'},
    ]} />

  <!-- 3. TEASER COLIVING AOÛT 2026 -->
  <CtaSection bg="bg-[#FBF6EA]" img={F('cta')}
    eyebrow="Coliving entrepreneurs"
    title="Coliving entrepreneurs." accent="Août 2026."
    primaryText="Découvrir le programme" primaryHref="/coliving-aout/"
    items={[
      {title:'1 semaine · 12 places',desc:'Tout est inclus'},
      {title:'Hébergement & repas',desc:'Faits maison, terroir'},
      {title:'Coworking & activités',desc:'Sur le domaine'},
    ]} />

  <!-- 4. LE LIEU EN APERÇU -->
  <HabitatsSection bg="bg-[#F2EBDB]"
    eyebrow="Le lieu"
    title="Le domaine, en" accent="aperçu"
    intro="Des tipis, un potager, une guinguette, des chemins en forêt. Et la voie lactée, la nuit, sans aucune pollution lumineuse. Le domaine est à 1h30 de Montpellier, au milieu de nulle part. C’est exactement le point."
    items={[
      {img:L('tipis'),title:'Les tipis',desc:'Dormir au plus près du vivant.',href:'/le-lieu/'},
      {img:L('laom-potager'),title:'Le potager',desc:'Ce qui pousse ici finit dans l’assiette.',href:'/le-lieu/'},
      {img:L('riviere-laom'),title:'La nature',desc:'Forêt, rivière, ciel étoilé.',href:'/le-lieu/'},
    ]} />

  <!-- 5. LES FONDATEURS -->
  <AboutCards bg="bg-[#FBF6EA]"
    eyebrow="Les fondateurs"
    title="Charly & Amandine," accent="le cœur du lieu"
    intro="Ils ont créé LAOM avec une conviction simple : on vit mieux quand on choisit son cadre."
    items={[
      {kind:'photo',img:L('charly-amandine')},
      {kind:'text',color:'marron',title:'Un projet de vie',text:'Ils ont quitté la ville, acheté 21 hectares, et construit un lieu où le travail, la nature et la communauté cohabitent. → Lire notre histoire'},
    ]} />

  <!-- 6. QUIZ -->
  <CtaSection bg="bg-[#F2EBDB]" img={F('act-chillworking')}
    eyebrow="Le quiz"
    title="Vis-tu vraiment le mode de vie que tu" accent="veux ?"
    primaryText="Faire le quiz" primaryHref="/candidater/"
    items={[
      {title:'2 minutes',desc:'Un point sur ton équilibre'},
      {title:'Profil personnalisé',desc:'Reçu par email'},
      {title:'Sans engagement',desc:'Juste pour toi'},
    ]} />

  <SiteFooter />

  <!-- CTA sticky mobile (brief) -->
  <StickyCta text="Candidater" href="/candidater/" />
</Layout>
