---
// Page 1 — ACCUEIL (brief), direction B « contemplatif » : hero centré épuré,
// puis alternance aérée déclaration centrée ↔ photo/texte. Espace optimisé.
// Route isolée /accueil-labo (noindex, hors menu) — ne touche aucune page du site.
import Layout from '~/layouts/Layout.astro'
import HeroCenter from '~/components/laom/sections/HeroCenter.astro'
import Statement from '~/components/laom/sections/Statement.astro'
import MediaText from '~/components/laom/sections/MediaText.astro'
import ShowcaseBand from '~/components/laom/sections/ShowcaseBand.astro'
import StickyCta from '~/components/laom/StickyCta.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const F = (n: string) => `/images/festival/${n}.webp`
const L = (n: string) => `/images/laom/${n}.webp`

const navLinks = [
  { label: 'Accueil', href: '/' },
  { label: 'Coliving', href: '/coliving/' },
  { label: 'Le lieu', href: '/le-lieu/' },
  { label: 'Notre histoire', href: '/notre-histoire/' },
]
---

<Layout title="LAOM — Coliving entrepreneurs (accueil)" hideChrome={true} seo={{ noIndex: true }}>

  <!-- 1. HERO (direction B, validé) -->
  <HeroCenter
    video="/videos/aveyron_hero.webm" img={F('hero')} alt="Le domaine LAOM en sud Aveyron"
    navLinks={navLinks} navCta="Candidater" navCtaHref="/candidater/"
    eyebrow="Coliving pour entrepreneurs · Sud Aveyron"
    title="Vis et travaille autrement, en pleine nature," accent="entre pairs"
    subtitle="Une semaine pour changer de cadre, sans mettre ta vie pro en pause."
    ctaText="Candidater" ctaHref="/candidater/" />

  <!-- 2. LE DOMAINE — grande image + blocs (taille + atouts) -->
  <ShowcaseBand img="/images/vue-aeriene-laom2-hero.webp" alt="Vue aérienne du domaine LAOM, 21 hectares en sud Aveyron"
    eyebrow="Le domaine"
    title="On y a construit un" accent="lieu de vie."
    intro="Pas un hôtel, pas un centre de formation. 21 hectares entre causses et vallées, dans le sud de l’Aveyron — un endroit où l’on vit, où l’on travaille au calme, et où l’on partage le quotidien."
    stats={[
      {value:'21',unit:'ha',label:'Domaine préservé'},
      {value:'12',label:'places / semaine'},
      {value:'1h30',label:'de Montpellier'},
    ]}
    atouts={['Tipis','Coworking','Potager','Guinguette','Feu de camp']}
    note="Et la voie lactée, la nuit, sans aucune pollution lumineuse." />

  <!-- 3. TEASER COLIVING AOÛT (photo + texte) -->
  <MediaText bg="bg-[#F2EBDB]" img={F('cta')} alt="Coliving entrepreneurs à LAOM"
    eyebrow="Coliving entrepreneurs"
    title="Coliving entrepreneurs." accent="Août 2026."
    text="1 semaine. 12 places. Tout est inclus : hébergement, repas faits maison, espace de travail, activités. Un cadre qui change tout, sans mettre ta vie pro en pause."
    ctaText="Découvrir le programme" ctaHref="/coliving-aout/" />

  <!-- 4. LES FONDATEURS (photo nette à droite + texte) -->
  <MediaText bg="bg-[#FBF6EA]" reverse={true} img={L('charly-amandine')} alt="Charly et Amandine, fondateurs de LAOM"
    eyebrow="Les fondateurs"
    title="Charly & Amandine," accent="le cœur du lieu"
    text="Ils ont créé LAOM avec une conviction simple : on vit mieux quand on choisit son cadre. Ils ont quitté la ville, acheté 21 hectares, et construit un lieu où le travail, la nature et la communauté cohabitent."
    ctaText="Lire notre histoire" ctaHref="/notre-histoire/" />

  <!-- 5. QUIZ (déclaration centrée + CTA) -->
  <Statement bg="bg-[#F2EBDB]"
    eyebrow="Le quiz"
    title="Vis-tu vraiment le mode de vie que tu" accent="veux ?"
    intro="Un quiz de 2 minutes pour faire le point sur ton équilibre entre travail, cadre de vie, et ce qui compte vraiment pour toi. Tu reçois ton profil personnalisé par email."
    ctaText="Faire le quiz" ctaHref="/candidater/" />

  <SiteFooter />

  <StickyCta text="Candidater" href="/candidater/" />
</Layout>
