---
// PAGE DE VENTE — Variant B (gardée et optimisée). Techniques La Pioche en charte
// LAOM, posture LAOM. Optims : hero vidéo (sans bande de visages), témoignages en
// carrousel infini, prix retiré (max candidatures), process bienveillant en
// scroll-stack, journée type animée au scroll. Lead-gen : tout vers "Postuler".
// Route isolée /coliving-aout-labo-b (noindex).
import Layout from '~/layouts/Layout.astro'
import SiteNav from '~/components/laom/SiteNav.astro'
import MosaicGallery from '~/components/laom/sections/MosaicGallery.astro'
import MediaText from '~/components/laom/sections/MediaText.astro'
import Faq from '~/components/laom/sections/Faq.astro'
import CtaImage from '~/components/laom/sections/CtaImage.astro'
import StickyCta from '~/components/laom/StickyCta.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const L = (n: string) => `/images/laom/${n}.webp`
const POSTULER = '/candidater-labo/'

// Témoignages PLACEHOLDER — à remplacer par les vrais avis (Google + alumni juin).
const temoins = [
  { quote: 'En une semaine, j’ai pris des décisions que je repoussais depuis six mois.', name: 'Thomas', role: 'Coach indépendant · Lyon' },
  { quote: 'Venue pour souffler, repartie avec trois personnes que je vois encore.', name: 'Mathilde', role: 'Studio de design · Bordeaux' },
  { quote: 'J’avais peur de décrocher de mes clients. J’ai bossé chaque matin, et le reste m’a remis d’aplomb.', name: 'Sofiane', role: 'Consultant · Paris' },
  { quote: 'Le cadre fait le travail. Tu n’as rien à forcer, ça vient.', name: 'Inès', role: 'Naturopathe · Toulouse' },
]
const initiales = (n: string) => n.trim().slice(0, 1).toUpperCase()

const stats = [
  { v: '21 ha', l: 'de nature préservée' },
  { v: '12', l: 'places par semaine' },
  { v: '3', l: 'éditions en août' },
  { v: '1h30', l: 'de Montpellier' },
]
const pains = [
  { t: 'La solitude du fondateur', lead: 'Tu portes tout, seul.', body: 'Les décisions, les doutes, la pression. Autour de toi, personne ne comprend vraiment ta réalité. Tes proches voient « un truc qui marche ». Toi, tu vois tout ce qu’il y a derrière.', img: L('coworking-echange') },
  { t: 'Le rythme qui t’épuise', lead: 'Tu te dis que tu ralentiras plus tard.', body: 'Tu repousses le sport, tu manges vite, tu dors moyen. Le téléphone ne s’éteint jamais vraiment. Et plus tard, ça n’arrive jamais.', img: L('atelier-presentation') },
  { t: 'Le cadre qui t’éteint', lead: 'Les mêmes murs, le même bureau.', body: 'Ton décor ne te porte plus, il te vide. Tu crées dans un environnement qui n’a rien à voir avec la vie que tu voulais en te lançant.', img: L('coworking-coussins') },
]
const journee = [
  { time: '7h30', label: 'Réveil en pleine nature' },
  { time: '8h00', label: 'Pratique du matin : yoga, mouvement ou marche' },
  { time: '9h00', label: 'Petit-déjeuner du potager, face à la vallée' },
  { time: '9h30 – 13h', label: 'Travail au calme, wifi fibre' },
  { time: '13h00', label: 'Déjeuner à la grande table' },
  { time: '14h – 17h', label: 'Au choix : avancer, rivière, atelier, sieste' },
  { time: '19h30', label: 'Dîner fait maison' },
  { time: '21h00', label: 'Feu, soirée, voie lactée' },
]
const etapes = [
  { n: '01', t: 'Tu remplis le formulaire. Deux minutes, sans engagement.' },
  { n: '02', t: 'On s’appelle 15 minutes, juste pour faire connaissance et voir si c’est le bon moment pour toi.' },
  { n: '03', t: 'Si l’envie est là, ta place t’attend.' },
]
---

<Layout title="Coliving entrepreneurs · Août 2026 (B) · LAOM" hideChrome={true} seo={{ noIndex: true }}>

  <!-- ① HERO — vidéo plein écran -->
  <section class="relative min-h-screen w-full overflow-hidden flex flex-col text-[#F2EBDB]">
    <video autoplay muted loop playsinline poster="/images/hero-laom-poster-v2.webp" class="absolute inset-0 w-full h-full object-cover">
      <source src="/videos/hero-laom-v2.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(28,19,12,0.88) 0%,rgba(122,47,29,0.6) 55%,rgba(154,57,34,0.5) 100%)"></div>
    <SiteNav transparent={true} links={[]} ctaText="Postuler" ctaHref={POSTULER} />
    <div class="relative z-10 flex-1 flex flex-col items-center justify-center text-center px-6 pt-28 pb-20 max-w-4xl mx-auto">
      <span class="inline-block rounded-full bg-[#F2EBDB]/12 border border-[#F2EBDB]/15 px-5 py-2 text-[0.72rem] font-semibold tracking-[0.18em] uppercase text-[#F2EBDB]/90 mb-8">Coliving entrepreneurs · 3 éditions · Août 2026</span>
      <h1 class="font-extrabold text-[#F2EBDB] text-5xl md:text-6xl lg:text-7xl leading-[1.02] tracking-[-0.03em] text-balance">Cette semaine, ton bureau, <span class="italic font-medium text-[#E7C89A]">c’est 21 hectares de nature.</span></h1>
      <p class="text-lg md:text-xl text-[#F2EBDB]/85 mt-7 max-w-2xl mx-auto leading-relaxed">Six jours dans le sud de l’Aveyron, avec onze entrepreneurs qui te ressemblent. Tu continues de bosser, mais dans un cadre qui te nourrit au lieu de t’épuiser.</p>
      <a href={POSTULER} class="pill pill-light mt-10" style="padding:1rem 2.6rem">Postuler pour août 2026</a>
      <p class="text-xs tracking-[0.12em] uppercase text-[#F2EBDB]/55 mt-5">Candidature en 2 minutes · sans engagement</p>
      <p class="text-sm font-medium text-[#E7C89A] mt-3">Douze places par édition, et elles partent vite.</p>
    </div>
  </section>

  <!-- ② BANDE DE STATS -->
  <section class="bg-[#FBF6EA] py-16 md:py-20 border-b border-[#412F1F]/8">
    <div class="max-w-6xl mx-auto px-6 md:px-10 grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-6">
      {stats.map((s) => (
        <div class="text-center">
          <p class="font-extrabold text-[#9A3922] text-4xl md:text-5xl leading-none mb-2">{s.v}</p>
          <p class="text-sm text-[#1D1B18]/60">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ③ LE CONSTAT — douleurs nommées -->
  <section animate-fade-in-up class="opacity-0 bg-[#F2EBDB] py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14 grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-16 items-start">
      <div class="lg:pt-4">
        <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-5">Le constat</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.08] text-balance">On connaît <span class="acc">cette situation.</span></h2>
        <p class="text-lg text-[#1D1B18]/70 mt-6 leading-relaxed max-w-md">Parce qu’on l’a vue des dizaines de fois. Chez les entrepreneurs qui viennent à LAOM, trois choses reviennent presque à chaque fois.</p>
        <a href={POSTULER} class="pill pill-primary mt-9" style="padding:.9rem 2.2rem">Postuler pour août 2026</a>
      </div>
      <div class="space-y-5">
        {pains.map((p) => (
          <div class="rounded-3xl bg-[#9A3922] text-[#F2EBDB] p-7 md:p-8 flex gap-6 items-start">
            <img src={p.img} alt="" loading="lazy" class="w-20 h-20 md:w-24 md:h-24 rounded-2xl object-cover shrink-0" />
            <div>
              <h3 class="text-xl md:text-2xl font-extrabold text-[#F2EBDB] leading-tight mb-2">{p.t}</h3>
              <p class="font-semibold text-[#F2EBDB] mb-1.5">{p.lead}</p>
              <p class="text-sm text-[#F2EBDB]/80 leading-relaxed">{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ CRÉDIBILITÉ — le lieu existe -->
  <section animate-fade-in-up class="opacity-0 bg-[#FBF6EA] py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="imgzoom rounded-3xl overflow-hidden aspect-[4/3] order-2 lg:order-1">
        <img src="/images/vue-aeriene-laom2-hero.webp" alt="Le domaine LAOM, 21 hectares en sud Aveyron" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-5">Ce n’est pas un concept</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.06] text-balance">Un lieu qui <span class="acc">existe vraiment.</span></h2>
        <p class="text-lg text-[#1D1B18]/70 mt-6 leading-relaxed max-w-xl">Charly et Amandine ont acheté vingt-et-un hectares dans le sud de l’Aveyron et passé des années à bâtir, de leurs mains, un vrai lieu de vie. Des événements y sont organisés depuis plusieurs années, des résidents y vivent déjà à l’année. Le coliving d’août, c’est l’ouverture de ce mode de vie à douze entrepreneurs par semaine.</p>
        <div class="grid grid-cols-3 gap-4 mt-9">
          {[{v:'21 ha',l:'de domaine'},{v:'Plusieurs',l:'années de vie sur place'},{v:'Résidents',l:'à l’année'}].map((c) => (
            <div class="rounded-2xl border border-[#412F1F]/12 p-5 text-center">
              <p class="font-extrabold text-[#9A3922] text-xl md:text-2xl leading-tight mb-1">{c.v}</p>
              <p class="text-xs text-[#1D1B18]/55 leading-snug">{c.l}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ⑤ UNE JOURNÉE — défile au scroll -->
  <section id="journee" class="bg-[#F2EBDB] py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6 md:px-10">
      <div class="text-center mb-14">
        <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-5">Une journée type</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.08] text-balance">Du premier souffle <span class="acc">à la dernière étoile.</span></h2>
      </div>
      <div class="jt">
        <span class="jt-rail"></span>
        <span class="jt-fill" id="jtfill"></span>
        <ol>
          {journee.map((it) => (
            <li class="jt-item">
              <span class="jt-dot"></span>
              <span class="jt-time">{it.time}</span>
              <p class="jt-label">{it.label}</p>
            </li>
          ))}
        </ol>
      </div>
      <p class="text-center text-sm text-[#1D1B18]/55 mt-12 max-w-md mx-auto">Rien n’est obligatoire. Tout est proposé. Tu fais ta semaine à ton rythme.</p>
    </div>
  </section>

  <!-- ⑥ LE LIEU -->
  <div animate-fade-in-up class="opacity-0">
    <MosaicGallery bg="bg-[#FBF6EA]"
      eyebrow="Le lieu"
      title="Vingt-et-un hectares," accent="et plus rien autour."
      intro="Un ancien domaine agricole à 1h30 de Montpellier. Des tipis dans l’herbe, une rivière où se baigner, un potager qui nourrit la table. Et la nuit, un ciel sans pollution lumineuse où la voie lactée se voit à l’œil nu."
      images={[
        { src: '/images/vue-aeriene-laom2-hero.webp', alt: 'Vue aérienne du domaine LAOM' },
        { src: L('lieu-shala-tipis'), alt: 'Le shala et les tipis de LAOM' },
        { src: L('riviere-laom'), alt: 'La rivière du domaine' },
        { src: L('potager-rangs'), alt: 'Le potager de LAOM' },
        { src: L('diner-golden-hour-laom'), alt: 'Dîner en communauté à LAOM' },
      ]}
      ctaText="Postuler pour août 2026" ctaHref={POSTULER} />
  </div>

  <!-- ⑦ TRAVAILLER AUTREMENT -->
  <div animate-fade-in-up class="opacity-0">
    <MediaText bg="bg-[#F2EBDB]" img={L('coworking-duo-table')} alt="Entrepreneurs au travail à LAOM, face à la vallée"
      eyebrow="Le travail"
      title="Ton activité ne s’arrête pas." accent="Elle respire."
      text="Ici, tu travailles. Le Shala est un vrai espace de coworking, wifi fibre, au calme, la vallée pour fond d’écran. Tu prends tes calls, tu avances tes projets. La seule différence, c’est qu’entre deux sessions tu plonges dans la rivière au lieu de scroller. Tu ne perds pas une semaine de business. Tu en gagnes la clarté pour les six mois qui suivent." />
  </div>

  <!-- ⑦bis RESPIRATION — fond vidéo immersif -->
  <section class="relative overflow-hidden text-[#F2EBDB]">
    <video autoplay muted loop playsinline poster="/images/hero-laom-poster-v2.webp" class="absolute inset-0 w-full h-full object-cover">
      <source src="/videos/sec-domaine-2.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(29,27,24,0.5),rgba(29,27,24,0.72))"></div>
    <div class="relative max-w-3xl mx-auto px-6 py-28 md:py-40 text-center">
      <h2 class="text-4xl md:text-6xl font-extrabold text-[#F2EBDB] tracking-[-0.02em] leading-[1.05] text-balance">Imagine ton lundi matin, <span class="italic font-medium text-[#E7C89A]">ici.</span></h2>
      <p class="text-lg md:text-xl text-[#F2EBDB]/85 mt-6 max-w-xl mx-auto leading-relaxed">Le café face à la vallée, le calme, et tout à créer. Pendant que les autres reprennent le métro.</p>
      <a href={POSTULER} class="pill pill-light mt-9" style="padding:.95rem 2.4rem">Postuler pour août 2026</a>
    </div>
  </section>

  <!-- ⑧ TÉMOIGNAGES — carrousel infini -->
  <section class="bg-[#FBF6EA] py-20 md:py-28 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14 mb-12 text-center">
      <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-5">Ils l’ont vécu</p>
      <h2 class="text-4xl md:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.08] text-balance">Ce qu’ils en <span class="acc">disent.</span></h2>
    </div>
    <div class="marquee">
      <div class="marquee-track">
        {[...temoins, ...temoins].map((t) => (
          <figure class="tcard">
            <blockquote class="text-[#1D1B18]/85 leading-relaxed italic">“{t.quote}”</blockquote>
            <figcaption class="flex items-center gap-3 mt-5">
              <span class="w-10 h-10 rounded-full bg-[#9A3922] text-[#F2EBDB] grid place-items-center text-sm font-bold shrink-0">{initiales(t.name)}</span>
              <span class="leading-tight"><span class="block text-sm font-bold text-[#412F1F]">{t.name}</span><span class="block text-xs text-[#73673E]">{t.role}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑨ EST-CE FAIT POUR TOI — qualification sur photo sombre -->
  <section animate-fade-in-up class="opacity-0 relative overflow-hidden">
    <img src={L('festival-laom-ambiance-nature-aveyron')} alt="" loading="lazy" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0" style="background:rgba(29,27,24,0.82)"></div>
    <div class="relative max-w-6xl mx-auto px-6 md:px-10 lg:px-14 py-24 md:py-32 text-[#F2EBDB]">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#E7C89A] mb-5">Pour qui</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#F2EBDB] tracking-[-0.02em] leading-[1.06] text-balance">Est-ce que cette semaine est <span class="italic font-medium text-[#E7C89A]">faite pour toi ?</span></h2>
        <p class="text-lg text-[#F2EBDB]/75 mt-5 leading-relaxed">LAOM n’est pas pour tout le monde. Et c’est tant mieux. Voici comment savoir si c’est ton moment.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-5 md:gap-6">
        <div class="rounded-3xl bg-[#9A3922] p-8 md:p-9">
          <p class="flex items-center gap-3 text-xl font-extrabold mb-6"><span class="w-7 h-7 rounded-full bg-[#F2EBDB] text-[#9A3922] grid place-items-center"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>C’est pour toi si…</p>
          <ul class="space-y-3.5 text-[#F2EBDB]/90">
            {['Tu portes déjà un projet qui avance, pas une idée sur le papier','Tu veux changer de cadre sans mettre ton activité en pause','Tu cherches des pairs qui comprennent vraiment ta réalité','Tu sens que ton rythme n’est plus tenable et tu veux le bouger'].map((i) => <li class="leading-relaxed">{i}</li>)}
          </ul>
        </div>
        <div class="rounded-3xl bg-[#2A1E14] border border-[#F2EBDB]/10 p-8 md:p-9">
          <p class="flex items-center gap-3 text-xl font-extrabold text-[#F2EBDB]/80 mb-6"><span class="w-7 h-7 rounded-full bg-[#F2EBDB]/15 grid place-items-center"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></span>Ce n’est pas pour toi si…</p>
          <ul class="space-y-3.5 text-[#F2EBDB]/60">
            {['Tu cherches des vacances tout-inclus','Tu en es encore à chercher ton idée ou à la lancer','Tu veux tout couper et ne rien faire','Tu cherches une formation business'].map((i) => <li class="leading-relaxed">{i}</li>)}
          </ul>
        </div>
      </div>
      <div class="text-center mt-12">
        <a href={POSTULER} class="pill pill-light" style="padding:.95rem 2.4rem">Voir si j’ai ma place</a>
      </div>
    </div>
  </section>

  <!-- ⑩ LES FONDATEURS -->
  <div animate-fade-in-up class="opacity-0">
    <MediaText bg="bg-[#F2EBDB]" reverse={true} img={L('charly-amandine-rire')} alt="Charly et Amandine, fondateurs de LAOM"
      eyebrow="Les hôtes"
      title="Charly & Amandine," accent="le lieu, c’est eux."
      text="Ils ont quitté la ville, acheté vingt-et-un hectares dans le sud de l’Aveyron, et bâti de leurs mains le lieu qu’ils auraient voulu trouver. LAOM, c’est leur projet de vie. Le coliving, c’est leur façon de t’inviter à le vivre." />
  </div>

  <!-- ⑪ L'OFFRE + LE PROCESS (scroll-stack), sans prix -->
  <section class="bg-[#FBF6EA] py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 md:px-10 lg:px-14">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-5">L’offre</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.08] text-balance">Une semaine. Douze entrepreneurs. <span class="acc">Tout compris.</span></h2>
        <p class="text-lg text-[#1D1B18]/70 mt-6 leading-relaxed">Hébergement en tipi, repas du potager, pratiques du matin, ateliers, soirées, espace de travail wifi fibre. Le détail complet du programme, les dates et le tarif, on te les raconte de vive voix.</p>
      </div>

      <p class="text-sm uppercase tracking-[0.18em] font-semibold text-[#73673E] mt-20 mb-8 text-center">Comment ça se passe</p>
      <div class="pstack max-w-2xl mx-auto">
        {etapes.map((s, i) => (
          <article class="pstack-card bg-white border border-[#412F1F]/10 rounded-3xl p-8 md:p-10 flex items-center gap-7 shadow-[0_22px_44px_-26px_rgba(65,47,31,0.4)]" style={`--i:${i}`}>
            <p class="text-5xl md:text-6xl font-extrabold text-[#9A3922] leading-none shrink-0">{s.n}</p>
            <p class="text-lg text-[#412F1F] leading-relaxed">{s.t}</p>
          </article>
        ))}
      </div>

      <div class="text-center mt-14">
        <a href={POSTULER} class="pill pill-primary" style="padding:.95rem 2.4rem">Postuler pour août 2026</a>
        <p class="text-sm text-[#1D1B18]/55 mt-5">Candidature en 2 minutes. Pas de pitch, pas de pression.</p>
      </div>
    </div>
  </section>

  <!-- ⑫ FAQ -->
  <div animate-fade-in-up class="opacity-0">
    <Faq bg="bg-[#F2EBDB]"
      eyebrow="Questions fréquentes"
      title="Ce qu’on te demande" accent="le plus souvent."
      items={[
        { q: 'Une semaine, c’est long, et mes clients ?', a: 'Ton activité continue : wifi fibre, espaces de travail, tu organises ton temps comme tu veux. Ce n’est pas une parenthèse où tu coupes tout, c’est ton rythme et ton environnement qui changent.' },
        { q: 'L’Aveyron, c’est loin ?', a: 'On est en sud Aveyron, à 1h30 de Montpellier (gare TGV) et 2h de Toulouse. On s’occupe de ton arrivée. Et c’est précisément cette distance qui fait la valeur du lieu.' },
        { q: 'C’est pas un truc trop perché ?', a: 'Non. Un lieu exigeant, des entrepreneurs sérieux, et rien d’obligatoire : tu prends ce qui te parle, tu laisses le reste.' },
        { q: 'Il y aura qui d’autre ?', a: 'Douze personnes par semaine, choisies via le formulaire, avec des profils proches du tien. On te parle de la cohorte au téléphone.' },
        { q: 'Et le tarif ?', a: 'On t’en parle pendant l’échange de 15 minutes, en même temps que le programme et les dates. C’est un prix de lancement, tout compris.' },
      ]} />
  </div>

  <!-- ⑬ CTA FINAL -->
  <div animate-fade-in-up class="opacity-0">
    <CtaImage bg="bg-[#FBF6EA]" img={L('diner-golden-hour-laom')}
      eyebrow="Août 2026"
      title="Trois semaines. Douze places chacune." accent="Quand c’est complet, c’est complet."
      subtitle="Dates : 10-16, 17-23 et 24-30 août 2026. Douze places par édition, et elles partent vite. Le reste, on en parle ensemble."
      primaryText="Postuler pour août 2026" primaryHref={POSTULER} />
  </div>

  <SiteFooter />

  <StickyCta text="Postuler" href={POSTULER} />
</Layout>

<style>
  .marquee { display: flex; overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .marquee-track { display: flex; gap: 1.25rem; padding: 0 0.625rem; width: max-content; animation: tmarquee 42s linear infinite; }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  @keyframes tmarquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .tcard { flex: 0 0 330px; background: #fff; border: 0.5px solid rgba(65,47,31,0.1); border-radius: 1.25rem; padding: 1.5rem 1.6rem; }

  .jt { position: relative; }
  .jt ol { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.9rem; }
  .jt-rail, .jt-fill { position: absolute; left: 11px; top: 6px; bottom: 6px; width: 2px; border-radius: 2px; }
  .jt-rail { background: rgba(65,47,31,0.14); }
  .jt-fill { bottom: auto; height: 0; background: #9A3922; transition: height 0.12s linear; }
  .jt-item { position: relative; padding-left: 44px; opacity: 0.32; transform: translateY(8px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .jt-item.in { opacity: 1; transform: none; }
  .jt-dot { position: absolute; left: 4px; top: 5px; width: 16px; height: 16px; border-radius: 50%; background: #F2EBDB; border: 2px solid rgba(65,47,31,0.25); transition: border-color 0.4s ease, background 0.4s ease; }
  .jt-item.in .jt-dot { border-color: #9A3922; background: #9A3922; }
  .jt-time { display: block; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em; color: #9A3922; }
  .jt-label { margin-top: 2px; font-size: 1.05rem; color: #412F1F; }

  .pstack-card { position: sticky; top: calc(116px + var(--i, 0) * 16px); }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
    .pstack-card { position: static; }
    .jt-item { opacity: 1; transform: none; }
  }
</style>

<script>
  const sec = document.getElementById('journee')
  const fill = document.getElementById('jtfill')
  const jt = sec && sec.querySelector('.jt')
  if (sec && fill && jt) {
    const items = sec.querySelectorAll('.jt-item')
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in') })
    }, { threshold: 0.5 })
    items.forEach((i) => io.observe(i))
    const onScroll = () => {
      const r = jt.getBoundingClientRect()
      const p = Math.min(Math.max((window.innerHeight * 0.55 - r.top) / r.height, 0), 1)
      fill.style.height = (p * 100) + '%'
    }
    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('resize', onScroll)
  }
</script>
