// ==========================================
// CHARGE DE TRAVAIL
// ==========================================
const chargeCharly = [
  { tache: 'Post LinkedIn', frequence: '1/semaine', temps: '2h', total: '8h/mois' },
  { tache: 'Vidéo YouTube', frequence: '2/mois', temps: '6h', total: '12h/mois' },
  { tache: 'Review e-books', frequence: 'Ponctuel', temps: '2h/e-book', total: '6h total' },
  { tache: 'Calls prospects', frequence: 'Variable', temps: '30min/call', total: '~4h/mois' },
]

const chargeAmandine = [
  { tache: 'Post LinkedIn', frequence: '1/semaine', temps: '2h', total: '8h/mois' },
  { tache: 'Newsletter', frequence: '1/semaine', temps: '3h', total: '12h/mois' },
  { tache: 'Web-série montage', frequence: '1/semaine', temps: '4h', total: '16h/mois' },
  { tache: 'Rédaction e-books', frequence: 'Ponctuel', temps: '10h/e-book', total: '30h total' },
  { tache: 'Gestion tunnels/ads', frequence: 'Continue', temps: '2h/sem', total: '8h/mois' },
  { tache: 'Réflexion contenu EN', frequence: 'À partir sept', temps: '2h/sem', total: '8h/mois' },
]

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}
---

<Layout
  title="Stratégie Marketing & Acquisition 2026 — LAOM"
  description="Document de travail interne — Stratégie marketing et acquisition 2026"
  seo={{ noindex: true, nofollow: true }}
>

  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#C4A855]/10 border border-[#C4A855]/20 mb-6">
          <svg class="w-8 h-8 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Espace associés</h2>
        <p class="text-white/50 text-sm">Document de travail réservé aux associés LAOM</p>
      </div>
      
      <form id="password-form" class="space-y-4">
        <input 
          type="password" 
          id="password-input"
          placeholder="Mot de passe"
          class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#C4A855]/50 focus:ring-1 focus:ring-[#C4A855]/30 transition-all"
          autocomplete="off"
        />
        <button 
          type="submit"
          class="w-full px-6 py-4 rounded-sm bg-[#C4A855] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#B09A4A] transition-colors"
        >
          Accéder
        </button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <!-- Navbar interne -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#1a1a1a] border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16 h-14 flex items-center justify-between">
      <a href="/" class="text-white/50 hover:text-white text-sm font-light transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Retour</span>
      </a>
      <div class="flex items-center gap-1">
        <span class="hidden md:inline text-xs font-light tracking-[0.15em] uppercase text-white/30 mr-4">Espace associes</span>
        <a href="/previsionnel-2026" class="px-3 sm:px-4 py-2 text-xs sm:text-sm font-light text-white/50 hover:text-white hover:bg-white/5 rounded-sm transition-colors">
          Previ.
        </a>
        <a href="/strategie-2026" class="px-3 sm:px-4 py-2 text-xs sm:text-sm font-light text-white bg-white/10 rounded-sm">
          Strat.
        </a>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-24 sm:pt-32 pb-12 sm:pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-light tracking-[0.2em] uppercase text-white/40">Document de travail</span>
        <span class="text-white/20">·</span>
        <span class="text-xs font-light text-white/40">Non référencé</span>
      </div>
      <h1 class="font-playfair text-4xl md:text-5xl font-medium text-white mb-4 tracking-tight">
        Stratégie Marketing & Acquisition
      </h1>
      <p class="text-lg font-light text-white/60 max-w-2xl">
        Plan d'acquisition 2026 — Canaux organiques, tunnels payants, calendrier éditorial
      </p>
      
      <!-- Quick stats -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6 mt-12 pt-8 border-t border-white/10">
        <div>
          <p class="font-playfair text-3xl font-medium text-[#C4A855]">3</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Offres</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-white">4</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Canaux</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-white">3</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Tunnels</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-white">{formatNumber(budgetAdsTotal)}€</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Budget ads</p>
        </div>
        <div>
          <p class="font-playfair text-3xl font-medium text-[#4A7C59]">{formatNumber(caTotal)}€</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">CA potentiel</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: Les offres -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono tracking-[0.15em] uppercase text-[#C4A855]">01</span>
        <h2 class="font-playfair text-2xl font-medium text-[#2C2824]">Les offres à vendre</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {offres.map((offre) => (
          <div class="border border-[#2C2824]/10 rounded-sm overflow-hidden">
            <div class="p-6" style={`border-top: 3px solid ${offre.couleur}`}>
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-2">{offre.sessions} session{offre.sessions > 1 ? 's' : ''}</p>
              <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-1">{offre.nom}</h3>
              <p class="text-sm font-light text-[#2C2824]/50 mb-4">{offre.description}</p>
              
              <div class="flex items-baseline gap-2 mb-4">
                <span class="font-playfair text-3xl font-medium text-[#2C2824]">{formatNumber(offre.prix)}</span>
                <span class="text-sm font-light text-[#2C2824]/40">€/pers</span>
              </div>

              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-[#2C2824]/50">Places totales</span>
                  <span class="font-medium text-[#2C2824]">{offre.places}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#2C2824]/50">Objectif remplissage</span>
                  <span class="font-medium text-[#2C2824]">{offre.tauxRemplissage}%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#2C2824]/50">CA attendu</span>
                  <span class="font-medium" style={`color: ${offre.couleur}`}>{formatNumber(offre.prix * offre.places * offre.tauxRemplissage / 100)}€</span>
                </div>
              </div>

              <div class="mt-4 pt-4 border-t border-[#2C2824]/5">
                <p class="text-xs font-light text-[#2C2824]/40 uppercase tracking-wider mb-2">Dates</p>
                <div class="flex flex-wrap gap-2">
                  {offre.dates.map((d) => (
                    <span class="text-xs font-light text-[#2C2824]/70 bg-[#FAF8F5] px-2 py-1 rounded-sm">{d}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 p-6 bg-[#FAF8F5] rounded-sm">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <p class="text-sm font-light text-[#2C2824]/50">CA potentiel total (avec taux de remplissage)</p>
            <p class="font-playfair text-3xl font-medium text-[#2C2824]">{formatNumber(caTotal)} €</p>
          </div>
          <div class="text-right">
            <p class="text-sm font-light text-[#2C2824]/50">Répartition</p>
            <p class="text-sm font-light text-[#2C2824]/70">
              Clarté {Math.round(24000/caTotal*100)}% · School {Math.round(24000/caTotal*100)}% · Mouvement {Math.round(49500/caTotal*100)}%
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Canaux d'acquisition -->
  <section class="py-12 sm:py-16 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono tracking-[0.15em] uppercase text-[#C4A855]">02</span>
        <h2 class="font-playfair text-2xl font-medium text-[#2C2824]">Canaux d'acquisition organique</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- LinkedIn -->
        <div class="bg-white p-8 rounded-sm border border-[#2C2824]/5">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-[#0A66C2]/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-playfair text-lg font-medium text-[#2C2824]">LinkedIn</h3>
              <p class="text-xs font-light text-[#2C2824]/50">Charly + Amandine</p>
            </div>
          </div>

          <div class="space-y-4 mb-6">
            <div class="flex items-center justify-between py-3 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Fréquence</span>
              <span class="text-sm font-medium text-[#2C2824]">2 posts/semaine (1 chacun)</span>
            </div>
            <div class="flex items-center justify-between py-3 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Total mensuel</span>
              <span class="text-sm font-medium text-[#2C2824]">8 posts</span>
            </div>
          </div>

          <div class="space-y-3">
            <p class="text-xs font-light tracking-[0.15em] uppercase text-[#2C2824]/40">Stratégie TOFU/MOFU/BOFU</p>
            <div class="grid grid-cols-3 gap-2 text-center">
              <div class="bg-[#FAF8F5] p-3 rounded-sm">
                <p class="text-xs font-medium text-[#2C2824]">TOFU</p>
                <p class="text-[10px] text-[#2C2824]/50 mt-1">Découvrabilité</p>
                <p class="text-lg font-medium text-[#C4A855] mt-2">2/mois</p>
              </div>
              <div class="bg-[#FAF8F5] p-3 rounded-sm">
                <p class="text-xs font-medium text-[#2C2824]">MOFU</p>
                <p class="text-[10px] text-[#2C2824]/50 mt-1">Expertise</p>
                <p class="text-lg font-medium text-[#C4A855] mt-2">1/mois</p>
              </div>
              <div class="bg-[#FAF8F5] p-3 rounded-sm">
                <p class="text-xs font-medium text-[#2C2824]">BOFU</p>
                <p class="text-[10px] text-[#2C2824]/50 mt-1">Conversion</p>
                <p class="text-lg font-medium text-[#C4A855] mt-2">1/mois</p>
              </div>
            </div>
          </div>

          <div class="mt-6 pt-6 border-t border-[#2C2824]/5">
            <p class="text-xs font-light text-[#2C2824]/50 mb-3">Thèmes Charly</p>
            <p class="text-sm text-[#2C2824]/70">PARA, IA, multi-projets, autoconstruction, entrepreneuriat</p>
            <p class="text-xs font-light text-[#2C2824]/50 mt-4 mb-3">Thèmes Amandine</p>
            <p class="text-sm text-[#2C2824]/70">Storytelling LAOM, behind the scenes, vie collective, parentalité</p>
          </div>
        </div>

        <!-- Instagram -->
        <div class="bg-white p-8 rounded-sm border border-[#2C2824]/5">
          <div class="flex items-center gap-3 mb-6">
