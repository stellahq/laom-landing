      { nom: 'Optimisation', duree: '16-31 mars', budget: 400, objectif: 'Améliorer CPL < 5€' },
      { nom: 'Scale', duree: '1-17 avril', budget: 600, objectif: 'Remplir avant Clarté' },
    ],
    budgetTotal: 1300,
    objectifLeads: 260,
    objectifVentes: 10,
  },
  {
    nom: 'LAOM School',
    ebook: 'Le business model qui peut sauver les écolieux',
    ebookPages: '20-25 pages',
    ebookContenu: ['Analyse des modèles qui échouent', 'Le modèle SCIA expliqué', 'Checklist juridique'],
    phases: [
      { nom: 'Test A/B', duree: '1-15 avril', budget: 300, objectif: 'Trouver la meilleure créa' },
      { nom: 'Optimisation', duree: '16-30 avril', budget: 400, objectif: 'Améliorer CPL < 5€' },
      { nom: 'Scale #1', duree: '1-7 mai', budget: 500, objectif: 'Remplir School #1' },
      { nom: 'Relance', duree: 'Sept-Oct', budget: 500, objectif: 'Remplir School #2' },
    ],
    budgetTotal: 1700,
    objectifLeads: 340,
    objectifVentes: 15,
  },
  {
    nom: 'En Mouvement',
    ebook: 'Libérer ton corps : la science derrière le mouvement conscient',
    ebookPages: '15-20 pages',
    ebookContenu: ['Études scientifiques danse & trauma', 'Témoignages participants', 'Exercices à faire chez soi'],
    phases: [
      { nom: 'Test A/B', duree: '1-15 juin', budget: 300, objectif: 'Trouver la meilleure créa' },
      { nom: 'Optimisation', duree: '16-30 juin', budget: 400, objectif: 'Améliorer CPL < 5€' },
      { nom: 'Scale', duree: '1 juil - 5 août', budget: 800, objectif: 'Remplir les 3 sessions' },
    ],
    budgetTotal: 1500,
    objectifLeads: 300,
    objectifVentes: 20,
  },
]

const budgetAdsTotal = tunnels.reduce((acc, t) => acc + t.budgetTotal, 0)
const ventesAttendue = tunnels.reduce((acc, t) => acc + t.objectifVentes, 0)

// ==========================================
// WEB-SÉRIE INSTAGRAM
// ==========================================
const webSerie = [
  { ep: 1, titre: 'L\'impulsion', desc: 'Pourquoi ce projet fou' },
  { ep: 2, titre: 'La découverte', desc: 'Le terrain en Aveyron' },
  { ep: 3, titre: 'Le saut', desc: 'L\'achat du domaine' },
