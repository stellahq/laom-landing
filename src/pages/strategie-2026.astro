---
import Layout from '~/layouts/Layout.astro'

export const prerender = true

// ==========================================
// OFFRES 2026
// ==========================================
const offres = [
  { 
    nom: 'Clarte', 
    prix: 1000, 
    places: 24, 
    sessions: 2, 
    dates: ['17-19 avril', '25-27 avril'],
    tauxRemplissage: 100,
    description: 'Vision + PARA + Claude Code',
    couleur: '#C4A855'
  },
  { 
    nom: 'LAOM School', 
    prix: 1000, 
    places: 30, 
    sessions: 2, 
    dates: ['8-10 mai', '16-18 octobre'],
    tauxRemplissage: 80,
    description: 'Creer son ecolieu',
    couleur: '#2C2824'
  },
  { 
    nom: 'En Mouvement', 
    prix: 1100, 
    places: 45, 
    sessions: 3, 
    dates: ['5-9 aout', '11-15 aout', '16-20 aout'],
    tauxRemplissage: 100,
    description: 'Immersion danse',
    couleur: '#4A7C59'
  },
]

const caTotal = offres.reduce((acc, o) => acc + (o.prix * o.places * o.tauxRemplissage / 100), 0)

// ==========================================
// TUNNELS D'ACQUISITION - NOUVELLE STRATEGIE
// CPL cible: 2,50-3€ max
// Tripwire payant pour break-even
// Budget continu tant que rentable
// ==========================================
const tunnels = [
  {
    nom: 'Clarte',
    tripwire: 'Le systeme PARA',
    prixTripwire: 7,
    cplCible: 2.50,
    budgetMensuel: 400,
    debutTunnel: 'Fevrier 2026',
    objectifLeadsMois: 160,
    couleur: '#C4A855'
  },
  {
    nom: 'LAOM School',
    tripwire: 'Business model ecolieux',
    prixTripwire: 9,
    cplCible: 3.00,
    budgetMensuel: 400,
    debutTunnel: 'Mars 2026',
    objectifLeadsMois: 130,
    couleur: '#2C2824'
  },
  {
    nom: 'En Mouvement',
    tripwire: 'Science du mouvement',
    prixTripwire: 7,
    cplCible: 2.50,
    budgetMensuel: 400,
    debutTunnel: 'Mai 2026',
    objectifLeadsMois: 160,
    couleur: '#4A7C59'
  },
]

const budgetAdsMensuel = tunnels.reduce((acc, t) => acc + t.budgetMensuel, 0)

// Projection leads par mois (simplifie)
const leadsParMois = [
  { mois: 'Fev', clarte: 160, school: 0, mvt: 0 },
  { mois: 'Mars', clarte: 160, school: 130, mvt: 0 },
  { mois: 'Avr', clarte: 160, school: 130, mvt: 0 },
  { mois: 'Mai', clarte: 160, school: 130, mvt: 160 },
  { mois: 'Juin', clarte: 160, school: 130, mvt: 160 },
  { mois: 'Juil', clarte: 160, school: 130, mvt: 160 },
  { mois: 'Aout', clarte: 160, school: 130, mvt: 160 },
]

const totalLeads = leadsParMois.reduce((acc, m) => acc + m.clarte + m.school + m.mvt, 0)

// ==========================================
// CHARGE DE TRAVAIL - MISE A JOUR
// Amandine: 20h/semaine = 80h/mois
// ==========================================
const chargeCharly = [
  { tache: 'Posts LinkedIn', frequence: '4/semaine', temps: '30min', total: '8h/mois' },
  { tache: 'Videos YouTube (offres)', frequence: '2/mois', temps: '6h', total: '12h/mois' },
  { tache: 'Review e-books', frequence: 'Ponctuel', temps: '2h/e-book', total: '6h total' },
  { tache: 'Calls prospects', frequence: 'Variable', temps: '30min/call', total: '~4h/mois' },
]

const chargeAmandine = [
  { tache: 'Posts LinkedIn', frequence: '4/semaine', temps: '1h', total: '16h/mois' },
  { tache: 'Newsletter', frequence: '1/semaine', temps: '2h', total: '8h/mois' },
  { tache: 'Web-serie (script+montage)', frequence: '1/semaine', temps: '4h', total: '16h/mois' },
  { tache: 'YouTube vlogs (montage)', frequence: '2/mois', temps: '4h', total: '8h/mois' },
  { tache: 'Gestion tunnels/ads', frequence: 'Continue', temps: '2h/sem', total: '8h/mois' },
  { tache: 'E-books (ponctuel)', frequence: '3 total', temps: '10h/e-book', total: '~3h/mois' },
]

const totalChargeAmandine = 56 // heures recurrentes
const margeAmandine = 80 - totalChargeAmandine // 24h de marge

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}
---

<Layout
  title="Strategie Marketing & Acquisition 2026 — LAOM"
  description="Document de travail interne — Strategie marketing et acquisition 2026"
  seo={{ noindex: true, nofollow: true }}
>

  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#C4A855]/10 border border-[#C4A855]/20 mb-6">
          <svg class="w-8 h-8 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Espace associes</h2>
        <p class="text-white/50 text-sm">Document de travail reserve aux associes LAOM</p>
      </div>
      
      <form id="password-form" class="space-y-4">
        <input 
          type="password" 
          id="password-input"
          placeholder="Mot de passe"
          class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#C4A855]/50 focus:ring-1 focus:ring-[#C4A855]/30 transition-all"
          autocomplete="off"
        />
        <button 
          type="submit"
          class="w-full px-6 py-4 rounded-sm bg-[#C4A855] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#B09A4A] transition-colors"
        >
          Acceder
        </button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <!-- Navbar interne -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#1a1a1a] border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16 h-14 flex items-center justify-between">
      <a href="/" class="text-white/50 hover:text-white text-sm font-light transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Retour</span>
      </a>
      <div class="flex items-center gap-1">
        <span class="hidden md:inline text-xs font-light tracking-[0.15em] uppercase text-white/30 mr-4">Espace associes</span>
        <a href="/previsionnel-2026" class="px-3 sm:px-4 py-2 text-xs sm:text-sm font-light text-white/50 hover:text-white hover:bg-white/5 rounded-sm transition-colors">
          Previ.
        </a>
        <a href="/strategie-2026" class="px-3 sm:px-4 py-2 text-xs sm:text-sm font-light text-white bg-white/10 rounded-sm">
          Strat.
        </a>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-24 sm:pt-32 pb-12 sm:pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-light tracking-[0.2em] uppercase text-white/40">Document de travail</span>
        <span class="text-white/20">·</span>
        <span class="text-xs font-light text-white/40">4 fevrier 2026</span>
      </div>
      <h1 class="font-playfair text-4xl md:text-5xl font-medium text-white mb-4 tracking-tight">
        Strategie Marketing 2026
      </h1>
      <p class="text-lg font-light text-white/60 max-w-2xl">
        Plan d'acquisition — Canaux organiques, tunnels payants, calendrier editorial
      </p>
      
      <!-- Quick stats -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 sm:gap-6 mt-12 pt-8 border-t border-white/10">
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-[#C4A855]">3</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Offres</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-white">4</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Canaux</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-white">{formatNumber(totalLeads)}</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Leads cibles</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-white">{formatNumber(budgetAdsMensuel)}€</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">Budget/mois</p>
        </div>
        <div>
          <p class="font-playfair text-2xl sm:text-3xl font-medium text-[#4A7C59]">{formatNumber(caTotal)}€</p>
          <p class="text-xs font-light text-white/40 uppercase tracking-wider mt-1">CA potentiel</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: Les offres -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono tracking-[0.15em] uppercase text-[#C4A855]">01</span>
        <h2 class="font-playfair text-2xl font-medium text-[#2C2824]">Les offres a vendre</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {offres.map((offre) => (
          <div class="border border-[#2C2824]/10 rounded-sm overflow-hidden">
            <div class="p-6" style={`border-top: 3px solid ${offre.couleur}`}>
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-2">{offre.sessions} session{offre.sessions > 1 ? 's' : ''}</p>
              <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-1">{offre.nom}</h3>
              <p class="text-sm text-[#2C2824]/60 mb-4">{offre.description}</p>
              
              <div class="flex items-baseline gap-1 mb-4">
                <span class="font-playfair text-2xl font-medium text-[#2C2824]">{formatNumber(offre.prix)}€</span>
                <span class="text-sm text-[#2C2824]/40">/pers</span>
              </div>

              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-[#2C2824]/60">Places</span>
                  <span class="font-medium text-[#2C2824]">{offre.places}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#2C2824]/60">Taux cible</span>
                  <span class="font-medium text-[#2C2824]">{offre.tauxRemplissage}%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#2C2824]/60">CA potentiel</span>
                  <span class="font-medium" style={`color: ${offre.couleur}`}>{formatNumber(offre.prix * offre.places * offre.tauxRemplissage / 100)}€</span>
                </div>
              </div>

              <div class="mt-4 pt-4 border-t border-[#2C2824]/10 flex flex-wrap gap-2">
                {offre.dates.map((d) => (
                  <span class="text-xs font-light text-[#2C2824]/70 bg-[#FAF8F5] px-2 py-1 rounded-sm">{d}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 2: Canaux d'acquisition organique -->
  <section class="py-12 sm:py-16 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-xs font-mono tracking-[0.15em] uppercase text-[#C4A855]">02</span>
        <h2 class="font-playfair text-2xl font-medium text-[#2C2824]">Canaux d'acquisition organique</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- LinkedIn -->
        <div class="bg-white p-6 sm:p-8 rounded-sm border border-[#2C2824]/5">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-[#0A66C2]/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-playfair text-lg font-medium text-[#2C2824]">LinkedIn</h3>
              <p class="text-xs font-light text-[#2C2824]/50">Charly + Amandine</p>
            </div>
          </div>

          <div class="space-y-3 mb-6">
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Frequence</span>
              <span class="text-sm font-medium text-[#2C2824]">8 posts/semaine (4 chacun)</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Total mensuel</span>
              <span class="text-sm font-medium text-[#0A66C2]">32 posts</span>
            </div>
          </div>

          <div class="bg-[#FAF8F5] p-4 rounded-sm mb-6">
            <p class="text-xs font-light text-[#2C2824]/50 mb-2">Strategie</p>
            <p class="text-sm text-[#2C2824]/70">TOFU/MOFU/BOFU aligne sur calendrier des offres. Charly = expertise. Amandine = storytelling.</p>
          </div>

          <a href="/strategie-2026/linkedin" class="flex items-center justify-center gap-2 w-full py-3 bg-[#0A66C2]/10 hover:bg-[#0A66C2]/20 text-[#0A66C2] text-sm font-medium rounded-sm transition-colors">
            Voir le backlog
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Instagram -->
        <div class="bg-white p-6 sm:p-8 rounded-sm border border-[#2C2824]/5">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#833AB4] via-[#FD1D1D] to-[#FCAF45] flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-playfair text-lg font-medium text-[#2C2824]">Instagram</h3>
              <p class="text-xs font-light text-[#2C2824]/50">Web-serie LAOM</p>
            </div>
          </div>

          <div class="space-y-3 mb-6">
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Format</span>
              <span class="text-sm font-medium text-[#2C2824]">Reels 30-90s</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Frequence</span>
              <span class="text-sm font-medium text-[#2C2824]">1 episode/semaine</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Episodes</span>
              <span class="text-sm font-medium text-[#E1306C]">30+ episodes (5 actes)</span>
            </div>
          </div>

          <div class="bg-[#FAF8F5] p-4 rounded-sm mb-6">
            <p class="text-xs font-light text-[#2C2824]/50 mb-2">Concept</p>
            <p class="text-sm text-[#2C2824]/70">L'histoire de LAOM de 2021 a 2026. Arc narratif complet avec hauts et bas. CTA newsletter.</p>
          </div>

          <a href="/strategie-2026/instagram" class="flex items-center justify-center gap-2 w-full py-3 bg-gradient-to-r from-[#833AB4]/10 to-[#FCAF45]/10 hover:from-[#833AB4]/20 hover:to-[#FCAF45]/20 text-[#E1306C] text-sm font-medium rounded-sm transition-colors">
            Voir la web-serie
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- YouTube -->
        <div class="bg-white p-6 sm:p-8 rounded-sm border border-[#2C2824]/5">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-[#FF0000]/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#FF0000]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-playfair text-lg font-medium text-[#2C2824]">YouTube</h3>
              <p class="text-xs font-light text-[#2C2824]/50">Charly Aubert</p>
            </div>
          </div>

          <div class="space-y-3 mb-6">
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Frequence</span>
              <span class="text-sm font-medium text-[#FF0000]">4 videos/mois</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Mix</span>
              <span class="text-sm font-medium text-[#2C2824]">2 offres + 2 vlogs</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-sm text-[#2C2824]/70">Total</span>
              <span class="text-sm font-medium text-[#2C2824]">28 videos (7 mois)</span>
            </div>
          </div>

          <div class="bg-[#FAF8F5] p-4 rounded-sm mb-6">
            <p class="text-xs font-light text-[#2C2824]/50 mb-2">Strategie</p>
            <p class="text-sm text-[#2C2824]/70">Videos offres = valeur standalone + lien event. Vlogs = behind the scenes, chantier, vie LAOM.</p>
          </div>

          <a href="/strategie-2026/youtube" class="flex items-center justify-center gap-2 w-full py-3 bg-[#FF0000]/10 hover:bg-[#FF0000]/20 text-[#FF0000] text-sm font-medium rounded-sm transition-colors">
            Voir le planning
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Newsletter -->
