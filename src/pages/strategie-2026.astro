---
import Layout from '~/layouts/Layout.astro'

export const prerender = true

// ==========================================
// OFFRES 2026
// ==========================================
const offres = [
  { 
    nom: 'Clarté', 
    prix: 1000, 
    places: 24, 
    sessions: 2, 
    dates: ['17-19 avril', '25-27 avril'],
    tauxRemplissage: 100,
    description: 'Vision + PARA + Claude Code',
    couleur: '#C4A855'
  },
  { 
    nom: 'LAOM School', 
    prix: 1000, 
    places: 30, 
    sessions: 2, 
    dates: ['8-10 mai', '16-18 octobre'],
    tauxRemplissage: 80,
    description: 'Créer son écolieu',
    couleur: '#2C2824'
  },
  { 
    nom: 'En Mouvement', 
    prix: 1100, 
    places: 45, 
    sessions: 3, 
    dates: ['5-9 août', '11-15 août', '16-20 août'],
    tauxRemplissage: 100,
    description: 'Immersion danse',
    couleur: '#4A7C59'
  },
]

const caTotal = offres.reduce((acc, o) => acc + (o.prix * o.places * o.tauxRemplissage / 100), 0)

// ==========================================
// CALENDRIER ÉDITORIAL
// ==========================================
const calendrierYouTube = [
  { mois: 'Février', videos: ['Mon système PARA expliqué', 'Comment je gère 5 projets en parallèle'], lien: 'Clarté' },
  { mois: 'Mars', videos: ['Claude Code : mon copilote IA', 'Pourquoi j\'ai quitté Notion pour Obsidian'], lien: 'Clarté' },
  { mois: 'Avril', videos: ['Le business model qui sauve les écolieux', 'SCIA : la structure juridique de LAOM'], lien: 'LAOM School' },
  { mois: 'Mai', videos: ['Autoconstruire : par où commencer', 'Les 5 erreurs des projets collectifs'], lien: 'LAOM School' },
  { mois: 'Juin', videos: ['850m² en paille porteuse : le bilan', 'Créer un lieu de vie : le vrai coût'], lien: 'LAOM School' },
  { mois: 'Juillet', videos: ['Libérer son corps : la science du mouvement', 'Pourquoi la danse change tout'], lien: 'En Mouvement' },
]

