---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Organiser un événement à LAOM',
  url: Astro.url.toString(),
  description: 'Découvrez nos tarifs de location et nos conditions pour organiser un stage, une retraite ou un événement à LAOM.',
})
---

<Layout
  title="Organiser un événement à LAOM"
  description="Découvrez nos tarifs de location et nos conditions pour organiser un stage, une retraite ou un événement à LAOM."
  seo={{ ldJSON: pageSchema }}
>
  <section class="relative py-32 lg:py-40 flex items-center justify-center overflow-hidden -mt-24 md:-mt-28 min-h-screen">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/salle-de-pratique.webp"
        alt="Salle de pratique LAOM"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>

    <div class="relative z-10 max-w-lg mx-auto px-10 sm:px-16">
      <div class="bg-white rounded-sm p-8 md:p-10 shadow-xl">
        <!-- Logo -->
        <div class="text-center mb-8">
          <img
            src="/images/laom/presentation/logo-laom.webp"
            alt="Logo LAOM"
            class="h-12 mx-auto mb-6"
          />
          <h1 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight mb-3">
            Organiser un événement à LAOM
          </h1>
          <p class="text-base font-light text-[#2C2824]/60 leading-relaxed">
            Recevez nos tarifs de location, nos conditions et les dates disponibles.
          </p>
        </div>

        <!-- Formulaire -->
        <form id="location-form" class="space-y-4">
          <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-sm px-4 py-3 text-sm"></div>
          <div>
            <label class="block text-sm font-medium text-[#2C2824] mb-1.5">Prénom</label>
            <input
              id="first-name"
              class="w-full rounded-sm border border-[#2C2824]/15 px-4 py-3 text-sm text-[#2C2824] placeholder-[#2C2824]/40 focus:outline-none focus:border-[#C4A855] focus:ring-1 focus:ring-[#C4A855]/30 transition-colors"
              type="text"
              required
              placeholder="Votre prénom"
              autocomplete="given-name"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-[#2C2824] mb-1.5">Email</label>
            <input
              id="email"
              class="w-full rounded-sm border border-[#2C2824]/15 px-4 py-3 text-sm text-[#2C2824] placeholder-[#2C2824]/40 focus:outline-none focus:border-[#C4A855] focus:ring-1 focus:ring-[#C4A855]/30 transition-colors"
              type="email"
              required
              placeholder="votre@email.com"
              autocomplete="email"
            />
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full rounded-sm bg-[#2C2824] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors"
          >
            J'accède aux conditions et dates disponibles
          </button>
        </form>

        <p class="text-xs font-light text-[#2C2824]/40 text-center mt-4">
          Vous serez également inscrit à la LAOM Letter, notre newsletter mensuelle.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('location-form');
    const btn = document.getElementById('submit-btn');
    const errorDiv = document.getElementById('form-error');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const firstName = document.getElementById('first-name').value.trim();
      const email = document.getElementById('email').value.trim();

      if (!firstName || !email) {
        errorDiv.textContent = 'Merci de remplir tous les champs.';
        errorDiv.classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Envoi en cours...';
      errorDiv.classList.add('hidden');

      try {
        // Submit ONLY to the dedicated location form
        const formData = new FormData();
        formData.append('email_address', email);
        formData.append('fields[first_name]', firstName);

        await fetch('https://app.kit.com/landing_pages/b4557c3936/subscribe', {
          method: 'POST',
          body: formData,
          mode: 'no-cors'
        });

        // Redirect to tarifs page
        window.location.href = '/tarifs-location/';

      } catch (err) {
        // Even if fetch fails with no-cors, the subscription likely went through
        // Redirect anyway
        window.location.href = '/tarifs-location/';
      }
    });
  });
</script>
