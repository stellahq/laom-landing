---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Organiser un événement à LAOM',
  url: Astro.url.toString(),
  description: 'Découvrez nos tarifs de location et nos conditions pour organiser un stage, une retraite ou un événement à LAOM.',
})
---

<Layout
  title="Organiser un événement à LAOM"
  description="Découvrez nos tarifs de location et nos conditions pour organiser un stage, une retraite ou un événement à LAOM."
  seo={{ ldJSON: pageSchema }}
>
  <section class="relative py-32 lg:py-40 flex items-center justify-center overflow-hidden -mt-24 md:-mt-28 min-h-screen">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/salle-de-pratique.webp"
        alt="Salle de pratique LAOM"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>

    <div class="relative z-10 max-w-lg mx-auto px-10 sm:px-16">
      <div class="bg-white rounded-sm p-8 md:p-10 shadow-xl">
        <!-- Logo -->
        <div class="text-center mb-8">
          <img
            src="/images/laom/presentation/logo-laom.webp"
            alt="Logo LAOM"
            class="h-12 mx-auto mb-6"
          />
          <h1 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight mb-3">
            Organiser un événement à LAOM
          </h1>
          <p class="text-base font-light text-[#2C2824]/60 leading-relaxed">
            Recevez nos tarifs de location, nos conditions et les dates disponibles.
          </p>
        </div>

        <!-- Formulaire -->
        <form
          id="location-form"
          action="https://app.kit.com/forms/8987350/subscriptions"
          class="seva-form formkit-form"
          method="post"
          data-sv-form="8987350"
          data-uid="af2e0fc1e5"
          data-format="inline"
          data-version="5"
        >
          <div data-style="clean">
            <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert" aria-live="polite"></ul>
            <div data-element="fields" class="space-y-4">
              <div class="formkit-field">
                <label class="block text-sm font-medium text-[#2C2824] mb-1.5">Prénom</label>
                <input
                  class="formkit-input w-full rounded-sm border border-[#2C2824]/15 px-4 py-3 text-sm text-[#2C2824] placeholder-[#2C2824]/40 focus:outline-none focus:border-[#C4A855] focus:ring-1 focus:ring-[#C4A855]/30 transition-colors"
                  name="fields[first_name]"
                  type="text"
                  required
                  placeholder="Votre prénom"
                  autocomplete="given-name"
                />
              </div>
              <div class="formkit-field">
                <label class="block text-sm font-medium text-[#2C2824] mb-1.5">Email</label>
                <input
                  class="formkit-input w-full rounded-sm border border-[#2C2824]/15 px-4 py-3 text-sm text-[#2C2824] placeholder-[#2C2824]/40 focus:outline-none focus:border-[#C4A855] focus:ring-1 focus:ring-[#C4A855]/30 transition-colors"
                  name="email_address"
                  type="email"
                  required
                  placeholder="votre@email.com"
                  autocomplete="email"
                />
              </div>
              <!-- Hidden tag field -->
              <input type="hidden" name="tags[]" value="prospect-location" />

              <button
                type="submit"
                data-element="submit"
                class="formkit-submit w-full rounded-sm bg-[#2C2824] text-white px-8 py-3.5 text-xs tracking-[0.2em] uppercase hover:bg-[#3D3832] transition-colors relative"
              >
                <div class="formkit-spinner" aria-hidden="true">
                  <div></div>
                  <div></div>
                  <div></div>
                </div>
                <span>Recevoir les conditions</span>
              </button>
            </div>
          </div>
        </form>

        <p class="text-xs font-light text-[#2C2824]/40 text-center mt-4">
          Vous serez également inscrit à la LAOM Letter, notre newsletter mensuelle.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // After Kit form submission, redirect to tarifs page
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('location-form');
    if (!form) return;

    // Watch for Kit's success message to appear, then redirect
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        mutation.addedNodes.forEach(function(node) {
          if (node.nodeType === 1 && (node.classList?.contains('formkit-alert-success') || node.textContent?.includes('Parfait'))) {
            setTimeout(function() {
              window.location.href = '/tarifs-location/';
            }, 1500);
          }
        });
      });
    });

    observer.observe(form, { childList: true, subtree: true });

    // Fallback: also watch for success class on existing elements
    const checkSuccess = setInterval(function() {
      const success = form.querySelector('.formkit-alert-success');
      if (success && success.textContent.length > 0) {
        clearInterval(checkSuccess);
        setTimeout(function() {
          window.location.href = '/tarifs-location/';
        }, 1500);
      }
    }, 500);

    // Stop checking after 60 seconds
    setTimeout(function() { clearInterval(checkSuccess); }, 60000);
  });
</script>

<style is:global>
  #location-form .formkit-submit[data-active] .formkit-spinner {
    opacity: 1;
    display: flex;
  }
  #location-form .formkit-submit[data-active] .formkit-spinner ~ span {
    opacity: 0;
  }
  #location-form .formkit-spinner {
    display: none;
    align-items: center;
    justify-content: center;
    position: absolute;
    inset: 0;
  }
  #location-form .formkit-spinner > div {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.7);
    margin: 0 2px;
    animation: location-spinner 1.4s ease-in-out infinite both;
  }
  #location-form .formkit-spinner > div:nth-child(1) { animation-delay: -0.32s; }
  #location-form .formkit-spinner > div:nth-child(2) { animation-delay: -0.16s; }
  @keyframes location-spinner {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1); }
  }
  #location-form .formkit-alert:empty { display: none; }
  #location-form .formkit-alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    border-radius: 0.25rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    list-style: none;
    margin: 0 0 0.75rem 0;
  }
  #location-form .formkit-alert-success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #166534;
    border-radius: 0.25rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    list-style: none;
    margin: 0;
  }
</style>
