---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'
import {
  getTranslations as getI18nTranslations,
  getLocalizedPath,
} from '~/i18n/utils'
import { INSTAGRAM_URL } from '~/i18n/translations'

const lang = (Astro.currentLocale || 'fr') as 'fr' | 'en'
const t = getI18nTranslations(lang)
const a = t.pages.accueilColivingPage

const home = getLocalizedPath('/', lang)
const candidater = getLocalizedPath('/candidater/', lang)
const coliving = getLocalizedPath('/coliving/', lang)

const pageSchema = createWebPageSchema({
  name: 'LAOM – Coliving pour entrepreneurs',
  url: Astro.url.toString(),
  description: a.heroOverlay,
})
---

<Layout
  title="LAOM – Coliving pour entrepreneurs en pleine nature, sud Aveyron"
  description={a.heroOverlay}
  hideChrome={true}
  seo={{ ldJSON: pageSchema }}
>
  <div class="laom-home bg-[#F2EBDB] text-[#2A1E14] selection:bg-[#9A3922] selection:text-[#F2EBDB]">
    <!-- HEADER -->
    <header class="absolute top-0 left-0 right-0 z-30">
      <nav class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14 h-24 flex items-center justify-between">
        <a href={home} class="inline-block hover:opacity-80 transition-opacity">
          <img src="/images/brand/logo-laom-wordmark-beige.svg" alt="LAOM" width="128" height="28" class="h-7 w-auto" />
        </a>
        <div class="hidden lg:flex items-center gap-10 text-[0.8rem] font-medium tracking-[0.08em] uppercase text-[#F2EBDB]/80">
          <a href={coliving} class="hover:text-white transition-colors">{a.nav.coliving}</a>
          <a href="#lieu" class="hover:text-white transition-colors">{a.espacesEyebrow}</a>
          <a href="#vivre" class="hover:text-white transition-colors">{a.vivreEyebrow}</a>
          <a href="#histoire" class="hover:text-white transition-colors">{a.foundersEyebrow}</a>
        </div>
        <a
          href={candidater}
          class="group inline-flex items-center gap-2.5 rounded-full border border-[#F2EBDB]/40 px-6 py-2.5 text-[0.72rem] font-semibold tracking-[0.18em] uppercase text-[#F2EBDB] hover:bg-[#F2EBDB] hover:text-[#2A1E14] transition-all"
        >
          {a.nav.cta}
          <span class="w-1.5 h-1.5 rounded-full bg-[#9A3922] group-hover:bg-[#2A1E14] transition-colors"></span>
        </a>
      </nav>
    </header>

    <!-- 1. HERO -->
    <section class="relative min-h-screen w-full overflow-hidden flex flex-col justify-end">
      <video autoplay muted loop playsinline poster="/images/vue-aeriene-laom2-hero.webp" class="absolute inset-0 w-full h-full object-cover">
        <source src="/videos/aveyron_hero.webm" type="video/webm" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-[#1c130c]/65 via-[#1c130c]/25 to-[#1c130c]/85"></div>

      <div class="relative z-10 max-w-[1240px] w-full mx-auto px-6 sm:px-10 lg:px-14 pt-32 pb-14">
        <span class="flex items-center gap-4 text-[#F2EBDB]/75 text-[0.72rem] font-semibold tracking-[0.32em] uppercase mb-8">
          <span class="w-10 h-px bg-[#F2EBDB]/40"></span>{a.heroEyebrow}
        </span>
        <h1 class="font-display font-medium text-[#F2EBDB] max-w-4xl text-[clamp(2.8rem,7vw,6rem)] leading-[0.98] tracking-[-0.01em]">
          Vis et travaille <em class="italic text-[#E7C89A]">autrement</em>, en pleine nature, entre pairs.
        </h1>
        <p class="mt-8 max-w-xl text-lg md:text-xl font-light text-[#F2EBDB]/85 leading-relaxed">{a.heroSub}</p>
        <div class="mt-10 flex flex-wrap items-center gap-6">
          <a href={candidater} class="group inline-flex items-center gap-3 rounded-full bg-[#9A3922] text-[#F2EBDB] pl-8 pr-6 py-4 text-[0.8rem] font-semibold tracking-[0.16em] uppercase hover:bg-[#822f1c] transition-colors">
            {a.heroCta}
            <span class="grid place-items-center w-7 h-7 rounded-full bg-[#F2EBDB]/15 group-hover:translate-x-0.5 transition-transform">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <a href="#manifeste" class="text-[#F2EBDB]/70 text-sm tracking-wide hover:text-white transition-colors underline underline-offset-[6px] decoration-[#F2EBDB]/30">Découvrir le projet</a>
        </div>
      </div>

      <!-- bande de stats, fine et éditoriale -->
      <div class="relative z-10 border-t border-[#F2EBDB]/15 bg-[#1c130c]/30 backdrop-blur-[2px]">
        <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14 py-7 grid grid-cols-3 divide-x divide-[#F2EBDB]/15">
          {a.stats.map((s) => (
            <div class="px-4 sm:px-8 first:pl-0">
              <p class="font-display text-[#F2EBDB] text-3xl sm:text-5xl leading-none">{s.value}<span class="text-xl sm:text-2xl text-[#E7C89A]">{s.suffix}</span></p>
              <p class="mt-2 text-[0.7rem] sm:text-xs font-medium tracking-[0.12em] uppercase text-[#F2EBDB]/60">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 2. MANIFESTE -->
    <section id="manifeste" class="py-28 md:py-40">
      <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14 grid lg:grid-cols-[1fr_1.05fr] gap-14 lg:gap-24 items-center">
        <div class="relative">
          <img src="/images/laom/festival-laom-ambiance-nature-aveyron.webp" alt="Ambiance nature et communauté au domaine LAOM" width="720" height="900" loading="lazy" class="w-full aspect-[4/5] object-cover rounded-[2px]" />
          <div class="absolute -bottom-8 -right-3 sm:-right-8 bg-[#F2EBDB] border border-[#2A1E14]/10 rounded-[2px] px-7 py-6 max-w-[250px] shadow-[0_20px_50px_-20px_rgba(42,30,20,0.4)]">
            <p class="font-display italic text-2xl leading-snug text-[#9A3922]">{a.statsTag}</p>
          </div>
        </div>
        <div>
          <span class="flex items-center gap-4 text-[#9A3922] text-[0.72rem] font-semibold tracking-[0.28em] uppercase mb-7">
            <span class="w-10 h-px bg-[#9A3922]/50"></span>{a.aboutEyebrow}
          </span>
          <h2 class="font-display font-medium text-[clamp(2.2rem,4.2vw,3.6rem)] leading-[1.04] tracking-[-0.01em] mb-8">
            {a.aboutTitle}<em class="italic text-[#9A3922]">{a.aboutTitleAccent}</em>
          </h2>
          <p class="text-lg font-light text-[#2A1E14]/75 leading-[1.7] mb-12 max-w-xl">{a.aboutSubtitle}</p>
          <div class="grid sm:grid-cols-2 gap-x-10 gap-y-8 border-t border-[#2A1E14]/10 pt-10">
            <div>
              <h3 class="font-display text-2xl mb-2 text-[#2A1E14]">{a.aboutBlock1Title}</h3>
              <p class="text-[0.95rem] font-light text-[#2A1E14]/65 leading-relaxed">{a.aboutBlock1Text}</p>
            </div>
            <div>
              <h3 class="font-display text-2xl mb-2 text-[#2A1E14]">{a.aboutBlock2Title}</h3>
              <p class="text-[0.95rem] font-light text-[#2A1E14]/65 leading-relaxed">{a.aboutBlock2Text}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. LE LIEU -->
    <section id="lieu" class="py-28 md:py-40 bg-[#2A1E14] text-[#F2EBDB]">
      <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14">
        <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-20 items-end mb-16">
          <div>
            <span class="flex items-center gap-4 text-[#E7C89A] text-[0.72rem] font-semibold tracking-[0.28em] uppercase mb-7">
              <span class="w-10 h-px bg-[#E7C89A]/40"></span>{a.espacesEyebrow}
            </span>
            <h2 class="font-display font-medium text-[clamp(2.2rem,4.5vw,3.8rem)] leading-[1.02] tracking-[-0.01em]">{a.espacesTitle}</h2>
          </div>
          <p class="text-lg font-light text-[#F2EBDB]/65 leading-[1.7] lg:pb-3 lg:border-l lg:border-[#F2EBDB]/15 lg:pl-10">{a.espacesSubtitle}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-[#F2EBDB]/12">
          {a.espaces.map((e, i) => (
            <div class="group border-b border-r border-[#F2EBDB]/12 px-8 py-10 hover:bg-[#33251a] transition-colors">
              <div class="flex items-start justify-between mb-6">
                <span class="font-display text-3xl text-[#E7C89A]/70">{String(i + 1).padStart(2, '0')}</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-[#F2EBDB]/30 group-hover:text-[#9A3922] group-hover:translate-x-1 group-hover:-translate-y-1 transition-all"><path d="M7 17L17 7M9 7h8v8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="font-display text-2xl mb-2">{e.title}</h3>
              <p class="text-[0.95rem] font-light text-[#F2EBDB]/60 leading-relaxed">{e.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. BANDE CTA -->
    <section class="grid lg:grid-cols-2">
      <div class="min-h-[380px] lg:min-h-[560px]">
        <img src="/images/laom/diner-golden-hour-laom.webp" alt="Dîner en communauté à LAOM, lumière dorée" width="980" height="760" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div class="bg-[#9A3922] text-[#F2EBDB] flex flex-col justify-center px-8 sm:px-16 lg:px-20 py-20 lg:py-0">
        <span class="flex items-center gap-4 text-[#F2EBDB]/70 text-[0.72rem] font-semibold tracking-[0.28em] uppercase mb-7">
          <span class="w-10 h-px bg-[#F2EBDB]/40"></span>{a.prixEyebrow}
        </span>
        <h2 class="font-display font-medium text-[clamp(2.2rem,4.5vw,3.6rem)] leading-[1.03] mb-7">{a.ctaBandTitle}</h2>
        <p class="text-lg font-light text-[#F2EBDB]/85 leading-[1.7] mb-10 max-w-md">{a.ctaBandText}</p>
        <a href={candidater} class="group inline-flex w-fit items-center gap-3 rounded-full bg-[#F2EBDB] text-[#9A3922] pl-8 pr-6 py-4 text-[0.8rem] font-semibold tracking-[0.16em] uppercase hover:bg-white transition-colors">
          {a.ctaBandButton}
          <span class="grid place-items-center w-7 h-7 rounded-full bg-[#9A3922]/12 group-hover:translate-x-0.5 transition-transform">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      </div>
    </section>

    <!-- 5. CE QUE TU VIENS VIVRE -->
    <section id="vivre" class="py-28 md:py-40">
      <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14">
        <div class="max-w-2xl mb-16">
          <span class="flex items-center gap-4 text-[#9A3922] text-[0.72rem] font-semibold tracking-[0.28em] uppercase mb-7">
            <span class="w-10 h-px bg-[#9A3922]/50"></span>{a.vivreEyebrow}
          </span>
          <h2 class="font-display font-medium text-[clamp(2.2rem,4.5vw,3.8rem)] leading-[1.02] tracking-[-0.01em] mb-6">{a.vivreTitle}</h2>
          <p class="text-lg font-light text-[#2A1E14]/70 leading-[1.7]">{a.vivreSubtitle}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-[#2A1E14]/10 border border-[#2A1E14]/10 rounded-[2px] overflow-hidden">
          {a.vivreItems.map((v, i) => (
            <div class="bg-[#F2EBDB] hover:bg-white transition-colors px-8 py-10">
              <span class="font-display text-2xl text-[#9A3922] block mb-5">— 0{i + 1}</span>
              <h3 class="font-display text-2xl mb-2 text-[#2A1E14]">{v.title}</h3>
              <p class="text-[0.95rem] font-light text-[#2A1E14]/65 leading-relaxed">{v.text}</p>
            </div>
          ))}
          <div class="bg-[#73673E] text-[#F2EBDB] px-8 py-10 flex flex-col justify-center">
            <p class="font-display italic text-2xl leading-snug mb-5">{a.statsTag}</p>
            <a href={coliving} class="inline-flex items-center gap-2 text-[0.75rem] font-semibold tracking-[0.16em] uppercase hover:gap-3 transition-all">
              {a.prixButtonAlt}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. PRIX -->
    <section class="py-28 md:py-40 bg-[#73673E] text-[#F2EBDB]">
      <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14 grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="flex items-center gap-4 text-[#F2EBDB]/70 text-[0.72rem] font-semibold tracking-[0.28em] uppercase mb-7">
            <span class="w-10 h-px bg-[#F2EBDB]/50"></span>{a.prixEyebrow}
          </span>
          <h2 class="font-display font-medium text-[clamp(2.6rem,5vw,4.4rem)] leading-[1.0] mb-7">{a.prixTitle}</h2>
          <p class="text-lg font-light text-[#F2EBDB]/80 leading-[1.7] mb-10 max-w-md">{a.prixText}</p>
          <div class="flex flex-wrap gap-4">
            <a href={candidater} class="inline-flex items-center rounded-full bg-[#9A3922] text-[#F2EBDB] px-9 py-4 text-[0.8rem] font-semibold tracking-[0.16em] uppercase hover:bg-[#822f1c] transition-colors">{a.prixButton}</a>
            <a href={coliving} class="inline-flex items-center rounded-full border border-[#F2EBDB]/40 px-9 py-4 text-[0.8rem] font-semibold tracking-[0.16em] uppercase hover:bg-[#F2EBDB] hover:text-[#2A1E14] transition-colors">{a.prixButtonAlt}</a>
          </div>
        </div>
        <ul class="divide-y divide-[#F2EBDB]/15 border-y border-[#F2EBDB]/15">
          {a.inclusItems.map((item) => (
            <li class="flex items-center gap-5 py-5">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="text-[#E7C89A] shrink-0"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span class="text-lg font-light">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 7. FONDATEURS -->
    <section id="histoire" class="py-28 md:py-40">
      <div class="max-w-[1100px] mx-auto px-6 sm:px-10 lg:px-14">
        <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="grid grid-cols-2 gap-5">
            <img src="/images/charly-aubert.webp" alt="Charly Aubert, cofondateur de LAOM" width="420" height="540" loading="lazy" class="w-full aspect-[4/5] object-cover rounded-[2px]" />
            <img src="/images/amandine-orriols.webp" alt="Amandine Orriols, cofondatrice de LAOM" width="420" height="540" loading="lazy" class="w-full aspect-[4/5] object-cover rounded-[2px] mt-12" />
          </div>
          <div>
            <span class="flex items-center gap-4 text-[#9A3922] text-[0.72rem] font-semibold tracking-[0.28em] uppercase mb-7">
              <span class="w-10 h-px bg-[#9A3922]/50"></span>{a.foundersEyebrow}
            </span>
            <h2 class="font-display font-medium text-[clamp(2.2rem,4vw,3.4rem)] leading-[1.04] mb-8">{a.foundersTitle}</h2>
            <p class="text-lg font-light text-[#2A1E14]/80 leading-[1.7] mb-5">{a.foundersText1}</p>
            <p class="text-lg font-light text-[#2A1E14]/80 leading-[1.7] mb-10">{a.foundersText2}</p>
            <a href={coliving} class="group inline-flex items-center gap-3 text-[#9A3922] text-[0.78rem] font-semibold tracking-[0.14em] uppercase">
              {a.foundersCta}
              <span class="w-8 h-px bg-[#9A3922] group-hover:w-12 transition-all"></span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 8. QUIZ -->
    <section class="py-28 md:py-40 bg-[#1c130c] text-[#F2EBDB] text-center">
      <div class="max-w-3xl mx-auto px-6 sm:px-10">
        <span class="text-[#E7C89A] text-[0.72rem] font-semibold tracking-[0.28em] uppercase">Lead magnet</span>
        <h2 class="font-display font-medium text-[clamp(2.4rem,5vw,4rem)] leading-[1.03] my-8">{a.quizTitle}</h2>
        <p class="text-lg font-light text-[#F2EBDB]/70 leading-[1.7] mb-12 max-w-xl mx-auto">{a.quizSub}</p>
        <a href={candidater} class="group inline-flex items-center gap-3 rounded-full bg-[#9A3922] text-[#F2EBDB] pl-9 pr-6 py-4 text-[0.8rem] font-semibold tracking-[0.16em] uppercase hover:bg-[#822f1c] transition-colors">
          {a.quizCta}
          <span class="grid place-items-center w-7 h-7 rounded-full bg-[#F2EBDB]/15 group-hover:translate-x-0.5 transition-transform">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-[#2A1E14] text-[#F2EBDB]/70">
      <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14 py-20 grid gap-12 md:grid-cols-[1.5fr_1fr_1fr]">
        <div class="max-w-sm">
          <img src="/images/brand/logo-laom-wordmark-beige.svg" alt="LAOM" width="132" height="29" class="h-7 w-auto mb-6" />
          <p class="font-display italic text-2xl text-[#F2EBDB]/85 leading-snug">{a.footerTagline}</p>
        </div>
        <div>
          <p class="text-[0.7rem] font-semibold tracking-[0.2em] uppercase text-[#F2EBDB]/40 mb-5">{a.footerNavTitle}</p>
          <ul class="space-y-3 text-[0.95rem] font-light">
            <li><a href={coliving} class="hover:text-white transition-colors">{a.nav.coliving}</a></li>
            <li><a href="#lieu" class="hover:text-white transition-colors">{a.espacesEyebrow}</a></li>
            <li><a href="#vivre" class="hover:text-white transition-colors">{a.vivreEyebrow}</a></li>
            <li><a href="#histoire" class="hover:text-white transition-colors">{a.foundersEyebrow}</a></li>
            <li><a href={candidater} class="hover:text-white transition-colors">{a.nav.cta}</a></li>
          </ul>
        </div>
        <div>
          <p class="text-[0.7rem] font-semibold tracking-[0.2em] uppercase text-[#F2EBDB]/40 mb-5">{a.footerContactTitle}</p>
          <ul class="space-y-3 text-[0.95rem] font-light">
            <li><a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="hover:text-white transition-colors">{a.footerInstagram}</a></li>
            <li><a href="mailto:hello@laom.fr" class="hover:text-white transition-colors">hello@laom.fr</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-[#F2EBDB]/10">
        <div class="max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-14 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[#F2EBDB]/45">
          <p>{a.footerCopyright}</p>
          <div class="flex gap-6">
            <a href={candidater} class="hover:text-white transition-colors">{a.footerPrivacy}</a>
            <a href={candidater} class="hover:text-white transition-colors">{a.footerTerms}</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  /* Police de marque LAOM — Host Grotesk (self-hostée), normale + italique */
  @font-face {
    font-family: 'Host Grotesk';
    src: url('/fonts/HostGrotesk-VariableFont_wght.ttf') format('truetype-variations');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Host Grotesk';
    src: url('/fonts/HostGrotesk-Italic-VariableFont_wght.ttf') format('truetype-variations');
    font-weight: 100 900;
    font-style: italic;
    font-display: swap;
  }
  .laom-home {
    font-family: 'Host Grotesk', system-ui, -apple-system, sans-serif;
  }
  /* Les titres gardent la même police que le corps (charte LAOM),
     mais avec un traitement "display" : graisse forte + interlettrage
     serré pour conserver la hiérarchie et le côté éditorial. */
  .laom-home .font-display {
    font-family: 'Host Grotesk', system-ui, sans-serif;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  /* Les accents en italique (mots/citations) restent plus légers. */
  .laom-home .font-display.italic {
    font-weight: 500;
    letter-spacing: -0.015em;
  }
</style>
