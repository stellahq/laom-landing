    <script is:inline>
      (function () {
        const BASE = 60
        const meals = document.querySelectorAll('.forum-meal')
        const recapEl = document.querySelector('[data-recap]')
        const totalEl = document.querySelector('[data-total]')
        const ctaEl = document.querySelector('[data-cta]')
        const allBtn = document.querySelector('[data-meals-all]')
        const resetBtn = document.querySelector('[data-meals-reset]')
        const form = document.getElementById('forum-reservation')

        function recompute() {
          let mealsTotal = 0
          let count = 0
          meals.forEach((m) => {
            if (m.checked) {
              mealsTotal += parseInt(m.value, 10)
              count += 1
            }
          })
          const total = BASE + mealsTotal
          if (recapEl) recapEl.textContent = 'Accès (60 €) + ' + count + ' repas (' + mealsTotal + ' €)'
          if (totalEl) totalEl.textContent = total + ' €'
          if (ctaEl) ctaEl.textContent = 'Je réserve ma place — ' + total + ' €'
        }
        meals.forEach((m) => m.addEventListener('change', recompute))
        if (allBtn) allBtn.addEventListener('click', () => { meals.forEach((m) => (m.checked = true)); recompute() })
        if (resetBtn) resetBtn.addEventListener('click', () => { meals.forEach((m) => (m.checked = false)); recompute() })
        const errorEl = document.querySelector('[data-error]')
        function showError(msg) {
          if (!errorEl) return
          errorEl.textContent = msg
          errorEl.classList.remove('hidden')
        }
        function clearError() {
          if (!errorEl) return
          errorEl.textContent = ''
          errorEl.classList.add('hidden')
        }

        if (form) form.addEventListener('submit', async (e) => {
          e.preventDefault()
          clearError()
          const data = new FormData(form)
          const email = String(data.get('email') || '').trim()
          const firstName = String(data.get('firstname') || '').trim()
          const lastName = String(data.get('lastname') || '').trim()
          if (!email) { showError('Email obligatoire.'); return }

          const selectedMeals = Array.from(meals)
            .filter((m) => m.checked)
            .map((m) => m.getAttribute('data-meal-id'))
            .filter(Boolean)

          if (!ctaEl) return
          const originalLabel = ctaEl.textContent
          ctaEl.disabled = true
          ctaEl.textContent = 'Redirection vers le paiement…'

          try {
            const res = await fetch('/api/mollie/create-payment/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                product: 'forum-eco-construction',
                email,
                firstName,
                lastName,
                meals: selectedMeals,
              }),
            })
            const json = await res.json()
            if (!res.ok || !json.checkoutUrl) {
              showError(json.error || 'Erreur lors de la création du paiement.')
              ctaEl.disabled = false
              ctaEl.textContent = originalLabel
              return
            }
            window.location.href = json.checkoutUrl
          } catch (err) {
            showError('Service de paiement indisponible. Réessaie dans un instant.')
            ctaEl.disabled = false
            ctaEl.textContent = originalLabel
          }
        })
      })()
    </script>
