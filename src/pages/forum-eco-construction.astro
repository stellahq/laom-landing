---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

export const prerender = true

const pageSchema = createWebPageSchema({
  name: 'Forum Éco-Construction | LAOM',
  url: Astro.url.toString(),
  description:
    "Du 3 au 5 juillet 2026 à LAOM, Aveyron : le rendez-vous des bâtisseurs et passionnés de l'habitat naturel. Visites de 5 habitats écologiques, conférences, atelier enduit terre, soirées festives.",
})

const galleryImages = [
  '/images/laom/grand-shambala/grand-shambala-vue-drone-paille-porteuse-aveyron.webp',
  '/images/laom/grand-shambala/coupe-technique-mur-paille-porteuse-detail.webp',
  '/images/laom/grand-shambala/fenetre-mur-paille-paysage-aveyron.webp',
  '/images/laom/grand-shambala/projection-enduit-terre-detail-finition.webp',
  '/images/laom/grand-shambala/application-enduit-chaux-murs-paille-grand-shambala.webp',
  '/images/laom/grand-shambala/facade-sud-grand-shambala-ouvertures-2025.webp',
  '/images/laom/grand-shambala/charpente-fermettes-pose-toiture-grand-shambala.webp',
  '/images/laom/grand-shambala/jonction-soubassement-bottes-paille-grand-shambala.webp',
  '/images/laom/grand-shambala/isolation-paille-hachee-combles-grand-shambala.webp',
  '/images/laom/financement-participatif/communaute-laom-chantier-participatif.webp',
  '/images/laom/financement-participatif/grand-shambala-avant-construction.webp',
  '/images/laom/financement-participatif/grand-shambala-apres-construction.webp',
]
---

<Layout
  title="Forum Éco-Construction | LAOM"
  description="Du 3 au 5 juillet 2026 à LAOM, Aveyron : le rendez-vous des bâtisseurs et passionnés de l'habitat naturel. Visites de 5 habitats écologiques, conférences, atelier enduit terre."
  seo={{ ldJSON: pageSchema }}
  hideChrome={true}
>

  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/laom-batiment-paille-hero.jpeg"
        alt="Bâtiment paille porteuse à LAOM, Aveyron — hôte du Forum Éco-Construction"
        title="LAOM — Grand Shambala paille porteuse"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/35 to-black/15"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center pt-32 pb-16">
      <p class="text-xs font-light tracking-[0.3em] uppercase text-white/75 mb-6">3 — 5 juillet 2026 · LAOM, Aveyron</p>
      <p class="font-playfair text-2xl md:text-3xl font-light text-white/90 mb-3 italic">Rencontre</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-8 tracking-tight leading-tight drop-shadow-lg">
        Forum Éco-Construction
      </h1>
      <p class="text-lg md:text-xl font-light text-white/90 max-w-2xl mx-auto leading-relaxed mb-10">
        Le rendez-vous des bâtisseurs et des passionnés de l'habitat naturel.<br/>
        Paille, terre, bois, autoconstruction, etc.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#reserver" class="inline-block px-8 py-3 bg-white text-[#2C2824] text-sm font-medium tracking-wide uppercase hover:bg-white/90 transition-colors">
          Je réserve ma place
        </a>
        <a href="#programme" class="inline-block px-8 py-3 border border-white/60 text-white text-sm font-medium tracking-wide uppercase hover:bg-white/10 transition-colors">
          Voir le programme
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
      <a href="#chiffres" class="block text-white/50 hover:text-white transition-colors" aria-label="Défiler">
        <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Chiffres-clés -->
  <section id="chiffres" class="py-20 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-10 text-center">
        <div>
          <p class="font-playfair text-5xl md:text-6xl font-medium text-[#2C2824] mb-2">3</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A]">jours</p>
        </div>
        <div>
          <p class="font-playfair text-5xl md:text-6xl font-medium text-[#2C2824] mb-2">150</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A]">places</p>
        </div>
        <div>
          <p class="font-playfair text-5xl md:text-6xl font-medium text-[#2C2824] mb-2">5</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A]">habitats visités</p>
        </div>
        <div>
          <p class="font-playfair text-5xl md:text-6xl font-medium text-[#2C2824] mb-2">4</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A]">conférences</p>
        </div>
        <div>
          <p class="font-playfair text-5xl md:text-6xl font-medium text-[#2C2824] mb-2">1</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A]">atelier pratique</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Manifeste -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-8">Manifeste</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-10 leading-tight">
        On croit à une construction vertueuse.
      </h2>
      <div class="space-y-6 text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        <p>
          Au Forum Éco-Construction de LAOM, on rassemble une <strong class="font-medium text-[#2C2824]">communauté de pros, d'autoconstructeurs et de curieux</strong> qui refusent l'habitat standardisé. Des gens qui bâtissent avec ce que la terre offre (paille, terre, bois, pierre, etc.) et qui prouvent que l'habitat peut être <strong class="font-medium text-[#2C2824]">naturel, beau et sain</strong>.
        </p>
        <p>
          Voir, toucher, apprendre, pratiquer. Ici, on ne parle pas en concepts : on rentre dans le <strong class="font-medium text-[#2C2824]">Grand Shambala — 800 m² de paille porteuse</strong>, on touche les murs, on met les mains dans l'enduit terre.
        </p>
        <p>
          Un forum, c'est le format parfait pour ça.
        </p>
      </div>
    </div>
  </section>

  <!-- Image salle de pratique -->
  <section class="bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24 pb-24 md:pb-32">
      <img
        src="/images/laom/grand-shambala/grand-shambala-vue-drone-paille-porteuse-aveyron.webp"
        alt="Vue drone du Grand Shambala — plus grand bâtiment paille porteuse au monde, à LAOM"
        class="w-full aspect-[16/10] object-cover rounded-sm border border-black/10"
        loading="lazy"
      />
      <p class="mt-4 text-xs font-light tracking-[0.15em] uppercase text-[#8B7A3A] text-center">Le Grand Shambala — 800 m² de paille porteuse</p>
    </div>
  </section>

  <!-- L'expérience : 3 piliers -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6 text-center">L'expérience</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4 text-center">3 jours pour construire autrement</h2>
      <p class="text-lg font-light text-[#2C2824]/70 text-center max-w-2xl mx-auto mb-16 leading-relaxed">
        Conférences, visites, atelier pratique et soirées festives — au cœur d'un lieu d'habitat et d'accueil où l'éco-construction est une réalité du quotidien, pas une promesse.
      </p>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <div class="bg-[#FAF8F5] border border-black/10 p-8 lg:p-10">
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4">01</p>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-4">Visiter</h3>
          <p class="text-base font-light text-[#2C2824]/75 leading-relaxed">
            <strong class="font-medium text-[#2C2824]">5 habitats écologiques à explorer</strong> en sous-groupes de 20 à 30 personnes. Du Grand Shambala (800 m² paille porteuse) aux tiny houses, en passant par la maison, l'extension et la salle polyvalente.
          </p>
        </div>

        <div class="bg-[#FAF8F5] border border-black/10 p-8 lg:p-10">
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4">02</p>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-4">Apprendre</h3>
          <p class="text-base font-light text-[#2C2824]/75 leading-relaxed">
            <strong class="font-medium text-[#2C2824]">4 conférences soigneusement sélectionnées</strong> sur la journée du samedi. Architectes, pailleux, terreux, urbanistes : ceux qui font, qui partagent leurs choix techniques, leurs erreurs, leur trajectoire.
          </p>
        </div>

        <div class="bg-[#FAF8F5] border border-black/10 p-8 lg:p-10">
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4">03</p>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-4">Pratiquer</h3>
          <p class="text-base font-light text-[#2C2824]/75 leading-relaxed">
            <strong class="font-medium text-[#2C2824]">Atelier enduit terre</strong> le dimanche matin, encadré par des pailleux et terreux expérimentés. On met les mains dedans, on apprend les bons gestes, on repart avec du concret.
          </p>
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="#reserver" class="inline-block px-10 py-4 bg-[#2C2824] text-white text-sm font-medium tracking-wide uppercase hover:bg-[#2C2824]/90 transition-colors">
          Composer mon séjour
        </a>
      </div>
    </div>
  </section>

  <!-- Programme -->
  <section id="programme" class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6 text-center">Programme</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-4 text-center">Le déroulé du forum</h2>
      <p class="text-base font-light text-[#2C2824]/70 text-center mb-16 leading-relaxed">
        Vendredi : arrivée · Samedi : conférences + visites · Dimanche : atelier + départ
      </p>

      <div class="space-y-12">
        <!-- Vendredi -->
        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4">Vendredi 3 juillet</p>
          <div class="space-y-4">
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">18h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Arrivée & installation</p>
                <p class="text-sm font-light text-[#2C2824]/70">Accueil, installation des vans et tentes, premiers échanges autour d'un verre.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">20h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Dîner d'ouverture</p>
                <p class="text-sm font-light text-[#2C2824]/70">Cuisine maison, produits du jardin et du Larzac, grandes tablées en plein air.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">21h30</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Soirée festive</p>
                <p class="text-sm font-light text-[#2C2824]/70">Musique, feu, danse — pour ouvrir le forum en convivialité.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Samedi -->
        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4">Samedi 4 juillet</p>
          <div class="space-y-4">
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">9h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Petit-déjeuner</p>
                <p class="text-sm font-light text-[#2C2824]/70">Pour bien démarrer la journée la plus dense du forum.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">10h30</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Conférences</p>
                <p class="text-sm font-light text-[#2C2824]/70">4 conférences sur la journée dans la salle de pratique. Paille porteuse ; urbanisme, permis et autorisations ; finitions naturelles (enduits naturels) ; retours sur notre expérience d'autoconstruction.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">13h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Déjeuner</p>
                <p class="text-sm font-light text-[#2C2824]/70">Repas convivial, sous la tente chapiteau ouverte sur la vallée.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">15h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Visites des 5 habitats</p>
                <p class="text-sm font-light text-[#2C2824]/70">Sous-groupes de 20-30 personnes : Grand Shambala (800 m² paille porteuse), salle polyvalente (130 m²), maison (75 m²), extension (40 m²), tiny houses.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">20h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Dîner</p>
                <p class="text-sm font-light text-[#2C2824]/70">Repas du soir ensemble, autour de grandes tables.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">21h30</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Soirée festive</p>
                <p class="text-sm font-light text-[#2C2824]/70">Musique live, danse, échanges autour du feu sous les étoiles.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Dimanche -->
        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-4">Dimanche 5 juillet</p>
          <div class="space-y-4">
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">9h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Petit-déjeuner</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline border-b border-black/10 pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">10h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Atelier enduit terre & visites de rattrapage</p>
                <p class="text-sm font-light text-[#2C2824]/70">Mains dans la matière. Ceux qui n'ont pas pu faire les visites samedi peuvent les rattraper en parallèle.</p>
              </div>
            </div>
            <div class="flex gap-6 items-baseline pb-4">
              <p class="font-playfair text-xl font-medium text-[#2C2824] w-20 shrink-0">13h</p>
              <div>
                <p class="font-medium text-[#2C2824] mb-1">Déjeuner & départ</p>
                <p class="text-sm font-light text-[#2C2824]/70">Dernier repas ensemble, échanges de contacts, retours.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="#reserver" class="inline-block px-10 py-4 bg-[#2C2824] text-white text-sm font-medium tracking-wide uppercase hover:bg-[#2C2824]/90 transition-colors">
          Je réserve ma place
        </a>
      </div>
    </div>
  </section>

  <!-- Conférences -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-16">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Conférences</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6 leading-tight">
            4 conférences. Ceux qui font, qui partagent.
          </h2>
          <p class="text-lg font-light text-[#2C2824]/75 leading-relaxed">
            Des intervenants soigneusement choisis pour partager leur trajectoire, leurs choix techniques et leurs erreurs.
          </p>
        </div>
        <div>
          <img
            src="/images/laom/sol-terre-crue-laom.png"
            alt="Sol en terre crue à LAOM — finition naturelle"
            class="w-full aspect-[4/3] object-cover rounded-sm border border-black/10"
            loading="lazy"
          />
        </div>
      </div>

      <p class="text-sm font-light text-[#2C2824]/55 italic text-center mt-8">Programme et intervenants annoncés prochainement.</p>
    </div>
  </section>

  <!-- Visites des habitats -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <img
            src="/images/laom/grand-shambala/coupe-technique-mur-paille-porteuse-detail.webp"
            alt="Détail technique d'un mur en paille porteuse au Grand Shambala"
            class="w-full aspect-[4/5] object-cover rounded-sm border border-black/10"
            loading="lazy"
          />
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Visites</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6 leading-tight">
            Voir, toucher, comprendre.
          </h2>
          <p class="text-lg font-light text-[#2C2824]/75 leading-relaxed mb-6">
            5 bâtiments construits à la main par la communauté LAOM, à explorer en sous-groupes de 20 à 30 personnes pour pouvoir poser toutes vos questions.
          </p>
          <ul class="space-y-3 text-base font-light text-[#2C2824]/80">
            <li class="flex gap-3"><span class="text-[#8B7A3A] font-medium">01</span><span><strong class="font-medium text-[#2C2824]">Grand Shambala</strong> — 800 m², plus grand bâtiment paille porteuse au monde</span></li>
            <li class="flex gap-3"><span class="text-[#8B7A3A] font-medium">02</span><span><strong class="font-medium text-[#2C2824]">Salle polyvalente</strong> — 130 m² <span class="text-[#2C2824]/60">(construction bois, technique japonaise du bois brûlé)</span></span></li>
            <li class="flex gap-3"><span class="text-[#8B7A3A] font-medium">03</span><span><strong class="font-medium text-[#2C2824]">Maison familiale</strong> — 75 m² <span class="text-[#2C2824]/60">(sol en terre crue, structure bois)</span></span></li>
            <li class="flex gap-3"><span class="text-[#8B7A3A] font-medium">04</span><span><strong class="font-medium text-[#2C2824]">Extension</strong> — 40 m²</span></li>
            <li class="flex gap-3"><span class="text-[#8B7A3A] font-medium">05</span><span><strong class="font-medium text-[#2C2824]">Deux tiny houses</strong></span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Atelier pratique -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Atelier</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6 leading-tight">
            Mains dans la terre.
          </h2>
          <p class="text-lg font-light text-[#2C2824]/75 leading-relaxed mb-6">
            Le dimanche matin, un atelier d'enduit terre encadré par des pailleux et terreux expérimentés. <strong class="font-medium text-[#2C2824]">2 à 3 heures pour comprendre le geste</strong> : préparation du mélange, application, finitions.
          </p>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
