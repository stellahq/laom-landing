---
import Layout from '~/layouts/Layout.astro'
import MobileNav from '~/components/MobileNav.astro'

export const prerender = true

// ==========================================
// VALORISATION FERME DU VERSEAU
// Document de travail — Février 2026
// ==========================================

// Actionnariat actuel
const actionnairiat = {
  avant: [
    { nom: 'Charly Aubert', parts: 75, statut: 'fondateur' },
    { nom: 'Grégoire Renovier', parts: 5, statut: 'sortant' },
    { nom: 'Claire Orriols', parts: 5, statut: 'sortant' },
    { nom: 'Paul Orriols', parts: 5, statut: 'sortant' },
    { nom: 'Patricia Salgon', parts: 5, statut: 'reste' },
    { nom: 'Khaldoun', parts: 5, statut: 'reste' },
  ],
  apres: [
    { nom: 'Charly Aubert', parts: 90, statut: 'fondateur' },
    { nom: 'Patricia Salgon', parts: 5, statut: 'associe' },
    { nom: 'Khaldoun', parts: 5, statut: 'associe' },
  ]
}

// Valorisation foncière
const foncier = [
  { actif: 'Salle de danse (Shala)', surface: '121 m²', valeur: 120000, note: 'Construit par Elliot' },
  { actif: 'Tiny Elliot', surface: '~20 m²', valeur: 40000, note: 'Construit par Elliot' },
  { actif: 'Coliving 7 chambres', surface: '125 m²', valeur: 100000, note: 'Hors d\'eau, à finir (prêt Oasis)' },
  { actif: '2/3 Foyer commun', surface: '60 m²', valeur: 50000, note: 'Hors d\'eau' },
  { actif: 'Cuisine d\'été', surface: '-', valeur: 15000, note: 'Existante, à rénover' },
  { actif: 'STECAL', surface: '-', valeur: 80000, note: 'Droit à construire, rare et stratégique' },
  { actif: 'Finition coliving', surface: '-', valeur: 200000, note: 'Prêt Oasis 200k€' },
]

const totalFoncier = foncier.reduce((sum, f) => sum + f.valeur, 0)

// Valorisation business
const business = {
  caProjecte: 450000,
  margeNette: 0.35,
  multiple: 3,
}
const resultatNet = business.caProjecte * business.margeNette
const valoBusiness = resultatNet * business.multiple

// Totaux
const preMoneyBrut = totalFoncier + valoBusiness
const preMoneyArrondi = 1000000 // Arrondi à 1M€

// CCA (hors négociation)
const cca = [
  { nom: 'Patricia Salgon', montant: 200000, note: '300k - 100k remboursement Laetitia' },
  { nom: 'Charly Aubert', montant: 160000, note: 'Apports personnels' },
]
const totalCCA = cca.reduce((sum, c) => sum + c.montant, 0)

// Apports prévus
const apports = [
  { nom: 'Elliot Meunier', montant: 220000, type: 'Apport en nature (créances)', note: 'Via Atomic Holding' },
  { nom: 'Laetitia', montant: 100000, type: 'Cash', note: '' },
  { nom: 'David Coste', montant: 50000, type: 'Cash', note: '12k déjà versés' },
]
const totalApports = apports.reduce((sum, a) => sum + a.montant, 0)

// Simulations split fondateurs
const splits = [
  { split: '80/20', charlyPre: 80, elliotPre: 20, charlyFinal: 57.0, elliotFinal: 14.2 },
  { split: '75/25', charlyPre: 75, elliotPre: 25, charlyFinal: 53.4, elliotFinal: 17.8 },
  { split: '70/30', charlyPre: 70, elliotPre: 30, charlyFinal: 53.2, elliotFinal: 22.8, recommande: true },
  { split: '65/35', charlyPre: 65, elliotPre: 35, charlyFinal: 46.3, elliotFinal: 24.9 },
]

// Répartition finale (avec split 70/30)
const repartitionFinale = [
  { nom: 'Charly Aubert', pourcentage: 53.2, valeur: 513000, couleur: 'charly' },
  { nom: 'Elliot Meunier', pourcentage: 22.8, valeur: 220000, couleur: 'elliot' },
  { nom: 'Laetitia', pourcentage: 10.4, valeur: 100000, couleur: 'investisseur' },
  { nom: 'David Coste', pourcentage: 5.2, valeur: 50000, couleur: 'investisseur' },
  { nom: 'Patricia Salgon', pourcentage: 4.2, valeur: 41000, couleur: 'associe' },
  { nom: 'Khaldoun', pourcentage: 4.2, valeur: 41000, couleur: 'associe' },
]

// Simulation Amandine (option B)
const repartitionAmandine = [
  { nom: 'Charly Aubert', pourcentage: 26.6, valeur: 256500 },
  { nom: 'Amandine Orriols', pourcentage: 26.6, valeur: 256500 },
  { nom: 'Bloc familial', pourcentage: 53.2, valeur: 513000, total: true },
]

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}

function formatK(n: number): string {
  return (n / 1000).toFixed(0) + 'k'
}
---

<Layout
  title="Valorisation FDV | LAOM"
  description="Valorisation Ferme du Verseau — Document de travail confidentiel"
  seo={{ noindex: true, nofollow: true }}
>
  <style is:global>
    .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 2px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; }
    .table-container { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .table-container table { min-width: 100%; }
    @media (max-width: 640px) {
      .table-container table { font-size: 0.8rem; }
      .table-container th, .table-container td { padding: 0.5rem 0.375rem; }
    }
  </style>

  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#8B5A3C]/10 border border-[#8B5A3C]/20 mb-6">
          <svg class="w-8 h-8 text-[#8B5A3C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Document confidentiel</h2>
        <p class="text-white/50 text-sm">Valorisation Ferme du Verseau</p>
      </div>
      
      <form id="password-form" class="space-y-4">
        <input 
          type="password" 
          id="password-input"
          placeholder="Mot de passe"
          class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#8B5A3C]/50 focus:ring-1 focus:ring-[#8B5A3C]/30 transition-all"
          autocomplete="off"
        />
        <button 
          type="submit"
          class="w-full px-6 py-4 rounded-sm bg-[#8B5A3C] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#7A4F35] transition-colors"
        >
          Accéder
        </button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <!-- Navbar -->
  <MobileNav currentPage="/valorisation-fdv/" />

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-20 sm:pt-24 pb-8 sm:pb-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 sm:mb-6">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B5A3C] mb-2">Document de travail</p>
          <h1 class="font-playfair text-2xl sm:text-3xl md:text-4xl font-medium text-white tracking-tight">
            Valorisation FDV
          </h1>
        </div>
        <div class="text-left sm:text-right">
          <p class="text-xs text-white/40">Février 2026</p>
          <p class="text-sm text-white/70">Confidentiel associés</p>
        </div>
      </div>
      <p class="text-sm text-white/50 max-w-2xl">
        Augmentation de capital de la Ferme du Verseau (SAS) — Méthodologie de valorisation et répartition proposée.
      </p>
    </div>
  </section>

  <!-- Navigation -->
  <nav class="sticky top-14 z-40 bg-white/95 backdrop-blur-sm border-b border-black/5 py-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="flex gap-3 sm:gap-4 overflow-x-auto text-xs sm:text-sm pb-1">
        <a href="#contexte" class="text-[#2C2824]/60 hover:text-[#8B5A3C] transition-colors whitespace-nowrap font-medium">Contexte</a>
        <a href="#valorisation" class="text-[#2C2824]/60 hover:text-[#8B5A3C] transition-colors whitespace-nowrap">Valorisation</a>
        <a href="#cofondateur" class="text-[#2C2824]/60 hover:text-[#8B5A3C] transition-colors whitespace-nowrap">Co-fondateur</a>
        <a href="#simulations" class="text-[#2C2824]/60 hover:text-[#8B5A3C] transition-colors whitespace-nowrap">Simulations</a>
        <a href="#amandine" class="text-[#2C2824]/60 hover:text-[#8B5A3C] transition-colors whitespace-nowrap">Amandine</a>
        <a href="#decisions" class="text-[#2C2824]/60 hover:text-[#8B5A3C] transition-colors whitespace-nowrap">Décisions</a>
      </div>
    </div>
  </nav>

  <!-- CONTEXTE JURIDIQUE -->
  <section id="contexte" class="py-8 sm:py-10 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Contexte juridique</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">SAS de droit français — Capital social actuel : 1 000 €</p>
      </div>

      <!-- Situation actuelle -->
      <div class="grid lg:grid-cols-2 gap-6 mb-8">
        <!-- Avant rachat -->
        <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6">
          <h3 class="text-sm font-medium text-[#2C2824] mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#2C2824]/30"></span>
            Actionnariat actuel
          </h3>
          <div class="space-y-2">
            {actionnairiat.avant.map((a) => (
              <div class={`flex items-center justify-between py-2 px-3 rounded-sm ${a.statut === 'sortant' ? 'bg-red-50 border border-red-100' : a.statut === 'fondateur' ? 'bg-[#8B5A3C]/5 border border-[#8B5A3C]/10' : 'bg-[#FAF8F5]'}`}>
                <span class={`text-sm ${a.statut === 'sortant' ? 'text-red-600 line-through' : 'text-[#2C2824]'}`}>{a.nom}</span>
                <span class={`text-sm font-medium ${a.statut === 'sortant' ? 'text-red-500' : 'text-[#2C2824]'}`}>{a.parts}%</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Après rachat -->
        <div class="bg-white rounded-sm border border-[#4A7C59]/20 p-4 sm:p-6">
          <h3 class="text-sm font-medium text-[#4A7C59] mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#4A7C59]"></span>
            Après rachat des sortants
          </h3>
          <div class="space-y-2">
            {actionnairiat.apres.map((a) => (
              <div class={`flex items-center justify-between py-2 px-3 rounded-sm ${a.statut === 'fondateur' ? 'bg-[#8B5A3C]/5 border border-[#8B5A3C]/10' : 'bg-[#FAF8F5]'}`}>
                <span class="text-sm text-[#2C2824]">{a.nom}</span>
                <span class="text-sm font-medium text-[#2C2824]">{a.parts}%</span>
              </div>
            ))}
          </div>
          <div class="mt-4 pt-4 border-t border-black/5">
            <p class="text-xs text-[#2C2824]/50">
              <strong>Rachat au nominal :</strong> 50 € par sortant (Greg, Claire, Paul)
            </p>
          </div>
        </div>
      </div>

      <!-- Encart CCA -->
      <div class="bg-[#2C2824] rounded-sm p-4 sm:p-6 text-white">
        <h3 class="text-sm font-medium mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Comptes Courants d'Associés (CCA)
        </h3>
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          {cca.map((c) => (
            <div class="bg-white/5 rounded-sm p-3">
              <p class="text-white/70 text-sm">{c.nom}</p>
              <p class="text-xl font-medium text-[#C4A855]">{formatK(c.montant)} €</p>
              <p class="text-xs text-white/40 mt-1">{c.note}</p>
            </div>
          ))}
        </div>
        <div class="flex items-center justify-between pt-4 border-t border-white/10">
          <span class="text-white/50 text-sm">Total CCA</span>
          <span class="text-xl font-medium">{formatK(totalCCA)} €</span>
        </div>
        <p class="text-xs text-white/40 mt-4">
          <strong>Traitement :</strong> Les CCA restent au bilan et seront remboursés progressivement sur les bénéfices futurs. Ils sont <strong>hors négociation</strong> — la valorisation porte sur l'actif brut.
        </p>
      </div>
    </div>
  </section>

  <!-- VALORISATION -->
  <section id="valorisation" class="py-8 sm:py-10 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Valorisation pre-money</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">Approche Somme des Parties : Foncier + Business</p>
      </div>

      <!-- Valorisation foncière -->
      <div class="mb-8">
        <h3 class="text-sm font-medium text-[#8B5A3C] uppercase tracking-wider mb-4">A. Valorisation foncière</h3>
        <div class="table-container bg-[#FAF8F5] rounded-sm border border-black/5">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-black/10">
                <th class="text-left py-3 px-3 sm:px-4 font-medium text-[#2C2824]/70 text-xs uppercase tracking-wider">Actif</th>
                <th class="text-right py-3 px-3 sm:px-4 font-medium text-[#2C2824]/70 text-xs uppercase tracking-wider hidden sm:table-cell">Surface</th>
                <th class="text-right py-3 px-3 sm:px-4 font-medium text-[#2C2824]/70 text-xs uppercase tracking-wider">Valeur</th>
              </tr>
            </thead>
            <tbody>
              {foncier.map((f, i) => (
                <tr class={`border-b border-black/5 ${i === foncier.length - 1 ? 'bg-[#4A7C59]/5' : ''}`}>
                  <td class="py-3 px-3 sm:px-4">
                    <span class="text-[#2C2824] font-medium">{f.actif}</span>
                    <span class="block text-xs text-[#2C2824]/40 mt-0.5">{f.note}</span>
                  </td>
                  <td class="py-3 px-3 sm:px-4 text-right text-[#2C2824]/60 hidden sm:table-cell">{f.surface}</td>
                  <td class="py-3 px-3 sm:px-4 text-right font-medium text-[#2C2824]">{formatK(f.valeur)} €</td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr class="bg-[#8B5A3C]/10">
                <td class="py-3 px-3 sm:px-4 font-medium text-[#8B5A3C]" colspan="2">Total foncier</td>
                <td class="py-3 px-3 sm:px-4 text-right font-bold text-[#8B5A3C] text-lg">{formatK(totalFoncier)} €</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

      <!-- Valorisation business -->
      <div class="mb-8">
        <h3 class="text-sm font-medium text-[#8B5A3C] uppercase tracking-wider mb-4">B. Valorisation business</h3>
        <div class="grid sm:grid-cols-4 gap-4">
          <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4">
            <p class="text-xs text-[#2C2824]/50 uppercase tracking-wider mb-1">CA projeté</p>
            <p class="text-xl font-medium text-[#2C2824]">{formatK(business.caProjecte)} €/an</p>
          </div>
          <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4">
            <p class="text-xs text-[#2C2824]/50 uppercase tracking-wider mb-1">Marge nette</p>
            <p class="text-xl font-medium text-[#2C2824]">{(business.margeNette * 100).toFixed(0)}%</p>
          </div>
          <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4">
            <p class="text-xs text-[#2C2824]/50 uppercase tracking-wider mb-1">Résultat net</p>
            <p class="text-xl font-medium text-[#2C2824]">{formatK(resultatNet)} €/an</p>
          </div>
          <div class="bg-[#8B5A3C]/10 rounded-sm border border-[#8B5A3C]/20 p-4">
            <p class="text-xs text-[#8B5A3C]/70 uppercase tracking-wider mb-1">Multiple ×{business.multiple}</p>
            <p class="text-xl font-bold text-[#8B5A3C]">{formatK(valoBusiness)} €</p>
          </div>
        </div>
        <p class="text-xs text-[#2C2824]/40 mt-4">
          Inclut : marque LAOM, communauté, site internet, offres hybrides (physique + digital), potentiel de développement.
        </p>
      </div>

      <!-- Total -->
      <div class="bg-[#1a1a1a] rounded-sm p-4 sm:p-6">
        <div class="grid sm:grid-cols-3 gap-4 text-center">
          <div>
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Foncier</p>
            <p class="text-2xl font-medium text-white">{formatK(totalFoncier)} €</p>
          </div>
          <div>
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Business</p>
            <p class="text-2xl font-medium text-white">{formatK(valoBusiness)} €</p>
          </div>
          <div class="sm:border-l sm:border-white/10 sm:pl-4">
            <p class="text-xs text-[#C4A855] uppercase tracking-wider mb-1">Pre-money total</p>
            <p class="text-3xl font-bold text-[#C4A855]">~1M €</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CO-FONDATEUR ELLIOT -->
  <section id="cofondateur" class="py-8 sm:py-10 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Logique co-fondateur</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">Pourquoi Elliot n'est pas un simple investisseur</p>
      </div>

      <!-- Justification -->
      <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6 mb-6">
        <h3 class="text-sm font-medium text-[#2C2824] mb-4">Elliot Meunier — Contribution fondatrice</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">220k € investis en 2023</p>
                <p class="text-xs text-[#2C2824]/50">Sur terrain non constructible, avant STECAL</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">Risque juridique réel</p>
                <p class="text-xs text-[#2C2824]/50">Construction "illégale", confiance totale</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">3 ans d'attente</p>
                <p class="text-xs text-[#2C2824]/50">Argent exposé sans garantie juridique</p>
              </div>
            </div>
          </div>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#4A7C59]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-[#2C2824]">Réseau & notoriété</p>
                <p class="text-xs text-[#2C2824]/50">Connu sur internet, fait venir des gens</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#4A7C59]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
