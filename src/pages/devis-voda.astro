---
import Layout from '~/layouts/Layout.astro'
import MobileNav from '~/components/MobileNav.astro'

export const prerender = true

// ==========================================
// DEVIS IMPLEMENTATION IA — VODA ENERGIES
// Charly Aubert / La Ferme du Verseau
// Fevrier 2026
// ==========================================

// Phases du projet
const phases = [
  {
    numero: 0,
    titre: 'Fondations',
    duree: 'Semaine 1',
    prix: 1200,
    livrables: [
      'Serveur cloud (VPS) provisionne et securise',
      'Infrastructure Cloudflare (Workers, base de donnees D1, stockage KV)',
      'Catalogue fournisseur importe dans la base de donnees (200-300 references)',
      'Compte Tiime configure (societe, mentions legales, TVA)',
      'Board Trello structure (Prospect → Devis → Signe → En cours → Facture → Paye)',
      'Agent IA configure et connecte a l\u2019ensemble des services',
    ],
  },
  {
    numero: 1,
    titre: 'Pipeline devis + facturation',
    duree: 'Semaines 2-3',
    prix: 2400,
    livrables: [
      'Transcription vocale automatique (vocal du patron → texte structure)',
      'Generation intelligente de devis (IA matche avec votre catalogue fournisseur reel, calcule les marges)',
      'Creation automatique des devis dans Tiime avec lignes detaillees',
      'Synchronisation Trello (carte creee et deplacee automatiquement)',
      'Conversion devis → facture automatique quand le chantier est termine',
      'Envoi automatique des factures au client par email',
      'Tests avec 10-15 devis reels pour affiner la precision',
    ],
  },
  {
    numero: 2,
    titre: 'Relances + automatisations bureau',
    duree: 'Semaine 3',
    prix: 600,
    livrables: [
      'Relances automatiques des impayes (J+7, J+15, J+30)',
      'Synchronisation Tiime ↔ Trello (paiements, statuts)',
      'Notifications email sur evenements cles (devis cree, facture payee, alerte)',
    ],
  },
  {
    numero: 3,
    titre: 'Gestion des stocks',
    duree: 'Semaine 3-4',
    prix: 1200,
    livrables: [
      'Inventaire complet du depot dans la base de donnees',
      'Formulaire mobile pour les plombiers (sortie materiel avant chaque chantier)',
      'Mise a jour automatique des stocks en temps reel',
      'Alertes seuil bas (email + carte Trello \u00AB Commande a passer \u00BB)',
      'Generation automatique de bons de commande fournisseur pre-remplis',
      'L\u2019agent peut repondre : \u00AB combien de groupes secu en stock ? \u00BB',
    ],
  },
  {
    numero: 4,
    titre: 'Formation + optimisation',
    duree: 'Semaine 4',
    prix: 600,
    livrables: [
      'Formation patron a l\u2019utilisation de l\u2019agent',
      'Formation secretaire (devis, facturation, stocks, relances)',
      'Documentation complete des processus',
      'Affinage des prompts IA base sur les retours',
      'Tests finaux et recette avec validation client',
    ],
  },
]

const totalCatalogue = 12000
const remise = 50
const totalRemise = 6000

// Couts recurrents
const coutsRecurrents = [
  { poste: 'Serveur cloud (VPS)', cout: '~10', note: 'Hebergement de l\u2019agent' },
  { poste: 'Abonnement Claude (Pro)', cout: '~20', note: 'Intelligence de l\u2019agent' },
  { poste: 'API Whisper (OpenAI)', cout: '~3-5', note: 'Transcription vocale' },
  { poste: 'API Claude (Anthropic)', cout: '~10-15', note: 'Structuration des devis' },
  { poste: 'Tiime', cout: 'Gratuit', note: 'Avec expert-comptable partenaire' },
  { poste: 'Trello', cout: 'Gratuit', note: 'Plan existant' },
  { poste: 'Cloudflare (Workers/D1)', cout: 'Gratuit', note: 'Free tier largement suffisant' },
]

// Gains operationnels
const gains = [
  { poste: 'Temps secretaire (saisie/relance)', avant: '~40h/mois', apres: '~12h/mois', gain: '28h liberees' },
  { poste: 'Temps patron sur l\u2019admin', avant: '~15h/mois', apres: '~2h/mois', gain: '13h liberees' },
  { poste: 'Creation d\u2019un devis', avant: '20-30 min', apres: '2 min (vocal)', gain: 'x10 plus rapide' },
  { poste: 'Factures impayees', avant: '5-10%', apres: '\u003C 2%', gain: 'Tresorerie amelioree' },
  { poste: 'Commandes urgentes', avant: 'Frequentes', apres: 'Rares', gain: 'Fin des surcouts' },
  { poste: 'Double saisie', avant: 'Systematique', apres: 'Zero', gain: 'Eliminee' },
  { poste: 'Visibilite stocks', avant: 'Aucune', apres: 'Temps reel', gain: 'Nouveau' },
  { poste: 'Conformite fact. elec. 2026', avant: 'Non verifiee', apres: 'Prete (Tiime PA)', gain: 'Risque elimine' },
]

// Contreparties
const contreparties = [
  {
    titre: '3 recommandations actives',
    description: 'Recommander nos services a 3 entreprises dans les 6 mois suivant la livraison.',
  },
  {
    titre: 'Temoignage ecrit',
    description: 'Un temoignage utilisable sur notre site et nos supports commerciaux.',
  },
  {
    titre: 'Temoignage video',
    description: 'Participation a une etude de cas video (5-10 min) pour notre chaine YouTube.',
  },
  {
    titre: 'Droit d\u2019etude de cas',
    description: 'Autorisation d\u2019utiliser le projet comme etude de cas publique.',
  },
]

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}
---

<Layout
  title="Devis Implementation IA | LAOM"
  description="Devis d'implementation IA pour Voda Energies — Document confidentiel"
  seo={{ noindex: true, nofollow: true }}
>
  <style is:global>
    .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 2px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; }
    .table-container { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .table-container table { min-width: 100%; }
    @media (max-width: 640px) {
      .table-container table { font-size: 0.8rem; }
      .table-container th, .table-container td { padding: 0.5rem 0.375rem; }
    }
  </style>

  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#285230]/10 border border-[#285230]/20 mb-6">
          <svg class="w-8 h-8 text-[#285230]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Espace devis</h2>
        <p class="text-white/50 text-sm">Document confidentiel — Voda Energies</p>
      </div>
      
      <form id="password-form" class="space-y-4">
        <input 
          type="password" 
          id="password-input"
          placeholder="Mot de passe"
          class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#285230]/50 focus:ring-1 focus:ring-[#285230]/30 transition-all"
          autocomplete="off"
        />
        <button 
          type="submit"
          class="w-full px-6 py-4 rounded-sm bg-[#285230] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#1e3f24] transition-colors"
        >
          Acceder
        </button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <!-- Navbar -->
  <MobileNav currentPage="/devis-voda/" />

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-20 sm:pt-24 pb-8 sm:pb-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 sm:mb-6">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#285230] mb-2">Devis n°2026-02-VODA</p>
          <h1 class="font-playfair text-2xl sm:text-3xl md:text-4xl font-medium text-white tracking-tight">
            Implementation IA
          </h1>
          <p class="font-playfair text-lg sm:text-xl text-white/60 mt-1">Voda Energies</p>
        </div>
        <div class="text-left sm:text-right">
          <p class="text-xs text-white/40">Fevrier 2026</p>
          <p class="text-sm text-white/70">Validite : 30 jours</p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm text-white/50 mt-4 pt-4 border-t border-white/10">
        <div>
          <p class="text-white/30 text-xs uppercase tracking-wider mb-1">Prestataire</p>
          <p class="text-white/70">Charly Aubert — La Ferme du Verseau</p>
        </div>
        <div>
          <p class="text-white/30 text-xs uppercase tracking-wider mb-1">Client</p>
          <p class="text-white/70">Voda Energies</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <nav class="sticky top-14 z-40 bg-white/95 backdrop-blur-sm border-b border-black/5 py-2">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="flex gap-3 sm:gap-4 overflow-x-auto text-xs sm:text-sm pb-1">
        <a href="#contexte" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap font-medium">Contexte</a>
        <a href="#solution" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap">Solution</a>
        <a href="#livrables" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap">Livrables</a>
        <a href="#planning" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap">Planning</a>
        <a href="#investissement" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap">Investissement</a>
        <a href="#roi" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap">ROI</a>
        <a href="#conditions" class="text-[#2C2824]/60 hover:text-[#285230] transition-colors whitespace-nowrap">Conditions</a>
      </div>
    </div>
  </nav>

  <!-- CONTEXTE -->
  <section id="contexte" class="py-8 sm:py-10 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Contexte</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">Diagnostic operationnel — 3 silos identifies</p>
      </div>

      <!-- Les 3 silos -->
      <div class="grid lg:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-full bg-[#285230]/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-[#285230]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </span>
            <h3 class="text-sm font-medium text-[#2C2824]">Terrain</h3>
          </div>
          <p class="text-sm text-[#2C2824]/60 leading-relaxed">3 plombiers, information orale via Trello. Aucun retour materiel apres intervention. Le patron est le seul lien entre terrain et bureau.</p>
        </div>

        <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-full bg-[#285230]/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-[#285230]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </span>
            <h3 class="text-sm font-medium text-[#2C2824]">Bureau</h3>
          </div>
          <p class="text-sm text-[#2C2824]/60 leading-relaxed">1 secretaire, saisie manuelle dans ProGBat. Double saisie systematique (oral > Trello > ProGBat). Relances et facturation 100% manuelles.</p>
        </div>

        <div class="bg-white rounded-sm border border-black/5 p-4 sm:p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-full bg-[#285230]/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-[#285230]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </span>
            <h3 class="text-sm font-medium text-[#2C2824]">Depot</h3>
          </div>
          <p class="text-sm text-[#2C2824]/60 leading-relaxed">Aucun responsable dedie. Zero suivi des stocks. Inventaire papier. Commandes d'urgence frequentes et couteuses.</p>
        </div>
      </div>

      <!-- Cout de l'inaction -->
      <div class="bg-[#2C2824] rounded-sm p-4 sm:p-6 text-white">
        <h3 class="text-sm font-medium mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          Cout de l'inaction
        </h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="bg-white/5 rounded-sm p-3">
            <p class="text-2xl font-medium text-[#C4A855]">~40h</p>
            <p class="text-xs text-white/50 mt-1">Saisie et relance / mois</p>
          </div>
          <div class="bg-white/5 rounded-sm p-3">
            <p class="text-2xl font-medium text-[#C4A855]">~15h</p>
            <p class="text-xs text-white/50 mt-1">Patron sur l'admin / mois</p>
          </div>
          <div class="bg-white/5 rounded-sm p-3">
            <p class="text-2xl font-medium text-[#C4A855]">5-10%</p>
            <p class="text-xs text-white/50 mt-1">Factures impayees (oublis)</p>
          </div>
          <div class="bg-white/5 rounded-sm p-3">
            <p class="text-2xl font-medium text-[#C4A855]">ProGBat</p>
            <p class="text-xs text-white/50 mt-1">Non conforme fact. elec. 2026</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTION -->
  <section id="solution" class="py-8 sm:py-10 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">La solution</h2>
        <p class="text-sm text-[#2C2824]/50 mt-1">Un agent IA dedie a votre entreprise</p>
      </div>

      <!-- Principe -->
      <div class="bg-[#285230]/5 rounded-sm border border-[#285230]/20 p-4 sm:p-6 mb-8">
        <h3 class="text-sm font-medium text-[#285230] mb-4">Le principe</h3>
        <p class="text-sm text-[#2C2824]/70 leading-relaxed mb-4">
          Au lieu de multiplier les outils deconnectes, nous deployons un <strong>agent IA central</strong> qui comprend votre metier. Le patron et la secretaire lui parlent en langage naturel. L'agent orchestre tout : creation de devis, facturation, relances, gestion des stocks.
        </p>
        <p class="text-sm text-[#2C2824]/70 leading-relaxed">
          <strong>Concretement :</strong> le patron envoie un message vocal apres une visite client. L'agent transcrit, identifie le materiel dans votre catalogue fournisseur avec vos vrais prix negocies, calcule les marges, genere le devis dans Tiime, cree la carte Trello, et envoie le devis au client. Temps total : 2 minutes au lieu de 30.
        </p>
      </div>

      <!-- Architecture simplifiee -->
      <div class="mb-8">
        <h3 class="text-sm font-medium text-[#285230] uppercase tracking-wider mb-4">Architecture</h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <!-- Colonne gauche : ce que vous voyez -->
          <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4 sm:p-6">
            <h4 class="text-xs text-[#2C2824]/50 uppercase tracking-wider mb-4">Ce que vous voyez</h4>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-[#285230] text-white text-xs flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">Un agent IA intelligent</p>
                  <p class="text-xs text-[#2C2824]/50">Votre interlocuteur unique. Il comprend vos demandes en langage naturel.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-[#285230] text-white text-xs flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">Tiime (devis, factures, compta)</p>
                  <p class="text-xs text-[#2C2824]/50">Outil de gestion conforme facturation electronique 2026.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-[#285230] text-white text-xs flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">Trello (pipeline chantiers)</p>
                  <p class="text-xs text-[#2C2824]/50">Votre tableau de bord visuel, deja en place.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Colonne droite : ce qui tourne en arriere-plan -->
          <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4 sm:p-6">
            <h4 class="text-xs text-[#2C2824]/50 uppercase tracking-wider mb-4">Ce qui tourne en arriere-plan</h4>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-[#2C2824]/20 text-[#2C2824] text-xs flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" /></svg>
                </span>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">Cloudflare Workers</p>
                  <p class="text-xs text-[#2C2824]/50">Infrastructure cloud ultra-rapide. Execute les automatisations.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-[#2C2824]/20 text-[#2C2824] text-xs flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.343c2.673 0 4.012-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187 1.116-1.116A3 3 0 009 8.172z" clip-rule="evenodd" /></svg>
                </span>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">IA (Whisper + Claude)</p>
                  <p class="text-xs text-[#2C2824]/50">Transcription vocale + intelligence de structuration des devis.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-[#2C2824]/20 text-[#2C2824] text-xs flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z" /><path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z" /><path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z" /></svg>
                </span>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">Base de donnees (D1)</p>
                  <p class="text-xs text-[#2C2824]/50">Votre catalogue fournisseur, stocks et historique.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Transparence IA -->
      <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4 sm:p-6">
        <h3 class="text-sm font-medium text-[#2C2824] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#285230]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Note de transparence
        </h3>
        <p class="text-sm text-[#2C2824]/60 leading-relaxed">
