---
import Layout from '~/layouts/Layout.astro'
import MobileNav from '~/components/MobileNav.astro'

// SSR — pas de prerender, on lit D1
export const prerender = false

// ==========================================
// DONNEES STATIQUES LORENZO (planning long terme, conservees)
// ==========================================

const profil = {
  nom: 'Lorenzo',
  role: 'Chef Guinguette + Aide chantier',
  periode: 'Fevrier 2026 — Septembre 2026',
  contact: '06.73.68.35.73 (Charly)',
}

const cuissonsSignatures = [
  { nom: 'Four a pizza', desc: 'Heritage familial — pizzas farine kamut, fromage brebis' },
  { nom: 'Tandour indien', desc: 'Naans maison, brochettes marines, aubergines' },
  { nom: 'Tagine', desc: 'Cuissons lentes, epices (si Lily presente)' },
  { nom: 'Plancha', desc: 'Legumes du jardin, viandes Aubrac' },
]

const equipe = [
  { nom: 'Lily', role: 'Tagines, cuisine marocaine', statut: 'Si elle vient du Maroc' },
  { nom: 'Khaldoun', role: 'Mezzes syriens, baklava, soutien', statut: 'Disponible' },
  { nom: 'Extras', role: '1-2 personnes haute saison', statut: 'A recruter' },
]

const documentsObligatoires = [
  'Fiches temperatures (frigos, cuissons)',
  'Fiches reception produits',
  'Fiches nettoyage/desinfection',
  'Fiches entretien hottes/extracteurs',
  'Documents formation personnel',
  'Coordonnees fournisseurs',
  'Attestation formation hygiene',
  'Recepisse licence restaurant',
]

// ==========================================
// DONNEES DYNAMIQUES (D1)
// ==========================================
const db = (Astro.locals as any).runtime?.env?.DB

// Calculer la semaine courante (ISO week)
function getCurrentWeek(): string {
  const now = new Date()
  const d = new Date(Date.UTC(now.getFullYear(), now.getMonth(), now.getDate()))
  const dayNum = d.getUTCDay() || 7
  d.setUTCDate(d.getUTCDate() + 4 - dayNum)
  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1))
  const weekNo = Math.ceil((((d.getTime() - yearStart.getTime()) / 86400000) + 1) / 7)
  return `${d.getUTCFullYear()}-W${String(weekNo).padStart(2, '0')}`
}

const currentWeek = getCurrentWeek()
const today = new Date().toISOString().split('T')[0]

let tasks: any[] = []
let objectives: any[] = []
let observations: any[] = []

if (db) {
  try {
    const tasksRes = await db.prepare('SELECT * FROM tasks WHERE person = ? AND week = ? ORDER BY sort_order ASC, id ASC').bind('lorenzo', currentWeek).all()
    tasks = tasksRes.results || []

    const objRes = await db.prepare('SELECT * FROM weekly_objectives WHERE person = ? AND week = ? ORDER BY id ASC').bind('lorenzo', currentWeek).all()
    objectives = objRes.results || []

    const obsRes = await db.prepare('SELECT * FROM observations WHERE person = ? AND date = ? ORDER BY created_at DESC').bind('lorenzo', today).all()
    observations = obsRes.results || []
  } catch (e) {
    // DB tables might not exist yet — graceful fallback
  }
}

const dailyTasks = tasks.filter((t: any) => t.is_daily_highlight)
const allTasks = tasks
const completedCount = tasks.filter((t: any) => t.completed).length
---

<Layout
  title="Lorenzo — Espace Equipe | LAOM"
  description="Taches et planning Lorenzo - LAOM 2026"
  seo={{ noindex: true, nofollow: true }}
>
  <!-- Password Protection Overlay -->
  <div id="password-overlay" class="fixed inset-0 z-[100] bg-[#1a1a1a] flex items-center justify-center" style="display: flex;">
    <div class="max-w-md w-full mx-4 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#C4A855]/10 border border-[#C4A855]/20 mb-6">
          <span class="text-3xl">&#x1F468;&#x200D;&#x1F373;</span>
        </div>
        <h2 class="font-playfair text-2xl font-medium text-white mb-2">Espace Lorenzo</h2>
        <p class="text-white/50 text-sm">Equipe LAOM 2026</p>
      </div>
      <form id="password-form" class="space-y-4">
        <input type="password" id="password-input" placeholder="Mot de passe" class="w-full px-5 py-4 rounded-sm bg-white/5 border border-white/10 text-white placeholder-white/30 text-center text-lg tracking-widest focus:outline-none focus:border-[#C4A855]/50 focus:ring-1 focus:ring-[#C4A855]/30 transition-all" autocomplete="off" />
        <button type="submit" class="w-full px-6 py-4 rounded-sm bg-[#C4A855] text-white font-medium text-sm tracking-wider uppercase hover:bg-[#B09A4A] transition-colors">Acceder</button>
        <p id="password-error" class="text-red-400 text-sm hidden">Mot de passe incorrect</p>
      </form>
    </div>
  </div>

  <MobileNav currentPage="/lorenzo/" />

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-20 sm:pt-24 pb-8 sm:pb-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-[#C4A855]/20 flex items-center justify-center">
          <span class="text-3xl sm:text-4xl">&#x1F468;&#x200D;&#x1F373;</span>
        </div>
        <div>
          <h1 class="font-playfair text-3xl sm:text-4xl font-medium text-white tracking-tight">{profil.nom}</h1>
          <p class="text-[#C4A855] text-sm sm:text-base">{profil.role}</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-4 text-sm">
        <div class="bg-white/5 border border-white/10 rounded-sm px-4 py-2">
          <span class="text-white/50">Semaine : </span>
          <span class="text-white font-medium">{currentWeek}</span>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-sm px-4 py-2">
          <span class="text-white/50">Progression : </span>
          <span class="text-[#4A7C59] font-medium">{completedCount}/{tasks.length} taches</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Objectifs de la semaine -->
  {objectives.length > 0 && (
    <section class="py-6 sm:py-8 bg-[#C4A855]/10 border-b border-[#C4A855]/20">
      <div class="max-w-4xl mx-auto px-4 sm:px-8">
        <h2 class="text-xs font-medium tracking-[0.15em] uppercase text-[#C4A855] mb-3">Objectifs de la semaine</h2>
        <ul class="space-y-2">
          {objectives.map((obj: any) => (
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#C4A855] mt-2 flex-shrink-0"></span>
              <span class="text-sm sm:text-base text-[#2C2824] font-medium">{obj.content}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Taches du jour (highlight) -->
  {dailyTasks.length > 0 && (
    <section class="py-6 sm:py-8 bg-white border-b border-black/5">
      <div class="max-w-4xl mx-auto px-4 sm:px-8">
        <h2 class="text-xs font-medium tracking-[0.15em] uppercase text-red-500 mb-4">Taches du jour</h2>
        <div class="space-y-3">
          {dailyTasks.map((t: any) => (
            <div class="flex items-start gap-3 p-3 bg-red-50 rounded-sm border border-red-100" data-task-id={t.id}>
              <button
                class="task-toggle mt-0.5 w-6 h-6 rounded border-2 flex-shrink-0 flex items-center justify-center transition-colors cursor-pointer"
                data-completed={t.completed ? 'true' : 'false'}
                style={t.completed ? 'background-color: #4A7C59; border-color: #4A7C59;' : 'border-color: #dc2626;'}
              >
                {t.completed ? (
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                ) : null}
              </button>
              <span class={`text-sm sm:text-base ${t.completed ? 'line-through text-[#2C2824]/40' : 'text-[#2C2824]'}`}>{t.content}</span>
              {t.priority === 'high' && <span class="text-[10px] px-2 py-0.5 rounded bg-red-500/10 text-red-600 border border-red-200 flex-shrink-0">prioritaire</span>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Toutes les taches de la semaine -->
  <section class="py-8 sm:py-10 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <h2 class="font-playfair text-xl sm:text-2xl font-medium text-[#2C2824] mb-6">Taches de la semaine</h2>

      {allTasks.length > 0 ? (
        <div class="space-y-3">
          {allTasks.map((t: any) => (
            <div class={`flex items-start gap-3 p-3 rounded-sm border ${t.completed ? 'bg-[#4A7C59]/5 border-[#4A7C59]/20' : 'bg-white border-black/5'}`} data-task-id={t.id}>
              <button
                class="task-toggle mt-0.5 w-6 h-6 rounded border-2 flex-shrink-0 flex items-center justify-center transition-colors cursor-pointer"
                data-completed={t.completed ? 'true' : 'false'}
                style={t.completed ? 'background-color: #4A7C59; border-color: #4A7C59;' : 'border-color: #2C282440;'}
              >
                {t.completed ? (
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                ) : null}
              </button>
              <div class="flex-1 min-w-0">
                <span class={`text-sm sm:text-base ${t.completed ? 'line-through text-[#2C2824]/40' : 'text-[#2C2824]'}`}>{t.content}</span>
              </div>
              {t.priority === 'high' && <span class="text-[10px] px-2 py-0.5 rounded bg-red-500/10 text-red-600 border border-red-200 flex-shrink-0">prioritaire</span>}
              {t.priority === 'normal' && !t.is_daily_highlight && <span class="text-[10px] px-2 py-0.5 rounded bg-gray-100 text-gray-500 border border-gray-200 flex-shrink-0">normal</span>}
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-[#2C2824]/40">
          <p class="text-lg mb-1">Pas de taches pour cette semaine</p>
          <p class="text-sm">Charly va bientot poser les taches</p>
        </div>
      )}
    </div>
  </section>

  <!-- Zone Observation (dictee vocale) -->
  <section class="py-8 sm:py-10 bg-white border-t border-black/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <h2 class="font-playfair text-xl sm:text-2xl font-medium text-[#2C2824] mb-2">Observation du jour</h2>
      <p class="text-sm text-[#2C2824]/50 mb-6">Dicte ou ecris ce que tu veux remonter a Charly</p>

      <div class="bg-[#FAF8F5] rounded-sm border border-black/5 p-4 sm:p-6">
        <textarea
          id="observation-text"
          rows="4"
          placeholder="Appuie sur le micro pour dicter, ou ecris ici..."
          class="w-full bg-transparent border-none resize-none text-[#2C2824] placeholder-[#2C2824]/30 focus:outline-none text-sm sm:text-base"
        ></textarea>

        <div class="flex items-center justify-between mt-4 pt-4 border-t border-black/5">
          <button
            id="mic-button"
            class="flex items-center gap-2 px-4 py-3 rounded-sm bg-[#C4A855] text-white text-sm font-medium hover:bg-[#B09A4A] transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-14 0m7 7v4m-4 0h8M12 1a3 3 0 00-3 3v7a3 3 0 006 0V4a3 3 0 00-3-3z" />
            </svg>
            <span id="mic-label">Dicter</span>
          </button>

          <button
            id="send-observation"
            class="px-6 py-3 rounded-sm bg-[#4A7C59] text-white text-sm font-medium hover:bg-[#3d6a4a] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            disabled
          >
            Envoyer
          </button>
        </div>
      </div>

      <!-- Observations du jour -->
      {observations.length > 0 && (
        <div class="mt-6">
          <h3 class="text-xs font-medium tracking-[0.15em] uppercase text-[#2C2824]/40 mb-3">Envoye aujourd'hui</h3>
          <div class="space-y-2">
            {observations.map((obs: any) => (
              <div class="bg-[#4A7C59]/5 border border-[#4A7C59]/20 rounded-sm p-3">
                <p class="text-sm text-[#2C2824]">{obs.content}</p>
                <p class="text-[10px] text-[#2C2824]/30 mt-1">{new Date(obs.created_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Planning long terme (repliable) -->
  <section class="py-8 sm:py-10 bg-[#FAF8F5] border-t border-black/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <details>
        <summary class="font-playfair text-xl sm:text-2xl font-medium text-[#2C2824] cursor-pointer hover:text-[#C4A855] transition-colors">
          Planning long terme 2026
        </summary>

        <div class="mt-6">
          <!-- 4 Cuissons signatures -->
          <h3 class="text-sm font-medium text-[#C4A855] uppercase tracking-wider mb-3">Les 4 cuissons signatures</h3>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {cuissonsSignatures.map((c) => (
              <div class="bg-white rounded-sm border border-black/5 p-4">
                <h4 class="font-medium text-[#C4A855] mb-1">{c.nom}</h4>
                <p class="text-sm text-[#2C2824]/70">{c.desc}</p>
              </div>
            ))}
          </div>

          <!-- Equipe -->
          <h3 class="text-sm font-medium text-[#C4A855] uppercase tracking-wider mb-3">Ton equipe</h3>
          <div class="grid sm:grid-cols-3 gap-3 mb-8">
            {equipe.map((e) => (
              <div class="bg-white rounded-sm border border-black/5 p-4">
                <p class="font-medium text-[#2C2824]">{e.nom}</p>
                <p class="text-xs text-[#2C2824]/60 mb-2">{e.role}</p>
                <span class="text-xs text-[#4A7C59]">{e.statut}</span>
              </div>
            ))}
          </div>

          <!-- Documents obligatoires -->
          <h3 class="text-sm font-medium text-[#C4A855] uppercase tracking-wider mb-3">Documents obligatoires</h3>
          <div class="bg-white rounded-sm border border-black/5 p-4">
            <ul class="grid sm:grid-cols-2 gap-2">
              {documentsObligatoires.map((doc) => (
                <li class="flex items-center gap-2 text-sm text-[#2C2824]/80">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#C4A855] flex-shrink-0"></span>
                  {doc}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </details>
    </div>
  </section>

  <!-- Footer -->
  <section class="py-6 sm:py-8 bg-[#1a1a1a]">
    <div class="max-w-4xl mx-auto px-4 sm:px-8 text-center">
      <p class="text-sm text-white/50 mb-2">Questions ? Contacte Charly</p>
      <p class="text-white">{profil.contact}</p>
    </div>
  </section>

  <script is:inline>
    // ==========================================
    // PASSWORD PROTECTION
    // ==========================================
    const PASSWORD = 'laom2026'
    const STORAGE_KEY = 'laom_auth'
    const overlay = document.getElementById('password-overlay')
    const form = document.getElementById('password-form')
    const input = document.getElementById('password-input')
    const error = document.getElementById('password-error')

    if (localStorage.getItem(STORAGE_KEY) === 'true') {
      overlay.style.display = 'none'
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      if (input.value === PASSWORD) {
        localStorage.setItem(STORAGE_KEY, 'true')
        overlay.style.display = 'none'
      } else {
        error.classList.remove('hidden')
        input.classList.add('border-red-500')
      }
    })

    // ==========================================
    // TASK TOGGLE (checkboxes)
    // ==========================================
    document.querySelectorAll('.task-toggle').forEach(btn => {
      btn.addEventListener('click', async () => {
        const taskEl = btn.closest('[data-task-id]')
        if (!taskEl) return
        const taskId = taskEl.getAttribute('data-task-id')

        try {
          const res = await fetch(`/api/tasks/${taskId}`, { method: 'POST' })
          if (res.ok) {
            // Reload page to reflect new state
            window.location.reload()
          }
        } catch (e) {
          console.error('Toggle failed:', e)
        }
      })
    })

    // ==========================================
    // SPEECH-TO-TEXT (Web Speech API)
    // ==========================================
    const micBtn = document.getElementById('mic-button')
    const micLabel = document.getElementById('mic-label')
    const textArea = document.getElementById('observation-text')
    const sendBtn = document.getElementById('send-observation')

    let recognition = null
    let isRecording = false

    // Enable send button when text is present
    textArea.addEventListener('input', () => {
      sendBtn.disabled = !textArea.value.trim()
    })

    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition
      recognition = new SpeechRecognition()
      recognition.continuous = true
      recognition.interimResults = true
      recognition.lang = 'fr-FR'

      let finalTranscript = ''

      recognition.onresult = (event) => {
        let interim = ''
        for (let i = event.resultIndex; i < event.results.length; i++) {
          const transcript = event.results[i][0].transcript
          if (event.results[i].isFinal) {
            finalTranscript += transcript + ' '
          } else {
            interim += transcript
          }
        }
        textArea.value = finalTranscript + interim
        sendBtn.disabled = !textArea.value.trim()
      }

      recognition.onend = () => {
        if (isRecording) {
          // Auto-restart if user hasn't stopped manually
          recognition.start()
        }
      }

      recognition.onerror = (event) => {
        if (event.error === 'no-speech') return // Ignore silence
        console.error('Speech error:', event.error)
        isRecording = false
        micLabel.textContent = 'Dicter'
        micBtn.style.backgroundColor = '#C4A855'
      }

      micBtn.addEventListener('click', () => {
        if (isRecording) {
          isRecording = false
          recognition.stop()
          micLabel.textContent = 'Dicter'
          micBtn.style.backgroundColor = '#C4A855'
        } else {
          isRecording = true
          finalTranscript = textArea.value
          recognition.start()
          micLabel.textContent = 'Stop'
          micBtn.style.backgroundColor = '#dc2626'
        }
      })
    } else {
      // Pas de support Speech — cacher le bouton micro
      micBtn.style.display = 'none'
    }

    // ==========================================
    // SEND OBSERVATION
    // ==========================================
    sendBtn.addEventListener('click', async () => {
      const content = textArea.value.trim()
      if (!content) return

      sendBtn.disabled = true
      sendBtn.textContent = 'Envoi...'

      try {
        const today = new Date().toISOString().split('T')[0]
        const res = await fetch('/api/observations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ person: 'lorenzo', content, date: today })
        })

        if (res.ok) {
          textArea.value = ''
          window.location.reload()
        } else {
          alert('Erreur lors de l\'envoi')
          sendBtn.disabled = false
          sendBtn.textContent = 'Envoyer'
        }
      } catch (e) {
        alert('Erreur de connexion')
        sendBtn.disabled = false
        sendBtn.textContent = 'Envoyer'
      }
    })
  </script>
</Layout>
