---
import Layout from '~/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations, getLocalizedPath } from '~/i18n/utils'

import PageHeader from '~/components/laom/PageHeader.astro'
import SectionHead from '~/components/laom/sections/SectionHead.astro'
import BlogCard from '~/components/laom/BlogCard.astro'
import EventList from '~/components/laom/sections/EventList.astro'
import CtaSection from '~/components/laom/sections/CtaSection.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const lang = 'fr'
const t = getTranslations(lang as 'fr' | 'en')

const allPosts = await getCollection('blog', ({ data }) => data.locale === lang && !data.draft)
const posts = allPosts
  .filter((p) => !p.data.tags?.includes('newsletter'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const allNewsletters = await getCollection('newsletters')
const newsletters = allNewsletters
  .filter((e) => (!e.data.locale || e.data.locale === lang) && /LaomLetter/i.test(e.data.title))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const pageSchema = createWebPageSchema({
  name: t.blog.title,
  url: Astro.url.toString(),
  description: t.blog.description,
})

const F = (n: string) => `/images/festival/${n}.webp`
const fmtDate = (d: Date) => new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })

const cards = posts.map((p, i) => ({
  img: p.data.heroImage || F(`blog-${(i % 2) + 1}`),
  date: fmtDate(p.data.pubDate),
  title: p.data.title,
  href: getLocalizedPath(`/blog/${p.slug}/`, 'fr'),
}))
const letterRows = newsletters.map((n) => ({
  date: fmtDate(n.data.date),
  title: n.data.title,
  desc: n.data.description,
  href: n.data.url,
}))
---

<Layout
  title={`${t.blog.title} – LAOM`}
  description={t.blog.description}
  hideChrome={true}
  seo={{ ldJSON: pageSchema }}
>
  <PageHeader img={F('blog-2')} title={t.blog.title} subtitle={t.blog.heroSubtitle} />

  <section class="bg-[#F2EBDB] py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
      <SectionHead eyebrow={t.blog.heroLabel} title="Tous les" accent="récits" class="mb-12" />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {cards.map((c) => <BlogCard img={c.img} date={c.date} title={c.title} href={c.href} />)}
      </div>
    </div>
  </section>

  {letterRows.length > 0 && (
    <EventList eyebrow="Archives" title="Newsletters" accent="passées" bg="bg-[#FBF6EA]" events={letterRows} />
  )}

  <CtaSection img={F('cta')} bg="bg-[#F2EBDB]" eyebrow="Suivre le projet"
    title="Reçois les coulisses" accent="chaque dimanche"
    primaryText="Rejoindre la newsletter" primaryHref="/newsletter/"
    secondaryText="Découvrir le projet" secondaryHref="/qui-sommes-nous/"
    items={[
      {title:'Coulisses du chantier',desc:'Décisions et apprentissages'},
      {title:'Sans filtre',desc:'Les erreurs aussi'},
      {title:'Pas de spam',desc:'Désinscription en un clic'},
    ]} />

  <SiteFooter />
</Layout>
