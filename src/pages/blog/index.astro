---
import Layout from '~/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations } from '~/i18n/utils'

const lang = Astro.currentLocale || 'fr'
const t = getTranslations(lang as 'fr' | 'en')

const allPosts = await getCollection('blog', ({ data }) => {
  return data.locale === lang && !data.draft
})
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const featured = posts[0]
const rest = posts.slice(1)

const allNewsletters = await getCollection('newsletters')
const newsletters = allNewsletters
  .filter((e) => !e.data.locale || e.data.locale === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const pageSchema = createWebPageSchema({
  name: t.blog.title,
  url: Astro.url.toString(),
  description: t.blog.description,
})
---

<Layout
  title={`${t.blog.title} – LAOM`}
  description={t.blog.description}
  seo={{ ldJSON: pageSchema }}
>
  <!-- Hero -->
  <section class="py-32 lg:py-40 bg-[#F3EEDC]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Journal de bord</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-[#2C2824] mb-6 tracking-tight">
        {t.blog.title}
      </h1>
      <p class="text-xl md:text-2xl font-light text-[#2C2824]/60 max-w-3xl mx-auto leading-relaxed">
        Récits de construction, apprentissages et coulisses d'un écolieu en devenir.
      </p>
    </div>
  </section>

  {posts.length === 0 ? (
    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
        <p class="text-lg font-light text-[#2C2824]/60">{t.blog.empty}</p>
      </div>
    </section>
  ) : (
    <>
      <!-- Featured article,  full width hero style -->
      {featured && (
        <section class="bg-white">
          <a href={`/blog/${featured.slug}/`} class="group block">
            <div class="relative aspect-[21/9] overflow-hidden">
              {featured.data.heroImage ? (
                <img
                  src={featured.data.heroImage}
                  alt={featured.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700"
                  loading="eager"
                />
              ) : (
                <div class="w-full h-full bg-[#E8E3D8]"></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12 lg:p-16">
                <p class="text-xs font-light tracking-[0.2em] uppercase text-white/60 mb-4">
                  {new Date(featured.data.pubDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                </p>
                <h2 class="font-playfair text-3xl md:text-4xl lg:text-5xl font-medium text-white tracking-tight leading-tight mb-4 max-w-3xl">
                  {featured.data.title}
                </h2>
                <p class="text-base md:text-lg font-light text-white/75 leading-relaxed max-w-2xl line-clamp-2">
                  {featured.data.description}
                </p>
              </div>
            </div>
          </a>
        </section>
      )}

      <!-- Articles grid -->
      {rest.length > 0 && (
        <section class="py-20 md:py-24 bg-[#F3EEDC]">
          <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
            <div class="grid md:grid-cols-2 gap-x-10 gap-y-16">
              {rest.map((post) => (
                <a href={`/blog/${post.slug}/`} class="group block">
                  <article>
                    {post.data.heroImage && (
                      <div class="aspect-[16/10] overflow-hidden rounded-sm mb-6">
                        <img
                          src={post.data.heroImage}
                          alt={post.data.title}
                          class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                          loading="lazy"
                        />
                      </div>
                    )}
                    <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-3">
                      {new Date(post.data.pubDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                    </p>
                    <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-3 tracking-tight leading-snug group-hover:text-[#2C2824]/70 transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="text-base font-light text-[#2C2824]/60 leading-relaxed line-clamp-3">
                      {post.data.description}
                    </p>
                  </article>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </>
  )}

  <!-- Past Newsletters -->
  {newsletters.length > 0 && (
    <section class="py-20 md:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Archives</p>
        <h2 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight mb-10">{t.blog.newsletterSectionTitle}</h2>
        <div class="space-y-0">
          {newsletters.map((nl) => {
            const formattedDate = new Date(nl.data.date).toLocaleDateString('fr-FR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
            return (
              <a
                href={nl.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-baseline justify-between py-5 border-b border-black/10 hover:border-[#C4A855]/40 transition-colors"
                aria-label={`${nl.data.title} (opens in new tab)`}
              >
                <span class="font-playfair text-lg font-medium text-[#2C2824] group-hover:text-[#2C2824]/70 transition-colors tracking-tight">
                  {nl.data.title}
                </span>
                <span class="text-xs font-light text-[#2C2824]/40 tracking-[0.1em] uppercase flex-shrink-0 ml-6">
                  {formattedDate}
                </span>
              </a>
            )
          })}
        </div>
      </div>
    </section>
  )}
</Layout>
