---
import Layout from '~/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations } from '~/i18n/utils'
import { getLocalizedPath } from '~/i18n/utils'

const lang = Astro.currentLocale || 'fr'
const t = getTranslations(lang as 'fr' | 'en')

// Get all blog posts
const allPosts = await getCollection('blog')
const postEntry = allPosts.find((p) => p.slug === Astro.params.slug && p.data.locale === lang)

if (!postEntry) {
  return Astro.redirect('/blog/')
}

// Render the content
const { Content } = await postEntry.render()
const post = postEntry

// Format date
const formattedPubDate = new Date(post.data.pubDate).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

// Related articles: same locale, exclude current and newsletters (LaomLetters), max 3
const relatedPosts = allPosts
  .filter(p => p.data.locale === lang && !p.data.draft && !p.data.tags?.includes('newsletter') && p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

// Create article schema for JSON-LD
const pageSchema = createWebPageSchema({
  name: post.data.title,
  url: Astro.url.toString(),
  description: post.data.description,
  image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site || Astro.url).toString() : undefined,
})
---

<Layout
  title={`${post.data.title} – LAOM`}
  description={post.data.description}
  seo={{
    ldJSON: pageSchema,
    ogType: 'article',
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
    image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site || Astro.url).toString() : undefined,
  }}
>

  <article>
    <!-- Hero -->
    {post.data.heroImage && (
      <section class="relative w-full -mt-24 md:-mt-28">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          title={post.data.title}
          class="w-full h-[50vh] md:h-[65vh] lg:h-[75vh] object-cover object-center"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent flex flex-col items-center justify-end pb-10 md:pb-16 lg:pb-20 gap-2 md:gap-3">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-white/70 mb-1 md:mb-2">
            {formattedPubDate}
          </p>
          <h1 class="font-playfair text-2xl md:text-4xl lg:text-6xl font-medium text-white tracking-tight text-center max-w-4xl px-6 md:px-8 drop-shadow-lg leading-tight">
            {post.data.title}
          </h1>
        </div>
      </section>
    )}

    {!post.data.heroImage && (
      <section class="pt-16 pb-8 bg-white">
        <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-black/40 mb-6">
            {formattedPubDate}
          </p>
          <h1 class="font-playfair text-4xl md:text-5xl lg:text-6xl font-medium text-[#2C2824] tracking-tight leading-tight">
            {post.data.title}
          </h1>
        </div>
      </section>
    )}

    <!-- Intro -->
    <section class="py-12 md:py-16 bg-[#FAF8F5]">
      <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
        <p class="font-playfair text-xl md:text-2xl leading-relaxed text-[#2C2824]">
          {post.data.description}
        </p>
        {post.data.author && post.data.author !== 'LAOM' && (
          <p class="mt-6 text-sm font-light text-[#2C2824]/50">
            {t.blog.by} {post.data.author}
          </p>
        )}
      </div>
    </section>

    <!-- YouTube embed if present -->
    {post.data.youtubeId && (
      <section class="py-8 bg-white">
        <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
          <div class="aspect-video w-full rounded-sm overflow-hidden border border-black/5">
            <iframe
              src={`https://www.youtube.com/embed/${post.data.youtubeId}`}
              title={post.data.title}
              class="w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            />
          </div>
        </div>
      </section>
    )}

    <!-- Article Content -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24 article-content">
        <Content />
      </div>
    </section>

    <!-- A lire aussi -->
    {relatedPosts.length > 0 && (
      <section class="py-16 md:py-24 bg-[#FAF8F5] border-t border-black/5">
        <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
          <h2 class="font-playfair text-2xl md:text-3xl font-normal text-[#2C2824] tracking-tight mb-12">
            {t.blog.relatedTitle}
          </h2>

          <div class="grid md:grid-cols-3 gap-8">
            {relatedPosts.map((related) => (
              <a href={getLocalizedPath(`/blog/${related.slug}/`, lang as 'fr' | 'en')} class="group block">
                <article class="flex flex-col">
                  {related.data.heroImage && (
                    <div class="aspect-[16/10] overflow-hidden rounded-sm mb-5">
                      <img
                        src={related.data.heroImage}
                        alt={related.data.title}
                        title={related.data.title}
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-2">
                    {new Date(related.data.pubDate).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', { year: 'numeric', month: 'long' })}
                  </p>
                  <h3 class="font-playfair text-lg font-normal text-[#2C2824] mb-2 tracking-tight leading-snug group-hover:text-[#2C2824]/70 transition-colors">
                    {related.data.title}
                  </h3>
                  <p class="text-sm font-light text-[#2C2824]/60 leading-relaxed line-clamp-2">
                    {related.data.description}
                  </p>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Back -->
    <section class="py-12 bg-white">
      <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
        <a
          href={getLocalizedPath('/blog/', lang as 'fr' | 'en')}
          class="text-sm font-light text-[#2C2824]/40 hover:text-[#2C2824] transition-colors underline underline-offset-4"
        >
          &larr; {t.blog.backToBlogLabel}
        </a>
      </div>
    </section>
  </article>

  <style is:inline>
    /* Article content,  editorial styling */
    .article-content h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 2.25rem;
      font-weight: 500;
      color: #2C2824;
      margin-top: 0;
      margin-bottom: 2.5rem;
      letter-spacing: -0.02em;
      line-height: 1.25;
    }
    .article-content h2 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.75rem;
      font-weight: 500;
      color: #2C2824;
      margin-top: 3rem;
      margin-bottom: 1.25rem;
      letter-spacing: -0.02em;
      line-height: 1.3;
    }
    .article-content h3 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.35rem;
      font-weight: 500;
      color: #2C2824;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
    }
    .article-content p {
      font-size: 1.125rem;
      font-weight: 300;
      color: rgba(44, 40, 36, 0.85);
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }
    .article-content > p:first-of-type::first-letter {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 3.5rem;
      font-weight: 400;
      float: left;
      line-height: 1;
      margin-right: 0.5rem;
      margin-top: 0.15rem;
      color: #2C2824;
    }
    .article-content strong {
      font-weight: 500;
      color: #2C2824;
    }
    .article-content em {
      font-style: italic;
    }
    .article-content blockquote {
      border-left: 2px solid #C4A855;
      padding-left: 2rem;
      margin: 2.5rem 0;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
    .article-content blockquote p {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.25rem;
      font-style: italic;
      color: rgba(44, 40, 36, 0.85);
      line-height: 1.6;
    }
    .article-content ul, .article-content ol {
      font-size: 1.125rem;
      font-weight: 300;
      color: rgba(44, 40, 36, 0.85);
      line-height: 1.8;
      margin-bottom: 1.5rem;
      padding-left: 2rem;
      list-style-position: outside;
    }
    .article-content ul {
      list-style-type: disc;
    }
    .article-content ol {
      list-style-type: decimal;
    }
    .article-content li {
      margin-bottom: 0.5rem;
      padding-left: 0.35rem;
    }
    .article-content img {
      width: 100%;
      border-radius: 2px;
      margin: 2rem 0;
    }
    .article-content a {
      color: #8B7A3A;
      font-weight: 500;
      border-bottom: 2px solid #8B7A3A;
      text-decoration: none;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }
    .article-content a:hover {
      color: #6B5A2A;
      border-color: #6B5A2A;
      background: rgba(139, 122, 58, 0.08);
    }
    .article-content hr {
      border: none;
      border-top: 1px solid rgba(44, 40, 36, 0.1);
      margin: 3rem 0;
    }
  </style>

</Layout>
