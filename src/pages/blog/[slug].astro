---
// Article du journal — charte LAOM (Host Grotesk, beige/crème/terre/marron).
// Logique data/SEO inchangée ; seule la présentation a été rebrandée (juil. 2026).
import Layout from '~/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations } from '~/i18n/utils'
import { getLocalizedPath } from '~/i18n/utils'
import { laboNav as navLinks } from '~/data/laboNav'
import SiteNav from '~/components/laom/SiteNav.astro'
import SectionHead from '~/components/laom/sections/SectionHead.astro'
import BlogCard from '~/components/laom/BlogCard.astro'
import CtaBand from '~/components/laom/sections/CtaBand.astro'
import SiteFooter from '~/components/laom/SiteFooter.astro'

const lang = Astro.currentLocale || 'fr'
const t = getTranslations(lang as 'fr' | 'en')

// Get all blog posts
const allPosts = await getCollection('blog')
const postEntry = allPosts.find((p) => p.slug === Astro.params.slug && p.data.locale === lang)

if (!postEntry) {
  return Astro.redirect('/blog/')
}

// Render the content
const { Content } = await postEntry.render()
const post = postEntry

// Format date
const formattedPubDate = new Date(post.data.pubDate).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

// Related articles: same locale, exclude current and newsletters (LaomLetters), max 3
const relatedPosts = allPosts
  .filter(p => p.data.locale === lang && !p.data.draft && !p.data.tags?.includes('newsletter') && p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const fmtShort = (d: Date) =>
  new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })

// Create article schema for JSON-LD
const pageSchema = createWebPageSchema({
  name: post.data.title,
  url: Astro.url.toString(),
  description: post.data.description,
  image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site || Astro.url).toString() : undefined,
})
---

<Layout
  title={`${post.data.title} – LAOM`}
  description={post.data.description}
  hideChrome={true}
  seo={{
    ldJSON: pageSchema,
    ogType: 'article',
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
    image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site || Astro.url).toString() : undefined,
  }}
>
  <SiteNav transparent={Boolean(post.data.heroImage)} links={navLinks} ctaText="Candidater" ctaHref="/candidater/" />

  <article>
    {post.data.heroImage ? (
      <header class="relative w-full">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          title={post.data.title}
          class="w-full h-[55vh] md:h-[65vh] object-cover object-center"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#1D1B18]/85 via-[#1D1B18]/25 to-[#1D1B18]/20 flex flex-col items-center justify-end pb-12 md:pb-16 gap-4">
          <span class="rounded-full bg-[#F2EBDB]/95 text-[#412F1F] text-xs font-medium px-3 py-1.5">{formattedPubDate}</span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-[#F2EBDB] tracking-[-0.02em] leading-[1.1] text-balance text-center max-w-4xl px-6">
            {post.data.title}
          </h1>
        </div>
      </header>
    ) : (
      <header class="bg-[#FBF6EA] pt-36 md:pt-44 pb-10">
        <div class="max-w-3xl mx-auto px-6">
          <span class="inline-block rounded-full bg-[#412F1F]/8 text-[#412F1F] text-xs font-medium px-3 py-1.5 mb-6">{formattedPubDate}</span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.1] text-balance">
            {post.data.title}
          </h1>
        </div>
      </header>
    )}

    <!-- Lede -->
    <section class="bg-[#FBF6EA] py-12 md:py-16">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-xl md:text-2xl font-medium italic text-[#412F1F] leading-relaxed text-pretty">
          {post.data.description}
        </p>
        {post.data.author && post.data.author !== 'LAOM' && (
          <p class="mt-6 text-sm text-[#1D1B18]/60">
            {t.blog.by} {post.data.author}
          </p>
        )}
      </div>
    </section>

    <!-- YouTube embed if present -->
    {post.data.youtubeId && (
      <section class="bg-[#F2EBDB] pt-14 md:pt-20">
        <div class="max-w-4xl mx-auto px-6">
          <div class="aspect-video w-full rounded-2xl overflow-hidden">
            <iframe
              src={`https://www.youtube.com/embed/${post.data.youtubeId}`}
              title={post.data.title}
              class="w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            />
          </div>
        </div>
      </section>
    )}

    <!-- Article Content -->
    <section class="bg-[#F2EBDB] py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-6 article-content">
        <Content />
      </div>
      <div class="max-w-3xl mx-auto px-6 mt-14">
        <a href={getLocalizedPath('/blog/', lang as 'fr' | 'en')}
          class="pill pill-outline inline-flex" style="padding:.8rem 1.8rem">
          ← {t.blog.backToBlogLabel}
        </a>
      </div>
    </section>

    <!-- A lire aussi -->
    {relatedPosts.length > 0 && (
      <section class="bg-[#FBF6EA] py-20 md:py-28">
        <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
          <SectionHead eyebrow="Le journal" title={t.blog.relatedTitle} class="mb-12" />
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedPosts.map((related) => (
              <BlogCard
                img={related.data.heroImage || '/images/festival/blog-1.webp'}
                date={fmtShort(related.data.pubDate)}
                title={related.data.title}
                href={getLocalizedPath(`/blog/${related.slug}/`, lang as 'fr' | 'en')}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <CtaBand eyebrow="Suivre le projet"
    title="Reçois les coulisses" accent="chaque dimanche."
    subtitle="Le chantier, le lieu, la communauté — sans filtre, dans la LAOM Letter."
    primaryText="Rejoindre la newsletter" primaryHref="/newsletter/" />

  <SiteFooter />

  <style is:inline>
    /* Contenu d'article — charte LAOM (Host Grotesk, marron/terre sur beige). */
    .article-content h1,
    .article-content h2 {
      font-size: 1.9rem;
      font-weight: 800;
      color: #412F1F;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-top: 3rem;
      margin-bottom: 1.25rem;
      text-wrap: balance;
    }
    .article-content h3 {
      font-size: 1.4rem;
      font-weight: 800;
      color: #412F1F;
      letter-spacing: -0.01em;
      line-height: 1.25;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      text-wrap: balance;
    }
    .article-content p {
      font-size: 1.125rem;
      color: rgba(29, 27, 24, 0.92);
      line-height: 1.8;
      margin-bottom: 1.5rem;
      text-wrap: pretty;
    }
    .article-content > p:first-of-type::first-letter {
      font-size: 3.4rem;
      font-weight: 800;
      float: left;
      line-height: 0.95;
      margin-right: 0.6rem;
      margin-top: 0.3rem;
      color: #9A3922;
    }
    .article-content strong {
      font-weight: 700;
      color: #412F1F;
    }
    .article-content em { font-style: italic; }
    .article-content blockquote {
      background: #FBF6EA;
      border-radius: 1rem;
      padding: 1.75rem 2rem;
      margin: 2.5rem 0;
    }
    .article-content blockquote p {
      font-size: 1.25rem;
      font-weight: 500;
      font-style: italic;
      color: #412F1F;
      line-height: 1.6;
      margin-bottom: 0;
    }
    .article-content blockquote p + p { margin-top: 1rem; }
    .article-content ul, .article-content ol {
      font-size: 1.125rem;
      color: rgba(29, 27, 24, 0.92);
      line-height: 1.8;
      margin-bottom: 1.5rem;
      padding-left: 1.75rem;
      list-style-position: outside;
    }
    .article-content ul { list-style-type: disc; }
    .article-content ol { list-style-type: decimal; }
    .article-content li { margin-bottom: 0.5rem; padding-left: 0.35rem; }
    .article-content li::marker { color: #9A3922; }
    .article-content img {
      width: 100%;
      border-radius: 1rem;
      margin: 2.25rem 0 0.75rem;
    }
    /* Légendes d'images : un paragraphe qui ne contient qu'un <em> */
    .article-content p:has(> em:only-child) {
      text-align: center;
      font-size: 0.875rem;
      color: rgba(29, 27, 24, 0.6);
      margin-top: 0;
      margin-bottom: 2.25rem;
      line-height: 1.5;
    }
    .article-content a {
      color: #9A3922;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1.5px;
      transition: color 0.2s;
    }
    .article-content a:hover { color: #412F1F; }
    .article-content hr {
      border: none;
      border-top: 1px solid rgba(65, 47, 31, 0.15);
      margin: 3rem 0;
    }
  </style>
</Layout>
