        }
      ];

      // Skip tout si l'offre est déjà expirée
      var deadline = parseInt(localStorage.getItem(LS_KEY_DEADLINE) || '0', 10);
      if (deadline && deadline - Date.now() <= 0) return;

      var popupIndex = parseInt(localStorage.getItem(LS_KEY_EXIT) || '0', 10);
      var lastShownAt = 0;
      var popupShowing = false;
      var clicked = false;

      // Marquer si l'utilisateur clique sur un CTA Mollie (on stop d'afficher les popups)
      document.addEventListener('click', function(e) {
        if (e.target.closest('.mollie-cta')) clicked = true;
      });

      function renderPopup(p) {
        var eyebrowEl = document.getElementById('exit-popup-eyebrow');
        var titleEl = document.getElementById('exit-popup-title');
        var bodyEl = document.getElementById('exit-popup-body');
        var ctaEl = document.getElementById('exit-popup-cta');
        var mediaWrapper = document.getElementById('exit-popup-media');
        var gifEl = document.getElementById('exit-popup-gif');

        if (eyebrowEl) eyebrowEl.textContent = p.eyebrow;
        if (titleEl) titleEl.textContent = p.title;
        if (bodyEl) bodyEl.innerHTML = p.body;
        if (ctaEl) ctaEl.textContent = p.cta;

        // Gestion GIF : affiche si URL, sinon cache
        if (mediaWrapper && gifEl) {
          if (p.gif) {
            gifEl.src = p.gif;
            gifEl.alt = p.title;
            mediaWrapper.classList.remove('hidden');
          } else {
            gifEl.src = '';
            gifEl.alt = '';
            mediaWrapper.classList.add('hidden');
          }
        }
      }

      function openPopup() {
        var popup = document.getElementById('exit-popup');
        if (popup) {
          popup.classList.remove('hidden');
          popup.classList.add('flex');
        }
      }

      function closePopup() {
        var popup = document.getElementById('exit-popup');
        if (popup) {
          popup.classList.add('hidden');
          popup.classList.remove('flex');
        }
        popupShowing = false;
      }

      function showNextPopup() {
        if (popupShowing || clicked) return;
        if (Date.now() - lastShownAt < COOLDOWN_MS) return;
        if (popupIndex >= POPUPS.length) return; // Plus de popups, on arrête

        var p = POPUPS[popupIndex];
        renderPopup(p);
        openPopup();
        popupShowing = true;
        lastShownAt = Date.now();
        popupIndex++;
        localStorage.setItem(LS_KEY_EXIT, popupIndex.toString());

        // Tracking GA4
        if (typeof gtag === 'function') {
          gtag('event', 'exit_intent_popup_shown', {
            event_category: 'engagement',
            popup_index: popupIndex,
            popup_title: p.title
          });
        }
        // Tracking Meta Pixel
        if (typeof window.__laomTrack === 'function') {
          window.__laomTrack('ViewContent', {
            content_name: 'exit-intent-popup-' + popupIndex,
            content_category: 'exit_intent'
          });
        }
      }

      // Desktop : exit-intent (souris quitte le viewport par le haut)
      document.addEventListener('mouseout', function(e) {
        if (e.clientY <= 0) showNextPopup();
      });

      // Changement d'onglet / alt-tab (après 10s minimum sur la page)
      var pageLoadTime = Date.now();
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'hidden' && (Date.now() - pageLoadTime) > 10000) {
          showNextPopup();
        }
      });

      // Mobile : après 45s d'inactivité
      setTimeout(function() {
        if (window.innerWidth < 768) showNextPopup();
      }, 45000);

      // Fermer le popup
      var closeBtn = document.getElementById('exit-popup-close');
      if (closeBtn) closeBtn.addEventListener('click', closePopup);
      var popupBackdrop = document.getElementById('exit-popup');
      if (popupBackdrop) {
        popupBackdrop.addEventListener('click', function(e) {
          if (e.target === this) closePopup();
        });
      }
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closePopup();
      });
    })();
  </script>

  <!-- VSL tracking: ViewContent events on milestones (0/25/50/75/100) -->
  <script is:inline>
    (function initVslTracking() {
      var sdkScript = document.createElement('script');
      sdkScript.src = 'https://embed.videodelivery.net/embed/sdk.latest.js';
      sdkScript.async = true;
      sdkScript.onload = function() {
        var iframe = document.getElementById('vsl-player');
        if (!iframe || !window.Stream) return;

        var player = window.Stream(iframe);
        var milestones = { 25: false, 50: false, 75: false };
        var started = false;
        var completed = false;

        function fire(milestone, label) {
          var contentName = 'vsl-merci-' + label;
          if (typeof window.__laomTrack === 'function') {
            window.__laomTrack('ViewContent', {
              content_name: contentName,
              content_category: 'vsl_video',
              content_ids: ['vsl-merci'],
              value: milestone
            });
          }
          if (typeof gtag === 'function') {
            gtag('event', 'video_' + label, {
              video_title: 'vsl-merci',
              video_provider: 'cloudflare-stream',
              milestone: milestone
            });
          }
        }

        player.addEventListener('play', function() {
          if (started) return;
          started = true;
          fire(0, 'start');
        });

        player.addEventListener('timeupdate', function() {
          var duration = player.duration;
          var current = player.currentTime;
          if (!duration) return;
          var percent = (current / duration) * 100;
          [25, 50, 75].forEach(function(m) {
            if (!milestones[m] && percent >= m) {
              milestones[m] = true;
              fire(m, String(m));
            }
          });
        });

        player.addEventListener('ended', function() {
          if (completed) return;
          completed = true;
          fire(100, 'complete');
        });
      };
      document.head.appendChild(sdkScript);
    })();
  </script>

  <!-- Timer 1h script — persistance localStorage + état expiré -->
  <script is:inline>
    (function() {
      var LS_KEY_DEADLINE = 'laom-merci-deadline';
      var LS_KEY_EXPIRED_MODAL = 'laom-merci-expired-modal-shown';
      var DURATION_MS = 60 * 60 * 1000; // 60 min cohérent VSL

      // 1. Lire deadline existante ou créer nouvelle (persistance entre reloads/sessions)
      var stored = localStorage.getItem(LS_KEY_DEADLINE);
      var topDeadline;
      if (stored && parseInt(stored, 10) > 0) {
        topDeadline = parseInt(stored, 10);
      } else {
        topDeadline = Date.now() + DURATION_MS;
        localStorage.setItem(LS_KEY_DEADLINE, topDeadline.toString());
      }

      var expired = topDeadline - Date.now() <= 0;
      var expiredHandled = false;

      var pad = function(n) { return n < 10 ? '0' + n : n; };

      // 2. État expiré : swap CTA 147 → 497 + redirect + modal
      function applyExpiredState() {
        if (expiredHandled) return;
        expiredHandled = true;

        // 2a. Bandeau sticky : swap contenu
        var stickyBanner = document.querySelector('.sticky.top-0.z-50.bg-\\[\\#1a0a0a\\]');
        if (stickyBanner) {
          stickyBanner.innerHTML = [
            '<div class="hidden sm:flex max-w-5xl mx-auto px-4 py-3 items-center justify-center gap-6">',
            '  <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>',
            '  <span class="text-base font-medium text-white">Offre 147 EUR expirée</span>',
            '  <span class="text-xs text-white/60">—</span>',
            '  <span class="text-sm text-white/80">Formation disponible à <strong class="text-white">497 EUR</strong></span>',
            '  <a href="/school/online/" class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-5 py-2 text-xs tracking-[0.15em] uppercase hover:bg-[#B09A4A] transition-colors flex-shrink-0">J\'accède</a>',
            '</div>',
            '<a href="/school/online/" class="sm:hidden flex items-center justify-between px-4 py-2.5">',
            '  <div class="flex items-center gap-2">',
            '    <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>',
            '    <span class="text-xs font-medium text-white">Offre expirée</span>',
            '  </div>',
            '  <span class="text-xs text-white/80">497 EUR</span>',
            '  <span class="text-xs text-[#C4A855] font-medium uppercase tracking-wider">J\'accède</span>',
            '</a>'
          ].join('');
        }

        // 2b. Tous les CTA Mollie 147 EUR → lien /school/online/ 497 EUR
        var ctas = document.querySelectorAll('.mollie-cta, [data-mollie-product="school-merci"]');
        ctas.forEach(function(btn) {
          btn.removeAttribute('data-mollie-product');
          btn.classList.remove('mollie-cta');
          // Texte : remplace "147 EUR" par "497 EUR"
          var original = btn.textContent || '';
          if (original.indexOf('147') !== -1) {
            btn.textContent = original.replace(/147\s*EUR/g, '497 EUR');
          } else {
            btn.textContent = 'J\'accède à la formation · 497 EUR';
          }
          btn.style.cursor = 'pointer';
          // Redirige vers /school/online/ au clic
          btn.onclick = function(e) {
            e.preventDefault();
            window.location.href = '/school/online/';
          };
        });

        // 2c. Modal "Offre expirée" une seule fois (flag localStorage)
        if (!localStorage.getItem(LS_KEY_EXPIRED_MODAL)) {
          var modal = document.getElementById('expired-modal');
          if (modal) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            localStorage.setItem(LS_KEY_EXPIRED_MODAL, '1');
          }
        }

        // 2d. Tracking GA4 + Meta Pixel
        if (typeof gtag === 'function') {
          gtag('event', 'timer_expired', {
            event_category: 'engagement',
            value: 0
          });
        }
        if (typeof window.__laomTrack === 'function') {
          window.__laomTrack('ViewContent', {
            content_name: 'timer-expired',
            content_category: 'offer_lifecycle'
          });
        }
      }

      function updateTopTimer() {
        var now = Date.now();
        var diff = topDeadline - now;
        if (diff <= 0) {
          ['top-minutes','top-seconds','top-minutes-mobile','top-seconds-mobile'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.textContent = '00';
          });
          if (!expiredHandled) applyExpiredState();
          return;
        }
        var m = Math.floor(diff / (1000 * 60));
        var s = Math.floor((diff % (1000 * 60)) / 1000);
        var elMin = document.getElementById('top-minutes');
        var elSec = document.getElementById('top-seconds');
        if (elMin) elMin.textContent = pad(m);
        if (elSec) elSec.textContent = pad(s);
        var mm = document.getElementById('top-minutes-mobile');
        var sm = document.getElementById('top-seconds-mobile');
        if (mm) mm.textContent = pad(m);
        if (sm) sm.textContent = pad(s);
      }

      // 3. Si déjà expiré au chargement, appliquer l'état expiré immédiatement
      if (expired) {
        applyExpiredState();
      }

      updateTopTimer();
      setInterval(updateTopTimer, 1000);

      // 4. Bouton fermer modal expiré
      var expiredCloseBtn = document.getElementById('expired-modal-close');
      if (expiredCloseBtn) {
        expiredCloseBtn.addEventListener('click', function() {
          var modal = document.getElementById('expired-modal');
          if (modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
          }
        });
      }
      var expiredModal = document.getElementById('expired-modal');
      if (expiredModal) {
        expiredModal.addEventListener('click', function(e) {
          if (e.target === this) {
            this.classList.add('hidden');
            this.classList.remove('flex');
          }
        });
      }
    })();
  </script>

