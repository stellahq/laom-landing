---
import Layout from '~/layouts/Layout.astro'
import TunnelTracker from '~/components/TunnelTracker.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Inscription confirmée — Conférence LAOM School',
  url: Astro.url.toString(),
  description: 'Ton inscription est confirmée. Ajoute la conférence à ton calendrier et découvre une offre exclusive.',
})

// Webinar: Mardi 28 avril 2026, 20h30-21h30 (heure de Paris, UTC+2)
const eventTitle = 'Conférence LAOM School — Comment créer un écolieu rentable'
const eventDescription = 'Conférence live avec Charly Aubert. 45 min + Q&A.\\n\\nLien Zoom : https://us06web.zoom.us/webinar/register/WN_Mc2FJFd8TIOiLzTmmGOYuQ'
const eventLocation = 'Zoom (lien envoyé par email)'
const startUTC = '20260428T183000Z'
const endUTC = '20260428T193000Z'

const googleCalUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(eventTitle)}&dates=${startUTC}/${endUTC}&details=${encodeURIComponent('Conférence live avec Charly Aubert. 45 min + Q&A.\n\nLien Zoom : https://us06web.zoom.us/webinar/register/WN_Mc2FJFd8TIOiLzTmmGOYuQ')}&location=${encodeURIComponent(eventLocation)}`

const outlookCalUrl = `https://outlook.live.com/calendar/0/action/compose?rru=addevent&subject=${encodeURIComponent(eventTitle)}&startdt=2026-04-28T18:30:00Z&enddt=2026-04-28T19:30:00Z&body=${encodeURIComponent('Conférence live avec Charly Aubert. 45 min + Q&A.\n\nLien Zoom : https://us06web.zoom.us/webinar/register/WN_Mc2FJFd8TIOiLzTmmGOYuQ')}&location=${encodeURIComponent(eventLocation)}`

const icsContent = `BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//LAOM//School//FR
BEGIN:VEVENT
DTSTART:${startUTC}
DTEND:${endUTC}
SUMMARY:${eventTitle}
DESCRIPTION:${eventDescription}
LOCATION:${eventLocation}
URL:https://us06web.zoom.us/webinar/register/WN_Mc2FJFd8TIOiLzTmmGOYuQ
STATUS:CONFIRMED
END:VEVENT
END:VCALENDAR`

// Paiement Mollie — checkout dynamique à 147 EUR (offre inscrits webinar)
const ctaProductId = 'school-merci'

const modules = [
  {
    num: '01',
    titre: 'Achat et recherche de terrain',
    desc: 'Où chercher, comment évaluer et acheter à plusieurs, sans tomber dans les pièges classiques.',
    points: [
      'Où chercher selon les critères de ton groupe',
      'Comment lire un PLU : zonage, autorisations, constructibilité',
      'Évaluer la viabilité du projet : Géoportail, cadastre, DVF',
      'Évaluer l\'accessibilité : eau, électricité, route, exposition',
      'Acheter à plusieurs sans que ça finisse en conflit',
    ],
  },
  {
    num: '02',
    titre: 'Structure juridique',
    desc: 'Trouver le montage qui fonctionne pour ton groupe, et éviter les erreurs qui nous ont coûté 49 000 EUR.',
    points: [
      'Les 4 structures dans lesquelles on a navigué en 5 ans',
      'Indivision : pourquoi c\'est le piège classique',
      'SAS, SAS Coopérative, SCIA, SCI : avantages et limites',
      'Quand faire appel à un avocat / notaire, et quoi leur demander',
      'Les erreurs juridiques à éviter absolument',
    ],
  },
  {
    num: '03',
    titre: 'Financement et business plan',
    desc: 'Comment on a levé plus de 3M EUR sans prêt bancaire, et comment construire un business plan solide.',
    points: [
      'Les sources : prêts participatifs, love money, crowdfunding, subventions',
      'Construire ton plan de financement étape par étape',
      'Simulation financière : partir de ta situation réelle',
      'Business plan : les bases qui tiennent la route',
      'Présenter ton projet à des investisseurs, des prêteurs, la coopérative Oasis',
    ],
  },
  {
    num: '04',
    titre: 'Légalité et urbanisme',
    desc: 'Mairie, DDT, préfecture : comment leur parler et obtenir tes permis.',
    points: [
      'Les interlocuteurs clés : maire, DDT, ABF, CAUE, chambre d\'agriculture',
      'Les erreurs de posture qui bloquent tout',
      'DP, PC, permis d\'aménager : les démarches d\'urbanisme',
      'Gérer les refus (on en a eu 3) et rebondir',
    ],
  },
  {
    num: '05',
    titre: 'Construction',
    desc: 'Les choix de construction qui ont fait la différence, et ceux qu\'on éviterait aujourd\'hui.',
    points: [
      'Paille porteuse, bois, terre crue : les techniques qu\'on a testées',
      'Comment choisir en fonction de ton budget, ton climat, ton terrain',
      'Autoconstruction vs. faire appel à des pros : quand et pourquoi',
      'Les erreurs de construction : permis, dimensionnement, timing',
    ],
  },
  {
    num: '06',
    titre: 'Communauté et collectif',
    desc: 'Avant le lieu, il y a les gens. C\'est là que tout se joue, et que tout se plante.',
    points: [
      'La personne source : c\'est qui et pourquoi c\'est important',
      'Clarifier les intentions de chacun : vivre sur place, investir, participer de loin ?',
      'Définir les rôles : porteur de projet, gestionnaire, bâtisseur, investisseur passif',
      'Les red flags : quand un groupe ne tiendra pas',
      'Faire tenir une communauté dans le temps',
    ],
  },
  {
    num: '07',
    titre: 'Modèle économique',
    desc: 'Le modèle qui génère 200 à 500K EUR/an, sans devenir esclave du lieu.',
    points: [
      'Le piège du lieu militant sans modèle économique',
      'Les revenus possibles : hébergement, restauration, événements, formation, agritourisme',
      'Combiner les activités pour créer un modèle viable',
      'Construire et piloter ton prévisionnel',
    ],
  },
]

const chiffres = [
  { valeur: '21', unite: 'hectares', desc: 'achetés en collectif, à 8, sans se connaître' },
  { valeur: '850', unite: 'm²', desc: 'de construction écologique en paille porteuse, record mondial' },
  { valeur: '3M', unite: 'EUR', desc: 'levés sans prêt bancaire traditionnel' },
  { valeur: '15', unite: 'foyers', desc: 'qui vivent aujourd\'hui sur le domaine' },
  { valeur: '49K', unite: 'EUR', desc: 'en avocats et frais juridiques, à cause de simples erreurs' },
  { valeur: '5', unite: 'ans', desc: 'de terrain, d\'erreurs et de réussites' },
]

const temoignages = [
  {
    texte: 'Une heure. Il m\'a fallu une heure avec Charly pour avoir les réponses que je cherchais depuis des mois. Il a immédiatement vu les angles morts de mon plan de financement. Quand je fais le calcul des erreurs que j\'aurais commises sans cet échange, c\'est au moins 30 000 euros que je n\'aurai pas à perdre.',
    nom: 'Nicolas',
    role: 'Porteur de projet écolieu',
    initiales: 'N',
  },
  {
    texte: 'Échanger avec Charly, c\'est avoir accès à quelqu\'un qui a déjà porté un lieu pendant cinq ans et qui te dit les choses telles qu\'elles sont. Il nous a ouvert les yeux sur des pistes de financement qu\'on n\'avait pas envisagées. Ce qui a le plus de valeur, c\'est la relation de pair : quelqu\'un qui comprend exactement ce que tu traverses.',
    nom: 'Rico & Martin',
    role: 'Cofondateurs de Naturopia, Madère',
    initiales: 'R&M',
  },
  {
    texte: 'Jusque-là je n\'avais croisé que des alternatifs sans le sou ou des entrepreneurs qui n\'ont rien à faire des questions écologiques. Charly m\'a montré que cette intersection existe. Ça me donne de la force et l\'envie de bâtir des projets d\'envergure allant dans le sens de mes valeurs.',
    nom: 'Nicolas Zanuttini',
    role: 'Auto-entrepreneur',
    initiales: 'NZ',
  },
]

const faq = [
  {
    question: 'Je n\'ai pas encore de terrain. C\'est trop tôt pour moi ?',
    reponse: 'Non, c\'est le meilleur moment. Un des 7 thèmes est justement consacré à la recherche et l\'évaluation de terrain. Et les erreurs les plus coûteuses se font AVANT d\'acheter, sur le choix du groupe et de la structure juridique.',
  },
  {
    question: 'Je suis seul(e) pour l\'instant, je n\'ai pas de groupe. C\'est pertinent ?',
    reponse: 'Oui. Un des 7 thèmes est justement consacré à la communauté et au collectif : quel type de groupe tu cherches, quels rôles sont nécessaires, et comment éviter les erreurs de casting. Tu seras bien mieux armé(e) pour constituer ton collectif.',
  },
  {
    question: 'Je ne suis pas en France. Ça marche quand même ?',
    reponse: 'Les principes fondamentaux (groupe, financement, business model, erreurs à éviter) sont universels. La partie juridique et urbanisme est spécifique à la France, mais les grilles de lecture sont adaptables.',
  },
  {
    question: 'C\'est quoi la différence avec LAOM School Weekend ?',
    reponse: 'LAOM School Online, c\'est 12 lives collectifs avec Charly sur 6 mois, en distanciel. LAOM School Weekend, c\'est une immersion de 2-3 jours à LAOM en présentiel avec Charly : visite du lieu, ateliers, rencontres avec la communauté.',
  },
  {
    question: 'Combien de temps j\'ai accès à la formation ?',
    reponse: 'Accès à vie aux replays des 12 lives. Tu peux y revenir à ton rythme.',
  },
  {
    question: 'Je peux poser mes questions pendant les lives ?',
    reponse: 'Oui, c\'est fait pour. Chaque live est un Q&A / coaching collectif. Tu peux passer en "hot seat" pour avoir un retour personnalisé sur ton projet.',
  },
  {
    question: '147 EUR, c\'est vraiment le prix ?',
    reponse: 'Oui. Le prix normal est de 2 000 EUR, le prix inscrits conférence est de 497 EUR. En tant qu\'inscrit à la conférence du 28 avril, tu bénéficies du prix de 147 EUR, uniquement sur cette page. Tu économises 1 853 EUR par rapport au prix normal.',
  },
]
---

<Layout
  title="Inscription confirmée — Conférence LAOM School"
  description="Ton inscription est confirmée. Ajoute la conférence à ton calendrier."
  seo={{ ldJSON: pageSchema, noIndex: true }}
  hideChrome={true}
>

  <!-- Reset admin : ?reset-merci=1 purge les localStorage et reload -->
  <script is:inline>
    (function() {
      try {
        var params = new URL(window.location.href).searchParams;
        if (params.get('reset-merci') === '1') {
          localStorage.removeItem('laom-merci-deadline');
          localStorage.removeItem('laom-merci-exit-count');
          localStorage.removeItem('laom-merci-expired-modal-shown');
          window.location.replace('/school/merci/');
        }
      } catch (e) {}
    })();
  </script>

  <!-- ============================================ -->
  <!-- BLOC 1 — Confirmation + Calendrier (vert/doré) -->
  <!-- ============================================ -->
  <section class="bg-[#1a2e1a] py-8 md:py-10 border-b border-[#C4A855]/20">
    <div class="max-w-2xl mx-auto px-8 sm:px-12 text-center">
      <!-- Checkmark -->
      <div class="w-12 h-12 rounded-full border-2 border-[#4A7C59] bg-[#4A7C59]/20 flex items-center justify-center mx-auto mb-5">
        <svg class="w-6 h-6 text-[#6BBF7B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-playfair text-xl md:text-2xl font-medium text-white tracking-tight mb-3">
        Inscription confirmée. On se retrouve le 28 avril !
      </h1>

      <p class="text-sm font-light text-white/60 leading-relaxed mb-2">
        Tu vas recevoir un email avec toutes les infos. Si tu ne le vois pas d'ici quelques minutes, vérifie tes spams ou ton onglet Promotions (ça arrive plus souvent qu'on ne croit).
      </p>

      <p class="text-sm font-light text-white/50 mb-5">
        Hâte d'échanger avec toi !<br />
        <span class="text-white/70 font-normal">Charly</span>
      </p>

      <!-- Calendrier -->
      <p class="text-xs font-light text-white/40 mb-3">Mardi 28 avril 2026, 20h30. Ajoute à ton calendrier :</p>
      <div class="flex items-center justify-center gap-2">
        <a
          href={googleCalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-sm bg-white text-[#2C2824] px-4 py-2 text-[10px] tracking-[0.1em] uppercase hover:bg-white/90 transition-colors"
          aria-label="Ajouter au Google Calendar (ouvre dans un nouvel onglet)"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 3h-3V1.5h-1.5V3h-6V1.5H7.5V3h-3C3.675 3 3 3.675 3 4.5v15c0 .825.675 1.5 1.5 1.5h15c.825 0 1.5-.675 1.5-1.5v-15c0-.825-.675-1.5-1.5-1.5zm0 16.5h-15V8.25h15V19.5z"/></svg>
          Google
        </a>
        <a
          href={outlookCalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-sm border border-white/30 text-white px-4 py-2 text-[10px] tracking-[0.1em] uppercase hover:bg-white/10 transition-colors"
          aria-label="Ajouter au Outlook Calendar (ouvre dans un nouvel onglet)"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 3h-3V1.5h-1.5V3h-6V1.5H7.5V3h-3C3.675 3 3 3.675 3 4.5v15c0 .825.675 1.5 1.5 1.5h15c.825 0 1.5-.675 1.5-1.5v-15c0-.825-.675-1.5-1.5-1.5zm0 16.5h-15V8.25h15V19.5z"/></svg>
          Outlook
        </a>
        <a
          href={`data:text/calendar;charset=utf-8,${encodeURIComponent(icsContent)}`}
          download="conference-laom-school.ics"
          class="inline-flex items-center gap-1.5 rounded-sm border border-white/30 text-white px-4 py-2 text-[10px] tracking-[0.1em] uppercase hover:bg-white/10 transition-colors"
          aria-label="Télécharger le fichier .ics pour Apple Calendar"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 3h-3V1.5h-1.5V3h-6V1.5H7.5V3h-3C3.675 3 3 3.675 3 4.5v15c0 .825.675 1.5 1.5 1.5h15c.825 0 1.5-.675 1.5-1.5v-15c0-.825-.675-1.5-1.5-1.5zm0 16.5h-15V8.25h15V19.5z"/></svg>
          iCal
        </a>
      </div>
    </div>
  </section>

  <!-- Bandeau timer sticky (passe sous la confirmation puis reste collé) -->
  <div class="sticky top-0 z-50 bg-[#1a0a0a] border-b border-red-900/30">
    <!-- Desktop -->
    <div class="hidden sm:flex max-w-5xl mx-auto px-4 py-3 items-center justify-center gap-6">
      <div class="flex items-center gap-2.5">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>
        <span class="text-base font-medium text-white">Offre réservée aux inscrits</span>
      </div>
      <div class="flex items-center gap-1.5 bg-red-600/20 px-5 py-2 rounded-sm">
        <span class="font-playfair text-3xl font-bold text-red-400" id="top-minutes">60</span>
        <span class="text-xs text-red-400/70">min</span>
        <span class="text-red-400/50 text-xl mx-0.5">:</span>
        <span class="font-playfair text-3xl font-bold text-red-400" id="top-seconds">00</span>
        <span class="text-xs text-red-400/70">sec</span>
      </div>
      <a
        href="#offre"
        class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-5 py-2 text-xs tracking-[0.15em] uppercase hover:bg-[#B09A4A] transition-colors flex-shrink-0"
      >
        J'en profite
      </a>
    </div>
    <!-- Mobile -->
    <a href="#offre" class="sm:hidden flex items-center justify-between px-4 py-2.5">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>
        <span class="text-xs font-medium text-white">Offre inscrits</span>
      </div>
      <div class="flex items-center gap-1 bg-red-600/20 px-3 py-1 rounded-sm">
        <span class="font-playfair text-lg font-bold text-red-400" id="top-minutes-mobile">60</span>
        <span class="text-[10px] text-red-400/70">min</span>
        <span class="text-red-400/50 mx-0.5">:</span>
        <span class="font-playfair text-lg font-bold text-red-400" id="top-seconds-mobile">00</span>
        <span class="text-[10px] text-red-400/70">sec</span>
      </div>
      <span class="text-xs text-[#C4A855] font-medium uppercase tracking-wider">J'en profite</span>
    </a>
  </div>

  <!-- ============================================ -->
  <!-- BLOC 2 — Accroche + VSL + CTA #1             -->
  <!-- ============================================ -->
  <section class="pt-8 pb-4 md:pt-10 md:pb-6 bg-[#FAF8F5]">
    <div class="max-w-3xl mx-auto px-8 sm:px-12 text-center">


      <h2 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight mb-4">
        Tu n'as pas besoin d'attendre le 28 avril pour bosser sur ton projet.
      </h2>
      <p class="text-base font-light text-[#2C2824]/70 max-w-lg mx-auto mb-2">
        Tu veux créer un lieu. Tu cherches des réponses concrètes. On a passé 5 ans à les trouver, et on les a mises dans un seul endroit.
      </p>
      <p class="text-2xl text-[#C4A855] mb-2">&darr;&darr;&darr;</p>
      <p class="text-xs font-light text-[#2C2824]/40 max-w-lg mx-auto">
        C'est la seule page où tu verras cette offre. Elle ne sera pas répétée pendant la conférence.
      </p>
    </div>
  </section>

  <!-- VSL -->
  <section class="py-0 pb-10 md:pb-12 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-8 sm:px-12">
      <div class="aspect-video bg-[#2C2824] rounded-sm border border-black/10 overflow-hidden">
        <iframe
          id="vsl-player"
          src="https://customer-gkc27wxykzxme7de.cloudflarestream.com/be148f8016e2b02ad6e8dff65bf84afe/iframe?autoplay=true&muted=true&preload=auto&controls=true"
          loading="lazy"
          allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;"
          allowfullscreen
          class="w-full h-full border-0"
          title="LAOM School Online — Présentation vidéo"
        ></iframe>
      </div>

      <!-- CTA #1 — Sous la VSL -->
      <div class="text-center mt-10">
        <p class="text-xs font-light tracking-[0.15em] uppercase text-[#C4A855] mb-1">Offre exclusive inscrits conférence</p>
        <p class="text-xs font-light text-[#2C2824]/40 mb-4">Proposée uniquement sur cette page</p>
        <div class="mb-3">
          <span class="font-playfair text-xl font-light text-[#2C2824]/50 line-through mr-3">2 000 EUR</span>
          <span class="font-playfair text-xl font-light text-[#2C2824]/50 line-through mr-3">497 EUR</span>
          <span class="font-playfair text-2xl font-medium text-[#2C2824]">147 EUR</span>
          <span class="ml-1.5 bg-[#C4A855] text-white text-[10px] font-medium px-2 py-0.5 rounded-full align-top">-1 853 €</span>
        </div>
        <button
          type="button"
          data-mollie-product="school-merci"
          class="mollie-cta inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-10 py-4 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors cursor-pointer"
        >
          J'accède à la formation · 147 EUR
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOC 3 — Le problème                         -->
  <!-- ============================================ -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-8 sm:px-12">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Le constat</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8">
        Tu veux créer un lieu de vie alternatif. Mais tu te retrouves face à des questionnements, des doutes, des impasses.
      </h2>
      <div class="space-y-6 text-lg font-light text-[#2C2824]/75 leading-relaxed">
        <p>Un écolieu, un coliving, un tiers-lieu, un habitat partagé en pleine nature. Tu as l'élan. Tu as peut-être même le groupe. Tu te demandes peut-être :</p>
        <ul class="space-y-4 pl-0">
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Comment acheter un terrain à plusieurs sans que ça finisse en conflit ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Quelle structure juridique choisir en fonction de l'ADN de mon collectif ? (c'est très personnalisé)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Comment financer un projet à plusieurs centaines de milliers d'euros quand les banques disent non ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Et surtout : comment créer un lieu qui vit, avec <strong class="font-medium text-[#2C2824]">un collectif solide et qui tourne financièrement</strong> ?</span>
          </li>
        </ul>
        <p>
          Tu passes des mois à chercher des réponses. Des heures sur des forums, des groupes Facebook, des articles contradictoires. Tu parles à des gens qui ont "un projet" mais personne qui a <strong class="font-medium text-[#2C2824]">un lieu qui fonctionne depuis 5 ans</strong>.
        </p>
        <p class="text-[#2C2824] font-normal">
          On est passés par là. On a payé le prix fort pour certaines de ces réponses. Et pour d'autres, on a eu l'intuition juste, celle qui ne s'apprend pas dans les livres mais qui fait toute la différence sur le terrain.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOC 4 — La preuve (chiffres)                -->
  <!-- ============================================ -->
  <section class="py-24 md:py-32 bg-[#2C2824] text-white">
    <div class="max-w-5xl mx-auto px-8 sm:px-12">
      <div class="text-center mb-20">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">5 ans de terrain</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white tracking-tight">
          21 hectares. 3M EUR levés. Un business model qui tourne.
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-x-10 gap-y-12 mb-20">
        {chiffres.map((c) => (
          <div class="text-center">
