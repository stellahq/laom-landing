---
import Layout from '~/layouts/Layout.astro'
import TunnelTracker from '~/components/TunnelTracker.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Paiement confirmé — LAOM School Online',
  url: Astro.url.toString(),
  description: 'Merci pour ton achat. Tu as désormais accès à LAOM School Online.',
})


---

<Layout
  title="Bienvenue dans LAOM School Online"
  description="Ton accès à la formation est confirmé. Bienvenue !"
  seo={{ ldJSON: pageSchema, noIndex: true }}
  hideChrome={true}
>

  <!-- Confirmation -->
  <section class="min-h-screen flex items-center justify-center bg-[#FAF8F5]">
    <div class="max-w-2xl mx-auto px-8 sm:px-12 text-center py-24">

      <!-- Checkmark -->
      <div class="w-20 h-20 rounded-full border-2 border-[#4A7C59] bg-[#4A7C59]/20 flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-[#6BBF7B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6">
        Bienvenue dans LAOM School.
      </h1>

      <p class="text-lg font-light text-[#2C2824]/70 leading-relaxed mb-4">
        Ton paiement est en cours de traitement. Tu vas recevoir un email de confirmation à l'adresse que tu as utilisée pour le paiement.
      </p>

      <p class="text-lg font-light text-[#2C2824]/70 leading-relaxed mb-8">
        Si tu ne vois rien d'ici quelques minutes, vérifie tes spams ou ton onglet Promotions.
      </p>

      <!-- Récap -->
      <div class="bg-white border border-black/5 rounded-sm p-8 mb-10 text-left">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Ce que tu as obtenu</p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-base font-light text-[#2C2824]/70 leading-relaxed">
            <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
            <span><strong class="font-medium text-[#2C2824]">12 lives collectifs avec Charly</strong> — 6 mois</span>
          </li>
          <li class="flex items-start gap-3 text-base font-light text-[#2C2824]/70 leading-relaxed">
            <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
            <span><strong class="font-medium text-[#2C2824]">Communauté de porteurs de projet</strong></span>
          </li>
        </ul>

      </div>

      <!-- Prochaines étapes -->
      <div class="bg-[#2C2824] rounded-sm p-8 text-left">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Prochaines étapes</p>
        <ol class="space-y-4">
          <li class="flex items-start gap-4">
            <span class="w-7 h-7 rounded-full bg-[#C4A855] text-white text-sm flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
            <div>
              <p class="text-white font-medium text-sm">Rejoins le groupe WhatsApp LAOM School</p>
              <p class="text-white/50 font-light text-sm">C'est là que tout se passe : lien des lives, replays, échanges.</p>
              <a href="https://chat.whatsapp.com/G48sMmPvWZV1Nc6d5inYBr?mode=gi_t" target="_blank" rel="noopener noreferrer" aria-label="Rejoindre le groupe WhatsApp LAOM School (ouvre dans un nouvel onglet)" class="inline-block mt-2 text-sm font-medium text-[#C4A855] underline underline-offset-4 hover:text-[#d4bf6a] transition-colors">Rejoindre le groupe WhatsApp</a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="w-7 h-7 rounded-full bg-[#C4A855] text-white text-sm flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
            <div>
              <p class="text-white font-medium text-sm">Vérifie ta boîte mail</p>
              <p class="text-white/50 font-light text-sm">Tu vas recevoir un email de confirmation.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="w-7 h-7 rounded-full bg-[#C4A855] text-white text-sm flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
            <div>
              <p class="text-white font-medium text-sm">Rejoins la prochaine session</p>
              <p class="text-white/50 font-light text-sm">Mardi 19 mai à 20h. Le lien sera dans le groupe WhatsApp.</p>
            </div>
          </li>
        </ol>
      </div>

      <!-- Contact -->
      <p class="text-sm font-light text-[#2C2824]/40 mt-10">
        Une question ? <a href="mailto:hello@laom.fr" class="underline underline-offset-4 hover:text-[#2C2824]/60 transition-colors">hello@laom.fr</a>
      </p>
    </div>
  </section>

  <!-- Tunnel Tracker — tracking maison first-party -->
  <TunnelTracker page="/school/confirmation/" />

  <!-- Meta Pixel: Purchase event -->
  <script is:inline>
  (function() {
    if (typeof window.__laomTrack !== 'function') return;

    // Detect product/value from URL params (?product=oto-147&amount=147)
    var params = new URLSearchParams(window.location.search);
    var product = params.get('product') || 'laom-school';
    var amount = parseFloat(params.get('amount')) || 147;

    window.__laomTrack('Purchase', {
      value: amount,
      currency: 'EUR',
      content_name: product,
      content_type: 'product'
    });
  })();
  </script>

  <!-- Tunnel tracking hooks : WhatsApp click -->
  <script is:inline>
  (function() {
    if (typeof window.__tunnelTrack !== 'function') return;

    // Track WhatsApp group link clicks
    document.querySelectorAll('a[href*="chat.whatsapp.com"]').forEach(function(link) {
      link.addEventListener('click', function() {
        window.__tunnelTrack('whatsapp_click', {
          href: link.href
        });
      });
    });

    // Track product from URL params
    var params = new URLSearchParams(window.location.search);
    var product = params.get('product');
    if (product) {
      window.__tunnelTrack('page_view', {
        product: product,
        is_post_purchase: true
      });
    }
  })();
  </script>
</Layout>
