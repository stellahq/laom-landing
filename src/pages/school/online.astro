  <!-- Mollie checkout script -->
  <script is:inline>
    (function() {
      var pendingProduct = null;
      var pendingBtn = null;
      var pendingOriginalText = null;
      var modal = document.getElementById('email-modal');
      var emailInput = document.getElementById('email-input');
      var emailForm = document.getElementById('email-form');
      var closeBtn = document.getElementById('email-modal-close');

      // Ouvrir la modale au clic sur un CTA
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.mollie-cta');
        if (!btn) return;
        e.preventDefault();
        var product = btn.getAttribute('data-mollie-product');
        if (!product) return;

        pendingProduct = product;
        pendingBtn = btn;
        pendingOriginalText = btn.textContent;
        modal.classList.remove('hidden');
        emailInput.value = '';
        emailInput.focus();
      });

      // Fermer la modale
      closeBtn.addEventListener('click', function() {
        modal.classList.add('hidden');
        pendingProduct = null;
        pendingBtn = null;
      });
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.classList.add('hidden');
          pendingProduct = null;
          pendingBtn = null;
        }
      });

      // Soumettre l'email et lancer le paiement
      emailForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = emailInput.value.trim();
        if (!email || !pendingProduct) return;

        // Fermer la modale et désactiver le bouton
        modal.classList.add('hidden');
        if (pendingBtn) {
          pendingBtn.disabled = true;
          pendingBtn.textContent = 'Redirection en cours...';
          pendingBtn.style.opacity = '0.7';
        }

        var btn = pendingBtn;
        var originalText = pendingOriginalText;

        fetch('/api/mollie/create-payment/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product: pendingProduct, email: email })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.checkoutUrl) {
            window.location.href = data.checkoutUrl;
          } else {
            alert('Erreur lors de la création du paiement. Contacte-nous à hello@laom.fr');
            if (btn) { btn.disabled = false; btn.textContent = originalText; btn.style.opacity = '1'; }
          }
        })
        .catch(function() {
          alert('Erreur de connexion. Réessaie ou contacte-nous à hello@laom.fr');
          if (btn) { btn.disabled = false; btn.textContent = originalText; btn.style.opacity = '1'; }
        });
      });
    })();
  </script>

  <!-- Countdown 3 mai script -->
  <script is:inline>
    function updateCountdown() {
      var deadline = new Date('2026-05-03T21:00:00Z').getTime();
      var now = new Date().getTime();
      var diff = deadline - now;
      var pad = function(n) { return n < 10 ? '0' + n : n; };
      if (diff <= 0) {
        ['cd-days','cd-hours','cd-minutes','cd-seconds','cd-days-m','cd-hours-m','cd-minutes-m'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.textContent = '00';
        });
        return;
      }
      var d = Math.floor(diff / (1000 * 60 * 60 * 24));
      var h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      var s = Math.floor((diff % (1000 * 60)) / 1000);
      document.getElementById('cd-days').textContent = pad(d);
      document.getElementById('cd-hours').textContent = pad(h);
      document.getElementById('cd-minutes').textContent = pad(m);
      document.getElementById('cd-seconds').textContent = pad(s);
      var dm = document.getElementById('cd-days-m');
      var hm = document.getElementById('cd-hours-m');
      var mm = document.getElementById('cd-minutes-m');
      if (dm) dm.textContent = pad(d);
      if (hm) hm.textContent = pad(h);
      if (mm) mm.textContent = pad(m);
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);
  </script>
