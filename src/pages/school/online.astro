---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'LAOM School Online — La feuille de route pour créer ton lieu',
  url: Astro.url.toString(),
  description: 'Formation en ligne : 12 lives avec Charly pendant 6 mois, couvrant 7 thèmes essentiels. Tout ce qu\'on a appris en 5 ans pour créer un lieu qui tourne. 497 EUR.',
})

// Paiement Mollie — checkout dynamique à 497 EUR (ou 2 x 248,50 EUR)
const ctaProductId = 'school-online'

const modules = [
  {
    num: '01',
    titre: 'Achat et recherche de terrain',
    desc: 'Où chercher, comment évaluer et acheter à plusieurs, sans tomber dans les pièges classiques.',
    points: [
      'Où chercher selon les critères de ton groupe',
      'Comment lire un PLU : zonage, autorisations, constructibilité',
      'Évaluer la viabilité du projet : Géoportail, cadastre, DVF',
      'Évaluer l\'accessibilité : eau, électricité, route, exposition',
      'Acheter à plusieurs sans que ça finisse en conflit',
    ],
  },
  {
    num: '02',
    titre: 'Structure juridique',
    desc: 'Trouver le montage qui fonctionne pour ton groupe, et éviter les erreurs qui nous ont coûté 49 000 EUR.',
    points: [
      'Les 4 structures dans lesquelles on a navigué en 5 ans',
      'Indivision : pourquoi c\'est le piège classique',
      'SAS, SAS Coopérative, SCIA, SCI : avantages et limites',
      'Quand faire appel à un avocat / notaire, et quoi leur demander',
      'Les erreurs juridiques à éviter absolument',
    ],
  },
  {
    num: '03',
    titre: 'Financement et business plan',
    desc: 'Comment on a levé plus de 3M EUR sans prêt bancaire, et comment construire un business plan solide.',
    points: [
      'Les sources : prêts participatifs, love money, crowdfunding, subventions',
      'Construire ton plan de financement étape par étape',
      'Simulation financière : partir de ta situation réelle',
      'Business plan : les bases qui tiennent la route',
      'Présenter ton projet à des investisseurs, des prêteurs, la coopérative Oasis',
    ],
  },
  {
    num: '04',
    titre: 'Légalité et urbanisme',
    desc: 'Mairie, DDT, préfecture : comment leur parler et obtenir tes permis.',
    points: [
      'Les interlocuteurs clés : maire, DDT, ABF, CAUE, chambre d\'agriculture',
      'Les erreurs de posture qui bloquent tout',
      'DP, PC, permis d\'aménager : les démarches d\'urbanisme',
      'Gérer les refus (on en a eu 3) et rebondir',
    ],
  },
  {
    num: '05',
    titre: 'Construction',
    desc: 'Les choix de construction qui ont fait la différence, et ceux qu\'on éviterait aujourd\'hui.',
    points: [
      'Paille porteuse, bois, terre crue : les techniques qu\'on a testées',
      'Comment choisir en fonction de ton budget, ton climat, ton terrain',
      'Autoconstruction vs. faire appel à des pros : quand et pourquoi',
      'Les erreurs de construction : permis, dimensionnement, timing',
    ],
  },
  {
    num: '06',
    titre: 'Communauté et collectif',
    desc: 'Avant le lieu, il y a les gens. C\'est là que tout se joue, et que tout se plante.',
    points: [
      'La personne source : c\'est qui et pourquoi c\'est important',
      'Clarifier les intentions de chacun : vivre sur place, investir, participer de loin ?',
      'Définir les rôles : porteur de projet, gestionnaire, bâtisseur, investisseur passif',
      'Les red flags : quand un groupe ne tiendra pas',
      'Faire tenir une communauté dans le temps',
    ],
  },
  {
    num: '07',
    titre: 'Modèle économique',
    desc: 'Le modèle qui génère 200 à 500K EUR/an, sans devenir esclave du lieu.',
    points: [
      'Le piège du lieu militant sans modèle économique',
      'Les revenus possibles : hébergement, restauration, événements, formation, agritourisme',
      'Combiner les activités pour créer un modèle viable',
      'Construire et piloter ton prévisionnel',
    ],
  },
]

const chiffres = [
  { valeur: '21', unite: 'hectares', desc: 'achetés en collectif, à 8, sans se connaître' },
  { valeur: '850', unite: 'm²', desc: 'de construction écologique en paille porteuse, record mondial' },
  { valeur: '3M', unite: 'EUR', desc: 'levés sans prêt bancaire traditionnel' },
  { valeur: '15', unite: 'foyers', desc: 'qui vivent aujourd\'hui sur le domaine' },
  { valeur: '49K', unite: 'EUR', desc: 'en avocats et frais juridiques, à cause de simples erreurs' },
  { valeur: '5', unite: 'ans', desc: 'de terrain, d\'erreurs et de réussites' },
]

const temoignages = [
  {
    texte: 'Une heure. Il m\'a fallu une heure avec Charly pour avoir les réponses que je cherchais depuis des mois. Il a immédiatement vu les angles morts de mon plan de financement. Quand je fais le calcul des erreurs que j\'aurais commises sans cet échange, c\'est au moins 30 000 euros que je n\'aurai pas à perdre.',
    nom: 'Nicolas',
    role: 'Porteur de projet écolieu',
    initiales: 'N',
  },
  {
    texte: 'Échanger avec Charly, c\'est avoir accès à quelqu\'un qui a déjà porté un lieu pendant cinq ans et qui te dit les choses telles qu\'elles sont. Il nous a ouvert les yeux sur des pistes de financement qu\'on n\'avait pas envisagées. Ce qui a le plus de valeur, c\'est la relation de pair : quelqu\'un qui comprend exactement ce que tu traverses.',
    nom: 'Rico & Martin',
    role: 'Cofondateurs de Naturopia, Madère',
    initiales: 'R&M',
  },
  {
    texte: 'Jusque-là je n\'avais croisé que des alternatifs sans le sou ou des entrepreneurs qui n\'ont rien à faire des questions écologiques. Charly m\'a montré que cette intersection existe. Ça me donne de la force et l\'envie de bâtir des projets d\'envergure allant dans le sens de mes valeurs.',
    nom: 'Nicolas Zanuttini',
    role: 'Auto-entrepreneur',
    initiales: 'NZ',
  },
]

const faq = [
  {
    question: 'Je n\'ai pas encore de terrain. C\'est trop tôt pour moi ?',
    reponse: 'Non, c\'est le meilleur moment. Un des 7 thèmes est justement consacré à la recherche et l\'évaluation de terrain. Et les erreurs les plus coûteuses se font AVANT d\'acheter, sur le choix du groupe et de la structure juridique.',
  },
  {
    question: 'Je suis seul(e) pour l\'instant, je n\'ai pas de groupe. C\'est pertinent ?',
    reponse: 'Oui. Un des 7 thèmes est justement consacré à la communauté et au collectif : quel type de groupe tu cherches, quels rôles sont nécessaires, et comment éviter les erreurs de casting. Tu seras bien mieux armé(e) pour constituer ton collectif.',
  },
  {
    question: 'Je ne suis pas en France. Ça marche quand même ?',
    reponse: 'Les principes fondamentaux (groupe, financement, business model, erreurs à éviter) sont universels. La partie juridique et urbanisme est spécifique à la France, mais les grilles de lecture sont adaptables.',
  },
  {
    question: 'C\'est quoi la différence avec LAOM School Weekend ?',
    reponse: 'LAOM School Online, c\'est la formation + les lives en distanciel. LAOM School Weekend, c\'est une immersion de 2-3 jours à LAOM en présentiel avec Charly : visite du lieu, ateliers, rencontres avec la communauté.',
  },
  {
    question: 'Combien de temps j\'ai accès à la formation ?',
    reponse: 'Accès à vie aux modules. Les lives durent 6 mois (12 sessions).',
  },
  {
    question: 'Je peux poser mes questions pendant les lives ?',
    reponse: 'Oui, c\'est fait pour. Chaque live est une session de Q&A collectif. Tu peux obtenir un retour personnalisé de Charly sur ta situation.',
  },
  {
    question: '497 EUR, c\'est vraiment le prix ?',
    reponse: 'Oui. Le prix normal de la formation est de 2 000 EUR. Pour te donner un ordre d\'idée, des accompagnants de ce genre de projet facturent entre 4 000 et 6 000 EUR pour 6 mois. Et tu peux payer en 2 fois (2 x 248,50 EUR).',
  },
]
---

<Layout
  title="LAOM School Online — Crée ton lieu sans perdre 5 ans et 49 000 EUR en erreurs | LAOM"
  description="Formation en ligne : 12 lives avec Charly pendant 6 mois, couvrant 7 thèmes essentiels. La feuille de route complète pour créer un lieu qui tourne. 497 EUR."
  seo={{ ldJSON: pageSchema }}
  hideChrome={true}
>
  <!-- Bandeau timer sticky 3 mai -->
  <div class="sticky top-0 z-50 bg-[#1a0a0a] border-b border-red-900/30">
    <!-- Desktop -->
    <div class="hidden sm:flex max-w-5xl mx-auto px-4 py-3 items-center justify-center gap-6">
      <div class="flex items-center gap-2.5">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>
        <span class="text-base font-medium text-white">Offre de lancement</span>
      </div>
      <div class="flex items-center gap-1.5 bg-red-600/20 px-5 py-2 rounded-sm">
        <div class="text-center">
          <span class="font-playfair text-2xl font-bold text-red-400" id="cd-days">--</span>
          <span class="text-[10px] block text-red-400/70">j</span>
        </div>
        <span class="text-red-400/50 text-lg">:</span>
        <div class="text-center">
          <span class="font-playfair text-2xl font-bold text-red-400" id="cd-hours">--</span>
          <span class="text-[10px] block text-red-400/70">h</span>
        </div>
        <span class="text-red-400/50 text-lg">:</span>
        <div class="text-center">
          <span class="font-playfair text-2xl font-bold text-red-400" id="cd-minutes">--</span>
          <span class="text-[10px] block text-red-400/70">min</span>
        </div>
        <span class="text-red-400/50 text-lg">:</span>
        <div class="text-center">
          <span class="font-playfair text-2xl font-bold text-red-400" id="cd-seconds">--</span>
          <span class="text-[10px] block text-red-400/70">sec</span>
        </div>
      </div>
      <a
        href="#offre"
        class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-5 py-2 text-xs tracking-[0.15em] uppercase hover:bg-[#B09A4A] transition-colors flex-shrink-0"
      >
        J'en profite
      </a>
    </div>
    <!-- Mobile -->
    <a href="#offre" class="sm:hidden flex items-center justify-between px-4 py-2.5">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>
        <span class="text-xs font-medium text-white">Offre de lancement</span>
      </div>
      <div class="flex items-center gap-1 bg-red-600/20 px-3 py-1 rounded-sm">
        <span class="font-playfair text-base font-bold text-red-400" id="cd-days-m">--</span>
        <span class="text-[10px] text-red-400/70">j</span>
        <span class="text-red-400/50 mx-0.5">:</span>
        <span class="font-playfair text-base font-bold text-red-400" id="cd-hours-m">--</span>
        <span class="text-[10px] text-red-400/70">h</span>
        <span class="text-red-400/50 mx-0.5">:</span>
        <span class="font-playfair text-base font-bold text-red-400" id="cd-minutes-m">--</span>
        <span class="text-[10px] text-red-400/70">min</span>
      </div>
      <span class="text-xs text-[#C4A855] font-medium uppercase tracking-wider">J'en profite</span>
    </a>
  </div>

  <!-- Hero -->
  <section class="relative py-28 lg:py-36 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/grand-shambala/grand-shambala-vue-drone-paille-porteuse-aveyron.webp"
        alt="Vue aérienne du Grand Shambala, LAOM, Aveyron"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/55"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <h1 class="font-playfair text-3xl md:text-4xl lg:text-5xl font-medium text-white mb-6 tracking-tight drop-shadow-lg leading-tight max-w-3xl mx-auto">
        Crée un coliving durable en pleine nature.
      </h1>
      <p class="text-xl md:text-2xl font-normal text-white max-w-2xl mx-auto leading-relaxed mb-4">
        <span class="underline decoration-[#C4A855] underline-offset-4 decoration-2">Sans des années d'essais-erreurs</span>, et <span class="underline decoration-[#C4A855] underline-offset-4 decoration-2">sans attendre qu'une banque te dise oui</span>.
      </p>
      <p class="text-lg md:text-xl font-light text-white/70 max-w-2xl mx-auto leading-relaxed mb-12">
        5 ans de terrain condensés pour que tu puisses enfin te lancer.<br />On te montre tout !
      </p>

      <!-- VSL intégrée dans le hero (masquée tant qu'il n'y a pas de vidéo) -->
      <!--
      <div id="vsl" class="max-w-3xl mx-auto">
        <div class="aspect-video bg-black rounded-sm border border-white/10 flex items-center justify-center">
          <div class="text-center">
            <div class="w-20 h-20 rounded-full border-2 border-[#C4A855] flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-[#C4A855] ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
            <p class="text-sm font-light text-white/40 tracking-wide uppercase">VSL : vidéo à intégrer</p>
          </div>
        </div>
      </div>
      -->
    </div>
  </section>

  <!-- Le problème -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Le constat</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8">
        Tu veux créer un lieu de vie alternatif. Mais tu te retrouves face à des questionnements, des doutes, des impasses.
      </h2>
      <div class="space-y-6 text-lg font-light text-[#2C2824]/75 leading-relaxed">
        <p>Un écolieu, un coliving, un tiers-lieu, un habitat partagé en pleine nature. Tu as l'élan. Tu as peut-être même le groupe. Tu te demandes peut-être :</p>
        <ul class="space-y-4 pl-0">
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Comment acheter un terrain à plusieurs sans que ça finisse en conflit ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Quelle structure juridique choisir en fonction de l'ADN de mon collectif ? (c'est très personnalisé)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Comment financer un projet à plusieurs centaines de milliers d'euros quand les banques disent non ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&#x2022;</span>
            <span>Et surtout : comment créer un lieu qui vit, avec <strong class="font-medium text-[#2C2824]">un collectif solide et qui tourne financièrement</strong> ?</span>
          </li>
        </ul>
        <p>
          Tu passes des mois à chercher des réponses. Des heures sur des forums, des groupes Facebook, des articles contradictoires. Tu parles à des gens qui ont "un projet" mais personne qui a <strong class="font-medium text-[#2C2824]">un lieu qui fonctionne depuis 5 ans</strong>.
        </p>
        <p class="text-[#2C2824] font-normal">
          On est passés par là. On a payé le prix fort pour certaines de ces réponses. Et pour d'autres, on a eu l'intuition juste, celle qui ne s'apprend pas dans les livres mais qui fait toute la différence sur le terrain.
        </p>
      </div>
    </div>
  </section>

  <!-- La preuve (chiffres) -->
  <section class="py-24 md:py-32 bg-[#2C2824] text-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-20">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">5 ans de terrain</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white tracking-tight">
          21 hectares. 3M EUR levés. Un business model qui tourne.
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-x-10 gap-y-12 mb-20">
        {chiffres.map((c) => (
          <div class="text-center">
            <div class="mb-3">
              <span class="font-playfair text-5xl md:text-6xl font-medium text-[#C4A855]">{c.valeur}</span>
              <span class="text-lg font-light text-[#C4A855]/70 ml-1">{c.unite}</span>
            </div>
            <p class="text-sm font-light text-white/60 leading-relaxed max-w-[20ch] mx-auto">{c.desc}</p>
          </div>
        ))}
      </div>

      <div class="max-w-2xl mx-auto text-center border-t border-white/10 pt-16">
        <p class="text-lg font-light text-white/70 leading-relaxed mb-6">
          On s'appelle Charly et Amandine. On a co-fondé <strong class="text-white font-normal">LAOM</strong>, un coliving sur 21 hectares dans le sud de l'Aveyron.
        </p>
        <p class="text-lg font-light text-white/70 leading-relaxed">
          On n'avait aucun diplôme en BTP, en droit, ni en agriculture. On avait 5% du budget nécessaire. Pas de réseau. Pas de modèle à suivre.
        </p>
        <p class="text-lg font-light text-white/90 leading-relaxed mt-6">
          On a tout appris en faisant. Les erreurs, les galères, mais aussi les solutions pour créer un lieu attrayant et qui perdure durablement.
        </p>
      </div>
    </div>
  </section>

  <!-- La solution + 7 thèmes -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center mb-16">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">La solution</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6">
            LAOM School Online
          </h2>
          <div class="space-y-4 text-lg font-light text-[#2C2824]/80 leading-relaxed">
            <p>
              On a condensé tout ce qu'on a appris en <strong class="font-medium text-[#2C2824]">7 thèmes essentiels</strong> qui suivent le parcours réel d'un projet, de l'idée au lieu qui tourne.
            </p>
            <p>
              C'est l'algorithme qu'on aurait aimé avoir avant de se lancer.
            </p>
            <p>
              Ces 7 thèmes sont couverts pendant <strong class="font-medium text-[#2C2824]">12 lives collectifs avec Charly, un tous les 15 jours pendant 6 mois</strong>, pour travailler sur TON projet.
            </p>
          </div>
        </div>
        <div class="aspect-[4/3] rounded-sm overflow-hidden">
          <img
            src="/images/laom/grand-shambala/grand-shambala-vue-drone-paille-porteuse-aveyron.webp"
            alt="Le Grand Shambala, plus grand bâtiment en paille porteuse au monde"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- 7 thèmes -->
      <div class="text-center mb-12">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Programme</p>
        <h3 class="font-playfair text-2xl md:text-3xl font-medium text-[#2C2824] tracking-tight">
          7 thèmes, de l'idée au lieu qui tourne
        </h3>
        <p class="text-sm font-light text-[#2C2824]/50 mt-3">Couverts pendant 12 lives avec Charly, un tous les 15 jours</p>
      </div>

      <div class="space-y-4">
        {modules.map((mod) => (
          <details class="group bg-white rounded-sm overflow-hidden">
            <summary class="flex items-center gap-6 p-6 md:p-8 cursor-pointer list-none">
              <span class="text-2xl font-playfair font-medium text-[#C4A855] flex-shrink-0 w-10">{mod.num}</span>
              <div class="flex-1">
                <h4 class="font-playfair text-xl font-medium text-[#2C2824] mb-1">{mod.titre}</h4>
                <p class="text-sm font-light text-[#2C2824]/60">{mod.desc}</p>
              </div>
              <span class="text-[#C4A855] group-open:rotate-45 transition-transform text-2xl flex-shrink-0">+</span>
            </summary>
            <div class="px-6 md:px-8 pb-6 md:pb-8 ml-16">
              <ul class="space-y-3">
                {mod.points.map((point) => (
                  <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
                    <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Les lives -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Accompagnement live</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6">
            12 lives collectifs avec Charly pendant 6 mois
          </h2>
          <div class="space-y-4 text-lg font-light text-[#2C2824]/80 leading-relaxed">
            <p>
              Chaque thème est couvert par <strong class="font-medium text-[#2C2824]">1 live d'échange collectif tous les 15 jours pendant 6 mois</strong>.
            </p>
            <p>Premier live le mardi 5 mai. Ce sont des sessions de questions-réponses sur ton projet, en groupe :</p>
          </div>
        </div>
        <div class="bg-[#FAF8F5] border border-black/5 rounded-sm p-8">
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-base font-light text-[#2C2824]/70 leading-relaxed">
              <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
              <span>Poser tes questions sur <strong class="font-medium text-[#2C2824]">TON</strong> projet</span>
            </li>
            <li class="flex items-start gap-3 text-base font-light text-[#2C2824]/70 leading-relaxed">
              <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
              <span>Obtenir un retour personnalisé de Charly sur ta situation</span>
            </li>
