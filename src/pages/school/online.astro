---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'LAOM School Online — La feuille de route pour créer ton écolieu',
  url: Astro.url.toString(),
  description: 'Formation en ligne : 7 modules + 12 lives avec Charly pendant 6 mois. Tout ce qu\'on a appris en 5 ans pour créer un écolieu qui tourne. 147 EUR.',
})

const modules = [
  {
    num: '01',
    titre: 'Définir ton groupe',
    desc: 'Avant le lieu, il y a les gens. C\'est là que tout se joue — et que tout se plante.',
    points: [
      'Identifier la personne source — celle qui porte la vision',
      'Clarifier les intentions de chacun : vivre sur place, investir, participer de loin ?',
      'Définir les rôles : porteur de projet, gestionnaire, bâtisseur, investisseur passif',
      'Les red flags : quand un groupe ne tiendra pas',
    ],
  },
  {
    num: '02',
    titre: 'Trouver le lieu',
    desc: 'Comment chercher, évaluer et sécuriser le bon terrain — sans perdre 6 mois.',
    points: [
      'Où chercher : plateformes, réseaux, bouche-à-oreille, mairies',
      'Télécharger et lire le PLU : zonage, autorisations, constructibilité',
      'Évaluer l\'accessibilité : eau, électricité, route, exposition',
      'Outils concrets : Géoportail, cadastre, DVF, PLU en ligne',
    ],
  },
  {
    num: '03',
    titre: 'Structuration juridique',
    desc: 'Les 4 structures qu\'on a testées en 5 ans — et laquelle marche vraiment.',
    points: [
      'Indivision : pourquoi c\'est le piège classique',
      'SAS, SAS Coopérative, SCIA, SCI : avantages et limites',
      'Le montage qui fonctionne : notre retour d\'expérience',
      'Quand faire appel à un avocat / notaire — et quoi leur demander',
    ],
  },
  {
    num: '04',
    titre: 'Financer le projet',
    desc: 'Comment on a levé plus de 3M EUR sans prêt bancaire traditionnel.',
    points: [
      'Les sources : prêts participatifs, love money, crowdfunding, subventions',
      'Construire ton plan de financement étape par étape',
      'Monter un dossier de subvention : FDVA, LEADER, fondations',
      'Simulation financière : partir de ta situation réelle',
    ],
  },
  {
    num: '05',
    titre: 'Parler aux institutions',
    desc: 'Mairie, urbanisme, préfecture — comment leur parler et obtenir ce que tu veux.',
    points: [
      'Les interlocuteurs clés : maire, DDT, ABF, CAUE, chambre d\'agriculture',
      'Les erreurs de posture qui bloquent tout',
      'DP, PC, permis d\'aménager : les démarches d\'urbanisme',
      'Gérer les refus (on en a eu 3) et rebondir',
    ],
  },
  {
    num: '06',
    titre: 'Construire ton business model',
    desc: 'Le modèle qui génère 200 à 500K EUR/an — sans devenir esclave du lieu.',
    points: [
      'Les revenus possibles : hébergement, restauration, événements, coliving',
      'Combiner les activités pour créer un modèle viable',
      'Le piège du lieu militant sans modèle économique',
      'Construire et piloter ton prévisionnel',
    ],
  },
  {
    num: '07',
    titre: 'Éviter nos erreurs',
    desc: 'Les 7 erreurs qui nous ont coûté 49 000 EUR et 5 ans de chaos.',
    points: [
      'Les erreurs juridiques : indivision, clauses expirées, structures mal choisies',
      'Les erreurs humaines : départs, conflits, rôles flous',
      'Les erreurs de construction : permis, dimensionnement, timing',
      'Ce qu\'on ferait différemment — point par point',
    ],
  },
]

const chiffres = [
  { valeur: '21', unite: 'hectares', desc: 'achetés en collectif, à 8, sans se connaître' },
  { valeur: '850', unite: 'm²', desc: 'de construction en paille porteuse — record mondial' },
  { valeur: '3M', unite: 'EUR', desc: 'levés sans prêt bancaire traditionnel' },
  { valeur: '15', unite: 'familles', desc: 'qui vivent aujourd\'hui sur le domaine' },
  { valeur: '49K', unite: 'EUR', desc: 'dépensés en avocats et frais juridiques' },
  { valeur: '5', unite: 'ans', desc: 'de terrain, d\'erreurs et de réussites' },
]

const temoignages = [
  {
    texte: 'Une heure. Il m\'a fallu une heure avec Charly pour avoir les réponses que je cherchais depuis des mois. Il a immédiatement vu les angles morts de mon plan de financement. Quand je fais le calcul des erreurs que j\'aurais commises sans cet échange, c\'est au moins 30 000 euros que je n\'aurai pas à perdre.',
    nom: 'Nicolas',
    role: 'Porteur de projet écolieu',
    initiales: 'N',
  },
  {
    texte: 'Échanger avec Charly, c\'est avoir accès à quelqu\'un qui a déjà porté un lieu pendant cinq ans — et qui te dit les choses telles qu\'elles sont. Il nous a ouvert les yeux sur des pistes de financement qu\'on n\'avait pas envisagées. Ce qui a le plus de valeur, c\'est la relation de pair : quelqu\'un qui comprend exactement ce que tu traverses.',
    nom: 'Rico & Martin',
    role: 'Cofondateurs de Naturopia, Madère',
    initiales: 'R&M',
  },
  {
    texte: 'Jusque-là je n\'avais croisé que des alternatifs sans le sou et des entrepreneurs qui n\'ont rien à faire des questions écologiques — et Charly m\'a montré que cette intersection existe. Ça me donne de la force et l\'envie de bâtir des projets d\'envergure allant dans le sens de mes valeurs.',
    nom: 'Nicolas Zanuttini',
    role: 'Auto-entrepreneur',
    initiales: 'NZ',
  },
]

const faq = [
  {
    question: 'Je n\'ai pas encore de terrain. C\'est trop tôt pour moi ?',
    reponse: 'Non, c\'est le meilleur moment. Le Module 2 est justement fait pour t\'aider à chercher et évaluer les terrains. Et les erreurs les plus coûteuses se font AVANT d\'acheter — sur le choix du groupe et de la structure juridique.',
  },
  {
    question: 'Je suis seul(e) pour l\'instant, je n\'ai pas de groupe. C\'est pertinent ?',
    reponse: 'Oui. Le Module 1 t\'aide à comprendre quel type de groupe tu cherches, quels rôles sont nécessaires, et comment éviter les erreurs de casting. Tu seras bien mieux armé(e) pour constituer ton collectif.',
  },
  {
    question: 'Je ne suis pas en France. Ça marche quand même ?',
    reponse: 'Les principes fondamentaux (groupe, financement, business model, erreurs à éviter) sont universels. La partie juridique et urbanisme est spécifique à la France — mais les grilles de lecture sont adaptables.',
  },
  {
    question: 'C\'est quoi la différence avec LAOM School Weekend ?',
    reponse: 'LAOM School Online, c\'est la formation + les lives en distanciel. LAOM School Weekend, c\'est une immersion de 2-3 jours à LAOM en présentiel avec Charly — visite du lieu, ateliers, rencontres avec la communauté.',
  },
  {
    question: 'Combien de temps j\'ai accès à la formation ?',
    reponse: 'Accès à vie aux modules. Les lives durent 6 mois (12 sessions).',
  },
  {
    question: 'Je peux poser mes questions pendant les lives ?',
    reponse: 'Oui, c\'est fait pour. Chaque live est un Q&A / coaching collectif. Tu peux passer en "hot seat" pour avoir un retour personnalisé sur ton projet.',
  },
  {
    question: '147 EUR, c\'est vraiment le prix ?',
    reponse: 'C\'est le prix de lancement pour la première promotion. Il augmentera ensuite.',
  },
]
---

<Layout
  title="LAOM School Online — Crée ton écolieu sans perdre 5 ans et 49 000 EUR | LAOM"
  description="Formation en ligne : 7 modules + 12 lives avec Charly pendant 6 mois. La feuille de route complète pour créer un écolieu qui tourne. Offre de lancement 147 EUR."
  seo={{ ldJSON: pageSchema }}
>
  <!-- Hero + VSL -->
  <section class="relative py-32 lg:py-40 flex items-center justify-center overflow-hidden -mt-24 md:-mt-28">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/festival-laom-ambiance-nature-aveyron.webp"
        alt="Vue de LAOM, écolieu en Aveyron"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.25em] uppercase text-[#C4A855] mb-6">Formation en ligne</p>
      <h1 class="font-playfair text-4xl md:text-5xl lg:text-6xl font-medium text-white mb-6 tracking-tight drop-shadow-lg leading-tight">
        Crée ton écolieu sans perdre 5 ans et 49&nbsp;000&nbsp;EUR en erreurs
      </h1>
      <p class="text-lg md:text-xl font-light text-white/80 max-w-2xl mx-auto leading-relaxed mb-12">
        La feuille de route complète pour passer de l'idée au lieu qui tourne — par ceux qui l'ont fait.
      </p>
      <a
        href="#vsl"
        class="inline-flex items-center justify-center text-white/70 hover:text-white transition-colors group"
        aria-label="Voir la vidéo"
      >
        <span class="text-xs tracking-[0.2em] uppercase mr-3">Voir la vidéo</span>
        <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- VSL Video Placeholder -->
  <section id="vsl" class="py-16 md:py-20 bg-[#2C2824]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="aspect-video bg-black/40 rounded-sm border border-white/10 flex items-center justify-center">
        <!-- Remplacer ce bloc par l'embed de la VSL (Vimeo / YouTube) -->
        <div class="text-center">
          <div class="w-20 h-20 rounded-full border-2 border-[#C4A855] flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-[#C4A855] ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
          <p class="text-sm font-light text-white/40 tracking-wide uppercase">VSL — Vidéo à intégrer</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Le problème -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Le constat</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8">
        Tu veux créer un écolieu. Mais tu te retrouves face à un mur.
      </h2>
      <div class="space-y-5 text-base font-light text-[#2C2824]/75 leading-relaxed">
        <p>Tu as l'élan. Tu as peut-être même le groupe.</p>
        <ul class="space-y-3 pl-0">
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&mdash;</span>
            <span>Comment acheter un terrain à plusieurs sans que ça finisse en conflit ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&mdash;</span>
            <span>Quelle structure juridique choisir — et pourquoi la plupart des collectifs se plantent sur ce point ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&mdash;</span>
            <span>Comment financer un projet à plusieurs centaines de milliers d'euros quand les banques disent non ?</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#C4A855] mt-1 flex-shrink-0">&mdash;</span>
            <span>Et surtout : comment créer un lieu qui <strong class="font-medium text-[#2C2824]">vit et qui tourne financièrement</strong> ?</span>
          </li>
        </ul>
        <p>
          Tu passes des mois à chercher des réponses. Des heures sur des forums, des groupes Facebook, des articles contradictoires. Tu parles à des gens qui ont "un projet" mais personne qui a <strong class="font-medium text-[#2C2824]">un lieu qui fonctionne depuis 5 ans</strong>.
        </p>
        <p class="text-[#2C2824] font-normal text-lg">
          On est passés par là. Et on a payé le prix fort pour chaque réponse.
        </p>
      </div>
    </div>
  </section>

  <!-- La preuve (chiffres) -->
  <section class="py-20 md:py-24 bg-[#2C2824] text-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">5 ans de terrain</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white tracking-tight">
          21 hectares. 3M EUR levés. Un business model qui tourne.
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 mb-16">
        {chiffres.map((c) => (
          <div class="text-center">
            <div class="mb-2">
              <span class="font-playfair text-4xl md:text-5xl font-medium text-[#C4A855]">{c.valeur}</span>
              <span class="text-lg font-light text-[#C4A855]/70 ml-1">{c.unite}</span>
            </div>
            <p class="text-sm font-light text-white/50">{c.desc}</p>
          </div>
        ))}
      </div>

      <div class="max-w-3xl mx-auto text-center">
        <p class="text-base font-light text-white/60 leading-relaxed mb-4">
          On s'appelle Charly et Amandine. On a co-fondé <strong class="text-white font-normal">LAOM</strong>, un écolieu de 21 hectares dans le sud de l'Aveyron.
        </p>
        <p class="text-base font-light text-white/60 leading-relaxed">
          On n'avait aucun diplôme en BTP, en droit, ni en agriculture. On avait 10% du budget nécessaire. Pas de réseau. Pas de modèle à suivre.
          <strong class="text-white font-normal"> On a tout appris en faisant — et on a fait toutes les erreurs possibles.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- La solution -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">La solution</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6">
            LAOM School Online
          </h2>
          <div class="space-y-4 text-base font-light text-[#2C2824]/80 leading-relaxed">
            <p>
              On a condensé tout ce qu'on a appris en <strong class="font-medium text-[#2C2824]">7 modules</strong> qui suivent le parcours réel d'un projet d'écolieu — de l'idée au lieu qui tourne.
            </p>
            <p>
              C'est l'algorithme qu'on aurait aimé avoir avant de se lancer.
            </p>
            <p>
              Et en plus des modules, tu as accès à <strong class="font-medium text-[#2C2824]">1 live collectif tous les 15 jours avec Charly pendant 6 mois</strong> — pour travailler sur TON projet.
            </p>
          </div>
        </div>
        <div class="aspect-[4/3] rounded-sm overflow-hidden">
          <img
            src="/images/laom/grand-shambala/grand-shambala-vue-drone-paille-porteuse-aveyron.webp"
            alt="Le Grand Shambala, plus grand bâtiment en paille porteuse au monde"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Les 7 modules -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Programme</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">
          7 modules, de l'idée au lieu qui tourne
        </h2>
      </div>

      <div class="space-y-6">
        {modules.map((mod) => (
          <details class="group bg-[#FAF8F5] rounded-sm overflow-hidden">
            <summary class="flex items-center gap-6 p-6 md:p-8 cursor-pointer list-none">
              <span class="text-2xl font-playfair font-medium text-[#C4A855] flex-shrink-0 w-10">{mod.num}</span>
              <div class="flex-1">
                <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-1">{mod.titre}</h3>
                <p class="text-sm font-light text-[#2C2824]/60">{mod.desc}</p>
              </div>
              <span class="text-[#C4A855] group-open:rotate-45 transition-transform text-2xl flex-shrink-0">+</span>
            </summary>
            <div class="px-6 md:px-8 pb-6 md:pb-8 ml-16">
              <ul class="space-y-3">
                {mod.points.map((point) => (
                  <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
                    <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Les lives -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Accompagnement</p>
          <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-6">
            12 lives avec Charly pendant 6 mois
          </h2>
          <div class="space-y-4 text-base font-light text-[#2C2824]/80 leading-relaxed">
            <p>
              En plus des 7 modules, tu as accès à <strong class="font-medium text-[#2C2824]">1 live collectif tous les 15 jours</strong>.
            </p>
            <p>C'est 12 sessions en direct pour :</p>
          </div>
        </div>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
              <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
              <span>Poser tes questions sur <strong class="font-medium text-[#2C2824]">TON</strong> projet</span>
            </li>
            <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
              <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
              <span>Passer en "hot seat" — retour personnalisé de Charly</span>
            </li>
            <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
              <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
              <span>Avancer concrètement avec quelqu'un qui a déjà fait le chemin</span>
            </li>
            <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
              <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
              <span>Rejoindre une communauté de porteurs de projet qui avancent</span>
            </li>
          </ul>
          <p class="mt-6 text-sm font-light text-[#2C2824]/50 italic">
            Un seul appel avec Charly a permis à Nicolas d'éviter 30 000 EUR d'erreurs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Récap offre + Prix -->
  <section id="offre" class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-12">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">L'offre</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">
          Ce que tu obtiens
        </h2>
      </div>

      <!-- Recap -->
      <div class="bg-[#FAF8F5] rounded-sm p-8 md:p-10 mb-10">
        <ul class="space-y-4">
          <li class="flex items-start gap-4">
            <span class="text-[#C4A855] text-xl mt-0.5">&#10003;</span>
            <div>
              <span class="font-medium text-[#2C2824]">7 modules de formation</span>
              <span class="text-sm font-light text-[#2C2824]/60 block">La feuille de route complète, de l'idée au lieu qui tourne</span>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-[#C4A855] text-xl mt-0.5">&#10003;</span>
            <div>
              <span class="font-medium text-[#2C2824]">12 lives avec Charly</span>
              <span class="text-sm font-light text-[#2C2824]/60 block">1 live collectif / 15 jours pendant 6 mois — Q&A, coaching, hot seat</span>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-[#C4A855] text-xl mt-0.5">&#10003;</span>
            <div>
              <span class="font-medium text-[#2C2824]">Accès à vie aux modules</span>
              <span class="text-sm font-light text-[#2C2824]/60 block">Tu avances à ton rythme</span>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-[#C4A855] text-xl mt-0.5">&#10003;</span>
            <div>
              <span class="font-medium text-[#2C2824]">Communauté de porteurs de projet</span>
              <span class="text-sm font-light text-[#2C2824]/60 block">Tu n'es plus seul avec ton projet</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Prix -->
      <div class="bg-white border-2 border-[#C4A855] rounded-sm p-10 text-center">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Offre de lancement</p>
        <div class="mb-2">
          <span class="text-xl font-light text-[#2C2824]/30 line-through">800 EUR</span>
        </div>
        <div class="mb-4">
          <span class="font-playfair text-6xl font-medium text-[#2C2824]">147</span>
          <span class="text-xl font-light text-[#2C2824]/50 ml-1">EUR</span>
        </div>
        <p class="text-sm font-light text-[#2C2824]/50 mb-8 max-w-md mx-auto">
          C'est le prix d'un dîner au restaurant. Sauf qu'ici, ça peut t'éviter des dizaines de milliers d'euros en erreurs et des années de retard.
        </p>
        <!-- CTA : Remplacer le href par le lien Stripe / plateforme de paiement -->
        <a
          href="mailto:hello@laom.fr?subject=LAOM%20School%20Online%20—%20Je%20veux%20rejoindre"
          class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-10 py-4 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors"
        >
          Rejoindre LAOM School — 147 EUR
        </a>
        <p class="text-xs font-light text-[#2C2824]/30 mt-4">Ce prix ne sera pas maintenu.</p>
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Retours d'expérience</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">
          Ils portent des projets similaires
        </h2>
      </div>

      <div class="space-y-10">
        {temoignages.map((t, i) => (
          <div class="relative">
            <div class={`absolute top-0 ${i % 2 === 0 ? 'left-0 -translate-x-2' : 'right-0 translate-x-2 rotate-180'} font-playfair text-[100px] md:text-[120px] leading-none text-[#C4A855]/10 -translate-y-4 select-none pointer-events-none`}>"</div>
            <div class="bg-white p-8 md:p-10 rounded-sm pt-12">
              <blockquote class="text-base md:text-lg font-light text-[#2C2824]/80 leading-relaxed italic">
                <p>{t.texte}</p>
              </blockquote>
              <div class="flex items-center gap-4 mt-8">
                <div class="w-10 h-10 rounded-full bg-[#2C2824]/10 flex items-center justify-center text-xs font-medium text-[#2C2824]/50">{t.initiales}</div>
                <div>
                  <p class="text-sm font-medium text-[#2C2824]">{t.nom}</p>
                  <p class="text-xs text-[#2C2824]/40">{t.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">FAQ</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-12">Questions fréquentes</h2>

      <div class="space-y-6">
        {faq.map((item) => (
          <details class="group border-b border-black/10 pb-6">
            <summary class="flex justify-between items-center cursor-pointer list-none">
              <h3 class="font-medium text-[#2C2824] pr-8">{item.question}</h3>
              <span class="text-[#C4A855] group-open:rotate-45 transition-transform text-2xl">+</span>
            </summary>
            <p class="mt-4 text-base font-light text-[#2C2824]/70 leading-relaxed">
              {item.reponse}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Dernier CTA -->
  <section class="py-20 md:py-24 bg-[#2C2824]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">Tu as un projet de lieu. On a 5 ans de réponses.</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white tracking-tight mb-6">
        7 modules. 12 lives. 147&nbsp;EUR.
      </h2>
      <p class="text-base font-light text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">
        Tout ce qu'on a appris en 5 ans, structuré pour que tu ailles plus vite que nous.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <!-- CTA : Remplacer le href par le lien Stripe / plateforme de paiement -->
        <a
          href="mailto:hello@laom.fr?subject=LAOM%20School%20Online%20—%20Je%20veux%20rejoindre"
          class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-10 py-4 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors"
        >
          Rejoindre LAOM School — 147 EUR
        </a>
      </div>

      <p class="text-xs font-light text-white/30 mt-8">
        LAOM School Weekend (présentiel à LAOM) également disponible pour aller plus loin.
        <a href="/school/" class="underline underline-offset-4 hover:text-white/50 transition-colors">En savoir plus</a>
      </p>
    </div>
  </section>

  <!-- Footer mini -->
  <section class="py-10 bg-[#1E1B18] text-center">
    <p class="text-xs font-light text-white/30">
      <strong class="text-white/50 font-normal">LAOM School</strong> est une formation créée par Charly Aubert, co-fondateur de LAOM — écolieu de 21 hectares dans le sud de l'Aveyron.
    </p>
    <p class="text-xs font-light text-white/20 mt-2">
      Questions ? <a href="mailto:hello@laom.fr" class="underline underline-offset-4 hover:text-white/40 transition-colors">hello@laom.fr</a>
    </p>
  </section>
</Layout>
