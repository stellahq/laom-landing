---
import Layout from '~/layouts/Layout.astro'
import NewsletterBanner from '~/components/NewsletterBanner.astro'
import { createWebPageSchema } from '~/utils/schema'
import { getTranslations as getI18nTranslations, getLocalizedPath } from '~/i18n/utils'

const lang = Astro.currentLocale || 'fr'
const t = getI18nTranslations(lang as 'fr' | 'en')
const pageSchema = createWebPageSchema({
  name: t.pages.project.heroTitle,
  url: Astro.url.toString(),
  description: t.pages.project.heroSubtitle,
})

const heroImage = '/images/laom/presentation/img_2767---grande-c7779ff6.webp'
---

<Layout
  title={`${t.pages.project.heroTitle} – LAOM`}
  description={t.pages.project.heroSubtitle}
  seo={{
    ldJSON: pageSchema,
  }}
>
  <!-- Progress bar -->
  <div id="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="position: fixed; bottom: 0; left: 0; height: 4px; background-color: #C4A855; z-index: 9999; width: 0%; box-shadow: 0 0 8px rgba(196, 168, 85, 0.4); transition: none; pointer-events: none;"></div>

  <!-- Sticky sidebar TOC -->
  <nav id="sticky-toc" aria-label="Sommaire du projet" style="position: fixed; top: 140px; right: 32px; z-index: 50; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; display: none;">
    <div class="flex flex-col items-end gap-[2px]">
      <a href="#habitat" data-toc="habitat" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Habitat collectif">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Habitat</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
      <a href="#ferme" data-toc="ferme" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Ferme">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Ferme</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
      <a href="#batiments" data-toc="batiments" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Batiments">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Batiments</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
      <a href="#accueil" data-toc="accueil" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Accueil">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Accueil</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
      <a href="#experiences" data-toc="experiences" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Experiences">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Experiences</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
      <a href="#chronologie" data-toc="chronologie" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Chronologie">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Chronologie</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
      <a href="#pourquoi" data-toc="pourquoi" class="toc-link group flex items-center gap-3 py-[6px] transition-all duration-300" aria-label="Pourquoi LAOM">
        <span class="toc-label text-xs font-light text-[#2C2824]/0 group-hover:text-[#2C2824]/50 transition-all duration-300 whitespace-nowrap translate-x-2 group-hover:translate-x-0">Pourquoi</span>
        <span class="toc-dot w-[6px] h-[6px] rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      </a>
    </div>
  </nav>

  <style is:inline>
    @media (min-width: 1400px) { #sticky-toc { display: block !important; } }
    section[id] { scroll-margin-top: 6rem; }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var bar = document.getElementById('progress-bar');
      if (bar) {
        var ticking = false;
        function updateProgress() {
          var scrollTop = window.scrollY || document.documentElement.scrollTop;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          var progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
          bar.style.width = progress + '%';
          bar.setAttribute('aria-valuenow', Math.round(progress));
          ticking = false;
        }
        window.addEventListener('scroll', function () {
          if (!ticking) { requestAnimationFrame(updateProgress); ticking = true; }
        }, { passive: true });
        updateProgress();
      }
      var stickyToc = document.getElementById('sticky-toc');
      var heroSection = document.querySelector('section.relative');
      if (stickyToc && heroSection) {
        var tocVisible = false;
        var heroObserver = new IntersectionObserver(function (entries) {
          tocVisible = !entries[0].isIntersecting;
          stickyToc.style.opacity = tocVisible ? '1' : '0';
          stickyToc.style.pointerEvents = tocVisible ? 'auto' : 'none';
        }, { threshold: 0 });
        heroObserver.observe(heroSection);
      }
      var sections = document.querySelectorAll('section[id]');
      var tocLinks = document.querySelectorAll('#sticky-toc .toc-link');
      var currentActive = null;
      if (sections.length && tocLinks.length) {
        var chapterObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var activeId = entry.target.id;
              if (currentActive === activeId) return;
              currentActive = activeId;
              tocLinks.forEach(function (link) {
                var id = link.getAttribute('data-toc');
                var dot = link.querySelector('.toc-dot');
                var isActive = id === activeId;
                var label = link.querySelector('.toc-label');
                link.setAttribute('aria-current', isActive ? 'true' : 'false');
                if (dot) {
                  dot.style.backgroundColor = isActive ? '#C4A855' : '';
                  dot.style.width = isActive ? '8px' : '';
                  dot.style.height = isActive ? '8px' : '';
                  dot.style.boxShadow = isActive ? '0 0 6px rgba(196,168,85,0.4)' : '';
                }
                if (label) {
                  label.style.color = isActive ? 'rgba(44,40,36,0.7)' : '';
                  label.style.fontWeight = isActive ? '500' : '';
                }
              });
            }
          });
        }, { rootMargin: '-15% 0px -65% 0px' });
        sections.forEach(function (s) { chapterObserver.observe(s); });
      }
    });
  </script>
  <!-- Hero with LAOM photo background -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden -mt-24 md:-mt-28">
    <div class="absolute inset-0 z-0">
      <img
        src={heroImage}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/40 to-black/60"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-10 sm:px-16 lg:px-24 text-center py-32 lg:py-40">
      <span class="block text-xs font-light tracking-[0.2em] uppercase text-white/80 mb-6">LAOM</span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-light text-white mb-6 tracking-tight">
        {t.pages.project.heroTitle}
      </h1>
      <p class="text-xl md:text-2xl font-light text-white/90 max-w-3xl mx-auto leading-relaxed mb-4">
        {t.pages.project.heroSubtitle}
      </p>
      <p class="text-sm md:text-base font-light tracking-[0.15em] uppercase text-white/80">
        {t.pages.project.heroTagline}
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-lg md:text-xl font-light text-black/80 leading-relaxed mb-6">
        LAOM est né d'une intention simple : créer un lieu qui redonne de l'énergie plutôt que d'en consommer. Habiter autrement. Travailler autrement. Se relier autrement.<br />
        Un lieu où la nature, la création et la vie collective se nourrissent mutuellement.
      </p>
      <p class="text-lg md:text-xl font-light text-black/80 leading-relaxed mb-6">
        Le projet s'est construit dans le temps long. Nous avons formé le groupe en 2020. Nous avons acheté le lieu début 2021.<br />
        Nous avons commencé les premières briques de construction de LAOM en 2022. Plusieurs années de vie sur place, de démarches administratives, d'obstacles, d'apprentissages et de réajustements ont façonné bien plus qu'un lieu : une vision solide, une expertise de terrain et un modèle pensé pour durer, et être réplicable.
      </p>
      <p class="text-lg md:text-xl font-light text-black/80 leading-relaxed">
        Nous avons traversé les doutes, des départs, des arrivées, les remises en question et les rebonds. Cette réalité fait partie intégrante du projet.<br />
        Aujourd'hui, LAOM est un projet en construction active, structuré par un cadre juridique conçu pour soutenir le collectif et la vision à long terme.
      </p>
    </div>
  </section>

  <!-- Dimensions -->
  <section class="py-16 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-lg font-light text-black/80 leading-relaxed mb-6">
        LAOM rassemble, sur un même lieu, plusieurs dimensions complémentaires :
      </p>
      <ul class="space-y-3 text-lg font-light text-black/80">
        <li>– un lieu d'habitat collectif</li>
        <li>– un jardin maraîcher en agriculture régénératrice,</li>
        <li>– des bâtiments éco-construits,</li>
        <li>– un espace d'accueil pour les stages & le coliving</li>
        <li>– et des expériences immersives pour artistes, créateurs et explorateurs.</li>
      </ul>
    </div>
  </section>

  <!-- Un lieu d'habitat collectif et intergénérationnel -->
  <section id="habitat" class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Habitat</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">Un lieu d'habitat collectif et intergénérationnel</h2>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-8">
        LAOM est avant tout un lieu de vie.<br />
        Il s'inscrit au sein de l'écolieu Oasis La Margue, ce lieu très préservé au cœur du parc naturel des Grands Causses, un domaine habité collectivement, où nous expérimentons le vivre ensemble dans le respect des rythmes, des besoins et de l'autonomie de chacun.
      </p>
      <img 
          src="/images/laom/presentation-photo-2021-08-08-18-04-31-2-85890d29.webp" 
          alt="[Photo a prendre : vue d'ensemble des habitats LAOM,  Petit Shambala, Grand Shambala, tiny houses da"
          class="w-full h-full object-cover"
          loading="lazy"
        />

      <h3 class="text-xl md:text-2xl font-light text-black mb-4 mt-10">L'écolieu Oasis La Margue : le cadre global</h3>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-8">
        Oasis La Margue est l'écolieu dans son ensemble.<br />
        Le domaine a été acquis collectivement initialement et comprend des habitats historiques en pierre, déjà présents sur le site ainsi que 21 hectares de prairies et de forêt, sur une partie desquels le projet LAOM a été développé. Certains membres du collectif vivent aujourd'hui dans les maisons en pierre, et d'autres (nous !) dans les nouveaux bâtiments à l'Ouest.
      </p>

      <h3 class="text-xl md:text-2xl font-light text-black mb-4 mt-10">L'entité LAOM</h3>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        À l'ouest du domaine, <a href="/qui-sommes-nous/" target="_blank" rel="noopener noreferrer" aria-label="Qui sommes-nous (ouvre dans un nouvel onglet)" class="underline underline-offset-4 text-[#2d5016] hover:text-[#1a3d0d] transition-colors">certains membres du collectif</a> ont conçu et développé LAOM, une entité nouvelle, pensée comme un écosystème de vie, d'accueil et de régénération.<br />
        LAOM regroupe l'ensemble des espaces spécifiquement imaginés et construits pour soutenir les habitats écologiques, les projets, le coliving et les activités du lieu ; complémentaire aux habitats historiques.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-4">LAOM comprend :</p>
      <ul class="space-y-2 text-lg font-light text-[#2C2824]/85 mb-8">
        <li>– Petit Shambala, notre maison « test » en auto-construction (ossature bois, isolation fibre de bois, sol en terre crue, enduits terre)</li>
        <li>– Grand Shambala, qui accueille : des habitats permanents, des habitats semi-permanents, des chambres de coliving, un foyer commun ouvert à l'ensemble des habitants de l'écolieu, un studio d'art & de création</li>
        <li>– Le Shala, la salle d'activités dédiée aux pratiques et stages</li>
        <li>– Deux tiny houses</li>
        <li>– Un espace de restauration réservé aux personnes séjournant sur le lieu (résidents temporaires, stagiaires, invités) – actuellement ouvert en période estivale uniquement.</li>
        <li>– Une serre</li>
        <li>– Un jardin / ferme nourricière</li>
      </ul>

      <div class="rounded-lg border border-black/10 bg-[#FAF8F5] p-6 lg:p-8 mb-10">
        <h3 class="text-xl md:text-2xl font-light text-black mb-3">{t.pages.project.constructionBlogsTitle}</h3>
        <p class="text-base font-light text-black/70 mb-4">{t.pages.project.constructionBlogsIntro}</p>
        <ul class="space-y-2">
          {t.pages.project.constructionBlogs.map((item) => {
            const label = lang === 'fr' ? item.labelFr : item.labelEn
            const slug = lang === 'fr' ? item.slugFr : item.slugEn
            const isGrandShambala = slug.includes('grand-shambala')
            const href = isGrandShambala
              ? getLocalizedPath('/grand-shambala-v2/', lang as 'fr' | 'en')
              : getLocalizedPath(`/blog/${slug}/`, lang as 'fr' | 'en')
            return (
              <li>
                <a href={href} class="text-lg font-light text-black/80 hover:text-[#2d5016] transition-colors underline underline-offset-4">
                  {label}
                </a>
              </li>
            )
          })}
        </ul>
      </div>

      <h3 class="text-xl md:text-2xl font-light text-black mb-4 mt-10">Une diversité de manières d'habiter</h3>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
        Au sein de l'écolieu, les formes d'habitat sont multiples : résidents permanents, habitants semi-permanents et personnes de passage (coliving, stages, festivals, ateliers).
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-6">
        Dans l'entité LAOM, ces manières d'habiter s'inscrivent dans des principes communs : <strong>des habitats écologiques</strong>, conçus avec des matériaux naturels, sains (notamment en termes de qualité de l'air intérieur) et volontairement sobres et minimalistes, afin de réduire l'empreinte matérielle et de privilégier l'essentiel.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-6">
        Des espaces communs, existants et en cours de construction, sont pensés comme des lieux de rencontre et de partage entre les habitants. Ils soutiennent une vie collective choisie, respectueuse des rythmes, des besoins et de l'autonomie de chacun.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-6">
        Le collectif est intergénérationnel, de 2 à 70 ans, et évolue au fil du temps, des saisons et des projets.
      </p>
    </div>
  </section>

  <!-- Une ferme pédagogique en agriculture régénératrice -->
  <section id="ferme" class="py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Agriculture</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">Une ferme pédagogique en agriculture régénératrice</h2>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Nous expérimentons l'agriculture régénératrice, une approche qui vise à restaurer les écosystèmes en enrichissant les sols et en soutenant la biodiversité.
      </p>
      <div class="mt-8 mb-10 aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm">
        <p class="text-sm font-light text-[#2C2824]/40 px-8 text-center">[Photo a prendre : jardin maraicher en agriculture regeneratrice,  planches de culture, serre, paysage]</p>
      </div>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Face à la dégradation rapide des sols et aux enjeux écologiques actuels, notre démarche va bien au-delà de la simple production alimentaire. Elle s'inscrit comme un chemin d'apprentissage au service de la régénération des sols, avec la volonté que le jardin nourricier alimente à la fois les habitants du lieu et les personnes accueillies lors des stages et des évènements du lieu.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
        La ferme maraîchère pédagogique est un espace de transmission.<br />
        À travers des ateliers pratiques, des temps de sensibilisation et des expériences ouvertes aux enfants comme aux adultes, nous partageons ce que nous expérimentons, apprenons et ajustons.
      </p>
    </div>
  </section>

  <!-- Des bâtiments éco-construits -->
  <section id="batiments" class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Ecoconstruction</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">Des bâtiments éco-construits</h2>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Les constructions de LAOM sont conçues selon les principes de l'éco-construction, à partir de matériaux locaux, renouvelables ou recyclés.
      </p>
      <div class="mt-8 mb-10 aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm">
        <p class="text-sm font-light text-[#2C2824]/40 px-8 text-center">[Photo a prendre : detail mur paille porteuse,  texture, lumiere, enduit terre]</p>
      </div>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
        Paille porteuse, terre crue, enduits naturels : nous expérimentons des solutions durables, confortables et saines, en réduisant au maximum l'empreinte écologique.<br />
        Ces bâtiments ne sont pas seulement des lieux d'habitat ou d'accueil, mais aussi des supports pédagogiques et des démonstrateurs concrets de ce qu'il est possible de faire aujourd'hui.
      </p>
    </div>
  </section>

  <!-- Un espace d'accueil pour stages et retraites -->
  <section id="accueil" class="py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Accueil</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">Un espace d'accueil pour stages et retraites</h2>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Au cœur d'un environnement naturel préservé, l'espace d'accueil de LAOM propose des expériences immersives à celles et ceux qui souhaitent se ressourcer, apprendre et se reconnecter.
      </p>
      <div class="mt-8 mb-10 aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm">
        <p class="text-sm font-light text-[#2C2824]/40 px-8 text-center">[Photo a prendre : salle de pratique Le Shala,  interieur vide, lumiere naturelle, sol bois]</p>
      </div>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Au-delà de l'accueil de praticiens extérieurs, LAOM développe ses propres immersions et événements signature, ancrés dans l'esprit du lieu.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Se déconnecter du rythme effréné, se synchroniser avec les cycles du vivant, retrouver une présence plus fine à soi et au monde.<br />
        Se nourrir pour nourrir le monde.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
        Notre espace d'accueil offre une expérience immersive aux visiteurs désireux de découvrir non seulement la beauté naturelle du lieu, mais aussi d'interagir avec les autres dimensions du projet (agriculture régénératrice, vivre ensemble, éco-construction).
      </p>
    </div>
  </section>

  <!-- Expériences immersives, résidences, colivings et micro-festivals -->
  <section id="experiences" class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Experiences</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">Expériences immersives, résidences, colivings et micro-festivals</h2>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        LAOM accueille des expériences immersives, des résidences et des temps de coliving pour créateurs, artistes, leaders et personnes en quête de calme, de ressourcement ou de mieux-être.
      </p>
      <div class="mt-8 mb-10 aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm">
        <p class="text-sm font-light text-[#2C2824]/40 px-8 text-center">[Photo a prendre : micro-festival LAOM,  personnes autour du feu, lumiere doree, soiree]</p>
      </div>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Le coliving à LAOM propose des temps de vie intentionnels, sur des durées variables (résidences, moyens séjours), pour créer, se régénérer ou traverser une phase de transition, dans un environnement naturel, sobre et soutenant.<br />
        Ces séjours s'inscrivent en lien avec les différentes dimensions du lieu, dans le respect de son rythme et de ses usages.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Les micro-festivals sont des temps forts éphémères de célébration et de transmission, mêlant pratiques, rencontres et créations, pour explorer le lieu et le vivre autrement.
      </p>
      <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
        Le lieu a déjà accueilli des centaines de personnes venues de tous horizons.<br />
        Les expériences immersives proposées à LAOM sont conçues comme des espaces de transformation profonde. Les personnes qui y participent repartent nourries, inspirées et transformées, et seront naturellement amenées à diffuser ce qu'elles ont vécu autour d'elles, contribuant ainsi à un impact global de bien-être, de paix et d'harmonie. C'est un effet d'essaimage, un effet papillon.
      </p>
    </div>
  </section>

  <!-- Timeline des avancées -->
  <section id="chronologie" class="py-24 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
