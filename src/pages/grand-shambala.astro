---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'Le Grand Shambala,  Histoire d\'un bâtiment impossible',
  url: Astro.url.toString(),
  description:
    'Comment un petit groupe a construit le plus grand bâtiment en paille porteuse au monde : 850 m², deux niveaux, 90 jours. De l\'intuition Earthship aux enduits à la chaux, récit complet d\'un chantier hors-norme.',
})
---

<Layout
  title="Le Grand Shambala – LAOM"
  description="Comment un petit groupe a construit le plus grand bâtiment en paille porteuse au monde : 850 m², deux niveaux, 90 jours."
  seo={{ ldJSON: pageSchema }}
>

  <!-- Playfair Display for article headings -->
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap');
    .font-playfair { font-family: 'Playfair Display', Georgia, serif; }
  </style>

  <!-- Progress bar,  fixed bottom, thick, visible -->
  <div id="progress-bar" class="fixed bottom-0 left-0 h-[8px] bg-[#C4A855] z-50 transition-none" style="width: 0%; box-shadow: 0 0 12px rgba(196, 168, 85, 0.6);"></div>

  <!-- Sticky sidebar TOC,  desktop only, hidden until past inline TOC -->
  <nav id="sticky-toc" class="fixed left-8 top-1/2 -translate-y-1/2 z-40 flex-col gap-2 transition-opacity duration-500" style="max-width: 240px; display: none; opacity: 0; pointer-events: none;">
    <a href="#lhomme" data-toc="lhomme" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>1. L'homme qui regardait le champ</span>
    </a>
    <a href="#la-graine" data-toc="la-graine" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>2. La Graine</span>
    </a>
    <a href="#lobsession" data-toc="lobsession" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>3. L'Obsession</span>
    </a>
    <a href="#les-murs-qui-parlent" data-toc="les-murs-qui-parlent" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>4. Les Murs qui parlent</span>
    </a>
    <a href="#le-mur" data-toc="le-mur" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>5. Le Mur</span>
    </a>
    <a href="#90-jours" data-toc="90-jours" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>6. 90 Jours</span>
    </a>
    <a href="#humilite" data-toc="humilite" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>7. L'Humilité</span>
    </a>
    <a href="#la-peau" data-toc="la-peau" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>8. La Peau</span>
    </a>
    <a href="#programme" data-toc="programme" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>9. Le Programme</span>
    </a>
    <a href="#lhorizon" data-toc="lhorizon" class="toc-link flex items-center gap-3 py-2 text-sm text-[#2C2824]/35 hover:text-[#2C2824]/80 transition-all duration-300">
      <span class="toc-dot w-2 h-2 rounded-full bg-[#2C2824]/15 transition-all duration-300 shrink-0"></span>
      <span>10. L'Horizon</span>
    </a>
  </nav>

  <script is:inline>
    (function () {
      // Progress bar
      var bar = document.getElementById('progress-bar');
      if (!bar) return;
      var ticking = false;
      function updateProgress() {
        var scrollTop = window.scrollY || document.documentElement.scrollTop;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        var progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
        bar.style.width = progress + '%';
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(updateProgress); ticking = true; }
      }, { passive: true });
      updateProgress();

      // Sticky TOC,  show/hide based on inline TOC position
      var stickyToc = document.getElementById('sticky-toc');
      var inlineToc = document.getElementById('inline-toc');
      if (stickyToc && inlineToc && window.innerWidth >= 1024) {
        stickyToc.style.display = 'flex';
        // Use scroll listener for reliable show/hide
        function checkTocVisibility() {
          var rect = inlineToc.getBoundingClientRect();
          if (rect.bottom < 0) {
            stickyToc.style.opacity = '1';
            stickyToc.style.pointerEvents = 'auto';
          } else {
            stickyToc.style.opacity = '0';
            stickyToc.style.pointerEvents = 'none';
          }
        }
        window.addEventListener('scroll', checkTocVisibility, { passive: true });
        checkTocVisibility();
      }

      // Active chapter tracking
      var sections = document.querySelectorAll('section[id]');
      var tocLinks = document.querySelectorAll('.toc-link');
      var currentActive = null;
      if (sections.length && tocLinks.length) {
        var chapterObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var activeId = entry.target.id;
              if (currentActive === activeId) return;
              currentActive = activeId;
              tocLinks.forEach(function (link) {
                var id = link.getAttribute('data-toc');
                var dot = link.querySelector('.toc-dot');
                var isActive = id === activeId;
                link.style.color = isActive ? '#2C2824' : '';
                link.style.fontWeight = isActive ? '600' : '';
                link.style.transform = isActive ? 'translateX(4px)' : '';
                if (dot) {
                  dot.style.backgroundColor = isActive ? '#C4A855' : '';
                  dot.style.width = isActive ? '10px' : '';
                  dot.style.height = isActive ? '10px' : '';
                  dot.style.boxShadow = isActive ? '0 0 6px rgba(196,168,85,0.5)' : '';
                }
              });
            }
          });
        }, { rootMargin: '-15% 0px -65% 0px' });
        sections.forEach(function (s) { chapterObserver.observe(s); });
      }
    })();
  </script>

  <!-- ============================================================
       SECTION 0,  COLD OPEN
       Écran blanc, une phrase, puis le bâtiment se révèle au scroll.
       ============================================================ -->

  <!-- 0a. Hero image full-bleed with title overlay -->
  <section class="relative w-full -mt-24 md:-mt-28">
    <img src="/images/laom/grand-shambala/grand-shambala-vue-drone-paille-porteuse-aveyron.webp" alt="Vue drone du Grand Shambala à golden hour,  850 m² de paille porteuse dans le paysage aveyronnais" title="Le Grand Shambala vu du ciel au coucher du soleil" class="w-full object-cover" loading="eager" decoding="async" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent flex items-end justify-center pb-12 md:pb-20">
      <h1 class="font-playfair text-4xl md:text-6xl lg:text-7xl font-light text-white tracking-tight drop-shadow-lg">
        Grand Shambala
      </h1>
    </div>
  </section>

  <!-- 0c. Stats qui claquent -->
  <section class="py-20 lg:py-28 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 text-center">
        <div>
          <p class="text-4xl md:text-5xl lg:text-6xl font-light text-[#2C2824] tracking-tight">850</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/50 mt-2">m² de surface</p>
        </div>
        <div>
          <p class="text-4xl md:text-5xl lg:text-6xl font-light text-[#2C2824] tracking-tight">2</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/50 mt-2">niveaux,  paille porteuse</p>
        </div>
        <div>
          <p class="text-4xl md:text-5xl lg:text-6xl font-light text-[#2C2824] tracking-tight">90</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/50 mt-2">jours de chantier</p>
        </div>
        <div>
          <p class="text-4xl md:text-5xl lg:text-6xl font-light text-[#2C2824] tracking-tight">0</p>
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/50 mt-2">précédent juridique</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Temps de lecture + Table des matières discrète -->
  <section id="inline-toc" class="py-10 bg-white border-t border-black/5">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mb-8">Lecture : 18 minutes</p>
      <nav class="space-y-2">
        <p class="text-xs font-light tracking-[0.15em] uppercase text-[#2C2824]/30 mb-3">Sommaire</p>
        <a href="#lhomme" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">1. L'homme qui regardait le champ</a>
        <a href="#la-graine" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">2. La Graine,  L'intuition Earthship</a>
        <a href="#lobsession" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">3. L'Obsession,  Exploser les dimensions</a>
        <a href="#les-murs-qui-parlent" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">4. Les Murs qui parlent,  De l'acier à la paille</a>
        <a href="#le-mur" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">5. Le Mur,  4 ans de bataille administrative</a>
        <a href="#90-jours" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">6. 90 Jours,  Le chantier</a>
        <a href="#humilite" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">7. L'École de l'humilité,  Les enduits</a>
        <a href="#la-peau" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">8. La Peau,  L'intérieur prend vie</a>
        <a href="#programme" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">9. Ce que le bâtiment contient</a>
        <a href="#lhorizon" class="block text-sm font-light text-[#2C2824]/60 hover:text-[#2C2824] transition-colors">10. L'Horizon</a>
      </nav>
    </div>
  </section>


  <!-- ============================================================
       SECTION 1,  L'HOMME QUI REGARDAIT LE CHAMP
       Ouverture littéraire. Une scène, pas un CV.
       ============================================================ -->

  <section id="lhomme" class="py-24 lg:py-32 bg-white">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">

      <span class="block text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">Chapitre 1</span>
      <h2 class="font-playfair text-3xl md:text-4xl lg:text-5xl font-light text-[#2C2824] mb-12 tracking-tight leading-tight">
        L'homme qui regardait le champ
      </h2>

      <!--
        ┌──────────────────────────────────────────────────────────────┐
        │  📸 PLACEHOLDER,  PORTRAIT                                  │
        │                                                              │
        │  Portrait de Charly,  PAS corporate, PAS posé.              │
        │  Mains sales, ou penché sur des plans, ou debout dans le    │
        │  champ AVANT que rien ne soit construit.                     │
        │  Si possible : photo du terrain vierge superposée avec un   │
        │  wireframe fantôme du futur bâtiment. Contraste dévastateur.│
        │  Format : portrait ou 4/3, content-width.                    │
        └──────────────────────────────────────────────────────────────┘
      -->
      <img src="/images/laom/grand-shambala/charly-aubert-portrait-debut-projet-grand-shambala.webp" alt="Portrait de Charly,  les débuts du projet Grand Shambala" title="Charly Aubert, fondateur de LAOM" class="w-full aspect-[4/3] object-cover rounded-sm mb-10" loading="lazy" decoding="async" />

      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        <span class="text-5xl font-light text-[#2C2824] float-left mr-3 mt-1 leading-none">I</span>l y a un moment précis où le Grand Shambala a commencé à exister. Pas sur un plan. Pas dans une réunion. Dans un regard. Un homme debout dans un champ du sud de l'Aveyron, au cœur du Parc Naturel des Grands Causses, qui regarde une prairie en pente et voit,  avec une netteté absurde,  un bâtiment de 850 m² qui n'existe nulle part ailleurs que dans sa tête.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        Pas d'argent. Pas d'expérience en construction. Pas de terrain, pas encore. Juste une impulsion de joie. Le genre de certitude que les gens raisonnables appellent de la folie et que les bâtisseurs appellent le commencement.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        Le domaine de la Margue a été acquis collectivement en février 2021 par un groupe de onze personnes qui ne savaient pas exactement ce qu'elles allaient construire,  mais savaient pourquoi. Habiter autrement. Construire des murs qui respirent. Prouver qu'un lieu peut régénérer plutôt que consommer. LAOM n'était pas censé exister. Du moins, pas selon les critères habituels de faisabilité.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed">
        Mais l'histoire du Grand Shambala, c'est justement l'histoire de ce qui se passe quand on refuse de commencer par la question « est-ce possible ? » et qu'on commence par la question « est-ce nécessaire ? ».
      </p>
    </div>
  </section>


  <!-- ============================================================
       SECTION 2,  LA GRAINE,  L'INTUITION EARTHSHIP
       Compressée. Un moment de découverte, pas un cours.
       ============================================================ -->

  <section id="la-graine" class="py-24 lg:py-32 bg-[#FAF8F5]">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">

      <span class="block text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">Chapitre 2</span>
      <h2 class="font-playfair text-3xl md:text-4xl lg:text-5xl font-light text-[#2C2824] mb-12 tracking-tight leading-tight">
        La Graine
      </h2>

      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        Tout est parti des Earthships. Ces bâtiments inventés par l'architecte américain Michael Reynolds dans le désert du Nouveau-Mexique : des structures autonomes, bioclimatiques, construites avec des matériaux recyclés, capables de produire leur propre énergie, de collecter leur eau, de recycler leurs déchets, de nourrir leurs habitants grâce à une serre intégrée. Un bâtiment qui fait tout. Un organisme vivant.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        La philosophie Earthship tient en six principes : le solaire passif, la masse thermique, la gestion de l'eau, le recyclage des matériaux, la production alimentaire, et l'autonomie énergétique. Six dimensions d'un même rêve : un habitat qui donne plus qu'il ne prend.
      </p>

      <!--
        ┌──────────────────────────────────────────────────────────────┐
        │  📸 PLACEHOLDER,  DIAGRAMME EARTHSHIP                      │
        │                                                              │
        │  Illustration organique dessinée à la main, style croquis   │
        │  sur papier kraft. Les 6 principes Earthship disposés en    │
        │  cercle ou en constellation autour d'un Earthship central.  │
        │  Esthétique : carnet d'architecte, encre noire + touches    │
        │  ocre/or. PAS un infographique corporate.                   │
        │  Format : centré, flottant dans du whitespace.              │
        │  Envisager un fond subtle papier kraft uniquement pour      │
        │  cet élément, comme un scan de carnet.                      │
        └──────────────────────────────────────────────────────────────┘
      -->
      <img src="/images/laom/grand-shambala/diagramme-6-principes-earthship-solaire-thermique.webp" alt="Diagramme des 6 principes Earthship,  l'intuition à l'origine du Grand Shambala" title="Les 6 principes fondateurs du concept Earthship" class="my-12 w-full rounded-sm" loading="lazy" decoding="async" />

      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        On a étudié ces principes un par un. On les a décomposés, retournés, questionnés. Et c'est là qu'est survenue la question qui a tout changé :
      </p>

      <!-- Pull quote -->
      <blockquote class="my-12 py-8 border-l-2 border-[#C4A855] pl-8">
        <p class="text-xl md:text-2xl font-light italic text-[#2C2824]/90 leading-relaxed">
          Et si, au lieu de réduire le rêve pour qu'il rentre dans la technique, on agrandissait la technique pour qu'elle accueille le rêve ?
        </p>
      </blockquote>
    </div>
  </section>


  <!-- ============================================================
       SECTION 3,  L'OBSESSION,  EXPLOSER LES DIMENSIONS
       Le tournant : de l'Earthship au hameau.
       ============================================================ -->

  <section id="lobsession" class="py-24 lg:py-32 bg-white">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">

      <span class="block text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">Chapitre 3</span>
      <h2 class="font-playfair text-3xl md:text-4xl lg:text-5xl font-light text-[#2C2824] mb-12 tracking-tight leading-tight">
        L'Obsession
      </h2>

      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        Le problème avec un Earthship, c'est qu'il est pensé pour une famille isolée dans le désert. Nous, on n'était pas isolés. On était onze. Et on n'était pas dans le désert,  on était dans un écohameau de 21 hectares avec une rivière, des prairies, des forêts, et une ambition collective.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        Alors on a fait quelque chose que personne n'avait fait : on a <strong>explosé</strong> les dimensions de l'Earthship et on les a redistribuées à l'échelle du hameau.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        La serre qui, dans un Earthship classique, se trouve devant le bâtiment et assure à la fois la production alimentaire et l'apport thermique ? Nous, on n'avait pas besoin d'une serre intégrée au bâtiment. On avait la possibilité d'installer une vraie ferme maraîchère à l'échelle du domaine,  la Ferme du Verseau,  avec une production bien plus généreuse qu'une simple serre d'appoint.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        En revanche, l'apport solaire passif et thermique que la serre apportait au bâtiment Earthship, ça, on l'a conservé. On l'a reproduit avec une grande façade sud vitrée, conçue pour capter le soleil en hiver et s'en protéger en été. Le principe bioclimatique, intact. L'application, radicalement différente.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/80 leading-relaxed mb-6">
        L'autonomie en eau ? Elle se pense à l'échelle du domaine, avec la rivière et les sources. Le recyclage des matériaux ? Il se pratique sur chaque chantier, avec la terre excavée réutilisée en enduits, le bois local pour la charpente. Chaque principe Earthship a trouvé sa place,  non pas dans un seul bâtiment, mais dans un écosystème entier.
      </p>
    </div>

    <!--
      ┌──────────────────────────────────────────────────────────────┐
      │  📸 PLACEHOLDER,  COMPARAISON EARTHSHIP VS GRAND SHAMBALA   │
      │                                                              │
      │  Image split en deux :                                       │
      │  À gauche : un Earthship classique (petit, semi-enterré,     │
      │  module unique avec serre devant)                             │
      │  À droite : le Grand Shambala à la même échelle               │
      │  Une flèche ou un simple trait entre les deux.                │
      │  Légende : « Du module au monde »                            │
      │  Style : dessin architectural épuré ou photo/illustration.   │
      │  Format : full-width dans le container 5xl.                  │
      └──────────────────────────────────────────────────────────────┘
    -->
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 mt-4">
      <img src="/images/laom/grand-shambala/comparaison-earthship-vs-grand-shambala-collectif.webp" alt="Comparaison Earthship classique vs Grand Shambala,  du module au monde" title="Du module individuel au village collectif" class="w-full rounded-sm" loading="lazy" decoding="async" />
      <p class="text-center text-sm font-light italic text-[#2C2824]/40 mt-4">Du module au monde</p>
    </div>

    <!--
      ┌──────────────────────────────────────────────────────────────┐
      │  📸 PLACEHOLDER,  CROQUIS D'ÉVOLUTION                       │
      │                                                              │
      │  3 à 4 croquis / plans anciens montrant l'évolution de la   │
      │  réflexion. Dessins de napkin, premiers CAD, plans rejetés.  │
      │  Disposés en grille lâche ou en cascade diagonale.           │
      │  Plus c'est imparfait, mieux c'est. Montrer le PROCESS.     │
      │  Si possible inclure des annotations manuscrites.            │
      │  Format : grille 2x2 ou cascade, content-width.             │
      └──────────────────────────────────────────────────────────────┘
    -->
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 mt-12">
      <div class="grid grid-cols-2 gap-4">
