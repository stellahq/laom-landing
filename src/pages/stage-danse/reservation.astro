---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

export const prerender = true

const pageSchema = createWebPageSchema({
  name: 'Réserver En Mouvement — Immersion danse | LAOM',
  url: Astro.url.toString(),
  description: 'Réserve ta place pour En Mouvement. 5 jours d\'immersion par la danse et le mouvement. 1100€ tout inclus.',
})

const inclus = [
  { text: '5 jours de pratique intensive avec Samuel Planas' },
  { text: 'Hébergement sur place (tipi ou chambre)' },
  { text: 'Tous les repas (cuisine maison, produits locaux)' },
  { text: 'Accompagnement par Charly Aubert' },
  { text: 'Accès au domaine et aux espaces de détente' },
]

const reassurance = [
  { icon: 'users', title: '15 places max', desc: 'Groupe intime' },
  { icon: 'heart', title: 'Tous niveaux', desc: 'Aucun prérequis' },
  { icon: 'lock', title: 'Réservation simple', desc: 'Par email' },
  { icon: 'calendar', title: 'Annulation -14j', desc: 'Remboursement intégral' },
]
---

<Layout
  title="Réserver En Mouvement — Immersion danse | LAOM"
  description="Réserve ta place pour En Mouvement. 5 jours d'immersion par la danse et le mouvement. 1100€ tout inclus."
  seo={{ ldJSON: pageSchema, noindex: true }}
>
  <!-- Hero minimaliste -->
  <section class="bg-[#2C2824] -mt-24 md:-mt-28 pt-32 pb-16">
    <div class="max-w-3xl mx-auto px-8 md:px-12 lg:px-16 text-center">
      <a href="/stage-danse" class="inline-flex items-center gap-2 text-sm font-light text-white/50 hover:text-[#C4A855] transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        Retour à En Mouvement
      </a>
      <p class="text-xs font-light tracking-[0.25em] uppercase text-[#C4A855] mb-4">Réservation</p>
      <h1 class="font-playfair text-4xl md:text-5xl font-medium text-white mb-4 tracking-tight">
        En Mouvement
      </h1>
      <p class="text-lg font-light text-white/70 max-w-xl mx-auto">
        3 sessions en août 2026 · 5 jours d'immersion par la danse
      </p>
    </div>
  </section>

  <!-- Contenu principal -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-8 md:px-12 lg:px-16">
      
      <!-- Choix de session -->
      <div class="mb-12 p-8 bg-[#FAF8F5] rounded-sm">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Choisis ta session</p>
        
        <div class="grid md:grid-cols-3 gap-4 mb-8">
          <label class="session-choice relative cursor-pointer">
            <input type="radio" name="session" value="session1" class="sr-only peer" checked />
            <div class="p-6 border-2 border-[#2C2824]/10 rounded-sm peer-checked:border-[#C4A855] peer-checked:bg-white transition-colors">
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">Session 1</p>
              <p class="font-playfair text-lg font-medium text-[#2C2824]">5 – 9 août 2026</p>
              <p class="text-sm font-light text-[#2C2824]/50 mt-1">5 jours / 4 nuits</p>
            </div>
          </label>
          <label class="session-choice relative cursor-pointer">
            <input type="radio" name="session" value="session2" class="sr-only peer" />
            <div class="p-6 border-2 border-[#2C2824]/10 rounded-sm peer-checked:border-[#C4A855] peer-checked:bg-white transition-colors">
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">Session 2</p>
              <p class="font-playfair text-lg font-medium text-[#2C2824]">11 – 15 août 2026</p>
              <p class="text-sm font-light text-[#2C2824]/50 mt-1">5 jours / 4 nuits</p>
            </div>
          </label>
          <label class="session-choice relative cursor-pointer">
            <input type="radio" name="session" value="session3" class="sr-only peer" />
            <div class="p-6 border-2 border-[#2C2824]/10 rounded-sm peer-checked:border-[#C4A855] peer-checked:bg-white transition-colors">
              <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">Session 3</p>
              <p class="font-playfair text-lg font-medium text-[#2C2824]">16 – 20 août 2026</p>
              <p class="text-sm font-light text-[#2C2824]/50 mt-1">5 jours / 4 nuits</p>
            </div>
          </label>
        </div>
        
        <h3 class="text-sm font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Ce qui est inclus</h3>
        <div class="grid sm:grid-cols-2 gap-3">
          {inclus.map((item) => (
            <div class="flex items-start gap-3">
              <span class="text-[#C4A855] mt-0.5">&#10003;</span>
              <span class="text-base font-light text-[#2C2824]/80">{item.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- L'experience -->
      <div class="mb-12">
        <h2 class="font-playfair text-2xl font-medium text-[#2C2824] mb-6">Ce que tu vas vivre</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-6 border border-black/5 rounded-sm">
            <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">Le matin</p>
            <h3 class="font-playfair text-lg font-medium text-[#2C2824] mb-2">Pratique guidée</h3>
            <p class="text-sm font-light text-[#2C2824]/60">Mise en corps, flux continu, exploration du mouvement avec Samuel.</p>
          </div>
          <div class="p-6 border border-black/5 rounded-sm">
            <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">L'après-midi</p>
            <h3 class="font-playfair text-lg font-medium text-[#2C2824] mb-2">Ateliers & intégration</h3>
            <p class="text-sm font-light text-[#2C2824]/60">Travail relationnel, danse contact, temps de repos et partage.</p>
          </div>
        </div>
      </div>

      <!-- Prix et paiement -->
      <div class="mb-12 p-8 border-2 border-[#C4A855] rounded-sm bg-white">
        <div class="mb-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-2">Tarif tout inclus</p>
          <div class="flex items-baseline gap-3">
            <span class="font-playfair text-5xl font-medium text-[#2C2824]" data-em-total>1 100</span>
            <span class="text-xl font-light text-[#2C2824]/50">€</span>
            <span class="font-playfair text-2xl font-light text-[#2C2824]/35 line-through hidden" data-em-base>1 100 €</span>
          </div>
          <p class="text-sm font-light text-[#2C2824]/50 mt-2">Paiement unique · Hébergement et repas inclus</p>
        </div>

        <form id="em-form" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Prénom <span class="text-[#2C2824]/50">*</span></label>
              <input type="text" name="firstname" required placeholder="Ton prénom" class="w-full bg-[#FAF8F5] border border-black/10 px-4 py-3 text-sm text-[#2C2824] focus:outline-none focus:border-[#C4A855]" />
            </div>
            <div>
              <label class="block text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Nom <span class="text-[#2C2824]/50">*</span></label>
              <input type="text" name="lastname" required placeholder="Ton nom" class="w-full bg-[#FAF8F5] border border-black/10 px-4 py-3 text-sm text-[#2C2824] focus:outline-none focus:border-[#C4A855]" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Email <span class="text-[#2C2824]/50">*</span></label>
            <input type="email" name="email" required placeholder="ton@email.com" class="w-full bg-[#FAF8F5] border border-black/10 px-4 py-3 text-sm text-[#2C2824] focus:outline-none focus:border-[#C4A855]" />
          </div>
          <div>
            <label class="block text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Téléphone</label>
            <input type="tel" name="phone" placeholder="06 12 34 56 78" class="w-full bg-[#FAF8F5] border border-black/10 px-4 py-3 text-sm text-[#2C2824] focus:outline-none focus:border-[#C4A855]" />
          </div>
          <div>
            <label class="block text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Code promo</label>
            <div class="flex gap-2">
              <input type="text" name="coupon" placeholder="Entrer un code" class="flex-1 bg-[#FAF8F5] border border-black/10 px-4 py-3 text-sm text-[#2C2824] focus:outline-none focus:border-[#C4A855]" />
              <button type="button" data-em-apply class="px-5 py-3 border border-[#2C2824]/30 text-[#2C2824] text-xs tracking-wide uppercase hover:bg-[#2C2824] hover:text-white transition-colors">Appliquer</button>
            </div>
            <p class="text-xs font-light text-[#2C2824]/50 mt-2 hidden" data-em-coupon-msg></p>
          </div>

          <p class="text-xs text-red-600 hidden" data-em-error></p>

          <button type="submit" data-em-cta class="inline-flex items-center justify-center gap-3 rounded-sm bg-[#C4A855] text-white px-10 py-4 text-sm tracking-[0.1em] uppercase hover:bg-[#B09A4A] transition-colors w-full disabled:opacity-60 disabled:cursor-not-allowed">
            Je réserve En Mouvement — 1 100 €
          </button>
        </form>

        <div class="flex flex-wrap items-center justify-center gap-4 pt-6 mt-6 border-t border-black/5 text-xs font-light text-[#2C2824]/50">
          <span>Paiement sécurisé Mollie</span>
          <span>|</span>
          <span>Confirmation par email</span>
          <span>|</span>
          <span>Annulation -14j : remboursement intégral</span>
        </div>
      </div>

      <script is:inline>
        (function () {
          const BASE = 1100
          const form = document.getElementById('em-form')
          if (!form) return
          const totalEl = document.querySelector('[data-em-total]')
          const baseEl = document.querySelector('[data-em-base]')
          const ctaEl = document.querySelector('[data-em-cta]')
          const couponMsg = document.querySelector('[data-em-coupon-msg]')
          const errorEl = document.querySelector('[data-em-error]')
          const applyBtn = document.querySelector('[data-em-apply]')
          let currentTotal = BASE
          let appliedCoupon = null

          function fmt(n) { return n.toLocaleString('fr-FR') }

          function setTotal(total, coupon) {
            currentTotal = total
            appliedCoupon = coupon || null
            if (totalEl) totalEl.textContent = fmt(total)
            if (baseEl) {
              if (total !== BASE) {
                baseEl.textContent = fmt(BASE) + ' €'
                baseEl.classList.remove('hidden')
              } else baseEl.classList.add('hidden')
            }
            if (ctaEl) ctaEl.textContent = 'Je réserve En Mouvement — ' + fmt(total) + ' €'
          }

          function showError(msg) {
            if (!errorEl) return
            errorEl.textContent = msg
            errorEl.classList.remove('hidden')
          }
          function clearError() {
            if (!errorEl) return
            errorEl.textContent = ''
            errorEl.classList.add('hidden')
          }
          function showCouponMsg(msg, ok) {
            if (!couponMsg) return
            couponMsg.textContent = msg
            couponMsg.classList.remove('hidden')
            couponMsg.style.color = ok ? '#4A7C59' : '#dc2626'
          }

          if (applyBtn) applyBtn.addEventListener('click', () => {
            const couponInput = form.querySelector('input[name="coupon"]')
            const code = (couponInput && couponInput.value || '').trim().toUpperCase()
            if (!code) { setTotal(BASE, null); showCouponMsg('', true); couponMsg && couponMsg.classList.add('hidden'); return }
            if (code === 'TRIBULAOM') {
              setTotal(BASE * 0.8, code)
              showCouponMsg('Code TRIBULAOM appliqué : -20 %', true)
            } else {
              setTotal(BASE, null)
              showCouponMsg('Code promo invalide.', false)
            }
          })

          form.addEventListener('submit', async (e) => {
            e.preventDefault()
            clearError()
            const data = new FormData(form)
            const sessionInput = document.querySelector('input[name="session"]:checked')
            const session = sessionInput ? sessionInput.value : null
            const firstName = String(data.get('firstname') || '').trim()
            const lastName = String(data.get('lastname') || '').trim()
            const email = String(data.get('email') || '').trim()
            const phone = String(data.get('phone') || '').trim()
            const coupon = String(data.get('coupon') || '').trim()
            if (!firstName || !lastName || !email) { showError('Prénom, nom et email obligatoires.'); return }
            if (!session) { showError('Choisis une session.'); return }

            if (!ctaEl) return
            const originalLabel = ctaEl.textContent
            ctaEl.disabled = true
            ctaEl.textContent = 'Redirection vers le paiement…'

            try {
              const res = await fetch('/api/mollie/create-payment/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  product: 'en-mouvement',
                  firstName, lastName, email, phone, session, coupon,
                }),
              })
              const json = await res.json()
              if (!res.ok || !json.checkoutUrl) {
                showError(json.error || 'Erreur lors de la création du paiement.')
                ctaEl.disabled = false
                ctaEl.textContent = originalLabel
                return
              }
              window.location.href = json.checkoutUrl
            } catch (err) {
              showError('Service de paiement indisponible. Réessaie dans un instant.')
              ctaEl.disabled = false
              ctaEl.textContent = originalLabel
            }
          })
        })()
      </script>

      <!-- Elements de reassurance -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        {reassurance.map((r) => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-[#FAF8F5] flex items-center justify-center">
              {r.icon === 'users' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              )}
              {r.icon === 'heart' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              )}
              {r.icon === 'lock' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              )}
              {r.icon === 'calendar' && (
                <svg class="w-5 h-5 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              )}
            </div>
            <p class="text-sm font-medium text-[#2C2824]">{r.title}</p>
            <p class="text-xs font-light text-[#2C2824]/50 mt-1">{r.desc}</p>
          </div>
        ))}
      </div>

      <!-- Citation -->
      <div class="mb-12 p-8 bg-[#2C2824] rounded-sm text-center">
        <blockquote class="font-playfair text-xl md:text-2xl font-normal text-white/90 italic leading-relaxed">
          "Le corps garde la trace de ce qui n'a pas été digéré. La danse permet de remettre ces informations en circulation."
        </blockquote>
        <p class="text-sm font-light text-white/50 mt-4">— Samuel Planas</p>
      </div>

      <!-- Contact -->
      <div class="text-center p-8 bg-[#FAF8F5] rounded-sm">
        <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Une question avant de réserver ?</h3>
        <p class="text-base font-light text-[#2C2824]/60 mb-6">
          Échange directement avec Charly pour voir si En Mouvement est fait pour toi.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://cal.atomik.world/charly/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-sm border border-[#2C2824]/20 text-[#2C2824] px-6 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#2C2824] hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Reserver un appel
          </a>
          <a
            href="mailto:hello@laom.fr"
            class="inline-flex items-center justify-center gap-2 rounded-sm border border-[#2C2824]/20 text-[#2C2824] px-6 py-3 text-xs tracking-[0.2em] uppercase hover:bg-[#2C2824] hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            hello@laom.fr
          </a>
        </div>
      </div>
    </div>
  </section>


</Layout>
