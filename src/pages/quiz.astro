---
// Quiz lead magnet — "Où ça coince, vraiment ?"
// Natif, hébergé sur le site. Wizard 10 questions (5 piliers) -> coordonnées
// (prénom + email) -> DIAGNOSTIC : on pointe le plus gros décalage (pilier le plus
// bas), on explique le pourquoi (cause -> effet + système nerveux / cortisol),
// puis la "bascule" (première direction) qui amène LAOM. Épuré (logo seul).
// Backend : /api/form/quiz (lead D1 + email diagnostic Resend + Kit + QuizLead Meta + goal DataFast).
import Layout from '~/layouts/Layout.astro'
import Logo from '~/components/laom/Logo.astro'
import { piliers, diagnostics } from '~/data/quizDiagnostics'

const inputCls = 'w-full rounded-xl border border-[#412F1F]/15 bg-white px-4 py-3 text-[#1D1B18] placeholder:text-[#1D1B18]/40 focus:border-[#9A3922] focus:ring-1 focus:ring-[#9A3922] outline-none transition'


const questions = [
  { q: 'Ton environnement de travail au quotidien, il te ressemble ?', options: [
    { t: 'Oui, j’ai choisi mon cadre et il me nourrit chaque jour', p: 3 },
    { t: 'C’est correct mais ça ne m’inspire plus, je fais avec', p: 2 },
    { t: 'Non, je subis mon environnement, c’est un bureau par défaut', p: 1 } ] },
  { q: 'Quand tu imagines ton cadre de vie idéal, tu en es où ?', options: [
    { t: 'J’y suis déjà ou j’en suis très proche', p: 3 },
    { t: 'Je sais ce que je veux mais j’ai pas encore bougé', p: 2 },
    { t: 'J’y ai jamais vraiment réfléchi, j’ai la tête dans le guidon', p: 1 } ] },
  { q: 'Ton rythme de travail, il est soutenable ?', options: [
    { t: 'Oui, j’ai trouvé mon équilibre entre intensité et récupération', p: 3 },
    { t: 'Ça va par phases, des semaines je gère, d’autres je sature', p: 2 },
    { t: 'Non, je suis en surrégime et je sais que ça tiendra pas', p: 1 } ] },
  { q: 'Tu arrives à couper vraiment ?', options: [
    { t: 'Oui, quand je déconnecte, je déconnecte pour de vrai', p: 3 },
    { t: 'J’essaie mais mon cerveau tourne en fond en permanence', p: 2 },
    { t: 'Non, je suis toujours branché, même en vacances', p: 1 } ] },
  { q: 'Tu es entouré·e de gens qui comprennent ta réalité d’entrepreneur ?', options: [
    { t: 'Oui, j’ai un cercle de pairs avec qui j’échange régulièrement', p: 3 },
    { t: 'J’ai quelques personnes mais c’est pas un vrai cercle', p: 2 },
    { t: 'Non, je suis assez seul·e, personne ne comprend vraiment', p: 1 } ] },
  { q: 'Tu te nourris d’échanges avec d’autres entrepreneurs ?', options: [
    { t: 'Oui, c’est essentiel pour moi et je le fais activement', p: 3 },
    { t: 'J’aimerais mais j’ai pas trouvé le bon format ou les bonnes personnes', p: 2 },
    { t: 'J’y pense même pas, j’ai pas le temps ou l’occasion', p: 1 } ] },
  { q: 'Tu sais pourquoi tu fais ce que tu fais ?', options: [
    { t: 'Oui, ma direction est claire et elle me porte au quotidien', p: 3 },
    { t: 'J’avais la réponse mais je l’ai perdue en route', p: 2 },
    { t: 'Honnêtement, je sais plus trop, j’avance par inertie', p: 1 } ] },
  { q: 'Tu prends du temps pour toi, hors travail, hors logistique ?', options: [
    { t: 'Oui, j’ai des rituels et des moments qui m’appartiennent', p: 3 },
    { t: 'De temps en temps, mais c’est la première chose qui saute', p: 2 },
    { t: 'Non, tout tourne autour du boulot et du quotidien', p: 1 } ] },
  { q: 'Ton activité te permet de vivre comme tu veux ?', options: [
    { t: 'Oui, mon business est au service de ma vie, pas l’inverse', p: 3 },
    { t: 'Pas encore, mais j’y travaille', p: 2 },
    { t: 'Non, c’est ma vie qui s’est pliée à mon business', p: 1 } ] },
  { q: 'Si tu pouvais tout redesigner demain, tu changerais quoi en premier ?', options: [
    { t: 'Presque rien, je suis proche de ce que je veux', p: 3 },
    { t: 'Mon cadre de vie ou mon rythme, le fond est bon mais la forme me pèse', p: 2 },
    { t: 'Beaucoup de choses, j’ai construit un truc qui ne me ressemble plus', p: 1 } ] },
]

---

<Layout title="Le diagnostic · Qu’est-ce qui te freine vraiment ? · LAOM" description="En 2 minutes, mets le doigt sur ce qui t'épuise ou te ralentit vraiment — et découvre par où commencer pour que ça change." hideChrome={true} seo={{ noIndex: true }}>
  <div class="min-h-screen bg-[#FBF6EA] flex flex-col">

    <header class="px-6 md:px-10 lg:px-14 py-6 border-b border-[#412F1F]/10">
      <a href="/" class="text-[#9A3922] inline-block" aria-label="Retour à l’accueil"><Logo height="1.7rem" /></a>
    </header>

    <main class="flex-1 w-full max-w-2xl mx-auto px-6 py-14 md:py-20">

      <!-- ENTRÉE -->
      <section id="q-intro">
        <p class="text-xs uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-4">Le diagnostic · 2 minutes</p>
        <h1 class="text-3xl md:text-4xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.1] text-balance">Qu’est-ce qui te freine vraiment ?</h1>
        <p class="text-lg text-[#1D1B18]/70 mt-5 leading-relaxed">Tu sens que quelque chose t’épuise ou te ralentit, sans bien savoir quoi. En 2 minutes, ce diagnostic <strong class="text-[#412F1F] font-semibold">met le doigt dessus</strong>, t’explique pourquoi (ton corps autant que ta tête), et te montre par où commencer pour que ça change.</p>
        <button type="button" id="q-begin" class="pill pill-primary w-full sm:w-auto justify-center mt-10" style="padding:.95rem 2.4rem">Faire le diagnostic</button>
      </section>

      <!-- QUIZ -->
      <section id="q-quiz" hidden>
        <div class="flex items-center gap-4 mb-10">
          <div class="flex-1 h-1.5 rounded-full bg-[#412F1F]/10 overflow-hidden">
            <div id="q-progress" class="h-full bg-[#9A3922] rounded-full transition-all duration-300" style="width:10%"></div>
          </div>
          <span id="q-count" class="text-sm font-semibold text-[#412F1F]/60 tabular-nums">1 / 10</span>
        </div>

        {questions.map((qq, i) => (
          <div class="q-step" data-step={i} hidden>
            <p class="text-xs uppercase tracking-[0.18em] font-semibold text-[#CB7A5C] mb-3">{piliers[Math.floor(i / 2)]}</p>
            <h2 class="text-2xl md:text-3xl font-extrabold text-[#412F1F] leading-snug text-balance">{qq.q}</h2>
            <div class="grid gap-3 mt-8">
              {qq.options.map((o) => (
                <button type="button" class="q-opt text-left rounded-xl border border-[#412F1F]/15 bg-white px-5 py-4 text-[#412F1F] hover:border-[#9A3922] hover:bg-[#9A3922]/[0.04] transition" data-points={o.p}>{o.t}</button>
              ))}
            </div>
            {i > 0 && <button type="button" class="q-back mt-8 text-sm text-[#1D1B18]/55 hover:text-[#9A3922] inline-flex items-center gap-1.5 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>Question précédente</button>}
          </div>
        ))}
      </section>

      <!-- COORDONNÉES (juste avant le résultat) -->
      <section id="q-gate" hidden>
        <p class="text-xs uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-4">Presque fini</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.1] text-balance">Ton diagnostic est prêt.</h2>
        <p class="text-lg text-[#1D1B18]/70 mt-5 leading-relaxed">Laisse-nous ton prénom et ton email : on t’envoie ton diagnostic détaillé, et tu le découvres juste après.</p>
        <form id="q-gateform" class="mt-10 space-y-5" novalidate>
          <div class="space-y-2">
            <label for="q-prenom" class="font-semibold text-[#412F1F]">Ton prénom</label>
            <input id="q-prenom" name="prenom" type="text" required autocomplete="given-name" class={inputCls} />
          </div>
          <div class="space-y-2">
            <label for="q-email" class="font-semibold text-[#412F1F]">Ton email</label>
            <input id="q-email" name="email" type="email" required autocomplete="email" class={inputCls} />
          </div>
          <label class="flex items-start gap-3 text-sm text-[#1D1B18]/70">
            <input type="checkbox" name="rgpd" required class="mt-1 accent-[#9A3922] w-4 h-4 shrink-0" />
            <span>J’accepte de recevoir mon résultat et des informations sur LAOM. Je peux me désinscrire à tout moment.</span>
          </label>
          <button type="submit" class="pill pill-primary w-full sm:w-auto justify-center" style="padding:.95rem 2.4rem">Voir mon diagnostic</button>
        </form>
      </section>

      <!-- RÉSULTAT -->
      <section id="q-result" hidden></section>
    </main>
  </div>
</Layout>

<script define:vars={{ piliers, diagnostics }}>
  const intro = document.getElementById('q-intro')
  const quiz = document.getElementById('q-quiz')
  const gate = document.getElementById('q-gate')
  const result = document.getElementById('q-result')
  const steps = [...document.querySelectorAll('.q-step')]
  const progress = document.getElementById('q-progress')
  const count = document.getElementById('q-count')
  const total = steps.length
  const answers = new Array(total).fill(0)
  let cur = 0
  let lead = { prenom: '', email: '' }

  const show = (i) => {
    steps.forEach((s, k) => (s.hidden = k !== i))
    progress.style.width = ((i + 1) / total) * 100 + '%'
    count.textContent = (i + 1) + ' / ' + total
    cur = i
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  document.getElementById('q-begin').addEventListener('click', () => {
    intro.hidden = true
    quiz.hidden = false
    show(0)
  })

  const showGate = () => {
    quiz.hidden = true
    gate.hidden = false
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  document.getElementById('q-gateform').addEventListener('submit', (e) => {
    e.preventDefault()
    const f = e.target
    if (!f.checkValidity()) { f.reportValidity(); return }
    lead.prenom = f.prenom.value.trim().split(' ')[0]
    lead.email = f.email.value.trim()
    finish()
  })

  steps.forEach((step, i) => {
    step.querySelectorAll('.q-opt').forEach((btn) => {
      btn.addEventListener('click', () => {
        answers[i] = parseInt(btn.dataset.points, 10)
        if (i < total - 1) show(i + 1)
        else showGate()
      })
    })
    const back = step.querySelector('.q-back')
    if (back) back.addEventListener('click', () => show(i - 1))
  })

  const finish = () => {
    const pillarScores = [0, 1, 2, 3, 4].map((p) => answers[p * 2] + answers[p * 2 + 1]) // chacun /6
    let gap = 0
    for (let k = 1; k < pillarScores.length; k++) if (pillarScores[k] < pillarScores[gap]) gap = k
    const d = diagnostics[gap]
    const aligned = pillarScores[gap] >= 5

    // Backend : lead + email de diagnostic + Kit + analytics. Non bloquant pour l'UX.
    const eventId = (crypto.randomUUID && crypto.randomUUID()) || ('eid_' + Date.now() + '_' + Math.random().toString(36).slice(2))
    try { if (window.fbq) window.fbq('trackCustom', 'QuizLead', { content_name: 'quiz-diagnostic' }, { eventID: eventId }) } catch {}
    fetch('/api/form/quiz', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prenom: lead.prenom, email: lead.email, rgpd: true, answers, event_id: eventId }),
      keepalive: true,
    }).catch(() => {})

    const bars = pillarScores.map((s, k) => {
      const low = k === gap
      return `
      <div>
        <div class="flex justify-between text-sm mb-1.5">
          <span class="${low ? 'text-[#9A3922] font-bold' : 'text-[#412F1F] font-medium'}">${piliers[k]}${low ? ' · à reprendre en priorité' : ''}</span>
          <span class="text-[#1D1B18]/55 tabular-nums">${s}/6</span>
        </div>
        <div class="h-2 rounded-full bg-[#412F1F]/10 overflow-hidden">
          <div class="h-full rounded-full ${low ? 'bg-[#9A3922]' : 'bg-[#73673E]'}" style="width:${(s / 6) * 100}%"></div>
        </div>
      </div>`
    }).join('')

    result.innerHTML = `
      <p class="text-xs uppercase tracking-[0.18em] font-semibold text-[#73673E] mb-4">Ton diagnostic${lead.prenom ? ', ' + lead.prenom : ''}</p>
      ${aligned ? `<p class="text-base text-[#1D1B18]/70 mb-4">Globalement, tu es plutôt aligné·e. Mais s’il y a un point à reprendre en priorité, c’est celui-là.</p>` : ``}
      <h1 class="text-3xl md:text-4xl font-extrabold text-[#412F1F] tracking-[-0.02em] leading-[1.1] text-balance">Ton plus gros décalage : ${d.gap}.</h1>
      <p class="text-lg text-[#1D1B18]/75 mt-5 leading-relaxed">${d.why}</p>
      <div class="mt-7 border-l-4 border-[#9A3922] pl-5 md:pl-6">
        <p class="text-xs uppercase tracking-[0.18em] font-semibold text-[#9A3922] mb-2">La bascule</p>
        <p class="text-lg text-[#412F1F] leading-relaxed">${d.bascule}</p>
      </div>
      <div class="mt-10 space-y-4 rounded-2xl bg-white border border-[#412F1F]/10 p-6 md:p-8">
        <p class="font-semibold text-[#412F1F] mb-2">Où tu en es, pilier par pilier</p>
        ${bars}
      </div>
      <div class="mt-10 rounded-2xl bg-[#412F1F] text-[#F2EBDB] p-7 md:p-9">
        <p class="text-lg leading-relaxed">Cette bascule, on en a fait un lieu. Une semaine à LAOM, c’est se réveiller au calme, travailler face à la vallée, et le soir refaire le monde autour du feu avec des gens qui vivent la même chose que toi. Le cadre est prêt. Va voir s’il est fait pour toi.</p>
        <div class="flex flex-wrap gap-4 items-center mt-7">
          <a href="/coliving/" class="pill pill-light" style="padding:.85rem 1.8rem">Découvrir le coliving</a>
          <a href="/candidater/" class="text-[#F2EBDB]/85 underline underline-offset-4 hover:text-[#F2EBDB] transition text-sm">ou candidater directement</a>
        </div>
      </div>
      <p class="text-sm text-[#1D1B18]/55 mt-6">Ton diagnostic complet t’a aussi été envoyé par email.</p>`

    gate.hidden = true
    result.hidden = false
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }
</script>
