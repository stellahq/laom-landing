      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-[#2C2824]">Charge mentale</h2>
        <p class="text-xs text-[#2C2824]/50 mt-1">Parking lot — trucs a pas oublier</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {chargeMentale.map((cat) => (
          <div class="bg-white rounded-sm border border-black/5 p-4">
            <p class="text-xs font-medium text-[#C4A855] uppercase tracking-wider mb-3">{cat.categorie}</p>
            <ul class="space-y-2">
              {cat.items.map((item) => {
                const isDelegue = item.includes('DELEGUE') || item.includes('DELEGUER')
                return (
                  <li class="flex items-start gap-2 text-sm text-[#2C2824]/70">
                    <span class={`w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0 ${isDelegue ? 'bg-[#8B5A3C]' : 'bg-[#2C2824]/30'}`}></span>
                    <span class={isDelegue ? 'text-[#8B5A3C]' : ''}>{item}</span>
                  </li>
                )
              })}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- DECISIONS -->
  <!-- ============================================== -->
  <section id="decisions" class="py-10 bg-[#1a1a1a]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8">
      <div class="mb-6">
        <h2 class="font-playfair text-xl md:text-2xl font-medium text-white">Decisions recentes</h2>
      </div>

      <div class="space-y-3">
        {decisions.map((d) => (
          <div class="flex items-start gap-4 p-4 bg-white/5 border border-white/10 rounded-sm">
            <span class={`text-xs whitespace-nowrap px-2 py-1 rounded ${d.date === 'W06' ? 'bg-[#C4A855]/20 text-[#C4A855]' : 'text-white/40'}`}>{d.date}</span>
            <div>
              <p class="text-white font-medium">{d.decision}</p>
              <p class="text-sm text-white/50">{d.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <section class="py-6 bg-[#1a1a1a] border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 text-center">
      <p class="text-xs text-white/30">
        Cockpit Charly — NILA · Fevrier 2026
      </p>
    </div>
  </section>

  <script>
    // Password protection
    const PASSWORD = 'charly2026'
    const STORAGE_KEY = 'charly_cockpit_auth'
    
    const overlay = document.getElementById('password-overlay')
    const form = document.getElementById('password-form')
    const input = document.getElementById('password-input') as HTMLInputElement
    const error = document.getElementById('password-error')
    
    if (localStorage.getItem(STORAGE_KEY) === 'true') {
      overlay?.style.setProperty('display', 'none')
    }
    
    form?.addEventListener('submit', (e) => {
      e.preventDefault()
      if (input?.value === PASSWORD) {
        localStorage.setItem(STORAGE_KEY, 'true')
        overlay?.style.setProperty('display', 'none')
      } else {
        error?.classList.remove('hidden')
        input?.classList.add('border-red-500')
      }
    })

    // Week toggle
    document.querySelectorAll('.week-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLElement).dataset.target
        
        // Update buttons
        document.querySelectorAll('.week-toggle').forEach(b => {
          b.classList.remove('bg-[#C4A855]/30', 'font-medium')
          b.classList.add('text-white/40')
        })
        btn.classList.add('bg-[#C4A855]/30', 'font-medium')
        btn.classList.remove('text-white/40')
        
        // Toggle content
        document.querySelectorAll('[data-week]').forEach(el => {
          const weekEl = el as HTMLElement
          if (weekEl.dataset.week === target) {
            weekEl.classList.remove('hidden')
          } else {
            weekEl.classList.add('hidden')
          }
        })
      })
    })
  </script>
</Layout>
