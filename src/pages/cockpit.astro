// ==========================================
// DONNEES DYNAMIQUES EQUIPE (D1)
// ==========================================
const db = (Astro.locals as any).runtime?.env?.DB

function getCurrentWeek(): string {
  const now = new Date()
  const d = new Date(Date.UTC(now.getFullYear(), now.getMonth(), now.getDate()))
  const dayNum = d.getUTCDay() || 7
  d.setUTCDate(d.getUTCDate() + 4 - dayNum)
  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1))
  const weekNo = Math.ceil((((d.getTime() - yearStart.getTime()) / 86400000) + 1) / 7)
  return `${d.getUTCFullYear()}-W${String(weekNo).padStart(2, '0')}`
}

function getNextWeek(week: string): string {
  const [yearStr, wStr] = week.split('-W')
  const year = parseInt(yearStr)
  const wNum = parseInt(wStr)
  const jan4 = new Date(Date.UTC(year, 0, 4))
  const jan4Day = jan4.getUTCDay() || 7
  const week1Monday = new Date(jan4)
  week1Monday.setUTCDate(jan4.getUTCDate() - jan4Day + 1)
  const targetMonday = new Date(week1Monday)
  targetMonday.setUTCDate(week1Monday.getUTCDate() + (wNum - 1) * 7 + 7)
  const d = new Date(targetMonday)
  const dayNum = d.getUTCDay() || 7
  d.setUTCDate(d.getUTCDate() + 4 - dayNum)
  const ys = new Date(Date.UTC(d.getUTCFullYear(), 0, 1))
  const nextWNum = Math.ceil((((d.getTime() - ys.getTime()) / 86400000) + 1) / 7)
  return `${d.getUTCFullYear()}-W${String(nextWNum).padStart(2, '0')}`
}

const currentWeek = getCurrentWeek()
const nextWeek = getNextWeek(currentWeek)
const today = new Date().toISOString().split('T')[0]
const dateStr = new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })

interface TeamMember {
  name: string
  label: string
  color: string
  href: string
  tasks: any[]
  completedCount: number
  totalCount: number
  objectives: any[]
  todayObservations: any[]
}

// Semaine en cours
let weeklyContext: any = null
let teamMembers: TeamMember[] = []

// Semaine suivante
let weeklyContextNext: any = null
let teamMembersNext: TeamMember[] = []

const memberDefs = [
  { name: 'lorenzo', label: 'Lorenzo', color: '#C4A855', href: '/lorenzo/' },
  { name: 'khaldoun', label: 'Khaldoun', color: '#4A7C59', href: '/khaldoun/' },
  { name: 'amandine', label: 'Amandine', color: '#8B5A3C', href: '/amandine/' },
]

if (db) {
  try {
    // Weekly context
    weeklyContext = await db.prepare('SELECT * FROM weekly_context WHERE week = ? ORDER BY created_at DESC LIMIT 1').bind(currentWeek).first()
    weeklyContextNext = await db.prepare('SELECT * FROM weekly_context WHERE week = ? ORDER BY created_at DESC LIMIT 1').bind(nextWeek).first()

    // Team members — current week
    for (const m of memberDefs) {
      const tasksRes = await db.prepare('SELECT * FROM tasks WHERE person = ? AND week = ? ORDER BY sort_order ASC, id ASC').bind(m.name, currentWeek).all()
      const tasks = tasksRes.results || []
      const objRes = await db.prepare('SELECT * FROM weekly_objectives WHERE person = ? AND week = ? ORDER BY id ASC').bind(m.name, currentWeek).all()
      const obsRes = await db.prepare('SELECT * FROM observations WHERE person = ? AND date = ? ORDER BY created_at DESC LIMIT 3').bind(m.name, today).all()
      teamMembers.push({
        ...m,
        tasks,
        completedCount: tasks.filter((t: any) => t.completed).length,
        totalCount: tasks.length,
        objectives: objRes.results || [],
        todayObservations: obsRes.results || [],
      })
    }

    // Team members — next week
    for (const m of memberDefs) {
      const tasksRes = await db.prepare('SELECT * FROM tasks WHERE person = ? AND week = ? ORDER BY sort_order ASC, id ASC').bind(m.name, nextWeek).all()
      const tasks = tasksRes.results || []
      const objRes = await db.prepare('SELECT * FROM weekly_objectives WHERE person = ? AND week = ? ORDER BY id ASC').bind(m.name, nextWeek).all()
      teamMembersNext.push({
        ...m,
        tasks,
        completedCount: tasks.filter((t: any) => t.completed).length,
        totalCount: tasks.length,
        objectives: objRes.results || [],
        todayObservations: [],
      })
    }
  } catch (e) {}
}

function getStatutClass(statut: string): string {
  const classes: Record<string, string> = {
    'priorite': 'bg-[#C4A855] text-white',
    'urgent': 'bg-red-500 text-white',
    'a_faire': 'bg-[#2C2824] text-white',
    'a_deleguer': 'bg-[#8B5A3C] text-white',
    'planifie': 'bg-[#4A7C59]/80 text-white',
    'bloque': 'bg-red-800 text-white',
    'fait': 'bg-[#4A7C59] text-white',
    'attente': 'bg-white/10 text-white/60 border border-white/20',
  }
  return classes[statut] || 'bg-white/10 text-white/60'
}

function getStatutLabel(statut: string): string {
  const labels: Record<string, string> = {
    'priorite': 'Priorite',
    'urgent': 'Urgent',
    'a_faire': 'A faire',
    'a_deleguer': 'A deleguer',
    'planifie': 'Planifie',
    'bloque': 'Bloque',
    'fait': 'Fait',
    'attente': 'Attente',
  }
  return labels[statut] || statut
}
