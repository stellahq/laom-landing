      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Tresorerie -->
        <div class="bg-[#FAF8F5] rounded-sm border border-red-200 p-4">
          <p class="text-xs text-[#2C2824]/50 uppercase tracking-wider mb-1">Tresorerie FDV</p>
          <p class="text-xl font-medium text-red-500">{finances.tresorerie.statut}</p>
          <p class="text-xs text-[#2C2824]/40 mt-2">Factures impayees : {finances.facturesImpayees.toLocaleString()}\u20AC</p>
