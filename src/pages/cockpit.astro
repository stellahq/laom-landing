          <div class={`flex items-center gap-2 px-3 py-2 rounded-sm border ${j.priorite ? 'bg-[#C4A855]/10 border-[#C4A855]' : j.objectif ? 'bg-[#4A7C59]/10 border-[#4A7C59]' : j.fait ? 'bg-[#4A7C59]/10 border-[#4A7C59]/30' : 'bg-white border-black/5'}`}>
            <span class={`w-3 h-3 rounded-full flex-shrink-0 ${j.fait ? 'bg-[#4A7C59]' : j.priorite ? 'bg-[#C4A855]' : j.objectif ? 'bg-[#4A7C59]' : 'bg-[#2C2824]/20'}`}></span>
            <span class={`text-sm ${j.priorite ? 'text-[#C4A855] font-medium' : j.objectif ? 'text-[#4A7C59] font-medium' : 'text-[#2C2824]'}`}>{j.nom}</span>
