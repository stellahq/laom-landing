              <tr class={`border-b border-black/5 ${p.statut === 'priorite' ? 'bg-[#C4A855]/5' : p.statut === 'urgent' ? 'bg-red-50' : p.statut === 'fait' ? 'bg-[#4A7C59]/5' : 'hover:bg-[#FAF8F5]'}`}>
