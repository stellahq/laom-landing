---
import Layout from '~/layouts/Layout.astro'
import { createWebPageSchema } from '~/utils/schema'

const pageSchema = createWebPageSchema({
  name: 'LAOM School,  Écosystème pour porteurs de projet d\'écolieu',
  url: Astro.url.toString(),
  description: 'L\'écosystème pour les porteurs de projet d\'écolieu. 4 week-ends immersifs à LAOM, des permanences chaque mois, une communauté de bâtisseurs.',
})

const weekends = [
  {
    num: '01',
    date: 'Juin 2026',
    title: 'Projet & Financement',
    description: 'Clarifier ta vision. Structurer ton plan. Identifier les stratégies de financement adaptées à ton projet : subventions, SCIA, levée de fonds, autofinancement. Repartir avec un plan d\'action financé.',
    speaker: {
      role: 'Expert financement à impact',
      bio: 'Spécialiste du financement de projets à impact social et environnemental. Subventions publiques, fonds d\'investissement à impact, montages juridiques innovants.',
    },
  },
  {
    num: '02',
    date: 'Juillet 2026',
    title: 'Modèle économique',
    description: 'Construire un modèle économique viable sans trahir la vision. Positionnement, tarification, diversification des revenus : coliving, stages, agriculture, formation, événementiel. Ce qui marche. Ce qui ne marche pas.',
    speaker: {
      role: 'Fondateur de coliving / tiers-lieu rentable',
      bio: 'Entrepreneur qui a créé et stabilisé un modèle économique de lieu de vie. Retour d\'expérience concret sur les premières années, les pivots, et l\'équilibre financier.',
    },
  },
  {
    num: '03',
    date: 'Octobre 2026',
    title: 'Culture régénérative',
    description: 'Écoconstruction, agriculture régénératrice, autonomie énergétique, conception du lieu, intégration paysagère. Comment concevoir un lieu qui régénère plus qu\'il ne consomme. Les choix techniques, les erreurs à éviter, les coûts réels.',
    speaker: {
      role: 'Architecte / concepteur régénératif',
      bio: 'Praticien reconnu en écoconstruction ou en conception régénérative. Paille porteuse, terre crue, bioclimatique, permaculture appliquée à l\'échelle d\'un lieu de vie.',
    },
  },
  {
    num: '04',
    date: 'Mai 2027',
    title: 'Culture Communautaire',
    description: 'Gouvernance, intelligence collective, gestion des conflits, animation du collectif, cadre juridique du collectif. Comment créer un groupe qui tient dans la durée. Les départs, les arrivées, les crises,  et comment les traverser.',
    speaker: {
      role: 'Facilitateur / expert en gouvernance partagée',
      bio: 'Spécialiste de la gouvernance de collectifs. Sociocratie, holacratie, CNV, processus de décision. Intervient auprès de collectifs, coopératives et écolieux depuis plus de 10 ans.',
    },
  },
]

const formules = [
  {
    name: 'En ligne',
    price: '2 000',
    featured: false,
    items: [
      'Permanences mensuelles (appels ou visio de groupe)',
      'Rediffusions des sessions',
      'Communauté LAOM',
      'Accès aux ressources et outils',
    ],
  },
  {
    name: 'Les 4 week-ends',
    price: '4 000',
    featured: true,
    items: [
      '4 week-ends immersifs à LAOM',
      'Sessions avec intervenants invités',
      'Permanences mensuelles',
      'Rediffusions des sessions',
      'Communauté LAOM',
      'Hébergement et repas inclus',
    ],
  },
  {
    name: 'Accompagnement complet',
    price: '9 000',
    featured: false,
    items: [
      'Tout de la formule "Les 4 week-ends"',
      'Accompagnement financement personnalisé',
      'Accompagnement juridique personnalisé',
      'Accès LAOM Capital (fonds d\'amorçage)',
      'Suivi individuel entre les week-ends',
    ],
  },
]
---

<Layout
  title="LAOM School,  Écosystème pour porteurs de projet d'écolieu | LAOM"
  description="L'écosystème pour les porteurs de projet d'écolieu. 4 week-ends immersifs à LAOM, des permanences chaque mois, une communauté de bâtisseurs."
  seo={{
    ldJSON: pageSchema,
  }}
>
  <!-- Hero -->
  <section class="py-32 lg:py-40 bg-[#F3EEDC]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Promotion 1,  Juin 2026 / Mai 2027</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-[#2C2824] mb-8 tracking-tight">
        LAOM School
      </h1>
      <p class="text-xl md:text-2xl font-light text-[#2C2824]/60 max-w-3xl mx-auto leading-relaxed">
        L'écosystème pour les porteurs de projet d'écolieu. 4 week-ends immersifs à LAOM. Des permanences chaque mois. Une communauté de bâtisseurs.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 opacity-0" animate-fade-in-up>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed mb-6">
        Tu ne viens pas suivre un cours. Tu viens travailler sur ton projet, entouré de gens qui font la même chose, dans un lieu qui l'a déjà fait.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed mb-6">
        LAOM, c'est 5 ans de terrain. Au sein de l'Oasis la Margue, un domaine de 21 hectares que nous avons acquis en collectif. 15 foyers. Le plus grand bâtiment en paille porteuse au monde. Tout ce qu'on a appris,  les réussites, les erreurs, les raccourcis, les impasses,  on le met à disposition.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        Chaque week-end, tu viens avec ton projet. Tu travailles dessus. Tu confrontes tes idées à d'autres porteurs de projet et à des experts qui ont déjà fait le chemin. Tu repars avec des décisions prises, pas des diapositives.
      </p>
    </div>
  </section>

  <!-- Les 4 weekends -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Programme</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight title-underline mx-auto">
          4 week-ends, 4 thèmes
        </h2>
      </div>

      <div class="space-y-8 opacity-0" animate-fade-in-up>
        {weekends.map((w) => (
          <div class="bg-white border border-black/5 rounded-sm p-8 md:p-10">
            <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-10">
              <!-- Left: number + date -->
              <div class="flex-shrink-0 md:w-32">
                <span class="text-2xl font-light tracking-[0.1em] text-[#C4A855]">{w.num}</span>
                <p class="text-xs font-light tracking-[0.2em] uppercase text-[#2C2824]/40 mt-2">{w.date}</p>
              </div>

              <!-- Right: content -->
              <div class="flex-1">
                <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-4 tracking-tight">{w.title}</h3>
                <p class="text-base font-light text-[#2C2824]/70 leading-relaxed mb-8">
                  {w.description}
                </p>

                <!-- Speaker -->
                <div class="flex items-start gap-4 pt-6 border-t border-black/5">
                  <div class="w-12 h-12 rounded-full bg-[#E8E3D8] flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[#2C2824]/25" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-[#2C2824] mb-1">{w.speaker.role}</p>
                    <p class="text-sm font-light text-[#2C2824]/60 leading-relaxed mb-2">{w.speaker.bio}</p>
                    <p class="text-xs font-light text-[#C4A855]">Session,  samedi après-midi &middot; <em class="text-[#2C2824]/40">À confirmer</em></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Placeholder image -->
      <div class="mt-12 aspect-[16/9] bg-[#E8E3D8] flex items-center justify-center border border-black/5 rounded-sm opacity-0" animate-fade-in-up>
        <p class="text-sm font-light text-[#2C2824]/40 px-8 text-center">Photo à prendre : groupe de porteurs de projet en cercle au Grand Shambala, week-end LAOM School</p>
      </div>
    </div>
  </section>

  <!-- Office hours -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-10 sm:px-16 lg:px-24 opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Entre les week-ends</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-8 title-underline">
        Permanences
      </h2>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed mb-6">
        1 appel (ou visio) de groupe par mois. Tu avances sur ton projet, tu poses tes questions, tu bénéficies du regard des autres porteurs de projet et de l'équipe LAOM.
      </p>
      <p class="text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        Environ 10 sessions sur la durée de la formation, de juin 2026 à mai 2027. Inclus dans toutes les formules.
      </p>
    </div>
  </section>

  <!-- L'ecosysteme -->
  <section class="py-20 md:py-24 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Écosystème</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight title-underline mx-auto">
          Ce que tu rejoins
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 opacity-0" animate-fade-in-up>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Formation</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-4">LAOM School</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            4 week-ends immersifs à LAOM. Des sessions avec des experts. Des permanences mensuelles. Les rediffusions de toutes les sessions.
          </p>
        </div>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Communauté</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-4">Communauté LAOM</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Le réseau des bâtisseurs. Un espace d'entraide, de partage de ressources et de retours d'expérience entre ceux qui créent des lieux de vie. Entraide, co-développement, visites croisées.
          </p>
        </div>
        <div class="bg-white border border-black/5 rounded-sm p-8">
          <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-4">Financement</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-4">LAOM Capital</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Le fonds à impact pour soutenir les phases d'amorçage. Accompagnement financier et stratégique pour les projets d'écolieux qui sortent de LAOM School.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tarifs -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16 opacity-0" animate-fade-in-up>
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Tarifs</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight title-underline mx-auto">
          3 formules
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 opacity-0" animate-fade-in-up>
        {formules.map((f) => (
          <div class={`rounded-sm p-8 md:p-10 flex flex-col ${f.featured ? 'border-2 border-[#C4A855] bg-[#FAF8F5] relative' : 'border border-black/5 bg-[#FAF8F5]'}`}>
            {f.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#C4A855] text-white text-[10px] tracking-[0.2em] uppercase px-4 py-1 rounded-sm">Recommandé</span>
            )}
            <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-2">{f.name}</h3>
            <div class="mb-6">
              <span class="text-3xl font-light text-[#2C2824] tracking-tight">{f.price}</span>
              <span class="text-base font-light text-[#2C2824]/40 ml-1">€</span>
            </div>
            <ul class="space-y-3 mb-8 flex-1">
              {f.items.map((item) => (
                <li class="flex items-start gap-3 text-sm font-light text-[#2C2824]/70 leading-relaxed">
                  <span class="text-[#C4A855] mt-0.5 flex-shrink-0">&#10003;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="https://cal.atomik.world/charly/30min"
              target="_blank"
              rel="noopener noreferrer"
              class={`inline-flex items-center justify-center rounded-sm px-8 py-3.5 text-xs tracking-[0.2em] uppercase transition-colors text-center ${f.featured ? 'bg-[#C4A855] text-white hover:bg-[#B09A4A]' : 'bg-[#2C2824] text-white hover:bg-[#3D3832]'}`}
            >
              Réserver un appel
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-24 bg-[#2C2824]">
    <div class="max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center opacity-0" animate-fade-in-up>
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#C4A855] mb-6">Premier échange</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white tracking-tight mb-6">
        On en parle ?
      </h2>
      <p class="text-base font-light text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">
        30 minutes pour faire le point sur ton projet et voir si LAOM School est le bon cadre pour toi. En visio, sans engagement.
      </p>
      <a
        href="https://cal.atomik.world/charly/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-sm bg-[#C4A855] text-white px-10 py-4 text-xs tracking-[0.2em] uppercase hover:bg-[#B09A4A] transition-colors"
      >
        Réserver un appel
      </a>
    </div>
  </section>
</Layout>
