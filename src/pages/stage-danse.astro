---
import Layout from '~/layouts/Layout.astro'
import NewsletterForm from '~/components/NewsletterForm.astro'
import { createWebPageSchema } from '~/utils/schema'

export const prerender = true

const pageSchema = createWebPageSchema({
  name: 'En Mouvement,  Immersion par le corps | LAOM',
  url: Astro.url.toString(),
  description: '5 jours pour laisser émerger ce qui cherche à s\'exprimer, grâce à une pratique intensive de la danse et du mouvement. LAOM, Aveyron.',
})

const sessions = [
  { date: '5 à 9 août 2026', label: 'Session 1' },
  { date: '11 à 15 août 2026', label: 'Session 2' },
  { date: '16 à 20 août 2026', label: 'Session 3' },
]
---

<Layout
  title="En Mouvement,  Immersion par le corps | LAOM"
  description="5 jours pour laisser émerger ce qui cherche à s'exprimer, grâce à une pratique intensive de la danse et du mouvement. LAOM, Aveyron."
  seo={{ ldJSON: pageSchema }}
>

  <!-- Hero -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden -mt-24 md:-mt-28">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/laom/samuel-planas.webp"
        alt="Samuel Planas,  danseur et chorégraphe, guide des immersions En Mouvement"
        title="Samuel Planas en mouvement, immersion danse à LAOM"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-10 sm:px-16 lg:px-24 text-center pt-32 pb-16">
      <p class="text-xs font-light tracking-[0.25em] uppercase text-white/70 mb-6">LAOM présente</p>
      <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-6 tracking-tight leading-tight drop-shadow-lg">
        En Mouvement
      </h1>
      <p class="text-lg md:text-xl font-light text-white/85 max-w-2xl mx-auto leading-relaxed">
        5 jours pour laisser émerger ce qui cherche à s'exprimer, grâce à une pratique intensive de la danse et du mouvement.
      </p>
    </div>

    <!-- Scroll arrow -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
      <a href="#invitation" class="block text-white/50 hover:text-white transition-colors" aria-label="Défiler">
        <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- L'invitation -->
  <section id="invitation" class="py-24 md:py-32 bg-white">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-8">L'invitation</p>
      <div class="space-y-6 text-lg md:text-xl font-light text-[#2C2824]/85 leading-relaxed">
        <p>
          Tu sens que quelque chose en toi a envie de s'exprimer.
        </p>
        <p>
          Une énergie. Un élan. Une part de toi qui n'a pas encore trouvé son espace.
        </p>
        <p>
          Pendant 5 jours, dans un lieu hors du temps, tu vas explorer ce qui émerge quand tu te mets en mouvement avec un groupe qui te porte.
        </p>
        <p>
          Pas besoin de savoir danser. Juste l'envie de bouger, de te laisser surprendre, de découvrir ce qui se passe quand tu t'autorises à être pleinement là.
        </p>
      </div>
    </div>
  </section>

  <!-- Ce que tu vas vivre,  timeline élégante -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">La progression</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Les 5 jours, étape par étape</h2>

      <div class="border-l-2 border-[#C4A855] pl-8 space-y-14">
        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Jour 0,  Arrivée</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Se poser</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Tu découvres le lieu, les autres participants, les animateurs. Première danse libre pour briser la glace. Repas ensemble. On crée un cadre sécurisant et soutenant.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Jour 1</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Oser</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Mise en corps guidée en flux continu. Ateliers ludiques, un peu absurdes. Tu explores le mouvement sans te prendre au sérieux. La confiance se crée.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Jour 2</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Plonger</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Pratiques plus profondes, introspectives. État de chaos contrôlé. Le mental se dissout.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Les sensations deviennent plus fines.
            Ce qui était retenu peut se remettre en circulation.
          </p>
        </div>

        <!-- Video danseurs dans le Shala -->
        <div class="!ml-[-2.5rem] my-8">
          <div class="aspect-[16/9] overflow-hidden rounded-sm">
            <video
              autoplay
              muted
              loop
              playsinline
              class="w-full h-full object-cover"
            >
              <source src="/videos/danseurs-shala.webm" type="video/webm" />
            </video>
          </div>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Jour 3</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Créer ensemble</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Ateliers en collaboration. Travail relationnel et somatique.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Danse contact, écoute corporelle, qualité de présence dans la relation.
            On observe comment le corps réagit à l'autre, au collectif.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Si une énergie collective a émergé, travail sur un projet commun.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#8B7A3A] mb-2">Jour 4</p>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Partager</h3>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed">
            Intégration et expression.
            Ce que le corps a traversé trouve une forme.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Improvisations, petits groupes, expression individuelle.
            Cercle de clôture.
          </p>
          <p class="text-lg font-light text-[#2C2824]/85 leading-relaxed mt-2">
            Tu repars avec une expérience intégrée, inscrite dans le corps.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ce qui rend l'expérience unique -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">L'approche</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Ce qui rend cette expérience unique</h2>

      <div class="grid md:grid-cols-2 gap-x-16 gap-y-12">
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Une approche somatique</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Le point de départ n'est pas la tête, mais le corps.
            On travaille à partir des sensations, des impulsions, des micro-mouvements.
            Le mouvement devient un outil de régulation, d'expression et d'intégration.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Le flux continu</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            La musique ne s'arrête pas. Pas de moment où tu retombes dans ta tête pour analyser. Tu restes dans le mouvement, dans le corps, dans l'expérience.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Le groupe qui porte</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Repas ensemble, progression douce, moments de partage. Quand tu bouges avec d'autres, quand vos rythmes se synchronisent, ton système nerveux se régule naturellement.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">L'accompagnement dans le mouvement</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Les animateurs guident en continu, à travers le mouvement lui-même. Si quelque chose émerge, on le traverse ensemble,  par le corps, pas par l'analyse.
          </p>
        </div>
        <div>
          <h3 class="font-playfair text-xl font-medium text-[#2C2824] mb-3">Accessible à tous</h3>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Tu n'as pas besoin de technique. Juste l'envie de bouger et de te laisser surprendre. Samuel a l'habitude d'accompagner des groupes de 200 amateurs de tous niveaux.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi ca marche -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-[680px] mx-auto px-10 sm:px-16 lg:px-24">
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-10">Pourquoi le mouvement transforme</h2>
      <div class="space-y-6 text-lg font-light text-[#2C2824]/80 leading-relaxed">
        <p>
          La recherche en neurosciences nous montre que certaines transformations ne peuvent pas se faire par la réflexion seule.
        </p>
        <p>
          Le corps garde la trace de ce qui n'a pas été digéré : stress, émotions, expériences passées s'inscrivent dans le système nerveux et les tissus.
          La danse et plus largement le mouvement permettent de remettre ces informations en circulation.
        </p>
        <p>
          Quand on bouge ensemble, quand nos rythmes se synchronisent, notre système nerveux se régule naturellement. C'est pourquoi l'expérience de groupe est si puissante.
        </p>
        <p>
          Tout cela repose sur une base essentielle : la sécurité.
          Un cadre sécurisant permet au corps de se relâcher, d'explorer, d'intégrer, et de laisser apparaître de nouvelles réponses.
        </p>
      </div>
      <div class="mt-10 pt-8 border-t border-black/10">
        <p class="text-sm font-light text-[#2C2824]/40">
          Cette approche s'inspire des travaux de Bessel van der Kolk, Peter Levine et Stephen Porges, et de l'expérience directe du travail corporel en groupe.
        </p>
      </div>
    </div>
  </section>

  <!-- Temoignages -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <div class="text-center mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Retours d'expérience</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">Ce qu'ils ont vécu</h2>
      </div>

      <!-- Temoignage vedette — Camille -->
      <div class="mb-16 relative">
        <div class="absolute top-0 left-0 font-playfair text-[120px] md:text-[160px] leading-none text-[#C4A855]/10 -translate-x-2 -translate-y-4 select-none pointer-events-none">"</div>
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start pt-8">
          <div class="flex-shrink-0 mx-auto md:mx-0">
            <img
              src="/images/en-mouvement/camille.webp"
              alt="Camille, participante de la résidence danse En Mouvement"
              class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-2 border-[#C4A855]/20"
              loading="lazy"
              width="96"
              height="96"
            />
          </div>
          <div>
            <blockquote class="text-lg md:text-xl font-light text-[#2C2824]/80 italic leading-relaxed space-y-4">
              <p>Incroyable, apaisant, ressourçant. Le groupe était très diversifié — dans les personnalités, dans les générations. C'est ce qui a créé une vraie richesse autour de l'expérience.</p>
              <p>Je venais pour me reconnecter à moi, pour ressentir ces sensations de connexion à la vie, dans mon corps. Et je suis moi-même surprise d'avoir rétabli des connexions grâce aux autres, grâce au groupe. Là où j'avais la sensation d'un grand vide, quelque chose de presque vertigineux, je me sens emplie de tout l'amour qui a été véhiculé au cours de la semaine, toute la bienveillance, l'expression des singularités.</p>
              <p>Ça me donne envie de créer ce style de vie. C'est finalement des choses tellement simples : venez, et il se passera forcément des choses.</p>
            </blockquote>
            <p class="mt-6 text-sm font-medium text-[#2C2824]">Camille</p>
            <p class="text-xs text-[#2C2824]/40">Résidence danse, juin 2025</p>
          </div>
        </div>
      </div>

      <!-- Grille 2x2 -->
      <div class="grid md:grid-cols-2 gap-6 mb-6">

        <!-- Julyan -->
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <blockquote class="text-base font-light text-[#2C2824]/75 italic leading-relaxed mb-6">
            "Créatif, joueur, déjanté. Des gens venus de raisons très différentes, avec une envie de partager, de créer ensemble, de jouer. C'est une expérience à vivre, à la fois ancrée dans le monde, dans la nature environnante, avec des gens vivants, et à la fois une ouverture sur d'autres modes de vie."
          </blockquote>
          <div class="flex items-center gap-3">
            <img src="/images/en-mouvement/julyan.webp" alt="Julyan" class="w-10 h-10 rounded-full object-cover" loading="lazy" width="40" height="40" />
            <div>
              <p class="text-sm font-medium text-[#2C2824]">Julyan</p>
              <p class="text-xs text-[#2C2824]/40">Résidence danse, juin 2025</p>
            </div>
          </div>
        </div>

        <!-- Yaron -->
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <blockquote class="text-base font-light text-[#2C2824]/75 italic leading-relaxed mb-6">
            "Générosité, opulence, connexion. Le groupe était magique : beaucoup de rencontres, des partages vraiment corporels et humains d'une intensité folle. Je repars nourri de cette belle expérience que je vais pouvoir mettre en mouvement dans ma vie. Venez sans hésiter."
          </blockquote>
          <div class="flex items-center gap-3">
            <img src="/images/en-mouvement/yaron.webp" alt="Yaron" class="w-10 h-10 rounded-full object-cover" loading="lazy" width="40" height="40" />
            <div>
              <p class="text-sm font-medium text-[#2C2824]">Yaron</p>
              <p class="text-xs text-[#2C2824]/40">Résidence danse, juin 2025</p>
            </div>
          </div>
        </div>

        <!-- Anthony -->
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <blockquote class="text-base font-light text-[#2C2824]/75 italic leading-relaxed mb-6">
            "Ressourçant, intemporel, beau. Vraiment une bonne dynamique dans le groupe, une belle cohésion malgré nos backgrounds différents. Un endroit hors du temps qui contraste avec les endroits plus agités du quotidien. Je repars inspiré et plein de belles images en tête."
          </blockquote>
          <div class="flex items-center gap-3">
            <img src="/images/en-mouvement/anthony.webp" alt="Anthony" class="w-10 h-10 rounded-full object-cover" loading="lazy" width="40" height="40" />
            <div>
              <p class="text-sm font-medium text-[#2C2824]">Anthony</p>
              <p class="text-xs text-[#2C2824]/40">Résidence danse, juin 2025</p>
            </div>
          </div>
        </div>

        <!-- Perrine -->
        <div class="bg-[#FAF8F5] p-8 rounded-sm">
          <blockquote class="text-base font-light text-[#2C2824]/75 italic leading-relaxed mb-6">
            "Humain, proche de la nature, riche de sens. On venait tous d'horizons différents, ce qui rendait le groupe très riche. L'atmosphère était saine, paisible, tout le monde était disponible et dans son flot naturel. C'était émouvant et vrai. Je repars pleine de sensations et de questionnements nouveaux."
          </blockquote>
          <div class="flex items-center gap-3">
            <img src="/images/en-mouvement/perrine.webp" alt="Perrine" class="w-10 h-10 rounded-full object-cover" loading="lazy" width="40" height="40" />
            <div>
              <p class="text-sm font-medium text-[#2C2824]">Perrine</p>
              <p class="text-xs text-[#2C2824]/40">Résidence danse, juin 2025</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Temoignage de fermeture — Valentin (anglophone) -->
      <div class="relative mt-16">
        <div class="absolute top-0 right-0 font-playfair text-[100px] md:text-[140px] leading-none text-[#C4A855]/10 translate-x-2 -translate-y-4 select-none pointer-events-none rotate-180">"</div>
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
          <div class="flex-shrink-0 mx-auto md:mx-0">
            <img
              src="/images/en-mouvement/valentin.webp"
              alt="Valentin, participant de la résidence danse En Mouvement"
              class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-2 border-[#C4A855]/20"
              loading="lazy"
              width="96"
              height="96"
            />
          </div>
          <div>
            <blockquote class="text-lg md:text-xl font-light text-[#2C2824]/80 italic leading-relaxed">
              Community, peace, trance. People from all walks of life, all ages — it felt strange at first, and then we all connected through the dance. It feels like family. I didn't know you could have this depth of connection with a group of people so quickly. I leave with the knowledge that this kind of connection is possible — something I will seek, something I will try to emulate. It's outside of time and outside of your daily life. The people who live here set the vibe for everyone, and it gives everyone the chance to be their best self.
            </blockquote>
            <p class="mt-6 text-sm font-medium text-[#2C2824]">Valentin</p>
            <p class="text-xs text-[#2C2824]/40">Dance residency, June 2025</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Les animateurs -->
  <section class="py-24 md:py-32 bg-[#FAF8F5]">
    <div class="max-w-5xl mx-auto px-10 sm:px-16 lg:px-24">
      <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-6">Les guides</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight mb-16">Qui va te guider</h2>

      <div class="grid md:grid-cols-2 gap-16">
        <!-- Charly -->
        <div>
          <div class="aspect-[3/4] overflow-hidden rounded-sm mb-6">
            <img
              src="/images/en-mouvement/charly-aubert.webp"
              alt="Charly Aubert, co-fondateur de LAOM et guide de l'immersion En Mouvement"
              title="Portrait de Charly Aubert"
              class="w-full h-full object-cover object-top rounded-sm"
              loading="lazy"
            />
          </div>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">Charly Aubert</h3>
          <p class="text-sm font-light text-[#2C2824]/50 mb-4">Co-fondateur de LAOM</p>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            Bâtisseur, coach, polymathe. Charly apporte l'approche coaching, structure l'expérience et accompagne le processus dans son ensemble.
            Il accompagne à partir de ce qui se manifeste dans le corps (tensions, élans, émotions) et soutient le processus pour que chacun puisse traverser ce qui émerge, en mouvement.
          </p>
        </div>

        <!-- Samuel -->
        <div>
          <div class="aspect-[3/4] overflow-hidden rounded-sm mb-6">
            <img
              src="/images/laom/samuel-planas.webp"
              alt="Samuel Planas,  danseur et chorégraphe"
              title="Portrait de Samuel Planas, chorégraphe"
              class="w-full h-full object-cover object-top rounded-sm"
              loading="lazy"
            />
          </div>
          <h3 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">Samuel Planas</h3>
          <p class="text-sm font-light text-[#2C2824]/50 mb-4">Danseur professionnel et chorégraphe</p>
          <p class="text-base font-light text-[#2C2824]/70 leading-relaxed">
            À 23 ans, Samuel navigue entre les plus grandes scènes de danse contemporaine et l'accompagnement de groupes d'amateurs. Formé au Conservatoire National Supérieur de Paris, interprète pour Boris Charmatz, Noé Soulier et Wim Vandekeybus. Il a encadré 200 amateurs au Grand Palais dans le projet CERCLES.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Le lieu -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">

      <div class="text-center mb-16">
        <p class="text-xs font-light tracking-[0.2em] uppercase text-[#8B7A3A] mb-4">Le lieu</p>
        <h2 class="font-playfair text-3xl md:text-4xl font-medium text-[#2C2824] tracking-tight">Un écrin pour le mouvement</h2>
      </div>

      <!-- Photo pleine largeur — vue aérienne tipis + Shala -->
      <div class="aspect-[21/9] overflow-hidden rounded-sm mb-16">
        <img
          src="/images/en-mouvement/le-shala.webp"
          alt="Vue aérienne de LAOM : le Shala, salle de pratique de 120 m2, entouré de tipis dans une vallée verdoyante de l'Aveyron"
          title="Le Shala et les tipis à LAOM, Aveyron"
          class="w-full h-full object-cover"
          loading="lazy"
          width="1400"
          height="600"
        />
      </div>

      <!-- Texte + grille photos -->
