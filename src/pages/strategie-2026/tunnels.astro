---
import Layout from '~/layouts/Layout.astro'

export const prerender = true

// ==========================================
// TUNNELS D'ACQUISITION 2026
// Strategie : Tripwire payant pour break-even immediat
// ==========================================

const tunnels = [
  {
    nom: 'Clarte',
    couleur: '#C4A855',
    tripwire: {
      titre: 'Le systeme PARA : organise ta vie en 4 dossiers',
      prix: 7,
      pages: '15-20 pages',
      contenu: [
        'Presentation complete du systeme PARA',
        'Template Obsidian pret a l\'emploi',
        'Checklist de mise en place en 1 week-end',
        'Bonus : Mes 10 raccourcis Claude Code',
      ],
    },
    ads: {
      budget: 400,
      cplCible: 2.50,
      plateforme: 'Meta (LinkedIn en test)',
      ciblage: 'Entrepreneurs, freelances, multipotentiels, 25-45 ans',
    },
    sequence: [
      { jour: 0, objet: 'Bienvenue + Lien e-book', taux: '80%' },
      { jour: 2, objet: 'Comment j\'utilise PARA au quotidien', taux: '45%' },
      { jour: 5, objet: 'Le piege de la productivite (et comment l\'eviter)', taux: '40%' },
      { jour: 8, objet: 'Invitation appel decouverte Clarte', taux: '35%' },
      { jour: 12, objet: 'Dernieres places Clarte [mois]', taux: '30%' },
    ],
    metriques: {
      leadsParMois: 160,
      tauxTripwire: 35,
      revenusTrip: 160 * 0.35 * 7, // = 392€
      tauxCall: 10,
      tauxClosing: 40,
      ventesEstimees: 160 * 0.10 * 0.40, // = 6.4 ventes
    },
    debutTunnel: 'Fevrier 2026',
    finTunnel: 'Continu',
  },
  {
    nom: 'LAOM School',
    couleur: '#2C2824',
    tripwire: {
      titre: 'Le business model qui peut sauver les ecolieux',
      prix: 9,
      pages: '20-25 pages',
      contenu: [
        'Analyse des modeles qui echouent (et pourquoi)',
        'Le modele SCIA explique pas a pas',
        'Checklist juridique complete',
        'Bonus : Template previsionnel financier',
      ],
    },
    ads: {
      budget: 400,
      cplCible: 3.00,
      plateforme: 'Meta',
      ciblage: 'Porteurs projets ecolieux, habitat participatif, 30-55 ans',
    },
    sequence: [
      { jour: 0, objet: 'Bienvenue + Lien e-book', taux: '80%' },
      { jour: 2, objet: 'Les 3 erreurs qu\'on a faites (et vous ?)', taux: '45%' },
      { jour: 5, objet: 'Comment financer sans banque', taux: '40%' },
      { jour: 8, objet: 'Invitation LAOM School [dates]', taux: '35%' },
      { jour: 12, objet: 'FAQ + Dernieres places', taux: '30%' },
    ],
    metriques: {
      leadsParMois: 130,
      tauxTripwire: 33,
      revenusTrip: 130 * 0.33 * 9, // = 386€
      tauxCall: 10,
      tauxClosing: 40,
      ventesEstimees: 130 * 0.10 * 0.40, // = 5.2 ventes
    },
    debutTunnel: 'Mars 2026',
    finTunnel: 'Continu',
  },
  {
    nom: 'En Mouvement',
    couleur: '#4A7C59',
    tripwire: {
      titre: 'Liberer ton corps : la science derriere le mouvement conscient',
      prix: 7,
      pages: '15-20 pages',
      contenu: [
        'Etudes scientifiques danse & trauma',
        'Temoignages de participants',
        '5 exercices a faire chez soi',
        'Bonus : Playlist Spotify 2h',
      ],
    },
    ads: {
      budget: 400,
      cplCible: 2.50,
      plateforme: 'Meta + Instagram',
      ciblage: 'Developpement personnel, danse, yoga, 25-50 ans',
    },
    sequence: [
      { jour: 0, objet: 'Bienvenue + Lien e-book', taux: '80%' },
      { jour: 2, objet: 'Pourquoi la danse libere les emotions', taux: '45%' },
      { jour: 5, objet: 'Temoignage : "J\'ai pleure pendant 2h"', taux: '40%' },
      { jour: 8, objet: 'Samuel Planas : qui est-il ?', taux: '35%' },
      { jour: 12, objet: 'Inscription En Mouvement [dates]', taux: '30%' },
    ],
    metriques: {
      leadsParMois: 160,
      tauxTripwire: 35,
      revenusTrip: 160 * 0.35 * 7, // = 392€
      tauxCall: 8,
      tauxClosing: 50,
      ventesEstimees: 160 * 0.08 * 0.50, // = 6.4 ventes
    },
    debutTunnel: 'Mai 2026',
    finTunnel: 'Continu',
  },
]

// Projection leads cumulés AVEC SCALING
// Phase iteration: 400€/mois/tunnel (mois 1-2)
// Phase scale: 5000-10000€/mois/tunnel (mois 3+)
const projectionLeadsScaling = [
  { mois: 'Fev', phase: 'Iteration', budget: 400, leadsMois: 160, cumul: 160, revTripwire: 392, coutNet: 8 },
  { mois: 'Mars', phase: 'Iteration', budget: 800, leadsMois: 290, cumul: 450, revTripwire: 777, coutNet: 23 },
  { mois: 'Avr', phase: 'Scale Clarte', budget: 5400, leadsMois: 1960, cumul: 2410, revTripwire: 5145, coutNet: 255 },
  { mois: 'Mai', phase: 'Scale x2', budget: 10800, leadsMois: 3920, cumul: 6330, revTripwire: 10290, coutNet: 510 },
  { mois: 'Juin', phase: 'Scale x3', budget: 16200, leadsMois: 5880, cumul: 12210, revTripwire: 15435, coutNet: 765 },
  { mois: 'Juil', phase: 'Scale x3', budget: 16200, leadsMois: 5880, cumul: 18090, revTripwire: 15435, coutNet: 765 },
  { mois: 'Aout', phase: 'Scale x3', budget: 16200, leadsMois: 5880, cumul: 23970, revTripwire: 15435, coutNet: 765 },
]

// Totaux avec scaling
const totalBudgetScaling = projectionLeadsScaling.reduce((acc, m) => acc + m.budget, 0)
const totalLeadsScaling = projectionLeadsScaling[projectionLeadsScaling.length - 1].cumul
const totalRevTripwire = projectionLeadsScaling.reduce((acc, m) => acc + m.revTripwire, 0)
const totalCoutNet = projectionLeadsScaling.reduce((acc, m) => acc + m.coutNet, 0)

// Tunnel Conferences
const tunnelConferences = {
  nom: 'Conferences Live',
  couleur: '#C4A855',
  leadMagnet: 'Extrait video gratuit (10min)',
  prixConf: '67-97€',
  budgetParConf: 300,
  cplCible: 3.00,
  sequence: [
    { jour: 0, objet: 'Acces a l\'extrait video', taux: '80%' },
    { jour: 2, objet: 'Les coulisses de la conference', taux: '45%' },
    { jour: 5, objet: 'Qui sera present ? (intervenants)', taux: '40%' },
    { jour: 8, objet: 'Early bird -20% (48h)', taux: '35%' },
    { jour: 10, objet: 'Derniere chance inscription', taux: '30%' },
  ],
  metriques: {
    leadsParConf: 100,
    tauxInscription: 30,
    participantsMoyens: 30,
    caParConf: 2250,
  }
}

const totalBudgetMensuel = tunnels.reduce((acc, t) => acc + t.ads.budget, 0)
const totalLeadsMensuel = tunnels.reduce((acc, t) => acc + t.metriques.leadsParMois, 0)
const totalRevenusTrip = tunnels.reduce((acc, t) => acc + t.metriques.revenusTrip, 0)
const totalVentes = tunnels.reduce((acc, t) => acc + t.metriques.ventesEstimees, 0)

function formatNumber(n: number): string {
  return n.toLocaleString('fr-FR')
}
---

<Layout
  title="Tunnels d'acquisition 2026 — LAOM"
  description="Detail des tunnels d'acquisition payante 2026"
  seo={{ noindex: true, nofollow: true }}
>

  <!-- Password check -->
  <script is:inline>
    if (sessionStorage.getItem('laom_auth') !== 'true') {
      window.location.href = '/strategie-2026';
    }
  </script>

  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#1a1a1a] border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16 h-14 flex items-center justify-between">
      <a href="/strategie-2026" class="text-white/50 hover:text-white text-sm font-light transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Retour strategie</span>
      </a>
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-[#C4A855]/20 flex items-center justify-center">
          <svg class="w-4 h-4 text-[#C4A855]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span class="text-white font-medium">Tunnels</span>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-24 sm:pt-28 pb-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h1 class="font-playfair text-3xl md:text-4xl font-medium text-white mb-4">
        Tunnels d'acquisition 2026
      </h1>
      <p class="text-white/60 mb-8">
        Strategie tripwire : e-book payant (7-9€) pour break-even immediat + sequence email vers vente
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-white">{formatNumber(totalBudgetMensuel)}€</p>
          <p class="text-xs text-white/50">budget/mois</p>
        </div>
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-[#4A7C59]">~{totalLeadsMensuel}</p>
          <p class="text-xs text-white/50">leads/mois</p>
        </div>
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-[#C4A855]">{formatNumber(Math.round(totalRevenusTrip))}€</p>
          <p class="text-xs text-white/50">revenus tripwire/mois</p>
        </div>
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-white">~{Math.round(totalVentes)}</p>
          <p class="text-xs text-white/50">ventes/mois (3 tunnels)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Logique du tunnel -->
  <section class="py-8 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-medium text-[#2C2824] mb-4">Double objectif</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded-sm border-l-4 border-[#C4A855]">
          <h3 class="font-medium text-[#2C2824] mb-2">1. Remplir la base email</h3>
          <p class="text-sm text-[#2C2824]/60">Lead magnet payant (tripwire) qui rembourse les couts d'acquisition. La base email grandit a cout quasi-nul.</p>
        </div>
        <div class="bg-white p-6 rounded-sm border-l-4 border-[#4A7C59]">
          <h3 class="font-medium text-[#2C2824] mb-2">2. Vendre les events</h3>
          <p class="text-sm text-[#2C2824]/60">Sequence email nurturing qui convertit les leads en participants. Taux cible : 10% call → 40% closing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projection leads avec SCALING -->
  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-playfair text-2xl font-medium text-[#2C2824] mb-2">Projection leads cumules (avec scaling)</h2>
      <p class="text-sm text-[#2C2824]/50 mb-6">Si break-even atteint, budget scale de 400€ a 5-10k€/mois/tunnel</p>
      
      <!-- Graphique visuel -->
      <div class="bg-[#FAF8F5] p-6 rounded-sm mb-6">
        <div class="h-48 flex items-end gap-2">
          {projectionLeadsScaling.map((m) => {
            const maxHeight = 24000
            const height = (m.cumul / maxHeight) * 100
            const isScale = m.phase.includes('Scale')
            return (
              <div class="flex-1 flex flex-col items-center">
                <div class="w-full rounded-t-sm transition-all" style={`height: ${height}%; background: ${isScale ? '#4A7C59' : '#C4A855'}`}></div>
                <p class="text-xs text-[#2C2824]/50 mt-3">{m.mois}</p>
                <p class="text-sm font-medium text-[#2C2824]">{formatNumber(m.cumul)}</p>
              </div>
            )
          })}
        </div>
        <div class="flex justify-center gap-6 mt-6 text-xs">
          <span class="flex items-center gap-2"><span class="w-3 h-3 bg-[#C4A855] rounded-sm"></span> Phase iteration</span>
          <span class="flex items-center gap-2"><span class="w-3 h-3 bg-[#4A7C59] rounded-sm"></span> Phase scale</span>
        </div>
      </div>

      <!-- Tableau recapitulatif -->
      <div class="bg-[#2C2824] p-6 rounded-sm text-white overflow-x-auto">
        <p class="text-xs font-mono tracking-[0.15em] uppercase text-[#C4A855] mb-4">Tableau recapitulatif avec scaling</p>
        <table class="w-full text-sm min-w-[600px]">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left py-2 text-white/50 font-light">Mois</th>
              <th class="text-left py-2 text-white/50 font-light">Phase</th>
              <th class="text-right py-2 text-white/50 font-light">Budget</th>
              <th class="text-right py-2 text-white/50 font-light">Leads/mois</th>
              <th class="text-right py-2 text-white/50 font-light">Rev. tripwire</th>
              <th class="text-right py-2 text-white/50 font-light">Cout net</th>
              <th class="text-right py-2 text-white/50 font-light">Base cumulee</th>
            </tr>
          </thead>
          <tbody>
            {projectionLeadsScaling.map((m, i) => {
              const isScale = m.phase.includes('Scale')
              const isLast = i === projectionLeadsScaling.length - 1
              return (
                <tr class={`border-b ${isLast ? 'border-white/20 bg-white/5' : 'border-white/5'}`}>
                  <td class="py-2">{m.mois}</td>
                  <td class={`py-2 ${isScale ? 'text-[#4A7C59]' : 'text-[#C4A855]'}`}>{m.phase}</td>
                  <td class="py-2 text-right">{formatNumber(m.budget)}€</td>
                  <td class="py-2 text-right">{formatNumber(m.leadsMois)}</td>
                  <td class="py-2 text-right text-[#4A7C59]">+{formatNumber(m.revTripwire)}€</td>
                  <td class="py-2 text-right text-red-400">{formatNumber(m.coutNet)}€</td>
                  <td class={`py-2 text-right font-medium ${isLast ? 'text-[#C4A855] font-playfair text-lg' : ''}`}>{formatNumber(m.cumul)}</td>
                </tr>
              )
            })}
          </tbody>
        </table>
        <div class="mt-4 pt-4 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div>
            <p class="text-xs text-white/40">Budget total</p>
            <p class="font-playfair text-lg font-medium">{formatNumber(totalBudgetScaling)}€</p>
          </div>
          <div>
            <p class="text-xs text-white/40">Revenus tripwire</p>
            <p class="font-playfair text-lg font-medium text-[#4A7C59]">{formatNumber(totalRevTripwire)}€</p>
          </div>
          <div>
            <p class="text-xs text-white/40">Cout net</p>
            <p class="font-playfair text-lg font-medium text-red-400">{formatNumber(totalCoutNet)}€</p>
          </div>
          <div>
            <p class="text-xs text-white/40">Base email</p>
            <p class="font-playfair text-lg font-medium text-[#C4A855]">{formatNumber(totalLeadsScaling)}</p>
          </div>
        </div>
      </div>

      <p class="text-xs text-[#2C2824]/50 mt-4">
        <strong>Hypotheses :</strong> CPL moyen 2,75€ · Taux achat tripwire 35% · Prix tripwire moyen 7,5€ · Scale progressif des tunnels valides
      </p>
    </div>
  </section>

  <!-- Detail par tunnel -->
  {tunnels.map((tunnel, index) => (
    <section class={`py-12 ${index % 2 === 0 ? 'bg-[#FAF8F5]' : 'bg-white'}`}>
      <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
        <div class="flex items-center gap-4 mb-8">
          <span class="w-4 h-4 rounded" style={`background: ${tunnel.couleur}`}></span>
          <h2 class="font-playfair text-2xl font-medium text-[#2C2824]">Tunnel {tunnel.nom}</h2>
          <span class="ml-auto text-sm text-[#2C2824]/50">Debut : {tunnel.debutTunnel}</span>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Tripwire -->
          <div class="bg-white p-6 rounded-sm border border-[#2C2824]/10">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-medium text-[#2C2824]">Tripwire (E-book)</h3>
              <span class="font-playfair text-2xl font-medium" style={`color: ${tunnel.couleur}`}>{tunnel.tripwire.prix}€</span>
            </div>
            <p class="text-sm font-medium text-[#2C2824] mb-2">{tunnel.tripwire.titre}</p>
            <p class="text-xs text-[#2C2824]/50 mb-4">{tunnel.tripwire.pages}</p>
            <ul class="space-y-2">
              {tunnel.tripwire.contenu.map((item) => (
                <li class="text-sm text-[#2C2824]/70 flex items-start gap-2">
                  <span class="text-[#4A7C59]">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Ads -->
          <div class="bg-white p-6 rounded-sm border border-[#2C2824]/10">
            <h3 class="font-medium text-[#2C2824] mb-4">Configuration Ads</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between py-2 border-b border-[#2C2824]/5">
                <span class="text-[#2C2824]/60">Budget mensuel</span>
                <span class="font-medium text-[#2C2824]">{formatNumber(tunnel.ads.budget)}€</span>
              </div>
              <div class="flex justify-between py-2 border-b border-[#2C2824]/5">
                <span class="text-[#2C2824]/60">CPL cible</span>
                <span class="font-medium text-[#2C2824]">{tunnel.ads.cplCible.toFixed(2)}€</span>
              </div>
              <div class="flex justify-between py-2 border-b border-[#2C2824]/5">
                <span class="text-[#2C2824]/60">Plateforme</span>
                <span class="font-medium text-[#2C2824]">{tunnel.ads.plateforme}</span>
              </div>
              <div class="pt-2">
                <span class="text-[#2C2824]/60">Ciblage</span>
                <p class="font-medium text-[#2C2824] mt-1">{tunnel.ads.ciblage}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Sequence email -->
        <div class="mt-8 bg-white p-6 rounded-sm border border-[#2C2824]/10">
          <h3 class="font-medium text-[#2C2824] mb-4">Sequence email</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-[#2C2824]/10">
                  <th class="text-left py-2 font-light text-[#2C2824]/50">Jour</th>
                  <th class="text-left py-2 font-light text-[#2C2824]/50">Objet</th>
                  <th class="text-right py-2 font-light text-[#2C2824]/50">Taux ouv. cible</th>
                </tr>
              </thead>
              <tbody>
                {tunnel.sequence.map((email) => (
                  <tr class="border-b border-[#2C2824]/5">
                    <td class="py-3 font-mono text-[#2C2824]">J+{email.jour}</td>
                    <td class="py-3 text-[#2C2824]">{email.objet}</td>
                    <td class="py-3 text-right font-medium" style={`color: ${tunnel.couleur}`}>{email.taux}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Métriques -->
        <div class="mt-8 grid grid-cols-2 md:grid-cols-5 gap-4">
          <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
            <p class="text-xs text-[#2C2824]/50 mb-1">Leads/mois</p>
            <p class="font-playfair text-xl font-medium text-[#2C2824]">{tunnel.metriques.leadsParMois}</p>
          </div>
          <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
            <p class="text-xs text-[#2C2824]/50 mb-1">Taux tripwire</p>
            <p class="font-playfair text-xl font-medium text-[#2C2824]">{tunnel.metriques.tauxTripwire}%</p>
          </div>
          <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
            <p class="text-xs text-[#2C2824]/50 mb-1">Rev. tripwire/mois</p>
            <p class="font-playfair text-xl font-medium" style={`color: ${tunnel.couleur}`}>{formatNumber(Math.round(tunnel.metriques.revenusTrip))}€</p>
          </div>
          <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
            <p class="text-xs text-[#2C2824]/50 mb-1">Taux call</p>
            <p class="font-playfair text-xl font-medium text-[#2C2824]">{tunnel.metriques.tauxCall}%</p>
          </div>
          <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
            <p class="text-xs text-[#2C2824]/50 mb-1">Ventes/mois</p>
            <p class="font-playfair text-xl font-medium text-[#4A7C59]">~{Math.round(tunnel.metriques.ventesEstimees)}</p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Break-even analysis -->
  <section class="py-12 bg-[#2C2824]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-playfair text-2xl font-medium text-white mb-6">Analyse break-even</h2>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white/5 p-6 rounded-sm">
          <h3 class="text-white/60 text-sm mb-4">Depenses mensuelles</h3>
          <p class="font-playfair text-3xl font-medium text-white">{formatNumber(totalBudgetMensuel)}€</p>
          <p class="text-white/40 text-sm mt-2">Budget ads total</p>
        </div>
        <div class="bg-white/5 p-6 rounded-sm">
          <h3 class="text-white/60 text-sm mb-4">Revenus tripwire</h3>
          <p class="font-playfair text-3xl font-medium text-[#C4A855]">{formatNumber(Math.round(totalRevenusTrip))}€</p>
          <p class="text-white/40 text-sm mt-2">E-books vendus</p>
        </div>
        <div class="bg-white/5 p-6 rounded-sm">
          <h3 class="text-white/60 text-sm mb-4">Cout net acquisition</h3>
          <p class="font-playfair text-3xl font-medium text-[#4A7C59]">{formatNumber(totalBudgetMensuel - Math.round(totalRevenusTrip))}€</p>
          <p class="text-white/40 text-sm mt-2">Budget - Revenus tripwire</p>
        </div>
      </div>

      <div class="mt-8 p-4 bg-[#4A7C59]/20 rounded-sm">
        <p class="text-white/80 text-sm">
          <strong class="text-white">Conclusion :</strong> Avec un budget de {formatNumber(totalBudgetMensuel)}€/mois et ~{formatNumber(Math.round(totalRevenusTrip))}€ de revenus tripwire, le cout net d'acquisition de ~450 leads/mois est de <strong class="text-[#C4A855]">{formatNumber(totalBudgetMensuel - Math.round(totalRevenusTrip))}€</strong>, soit <strong class="text-[#C4A855]">{((totalBudgetMensuel - totalRevenusTrip) / totalLeadsMensuel).toFixed(2)}€/lead net</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- Tunnel Conferences Live -->
  <section class="py-12 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-4 h-4 rounded" style={`background: ${tunnelConferences.couleur}`}></span>
        <h2 class="font-playfair text-2xl font-medium text-[#2C2824]">Tunnel Conferences Live</h2>
        <span class="ml-auto text-sm text-[#2C2824]/50">12 conferences/an</span>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Lead Magnet -->
        <div class="bg-white p-6 rounded-sm border border-[#2C2824]/10">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-medium text-[#2C2824]">Lead Magnet (gratuit)</h3>
            <span class="text-xs bg-[#4A7C59]/10 text-[#4A7C59] px-2 py-1 rounded">Gratuit</span>
          </div>
          <p class="text-sm font-medium text-[#2C2824] mb-2">{tunnelConferences.leadMagnet}</p>
          <p class="text-xs text-[#2C2824]/50 mb-4">Extrait de 10min d'une conference precedente</p>
          <ul class="space-y-2">
            <li class="text-sm text-[#2C2824]/70 flex items-start gap-2">
              <span class="text-[#C4A855]">→</span>
              Teaser du contenu premium
            </li>
            <li class="text-sm text-[#2C2824]/70 flex items-start gap-2">
              <span class="text-[#C4A855]">→</span>
              Inscription email pour recevoir l'extrait
            </li>
            <li class="text-sm text-[#2C2824]/70 flex items-start gap-2">
              <span class="text-[#C4A855]">→</span>
              Sequence vers la prochaine conference
            </li>
          </ul>
        </div>

        <!-- Ads -->
        <div class="bg-white p-6 rounded-sm border border-[#2C2824]/10">
          <h3 class="font-medium text-[#2C2824] mb-4">Configuration Ads</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-[#2C2824]/60">Budget par conference</span>
              <span class="font-medium text-[#2C2824]">{tunnelConferences.budgetParConf}€</span>
            </div>
            <div class="flex justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-[#2C2824]/60">CPL cible</span>
              <span class="font-medium text-[#2C2824]">{tunnelConferences.cplCible.toFixed(2)}€</span>
            </div>
            <div class="flex justify-between py-2 border-b border-[#2C2824]/5">
              <span class="text-[#2C2824]/60">Plateforme</span>
              <span class="font-medium text-[#2C2824]">Meta + YouTube</span>
            </div>
            <div class="pt-2">
              <span class="text-[#2C2824]/60">Ciblage</span>
              <p class="font-medium text-[#2C2824] mt-1">Porteurs projets ecolieux, entrepreneurs ruraux, 28-55 ans</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sequence email -->
      <div class="mt-8 bg-white p-6 rounded-sm border border-[#2C2824]/10">
        <h3 class="font-medium text-[#2C2824] mb-4">Sequence email</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[#2C2824]/10">
                <th class="text-left py-2 font-light text-[#2C2824]/50">Jour</th>
                <th class="text-left py-2 font-light text-[#2C2824]/50">Objet</th>
                <th class="text-right py-2 font-light text-[#2C2824]/50">Taux ouv. cible</th>
              </tr>
            </thead>
            <tbody>
              {tunnelConferences.sequence.map((email) => (
                <tr class="border-b border-[#2C2824]/5">
                  <td class="py-3 font-mono text-[#2C2824]">J+{email.jour}</td>
                  <td class="py-3 text-[#2C2824]">{email.objet}</td>
                  <td class="py-3 text-right font-medium text-[#C4A855]">{email.taux}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Funnel visuel -->
      <div class="mt-8 bg-[#2C2824] p-6 rounded-sm text-white">
        <h3 class="font-medium text-white mb-4">Modelisation funnel (par conference)</h3>
        <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-4 text-xs sm:text-sm">
          <div class="text-center p-3 bg-white/5 rounded-sm">
            <p class="font-playfair text-xl font-medium text-white">300€</p>
            <p class="text-white/50">Budget</p>
          </div>
          <span class="text-white/30">→</span>
          <div class="text-center p-3 bg-white/5 rounded-sm">
            <p class="font-playfair text-xl font-medium text-white">{tunnelConferences.metriques.leadsParConf}</p>
            <p class="text-white/50">Leads</p>
          </div>
          <span class="text-white/30">→</span>
          <div class="text-center p-3 bg-white/5 rounded-sm">
            <p class="font-playfair text-xl font-medium text-[#C4A855]">{tunnelConferences.metriques.tauxInscription}%</p>
            <p class="text-white/50">Inscription</p>
          </div>
          <span class="text-white/30">→</span>
          <div class="text-center p-3 bg-white/5 rounded-sm">
            <p class="font-playfair text-xl font-medium text-white">{tunnelConferences.metriques.participantsMoyens}</p>
            <p class="text-white/50">Participants</p>
          </div>
          <span class="text-white/30">→</span>
          <div class="text-center p-3 bg-[#4A7C59]/20 rounded-sm">
            <p class="font-playfair text-xl font-medium text-[#4A7C59]">{formatNumber(tunnelConferences.metriques.caParConf)}€</p>
            <p class="text-white/50">CA</p>
          </div>
        </div>
        <p class="text-center text-xs text-white/40 mt-4">ROAS : {((tunnelConferences.metriques.caParConf / tunnelConferences.budgetParConf) * 100).toFixed(0)}% · Cout par participant : {(tunnelConferences.budgetParConf / tunnelConferences.metriques.participantsMoyens).toFixed(0)}€</p>
      </div>

      <!-- Projection annuelle -->
      <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
          <p class="text-xs text-[#2C2824]/50 mb-1">Conferences/an</p>
          <p class="font-playfair text-xl font-medium text-[#2C2824]">12</p>
        </div>
        <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
          <p class="text-xs text-[#2C2824]/50 mb-1">Budget total ads</p>
          <p class="font-playfair text-xl font-medium text-[#2C2824]">{formatNumber(12 * tunnelConferences.budgetParConf)}€</p>
        </div>
        <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
          <p class="text-xs text-[#2C2824]/50 mb-1">Leads totaux</p>
          <p class="font-playfair text-xl font-medium text-[#2C2824]">{formatNumber(12 * tunnelConferences.metriques.leadsParConf)}</p>
        </div>
        <div class="bg-white p-4 rounded-sm text-center border border-[#2C2824]/10">
          <p class="text-xs text-[#2C2824]/50 mb-1">CA annuel</p>
          <p class="font-playfair text-xl font-medium text-[#4A7C59]">{formatNumber(12 * tunnelConferences.metriques.caParConf)}€</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <section class="py-6 bg-[#1a1a1a]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16 text-center">
      <a href="/strategie-2026" class="text-white/50 hover:text-white text-sm transition-colors">
        ← Retour a la strategie
      </a>
    </div>
  </section>

</Layout>
