// ==========================================
// CALENDRIER MENSUEL
// ==========================================
const calendrier = [
  { 
    mois: 'Fevrier', 
    focus: 'Clarte',
    charly: ['TOFU Clarte', 'TOFU Clarte', 'MOFU Clarte', 'MOFU Clarte'],
    amandine: ['TOFU Clarte', 'TOFU vie LAOM', 'MOFU Clarte', 'TOFU vie LAOM'],
  },
  { 
    mois: 'Mars', 
    focus: 'Clarte + School',
    charly: ['MOFU Clarte', 'BOFU Clarte', 'TOFU School', 'MOFU Clarte'],
    amandine: ['BOFU Clarte', 'TOFU School', 'MOFU vie LAOM', 'TOFU School'],
  },
  { 
    mois: 'Avril', 
    focus: 'Clarte + School',
    charly: ['BOFU Clarte', 'BOFU Clarte', 'MOFU School', 'TOFU School'],
    amandine: ['BOFU Clarte', 'MOFU School', 'Behind scenes Clarte', 'TOFU School'],
  },
  { 
    mois: 'Mai', 
    focus: 'School + Mouvement',
    charly: ['BOFU School', 'MOFU School', 'TOFU Mvt', 'MOFU School'],
    amandine: ['BOFU School', 'Behind scenes School', 'TOFU Mvt', 'MOFU vie LAOM'],
  },
  { 
    mois: 'Juin', 
    focus: 'Mouvement',
    charly: ['MOFU Mvt', 'TOFU Mvt', 'MOFU Mvt', 'TOFU general'],
    amandine: ['TOFU Mvt', 'MOFU Mvt', 'TOFU vie LAOM', 'MOFU Mvt'],
  },
  { 
    mois: 'Juillet', 
    focus: 'Mouvement',
    charly: ['BOFU Mvt', 'MOFU Mvt', 'BOFU Mvt', 'TOFU general'],
    amandine: ['BOFU Mvt', 'TOFU vie LAOM', 'BOFU Mvt', 'Behind scenes'],
  },
]
---

<Layout
  title="Strategie LinkedIn 2026 — LAOM"
  description="Backlog et calendrier LinkedIn pour 2026"
  seo={{ noindex: true, nofollow: true }}
>

  <!-- Password check -->
  <script is:inline>
    if (sessionStorage.getItem('laom_auth') !== 'true') {
      window.location.href = '/strategie-2026';
    }
  </script>

  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#1a1a1a] border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16 h-14 flex items-center justify-between">
      <a href="/strategie-2026" class="text-white/50 hover:text-white text-sm font-light transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Retour strategie</span>
      </a>
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-[#0A66C2]/20 flex items-center justify-center">
          <svg class="w-4 h-4 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <span class="text-white font-medium">LinkedIn</span>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="bg-[#1a1a1a] pt-24 sm:pt-28 pb-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h1 class="font-playfair text-3xl md:text-4xl font-medium text-white mb-4">
        Strategie LinkedIn 2026
      </h1>
      <p class="text-white/60 mb-8">
        32 posts/mois (8/semaine) · Charly + Amandine · TOFU/MOFU/BOFU aligne sur les offres
      </p>

      <div class="grid grid-cols-3 gap-4">
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-white">32</p>
          <p class="text-xs text-white/50">posts/mois</p>
        </div>
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-[#0A66C2]">8</p>
          <p class="text-xs text-white/50">par semaine</p>
        </div>
        <div class="bg-white/5 p-4 rounded-sm text-center">
          <p class="text-2xl font-playfair font-medium text-white">2</p>
          <p class="text-xs text-white/50">auteurs</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategie TOFU/MOFU/BOFU -->
  <section class="py-12 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-playfair text-2xl font-medium text-[#2C2824] mb-6">Strategie TOFU/MOFU/BOFU</h2>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-sm border-t-4 border-[#C4A855]">
          <h3 class="font-medium text-[#2C2824] mb-2">TOFU - Decouverte</h3>
          <p class="text-sm text-[#2C2824]/60 mb-4">Attirer de nouveaux abonnes via des sujets larges et engageants.</p>
          <ul class="text-sm text-[#2C2824]/70 space-y-1">
            <li>- Hooks forts, sujets viraux</li>
            <li>- Problemes communs</li>
            <li>- CTA : Like/Comment</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-sm border-t-4 border-[#2C2824]">
          <h3 class="font-medium text-[#2C2824] mb-2">MOFU - Education</h3>
          <p class="text-sm text-[#2C2824]/60 mb-4">Apporter de la valeur, montrer l'expertise.</p>
          <ul class="text-sm text-[#2C2824]/70 space-y-1">
            <li>- Methodes, tutoriels</li>
            <li>- Behind the scenes</li>
            <li>- CTA : Newsletter</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-sm border-t-4 border-[#4A7C59]">
          <h3 class="font-medium text-[#2C2824] mb-2">BOFU - Conversion</h3>
          <p class="text-sm text-[#2C2824]/60 mb-4">Convertir les abonnes en participants.</p>
          <ul class="text-sm text-[#2C2824]/70 space-y-1">
            <li>- Offres directes</li>
            <li>- Temoignages</li>
            <li>- CTA : Inscription event</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Backlog Charly -->
  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-playfair text-2xl font-medium text-[#2C2824] mb-6">Backlog Charly</h2>
      
      <!-- Clarté -->
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-3 h-3 rounded-full bg-[#C4A855]"></span>
          <h3 class="font-medium text-[#2C2824]">Clarte</h3>
        </div>
        <div class="space-y-4">
          <div>
            <p class="text-xs font-medium text-[#C4A855] mb-2">TOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.clarte.tofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-medium text-[#2C2824] mb-2">MOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.clarte.mofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-medium text-[#4A7C59] mb-2">BOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.clarte.bofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm border-l-2 border-[#4A7C59]">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- LAOM School -->
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-3 h-3 rounded-full bg-[#2C2824]"></span>
          <h3 class="font-medium text-[#2C2824]">LAOM School</h3>
        </div>
        <div class="space-y-4">
          <div>
            <p class="text-xs font-medium text-[#C4A855] mb-2">TOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.school.tofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-medium text-[#2C2824] mb-2">MOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.school.mofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-medium text-[#4A7C59] mb-2">BOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.school.bofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm border-l-2 border-[#4A7C59]">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- En Mouvement -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-3 h-3 rounded-full bg-[#4A7C59]"></span>
          <h3 class="font-medium text-[#2C2824]">En Mouvement</h3>
        </div>
        <div class="space-y-4">
          <div>
            <p class="text-xs font-medium text-[#C4A855] mb-2">TOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.mouvement.tofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-medium text-[#2C2824] mb-2">MOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.mouvement.mofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-medium text-[#4A7C59] mb-2">BOFU</p>
            <div class="grid md:grid-cols-2 gap-3">
              {backlogCharly.mouvement.bofu.map((post) => (
                <div class="bg-[#FAF8F5] p-4 rounded-sm border-l-2 border-[#4A7C59]">
                  <p class="font-medium text-[#2C2824] text-sm mb-1">{post.titre}</p>
                  <p class="text-xs text-[#2C2824]/50">{post.angle} · CTA: {post.cta}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Backlog Amandine -->
  <section class="py-12 bg-[#FAF8F5]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-playfair text-2xl font-medium text-[#2C2824] mb-6">Backlog Amandine</h2>
      
      <p class="text-sm text-[#2C2824]/60 mb-6">Focus sur le storytelling, la vie quotidienne a LAOM, et le soutien des offres de Charly.</p>

      <div class="grid md:grid-cols-3 gap-6">
        {/* Clarté */}
        <div class="bg-white p-6 rounded-sm">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-3 h-3 rounded-full bg-[#C4A855]"></span>
            <h3 class="font-medium text-[#2C2824]">Clarte</h3>
          </div>
          <div class="space-y-2">
            {[...backlogAmandine.clarte.tofu, ...backlogAmandine.clarte.mofu, ...backlogAmandine.clarte.bofu].map((post) => (
              <div class="text-sm p-3 bg-[#FAF8F5] rounded-sm">
                <p class="text-[#2C2824]">{post.titre}</p>
              </div>
            ))}
          </div>
        </div>

        {/* School */}
        <div class="bg-white p-6 rounded-sm">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-3 h-3 rounded-full bg-[#2C2824]"></span>
            <h3 class="font-medium text-[#2C2824]">LAOM School</h3>
          </div>
          <div class="space-y-2">
            {[...backlogAmandine.school.tofu, ...backlogAmandine.school.mofu, ...backlogAmandine.school.bofu].map((post) => (
              <div class="text-sm p-3 bg-[#FAF8F5] rounded-sm">
                <p class="text-[#2C2824]">{post.titre}</p>
              </div>
            ))}
          </div>
        </div>

        {/* Mouvement */}
        <div class="bg-white p-6 rounded-sm">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-3 h-3 rounded-full bg-[#4A7C59]"></span>
            <h3 class="font-medium text-[#2C2824]">En Mouvement</h3>
          </div>
          <div class="space-y-2">
            {[...backlogAmandine.mouvement.tofu, ...backlogAmandine.mouvement.mofu, ...backlogAmandine.mouvement.bofu].map((post) => (
              <div class="text-sm p-3 bg-[#FAF8F5] rounded-sm">
                <p class="text-[#2C2824]">{post.titre}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendrier mensuel -->
  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h2 class="font-playfair text-2xl font-medium text-[#2C2824] mb-6">Calendrier mensuel</h2>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[600px]">
          <thead>
            <tr class="border-b border-[#2C2824]/10">
              <th class="text-left py-3 font-medium text-[#2C2824]">Mois</th>
              <th class="text-left py-3 font-medium text-[#2C2824]">Focus</th>
              <th class="text-left py-3 font-medium text-[#2C2824]">Charly (4/sem)</th>
              <th class="text-left py-3 font-medium text-[#2C2824]">Amandine (4/sem)</th>
            </tr>
          </thead>
          <tbody>
            {calendrier.map((row) => (
              <tr class="border-b border-[#2C2824]/5">
                <td class="py-4 font-medium text-[#2C2824]">{row.mois}</td>
                <td class="py-4">
                  <span class="text-xs font-medium bg-[#C4A855]/10 text-[#C4A855] px-2 py-1 rounded-sm">{row.focus}</span>
                </td>
                <td class="py-4 text-[#2C2824]/70">
                  {row.charly.map((p, i) => <span class="inline-block mr-1 mb-1 text-xs bg-[#FAF8F5] px-2 py-0.5 rounded">{p}</span>)}
                </td>
                <td class="py-4 text-[#2C2824]/70">
                  {row.amandine.map((p, i) => <span class="inline-block mr-1 mb-1 text-xs bg-[#FAF8F5] px-2 py-0.5 rounded">{p}</span>)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <section class="py-6 bg-[#1a1a1a]">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 md:px-12 lg:px-16 text-center">
      <a href="/strategie-2026" class="text-white/50 hover:text-white text-sm transition-colors">
        ← Retour a la strategie
      </a>
    </div>
  </section>

</Layout>
